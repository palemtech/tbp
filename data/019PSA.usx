<?xml version="1.0" encoding="utf-8"?>
<usx version="3.0">
  <book code="PSA" style="id">- Palembang: Tejemahan Basó Plembang</book>
  <para style="toc3">S.Ny.</para>
  <para style="toc2">Saér Nyanyian</para>
  <para style="toc1">Saér Nyanyian</para>
  <para style="mt1">SAÉR NYANYIAN</para>
  <para style="mt2">[VERSI AWAL]</para>
  <chapter number="1" style="c" sid="PSA 1" />
  <para style="s2">Jalan kebeneran itula yang mbékén seneng</para>
  <para style="q1">
    <verse number="1" style="v" sid="PSA 1:1" />Senengla wong yang</para>
  <para style="q2" vid="PSA 1:1">idak bejalan dalem anjóran wong jahat,</para>
  <para style="q2" vid="PSA 1:1">idak tegak dalem jalan wong beduso,</para>
  <para style="q2" vid="PSA 1:1">trós idak dódók dalem kómpólan wong yang galak ngino kebeneran;<verse eid="PSA 1:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 1:2" />melaénke dalem ajaran <char style="nd"><char style="w">ALLAHyhwh</char></char> iola kesenengannyo,</para>
  <para style="q2" vid="PSA 1:2">trós ajaran-Nyo dio renóngke siang malem.<verse eid="PSA 1:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 1:3" />Dio pecak pohon yang ditanem di pénggér aléran banyu,</para>
  <para style="q2" vid="PSA 1:3">yang bebua pas mósémnyo,</para>
  <para style="q2" vid="PSA 1:3">trós daónnyo idak layu;</para>
  <para style="q1" vid="PSA 1:3">slóró yang dio gaweke berasél.<note caller="-" style="x"><char style="xo" closed="false">1:2-3 </char><char style="xt" closed="false"><ref loc="JOS 1:8">Yosua 1:8</ref> </char></note><verse eid="PSA 1:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 1:4" />Idak cak itu dengen wong jahat,</para>
  <para style="q2" vid="PSA 1:4">melaénke dio pecak kólét padi yang dibuyarke angin.<verse eid="PSA 1:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 1:5" />Karno itula wong jahat dak bakal tahan ngadepi pengadélan <char style="add">Allah</char>,</para>
  <para style="q2" vid="PSA 1:5">jugo wong beduso dalem kelompok wong bener.<verse eid="PSA 1:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 1:6" />Soalnyo <char style="nd">ALLAHyhwh</char> nyago jalan wong bener,</para>
  <para style="q2" vid="PSA 1:6">tapi jalan wong jahat nuju kematian.<verse eid="PSA 1:6" /></para>
  <chapter eid="PSA 1" />
  <chapter number="2" style="c" sid="PSA 2" />
  <para style="s2">Pengangkatan rajo yang dilanték Allah<note caller="+" style="f"><char style="fr" closed="false">2:0 </char><char style="ft" closed="false">Saér 2 tebagé empat baét, iola: </char><char style="fp" closed="false">1. (ayat </char><char style="xt" link-href="PSA 2:1-3"><ref loc="PSA 2:1">1-3</ref></char>) Bangso-bangso dunio ngerencanoke pemberontakan samo Allah jugo rajo-Nyo. <char style="fp" closed="false">2. (ayat </char><char style="xt" link-href="PSA 2:4-6"><ref loc="PSA 2:4">4-6</ref></char>) Allah ngino rencano bangso-bangso tu dengen ngómómke amen Dio la ngangkat rajo-Nyo. <char style="fp" closed="false">3. (ayat </char><char style="xt" link-href="PSA 2:7-9"><ref loc="PSA 2:7">7-9</ref></char>) Rajo yang dipélé Allah bacoke isi kepótósan Allah yang ngangkat dio jadi rajo jugo janji slóró bangso dunio bakal dienjókke ke dio. <char style="fp" closed="false">4. (ayat </char><char style="xt" link-href="PSA 2:10-12"><ref loc="PSA 2:10">10-12</ref></char>) Bangso-bangso dunio diperingetke óntók nyera samo Allah supayo idak diancórke.</note></para>
  <para style="q1">
    <verse number="1" style="v" sid="PSA 2:1" />Ngapo bangso-bangso ni sekongkol,</para>
  <para style="q2" vid="PSA 2:1">trós ngapo suku-suku bangso ngerencanoke pasal yang sio-sio?<verse eid="PSA 2:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 2:2" />Rajo-rajo dunio besiap-siap,</para>
  <para style="q2" vid="PSA 2:2">trós pejabat-pejabat beróndéng</para>
  <para style="q2" vid="PSA 2:2">ngelawan <char style="nd"><char style="w">ALLAHyhwh</char></char> samo rajo yang dilanték-Nyo, <char style="add">ujinyo, </char><verse eid="PSA 2:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 2:3" />“Payó kito pótóske rante-rante dio wong</para>
  <para style="q2" vid="PSA 2:3">trós buangke tali-tali dio wong dari kito!”<verse eid="PSA 2:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 2:4" />Dio yang bekuaso di surgo ketawo.</para>
  <para style="q2" vid="PSA 2:4">Iyo! Tuan ngino dio wong.<verse eid="PSA 2:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 2:5" />Laju Dio ngomong dengen manas,</para>
  <para style="q2" vid="PSA 2:5">trós dengen kemarahan-Nyo Dio nakótke dio wong, <char style="add">uji-Nyo,</char><verse eid="PSA 2:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 2:6" />“Aku ni la ngangkat rajo Aku</para>
  <para style="q2" vid="PSA 2:6">di <char style="w">Sion</char>, bókét Aku yang suci!”<verse eid="PSA 2:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 2:7" />Aku nak ngómómke pasal kepótósan <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 2:7">Dio ngomong samo aku, “Kaula anak Aku.</para>
  <para style="q2" vid="PSA 2:7">Ari nila Aku jadi Aba kau.<verse eid="PSA 2:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 2:8" />Mintakla samo Aku,</para>
  <para style="q2" vid="PSA 2:8">trós Aku bakal ngenjókke bangso-bangso jadi warésan kau,</para>
  <para style="q2" vid="PSA 2:8">trós sampe ójóng bumi jadi punyo kau.<verse eid="PSA 2:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 2:9" />Kau bakal ngancórke dio wong makek tongkat besi,</para>
  <para style="q2" vid="PSA 2:9">trós ngeremókke dio wong pecak guci tukang keramék.”<verse eid="PSA 2:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 2:10" />Karno itu, ói rajo-rajo, bebuatla yang bijak!</para>
  <para style="q2" vid="PSA 2:10">Terimola peringetan ni, ói penguaso-penguaso dunio!<verse eid="PSA 2:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 2:11" />Layanila <char style="nd">ALLAHyhwh</char> dengen takót,</para>
  <para style="q2" vid="PSA 2:11">trós pujila dengen gemeter.<verse eid="PSA 2:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 2:12" />Sójódla dengen tólós<note caller="+" style="f"><char style="fr" closed="false">2:12 </char><char style="fq" closed="false">Sójódla dengen tólós: </char><char style="ft" closed="false">Ado kato di teks asli di sini yang kurang jelas maknonyo. Karno tu, barés ini pacak jugo ditejemake cak ini: “Sójódla di adepan anak tu”.</char></note></para>
  <para style="q2" vid="PSA 2:12">supayo Dio idak mara, trós kau idak mati ngejót<note caller="+" style="f"><char style="fr" closed="false">2:12 </char><char style="fq" closed="false">mati ngejót: </char><char style="ft" closed="false">Teks asli iola, “mati di jalan”. Maksódnyo, mati tibo-tibo pas ngelakuke gawean seari-ari.</char></note>,</para>
  <para style="q2" vid="PSA 2:12">olenyo gancang nian Dio naék dara.</para>
  <para style="b" vid="PSA 2:12" />
  <para style="q1" vid="PSA 2:12">Senengla slóró wong yang beléndóng samo Dio!<verse eid="PSA 2:12" /></para>
  <chapter eid="PSA 2" />
  <chapter number="3" style="c" sid="PSA 3" />
  <para style="s2">Nyanyian pagi ngadepi mósó</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 3:1" />Nyanyian <char style="w">Daód</char>, pas dio lari dari Absalom, anaknyo.<note caller="-" style="x"><char style="xo" closed="false">3:1 </char><char style="xt" closed="false"><ref loc="2SA 15-16">2 Samuel 15–16</ref></char></note><verse eid="PSA 3:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 3:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, alangke banyaknyo mósó aku ni!</para>
  <para style="q2" vid="PSA 3:2">Banyak yang bangkét ngelawan aku!<verse eid="PSA 3:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 3:3" />Banyak yang ngomongi aku,</para>
  <para style="q2" vid="PSA 3:3">“Katek keselametan óntók dio dari Allah!” <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 3:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 3:4" />Tapi Kau, ya <char style="nd">ALLAHyhwh</char>, iola tameng yang ngeléléngi aku.</para>
  <para style="q2" vid="PSA 3:4">Kaula kemulyoan aku jugo yang ngangkat palak aku.<verse eid="PSA 3:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 3:5" />Aku bejerét samo <char style="nd">ALLAHyhwh</char> dengen nyaréng,</para>
  <para style="q2" vid="PSA 3:5">trós Dio nyawab aku dari <char style="w" lemma="Sion">bókét suci-Nyo</char>. <char style="qs">Selah</char><verse eid="PSA 3:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 3:6" />Aku góléngan, tédók, trós bangón,</para>
  <para style="q2" vid="PSA 3:6">karno <char style="nd">ALLAHyhwh</char> nopang aku!<verse eid="PSA 3:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 3:7" />Aku idak takót samo pólóan ribu wong</para>
  <para style="q2" vid="PSA 3:7">yang ngepóng aku.<verse eid="PSA 3:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 3:8" />Bangkétla, ya <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 3:8">Selametkela aku, ya Tuhan aku!</para>
  <para style="q1" vid="PSA 3:8">Iyo, Kau bakal goco rahang slóró mósó aku</para>
  <para style="q2" vid="PSA 3:8">trós matake gigi wong-wong jahat.<verse eid="PSA 3:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 3:9" />Keselametan dateng dari <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 3:9">Berkah Kau óntók umat Kau! <char style="qs">Selah</char><verse eid="PSA 3:9" /></para>
  <chapter eid="PSA 3" />
  <chapter number="4" style="c" sid="PSA 4" />
  <para style="s2">Nyanyian pecayo samo Allah dalem iman</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 4:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi</char> kecapi. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 4:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 4:2" />Ya Allah, pembelaku,</para>
  <para style="q2" vid="PSA 4:2">jawabla aku pas aku bejerét.</para>
  <para style="q1" vid="PSA 4:2">Pas aku dalem kesesekan, Kau mbékén aku lego.</para>
  <para style="q1" vid="PSA 4:2">Mura atila samo aku trós dengerkela doa aku!<verse eid="PSA 4:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 4:3" />Ói wong-wong besak<note caller="+" style="f"><char style="fr" closed="false">4:3 </char><char style="fq" closed="false">wong-wong besak: </char><char style="ft" closed="false">Teks asli iola “anak-anak dari lanang”. Dalem baso asli, kato-kato ni jadi sebótan óntók wong-wong besak.</char></note>, sampe kapan kamu ngino kehormatan aku?</para>
  <para style="q2" vid="PSA 4:3">Sampe kapan kamu nyenengi pasal yang sio-sio</para>
  <para style="q2" vid="PSA 4:3">trós nyari kebohongan? <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 4:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 4:4" />Ketauila amen <char style="nd"><char style="w">ALLAHyhwh</char></char> la ngósóske wong além óntók Dio dewek!</para>
  <para style="q2" vid="PSA 4:4">
    <char style="nd">ALLAHyhwh</char> bakal ndenger pas aku bejerét samo Dio.<verse eid="PSA 4:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 4:5" />Gemeterla kamu, trós janganla bebuat duso!</para>
  <para style="q2" vid="PSA 4:5">Ngerenungla di jeró ati kau di tempat tédók kau,</para>
  <para style="q2" vid="PSA 4:5">trós tetepla diem. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 4:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 4:6" />Sembakela kórban sembeléhan yang bener,</para>
  <para style="q2" vid="PSA 4:6">trós pecayola samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 4:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 4:7" />Banyak wong ngomong, “Siapo bakal nónjókke kebaék'an samo kito?”</para>
  <para style="q2" vid="PSA 4:7">Ya <char style="nd">ALLAHyhwh</char>, biarla cahayo rai Kau nyinari kami!<verse eid="PSA 4:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 4:8" />Kau la ngenjókke kesenengan di jeró ati aku,</para>
  <para style="q2" vid="PSA 4:8">lebé daripado kesenengan wong pas gendóm jugo anggór melimpa.<verse eid="PSA 4:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 4:9" />Dengen tenang aku bakal bególéng trós tédók,</para>
  <para style="q2" vid="PSA 4:9">soalnyo cuman Kaula, ya <char style="nd">ALLAHyhwh</char>, yang mbékén aku netep dengen aman.<verse eid="PSA 4:9" /></para>
  <chapter eid="PSA 4" />
  <chapter number="5" style="c" sid="PSA 5" />
  <para style="s2">Doa mintak peléndóngan pas pagi ari</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 5:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi</char> soléng. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 5:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 5:2" />Dengerkela omongan aku, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>;</para>
  <para style="q2" vid="PSA 5:2">peratikela réntéan aku!<verse eid="PSA 5:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 5:3" />Dengerkela suaro aku mintak tolong,</para>
  <para style="q2" vid="PSA 5:3">ya Rajo aku jugo Tuhan aku,</para>
  <para style="q2" vid="PSA 5:3">karno samo Kaula aku bedoa.<verse eid="PSA 5:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 5:4" />Ya <char style="nd">ALLAHyhwh</char>, pas pagi ari Kau denger suaro aku.</para>
  <para style="q2" vid="PSA 5:4">Pas pagi ari aku ngatór óntók Kau</para>
  <para style="q3" vid="PSA 5:4">trós nunggu.<verse eid="PSA 5:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 5:5" />Soalnyo Kau tu bukan Tuhan yang seneng dengen kejahatan.</para>
  <para style="q2" vid="PSA 5:5">Wong jahat dak pacak tinggal dengen Kau.<verse eid="PSA 5:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 5:6" />Wong sombong dak bakal tahan pas diselédék'i Kau<note caller="+" style="f"><char style="fr" closed="false">5:6 </char><char style="fq" closed="false">pas diselédék'i Kau: </char><char style="ft" closed="false">Teks asli iola “di adepan mato Kau”, yang artinyo Allah nyelédék'i wong sombong tadi.</char></note>.</para>
  <para style="q2" vid="PSA 5:6">Kau mbenci galo-galo wong yang bebuat jahat.<verse eid="PSA 5:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 5:7" />Kau ngancórke wong-wong yang bebohong.</para>
  <para style="q2" vid="PSA 5:7">
    <char style="nd">ALLAHyhwh</char> nganggep kejem penumpa dara jugo penipu.<verse eid="PSA 5:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 5:8" />Tapi aku, karno sangkéng banyaknyo kasé stio Kau,</para>
  <para style="q2" vid="PSA 5:8">aku bakal masók ke jeró ruma Kau,</para>
  <para style="q2" vid="PSA 5:8">trós sójód ke ara <char style="w" lemma="Ruma Agóng Allah">Ruma Agóng Kau</char> yang suci, dengen takót samo Kau.<verse eid="PSA 5:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 5:9" />Ya <char style="nd">ALLAHyhwh</char>, pémpénla aku dalem kebeneran Kau ole karno mósó-mósó aku;</para>
  <para style="q2" vid="PSA 5:9">arakela aku di jalan Kau<note caller="+" style="f"><char style="fr" closed="false">5:9 </char><char style="fq" closed="false">arakela aku di jalan Kau: </char><char style="ft" closed="false">Teks asli iola “lóróskela jalan Kau di adepan aku”, yang artinyo dio mintak Allah óntók ngarake dio mangko jalan Allah jadi lórós di adepannyo.</char></note>.<verse eid="PSA 5:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 5:10" />Soalnyo, katek yang bener di mólót dio wong;</para>
  <para style="q2" vid="PSA 5:10">ati dio wong penu kebósókan.</para>
  <para style="q1" vid="PSA 5:10">Tenggorokan dio wong pecak kóbóran yang temangap;</para>
  <para style="q2" vid="PSA 5:10">lida dio wong licik.<verse eid="PSA 5:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 5:11" />Ya <char style="nd">ALLAHyhwh</char>, hókómla dio wong;</para>
  <para style="q2" vid="PSA 5:11">biarla dio wong nyampak karno rencano dio wong dewek!</para>
  <para style="q1" vid="PSA 5:11">Ósérla dio wong, karno sangkéng banyaknyo pelanggaran dio wong,</para>
  <para style="q2" vid="PSA 5:11">karno dio wong la durhako samo Kau.<verse eid="PSA 5:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 5:12" />Tapi sekironyo galo-galo wong yang beléndóng samo Kau beseneng,</para>
  <para style="q2" vid="PSA 5:12">trós biarkela dio wong besorak-sorak selamo-lamonyo!</para>
  <para style="q1" vid="PSA 5:12">Tódóngila dio wong,</para>
  <para style="q2" vid="PSA 5:12">supayo wong-wong yang ngaséhi namo Kau</para>
  <para style="q2" vid="PSA 5:12">pacak beseneng-seneng karno Kau.<verse eid="PSA 5:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 5:13" />Soalnyo Kau mberkahi wong bener, ya <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 5:13">Pecak tameng, Kau ngeléndóngi dio wong dengen kebaék'an Kau.<verse eid="PSA 5:13" /></para>
  <chapter eid="PSA 5" />
  <chapter number="6" style="c" sid="PSA 6" />
  <para style="s2">Doa pas kesaroan</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 6:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi </char> kecapi. <char style="add">Dinyanyike </char>nórót syeminit<note caller="+" style="f"><char style="fr" closed="false">6:1 </char><char style="fq" closed="false">Nórót syeminit: </char><char style="ft" closed="false">Biasonyo kato Ibrani ni maksódnyo ‘yang kelapan’, tapi di sini digunoke pecak istila kósós óntók musik. Maknonyo di sini kurang jelas, tapi móngkén nónjókke nada. </char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 6:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 6:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, janganla Kau hókóm aku dalem kemarahan Kau,</para>
  <para style="q2" vid="PSA 6:2">trós jangan hajar aku dalem kegereman Kau.<verse eid="PSA 6:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 6:3" />Mura atila samo aku, ya <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 6:3">karno aku lemes.</para>
  <para style="q1" vid="PSA 6:3">Sembókela aku, ya <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 6:3">karno tulang-tulang aku gemeter,<verse eid="PSA 6:3" /></para>
  <para style="q2">
    <verse number="4" style="v" sid="PSA 6:4" />jugo jiwo aku ketakótan nian.</para>
  <para style="q1" vid="PSA 6:4">Trós Kau, ya <char style="nd">ALLAHyhwh</char>, berapo lamo lagi?<verse eid="PSA 6:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 6:5" />Ya <char style="nd">ALLAHyhwh</char>, balékla trós selametkela jiwo aku!</para>
  <para style="q2" vid="PSA 6:5">Bebaskela aku karno kasé stio Kau.<verse eid="PSA 6:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 6:6" />Soalnyo dalem kematian idak ado lagi ingetan pasal Kau,</para>
  <para style="q2" vid="PSA 6:6">trós dalem alam kóbór, siapo nian yang pacak ngucapke sókór samo Kau?<verse eid="PSA 6:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 6:7" />Aku loyo dalem réntéan aku.</para>
  <para style="q2" vid="PSA 6:7">Sepanjang malem aku mbanjéri tempat tédók aku,</para>
  <para style="q2" vid="PSA 6:7">trós dengen banyu mato, aku mbasahi kasór aku.<verse eid="PSA 6:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 6:8" />Mato aku sembeb karno sedé,</para>
  <para style="q2" vid="PSA 6:8">trós jadi rabón karno banyaknyo mósó <char style="add">yang nyerang</char> aku.<verse eid="PSA 6:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 6:9" />Njaóla dari aku, ói galo-galo yang bebuat jahat,</para>
  <para style="q2" vid="PSA 6:9">karno <char style="nd">ALLAHyhwh</char> la ndenger suaro tangisan aku.<verse eid="PSA 6:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 6:10" />
    <char style="nd">ALLAHyhwh</char> la ndenger pintak'an aku.</para>
  <para style="q2" vid="PSA 6:10">
    <char style="nd">ALLAHyhwh</char> nerimo doa aku.<verse eid="PSA 6:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 6:11" />Galo-galo mósó aku bakal dipermaluke trós bakal ketakótan nian;</para>
  <para style="q2" vid="PSA 6:11">dio wong bakal balék trós dipermaluke dalem sekejep.<verse eid="PSA 6:11" /></para>
  <chapter eid="PSA 6" />
  <chapter number="7" style="c" sid="PSA 7" />
  <para style="s2">Doa mintak keadélan dari Allah, Hakém yang bener</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 7:1" />
    <char style="it">Syigayon</char>
    <note caller="+" style="f">
      <char style="fr" closed="false">7:1 </char>
      <char style="fq" closed="false">Syigayon: </char>
      <char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén namo jenis nyanyian. </char>
    </note> <char style="w">Daód</char>, yang dinyanyikenyo óntók <char style="nd"><char style="w">ALLAHyhwh</char></char> pasal Kus<note caller="+" style="f"><char style="fr" closed="false">7:1 </char><char style="fq" closed="false">Kus: </char><char style="ft" closed="false">Caknyo ini ni sala sikok mósó Daód.</char></note>, wong Benyamin.<verse eid="PSA 7:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 7:2" />Ya <char style="nd">ALLAHyhwh</char>, ya Tuhanku, samo Kaula aku beléndóng.</para>
  <para style="q1" vid="PSA 7:2">Selametkela aku dari slóró wong yang ngejer aku;</para>
  <para style="q2" vid="PSA 7:2">bebaske aku,<verse eid="PSA 7:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 7:3" />supayo dio wong dak nyakar aku pecak singo</para>
  <para style="q2" vid="PSA 7:3">trós ngoyak-ngoyak aku, sementaro dak katek yang bebaske.<verse eid="PSA 7:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 7:4" />Ya <char style="nd">ALLAHyhwh</char>, ya Tuhanku, amen aku lakuke ini,</para>
  <para style="q2" vid="PSA 7:4">amen ado pebuatan yang dak adél dalem tangan aku,<verse eid="PSA 7:4" /></para>
  <para style="q2">
    <verse number="5" style="v" sid="PSA 7:5" />amen aku bebuat jahat samo wong yang édóp damai dengen aku,</para>
  <para style="q2" vid="PSA 7:5">apo aku ngerampasi mósó aku tanpa alesan<note caller="+" style="f"><char style="fr" closed="false">7:5 </char><char style="fq" closed="false">apo aku ngerampasi mósó aku tanpa alesan: </char><char style="ft" closed="false">Makno teks asli dari barés ni dak pulok jelas. </char></note>,<verse eid="PSA 7:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 7:6" />biarla mósó aku ngejer trós nangkep aku,</para>
  <para style="q2" vid="PSA 7:6">nginjek-nginjek édóp aku sampe ke tana,</para>
  <para style="q2" vid="PSA 7:6">trós némbón kehormatan aku di dalem debu. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 7:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 7:7" />Ya <char style="nd">ALLAHyhwh</char>, bangkétla dalem kemarahan Kau!</para>
  <para style="q2" vid="PSA 7:7">Tegakla adepi amókan mósó-mósó aku!</para>
  <para style="q2" vid="PSA 7:7">Bangkétla óntók aku!</para>
  <para style="q2" vid="PSA 7:7">Kau la mrénto keadélan.<verse eid="PSA 7:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 7:8" />Biarla kómpólan bangso dateng ngadep Kau,</para>
  <para style="q2" vid="PSA 7:8">trós bekuasola di pócók dio wong di tempat yang tinggi.<verse eid="PSA 7:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 7:9" />
    <char style="nd">ALLAHyhwh</char> ngadéli bangso-bangso.</para>
  <para style="q1" vid="PSA 7:9">Ya <char style="nd">ALLAHyhwh</char>, hakémila aku</para>
  <para style="q2" vid="PSA 7:9">sesuai dengen kebeneran aku jugo ketólósan ati aku.<verse eid="PSA 7:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 7:10" />Kironyo kejahatan wong jahat beahér,</para>
  <para style="q2" vid="PSA 7:10">trós tegakkela wong bener,</para>
  <para style="q2" vid="PSA 7:10">
    <char style="add">ya Kau</char> yang nguji ati jugo batén, Allah Yang Mahabener.<verse eid="PSA 7:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 7:11" />Tameng aku iola Allah,</para>
  <para style="q2" vid="PSA 7:11">yang nyelametke wong yang lórós ati.<verse eid="PSA 7:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 7:12" />Allah iola hakém yang bener,</para>
  <para style="q2" vid="PSA 7:12">trós Dio iola Tuhan yang tiap ari nónjókke kemarahan-Nyo.<verse eid="PSA 7:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 7:13" />Amen wong dak betobat, Allah bakal ngasa pedang-Nyo,</para>
  <para style="q2" vid="PSA 7:13">Dio la ngelentórke bósór-Nyo trós mbékénnyo siap.<verse eid="PSA 7:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 7:14" />Dio la nyiapke diri-Nyo dengen senjato-senjato yang mematike,</para>
  <para style="q2" vid="PSA 7:14">jugo mbékén anak-anak pana-Nyo beapi-api.<verse eid="PSA 7:14" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="15" style="v" sid="PSA 7:15" />Jingokla! Wong tu bónténg kejahatan,</para>
  <para style="q2" vid="PSA 7:15">ngandóng kekejeman,</para>
  <para style="q2" vid="PSA 7:15">trós ngelaérke kebohongan.<verse eid="PSA 7:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 7:16" />Dio gali lobang trós dikedóknyo,</para>
  <para style="q2" vid="PSA 7:16">trós dio nyampak dewek ke jeró lobang yang la dibékénnyo.<verse eid="PSA 7:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 7:17" />Kekejemannyo bakal bebalék nimpo palaknyo dewek,</para>
  <para style="q2" vid="PSA 7:17">trós kekerasannyo bakal tórón ke pócók óbón-óbónnyo.<verse eid="PSA 7:17" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="18" style="v" sid="PSA 7:18" />Aku bakal ngucap sókór samo <char style="nd">ALLAHyhwh</char> karno kebeneran-Nyo,</para>
  <para style="q2" vid="PSA 7:18">trós aku bakal nyanyike puji-pujian óntók namo <char style="nd">ALLAHyhwh</char> Yang Mahabesak.<verse eid="PSA 7:18" /></para>
  <chapter eid="PSA 7" />
  <chapter number="8" style="c" sid="PSA 8" />
  <para style="s2">Allah yang mulyo nyadike manusio nguasoi ciptoan-Nyo</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 8:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Dinyanyike nórót gitit<note caller="+" style="f"><char style="fr" closed="false">8:1 </char><char style="fq" closed="false">gitit: </char><char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén namo alat, nada, apo dak tu jenis musik.</char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 8:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 8:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, ya Tuan kami,</para>
  <para style="q2" vid="PSA 8:2">alangke mulyo namo Kau di slóró bumi!</para>
  <para style="q2" vid="PSA 8:2">Kau tarokke<note caller="+" style="f"><char style="fr" closed="false">8:2 </char><char style="fq" closed="false">Kau tarokke: </char><char style="ft" closed="false">Teks asli dari kato ni dak pulok jelas.</char></note> keagóngan Kau di pócók langét.<verse eid="PSA 8:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 8:3" />Dari mólót budak jugo kupek yang netek, Kau bangón kekuatan<note caller="+" style="f"><char style="fr" closed="false">8:3 </char><char style="fq" closed="false">Dari mólót budak … Kau bangón kekuatan: </char><char style="ft" closed="false">Makno barés ni dak pulok jelas. Móngkén maksódnyo Allah makek wong yang lema óntók mbékén malu wong jahat, karno budak kecik lebé pecayo jugo muji Allah.</char></note></para>
  <para style="q2" vid="PSA 8:3">karno mósó-mósó Kau, óntók mbungkem lawan jugo pendendem.<verse eid="PSA 8:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 8:4" />Amen aku meratike langét Kau, békénan jari Kau,</para>
  <para style="q2" vid="PSA 8:4">bulan samo bintang yang la Kau tétépke,<verse eid="PSA 8:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 8:5" />apola manusio sampe-sampe Kau ngingetnyo,</para>
  <para style="q2" vid="PSA 8:5">jugo ketórónan Adam sampe-sampe Kau meratikenyo?<verse eid="PSA 8:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 8:6" />Kau mbékén dio wong sedikit lebé renda dari Allah<note caller="+" style="f"><char style="fr" closed="false">8:6 </char><char style="fq" closed="false">Allah: </char><char style="ft" closed="false">Teks asli pacak jugo diartike “malekat”. </char></note>,</para>
  <para style="q2" vid="PSA 8:6">trós ngenjók kemulyoan jugo kehormatan jadi mahkotanyo.<verse eid="PSA 8:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 8:7" />Kau mbékén dio wong nguasoi ciptoan tangan Kau.</para>
  <para style="q2" vid="PSA 8:7">Slórónyo Kau tarok di bawa sekelnyo:<verse eid="PSA 8:7" /></para>
  <para style="q3">
    <verse number="8" style="v" sid="PSA 8:8" />slóró kambéng domba samo sapi,</para>
  <para style="q3" vid="PSA 8:8">jugo binatang-binatang liar di darat,<verse eid="PSA 8:8" /></para>
  <para style="q3">
    <verse number="9" style="v" sid="PSA 8:9" />bóróng-bóróng di langét samo iwak-iwak di laót,</para>
  <para style="q3" vid="PSA 8:9">jugo mahlók-mahlók yang melok'i arós laótan.<verse eid="PSA 8:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 8:10" />Ya <char style="nd">ALLAHyhwh</char>, ya Tuan kami,</para>
  <para style="q2" vid="PSA 8:10">alangke mulyo namo Kau di slóró bumi!<verse eid="PSA 8:10" /></para>
  <chapter eid="PSA 8" />
  <chapter number="9" style="c" sid="PSA 9" />
  <para style="s2">Ucapan sókór samo Allah, Hakém yang bener<note caller="+" style="f"><char style="fr" closed="false">9:1 </char><char style="ft" closed="false">Ado kemóngkénan besak amen awal mulo S. Ny. 9-10 ni jadi sikok pas jaman bingen.</char></note></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 9:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót mut-laben<note caller="+" style="f"><char style="fr" closed="false">9:1 </char><char style="fq" closed="false">mut-laben: </char><char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén namo nyanyian apo dak tu petónjók musik.</char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 9:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 9:2" />Aku nak ngucap sókór samo <char style="nd"><char style="w">ALLAHyhwh</char></char> dengen segenep ati.</para>
  <para style="q1" vid="PSA 9:2">Aku nak nyeritoke pebuatan Kau yang ajaéb.<verse eid="PSA 9:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 9:3" />Aku nak besorak-sorak trós beseneng-seneng karno Kau.</para>
  <para style="q1" vid="PSA 9:3">Aku nak nyanyike puji-pujian óntók namo Kau, ya Yang Mahabesak.<verse eid="PSA 9:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 9:4" />Pas mósó-mósó aku móndór,</para>
  <para style="q2" vid="PSA 9:4">dio wong kesandóng trós binaso di adepan Kau.<verse eid="PSA 9:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 9:5" />Soalnyo Kau mbela keadélan óntók pekaro aku.</para>
  <para style="q1" vid="PSA 9:5">Kau dódók di korsi kekuasoan trós ngakémi dengen bener.<verse eid="PSA 9:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 9:6" />Kau nyegak bangso-bangso trós mbinasoke wong jahat.</para>
  <para style="q2" vid="PSA 9:6">Namo dio wong Kau apóske óntók seterósnyo jugo selamo-lamonyo.<verse eid="PSA 9:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 9:7" />Mósó-mósó la abés, jadi póéng-póéng selamonyo.</para>
  <para style="q2" vid="PSA 9:7">Kota-kota dio wong la Kau tumbangke.</para>
  <para style="q3" vid="PSA 9:7">Katek yang inget lagi pasal dio wong.<verse eid="PSA 9:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 9:8" />Tapi <char style="nd">ALLAHyhwh</char> tinggal óntók selamo-lamonyo,</para>
  <para style="q2" vid="PSA 9:8">Dio la negakke korsi kekuasoan-Nyo óntók ngakémi.<verse eid="PSA 9:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 9:9" />Diola yang ngakémi dunio ni dengen keadélan,</para>
  <para style="q2" vid="PSA 9:9">ngakémi bangso-bangso dengen kebeneran.<verse eid="PSA 9:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 9:10" />
    <char style="nd">ALLAHyhwh</char> iola tempat peléndóngan óntók wong yang tetindes,</para>
  <para style="q2" vid="PSA 9:10">tempat beléndóng pas dalem kesaroan.<verse eid="PSA 9:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 9:11" />Wong-wong yang tau namo baék Kau pecayo samo Kau,</para>
  <para style="q2" vid="PSA 9:11">karno Kau dak perna ninggalke wong yang nyari Kau, ya <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 9:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 9:12" />Nyanyikela puji-pujian óntók <char style="nd">ALLAHyhwh</char>, yang dódók di bókét <char style="w">Sion</char>!</para>
  <para style="q2" vid="PSA 9:12">Britokela samo bangso-bangso pasal pebuatan-pebuatan-Nyo!<verse eid="PSA 9:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 9:13" />Soalnyo Dio yang mbaleske penumpahan dara pasti nginget wong yang saro;</para>
  <para style="q2" vid="PSA 9:13">Dio idak lupo jerétan dio wong.<verse eid="PSA 9:13" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="14" style="v" sid="PSA 9:14" />Ya <char style="nd">ALLAHyhwh</char>, mura atila samo aku.</para>
  <para style="q1" vid="PSA 9:14">Jingokila kesaroan aku dari wong-wong yang mbenci aku,</para>
  <para style="q2" vid="PSA 9:14">ya <char style="add">Tuhan</char> yang ngangkat aku dari gerbang maót,<verse eid="PSA 9:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 9:15" />supayo aku pacak nyeritoke slóró kemulyoan Kau</para>
  <para style="q2" vid="PSA 9:15">di jeró gerbang Sion, yang iola anak gadés Kau.</para>
  <para style="q1" vid="PSA 9:15">Aku bakal besorak-sorak karno keselametan dari Kau.<verse eid="PSA 9:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 9:16" />Bangso-bangso tejeblos ke jeró lobang yang la dio wong mbékén.</para>
  <para style="q2" vid="PSA 9:16">Sekel dio wong tejiret jeró jaréng yang dio wong pasang dewek.<verse eid="PSA 9:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 9:17" />
    <char style="nd">ALLAHyhwh</char> la nyatoke diri-Nyo dengen nyalanke pengakéman.</para>
  <para style="q2" vid="PSA 9:17">Wong jahat tejiret dalem pebuatan tangannyo dewek. <char style="qs">Higayon. Selah.</char><note caller="+" style="f"><char style="fr" closed="false">9:17 </char><char style="fq" closed="false">Higayon. Selah: </char><char style="ft" closed="false">Keduo kato ni dari baso asli. Idak diartike karno idak jelas maknonyo, tapi móngkén digunoke jadi petónjók musik.</char></note><verse eid="PSA 9:17" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="18" style="v" sid="PSA 9:18" />Wong-wong jahat bakal balék ke alam kóbór,</para>
  <para style="q2" vid="PSA 9:18">iyo, segalo bangso yang ngelupoke Allah.<verse eid="PSA 9:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 9:19" />Tapi, wong méskén dak bakal dilupoke óntók seterósnyo,</para>
  <para style="q2" vid="PSA 9:19">trós arepan wong yang saro dak bakal ilang selamonyo.<verse eid="PSA 9:19" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="20" style="v" sid="PSA 9:20" />Ya <char style="nd">ALLAHyhwh</char>, bangkétla!</para>
  <para style="q2" vid="PSA 9:20">Jangan biarke manusio menang!</para>
  <para style="q1" vid="PSA 9:20">Békénla bangso-bangso diakémi di adepan Kau.<verse eid="PSA 9:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="PSA 9:21" />Békénla dio wong takót, ya <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q1" vid="PSA 9:21">Békénla bangso-bangso tau</para>
  <para style="q2" vid="PSA 9:21">amen dio wong cuman manusio. <char style="qs">Selah.</char><verse eid="PSA 9:21" /></para>
  <chapter eid="PSA 9" />
  <chapter number="10" style="c" sid="PSA 10" />
  <para style="s2">Doa óntók wong yang saro<note caller="+" style="f"><char style="fr" closed="false">10:1 </char><char style="ft" closed="false">Saér ni kemóngkénan besak iola lanjótan dari saér 9.</char></note></para>
  <para style="b" />
  <para style="q1">
    <verse number="1" style="v" sid="PSA 10:1" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, ngapo Kau tegak jaó-jaó?</para>
  <para style="q2" vid="PSA 10:1">Ngapo Kau nyingitke diri Kau pas <char style="add">kami</char> saro?<verse eid="PSA 10:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 10:2" />Dengen sombong wong jahat ngejer wong yang saro.</para>
  <para style="q2" vid="PSA 10:2">Biarkela wong <char style="add">jahat</char> ketangkep dalem rencano yang la dio wong mbékén dewek<note caller="+" style="f"><char style="fr" closed="false">10:2 </char><char style="fq" closed="false">Biarkela wong jahat … dio wong mbékén dewek: </char><char style="ft" closed="false">Teks asli barés ni pacak jugo diartike “wong <char style="add">saro</char> ketangkep dalem rencano yang la dibékén wong <char style="add">jahat</char>”.</char></note>.<verse eid="PSA 10:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 10:3" />Iyo, wong jahat nyombongke napsu atinyo.</para>
  <para style="q2" vid="PSA 10:3">Wong rakós ngótók'i trós ngino <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 10:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 10:4" />Uji wong jahat dengen rai tecungak, “Dio dak bakal nóntót!”</para>
  <para style="q2" vid="PSA 10:4">Pékérannyo cuman, “Dak katek Tuhan!”<note caller="+" style="sf"><char style="fr" closed="false">10:4 </char><char style="fq" closed="false">Uji wong jahat … “Dak katek Tuhan!”: </char><char style="ft" closed="false">Makno teks asli dari ayat ni dak pulok jelas.</char></note><verse eid="PSA 10:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 10:5" />Jalan-jalannyo berasél terós.</para>
  <para style="q1" vid="PSA 10:5">Hókóm-hókóm Kau ado di tempat tinggi, jaó dari <char style="add">pemékéran</char> dio.</para>
  <para style="q2" vid="PSA 10:5">Dio nganggep enteng galo-galo mósónyo.<verse eid="PSA 10:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 10:6" />Di jeró atinyo dio ngomong, “Aku dak bakal tegoyake!</para>
  <para style="q2" vid="PSA 10:6">Aku dak bakal perna keno kesaroan!”<verse eid="PSA 10:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 10:7" />Mólótnyo penu dengen kótók, kecalakan, jugo penindesan.</para>
  <para style="q2" vid="PSA 10:7">Di bawa lidanyo ado kesaroan jugo kejahatan.<verse eid="PSA 10:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 10:8" />Dio dódók nyegat di dósón-dósón.</para>
  <para style="q2" vid="PSA 10:8">Di tempat yang tesingit dio mbunu wong yang dak besala.</para>
  <para style="q2" vid="PSA 10:8">Matonyo ngintei wong yang sial.<verse eid="PSA 10:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 10:9" />Dio nyegat di tempat yang tesingit pecak singo di semak-semak.</para>
  <para style="q2" vid="PSA 10:9">Dio nyegat óntók nangkep wong yang saro.</para>
  <para style="q2" vid="PSA 10:9">Dio nangkep wong yang saro tu dengen naréknyo ke jeró jaréngnyo.<verse eid="PSA 10:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 10:10" />Dio mbóngkók trós ngendep-ngendep,</para>
  <para style="q2" vid="PSA 10:10">laju, dengen kekuatannyo, dio nyampakke wong yang sial tu<note caller="+" style="sf"><char style="fr" closed="false">10:10 </char><char style="fq" closed="false">Dio mbóngkók … wong yang sial tu: </char><char style="ft" closed="false">Makno teks asli dari ayat ni dak pulok jelas.</char></note>.<verse eid="PSA 10:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 10:11" />Uji <char style="add">wong jahat</char> di jeró atinyo,</para>
  <para style="q2" vid="PSA 10:11">“<char style="add">Nah</char>! Allah la lupo!</para>
  <para style="q2" vid="PSA 10:11">Dio la nyingitke rai-Nyo,</para>
  <para style="q2" vid="PSA 10:11">trós Dio dak bakal nyingoknyo!”<verse eid="PSA 10:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 10:12" />
    <char style="add">Jadi</char>, bangkétla, ya <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 10:12">Tórónla tangan Kau, Ya Tuhan!</para>
  <para style="q2" vid="PSA 10:12">Janganla ngelupoke wong yang saro.<verse eid="PSA 10:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 10:13" />Kok wong jahat ngino Allah?</para>
  <para style="q2" vid="PSA 10:13">Kok dio ngomong di jeró atinyo, “Allah<note caller="+" style="f"><char style="fr" closed="false">10:13 </char><char style="fq" closed="false">Allah: </char><char style="ft" closed="false">Teks asli iola “Kau”.</char></note> dak bakal nóntót!”?<verse eid="PSA 10:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 10:14" />Kau memang nyingoknyo!</para>
  <para style="q2" vid="PSA 10:14">Iyo, Kau meratike kesaroan jugo kesedéan.</para>
  <para style="q2" vid="PSA 10:14">Kau ngambéknyo ke dalem tangan Kau dewek.</para>
  <para style="q1" vid="PSA 10:14">Wong yang sial pasra samo Kau.</para>
  <para style="q2" vid="PSA 10:14">Kaula penolong anak yatém.<verse eid="PSA 10:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 10:15" />Patakela tangan wong yang beduso jugo wong jahat!</para>
  <para style="q2" vid="PSA 10:15">Tóntótla dusonyo sampe Kau dak nemukenyo lagi!<verse eid="PSA 10:15" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="16" style="v" sid="PSA 10:16" />
    <char style="nd">ALLAHyhwh</char> iola Rajo óntók seterósnyo jugo selamo-lamonyo;</para>
  <para style="q2" vid="PSA 10:16">bangso-bangso <char style="add">yang jahat</char> bakal dimusnake dari tana-Nyo.<verse eid="PSA 10:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 10:17" />Kepéngénan ati wong yang saro Kau dengerke, ya <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 10:17">Kau bakal nguatke ati dio wong.</para>
  <para style="q1" vid="PSA 10:17">Kau bakal nyiapke kópéng Kau<verse eid="PSA 10:17" /></para>
  <para style="q2">
    <verse number="18" style="v" sid="PSA 10:18" />óntók mbela anak yatém jugo wong yang tetindes,</para>
  <para style="q2" vid="PSA 10:18">sampe dak katek lagi wong yang nakótke di bumi.<verse eid="PSA 10:18" /></para>
  <chapter eid="PSA 10" />
  <chapter number="11" style="c" sid="PSA 11" />
  <para style="s2">Allah tempat peléndóngan wong bener</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 11:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Nyanyian ni</char> dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 11:1" />
  <para style="q1" vid="PSA 11:1">
    <char style="add">Ói mósóku!</char> Samo <char style="nd"><char style="w">ALLAHyhwh</char></char> aku beléndóng.</para>
  <para style="q1" vid="PSA 11:1">Cakmano nian kau pacak ngomong samo aku cak ini,</para>
  <para style="q2" vid="PSA 11:1">“Terbangla <char style="add">gancang</char> ke gónóng kau, pecak bóróng!<verse eid="PSA 11:1" /></para>
  <para style="q2">
    <verse number="2" style="v" sid="PSA 11:2" />Jingokla! Wong jahat ngelentórke bósórnyo</para>
  <para style="q3" vid="PSA 11:2">trós masang pana di tali bósórnyo</para>
  <para style="q3" vid="PSA 11:2">óntók meci dalem kegelepan wong yang lórós atinyo.<verse eid="PSA 11:2" /></para>
  <para style="q2">
    <verse number="3" style="v" sid="PSA 11:3" />Amen dasar-dasar <char style="add">masyarakat</char> la diancórke,</para>
  <para style="q3" vid="PSA 11:3">apo yang pacak wong bener lakuke?”<verse eid="PSA 11:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 11:4" />
    <char style="nd">ALLAHyhwh</char> ado di jeró Ruma Agóng-Nyo yang suci.</para>
  <para style="q2" vid="PSA 11:4">
    <char style="nd">ALLAHyhwh</char>! Korsi kekuasoan-Nyo ado di surgo!</para>
  <para style="q1" vid="PSA 11:4">Mato-Nyo masati;</para>
  <para style="q2" vid="PSA 11:4">sorotan mato-Nyo nyoboi anak-anak manusio.<verse eid="PSA 11:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 11:5" />
    <char style="nd">ALLAHyhwh</char> nyoboi wong bener samo wong jahat.</para>
  <para style="q2" vid="PSA 11:5">Dio benci wong yang cinto samo kekejeman.<verse eid="PSA 11:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 11:6" />Dio bakal ngujani wong jahat dengen baro areng.</para>
  <para style="q2" vid="PSA 11:6">Api, belerang, jugo angin panas iola bagéan takdér<note caller="+" style="f"><char style="fr" closed="false">11:6 </char><char style="fq" closed="false">takdér: </char><char style="ft" closed="false">Teks asli iola “cangkér”. Ini ni peumpamoan Ibrani pasal apo yang la Allah tentuke óntók keédópan wong.</char></note> dio wong.<verse eid="PSA 11:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 11:7" />
    <char style="nd">ALLAHyhwh</char> tu bener;</para>
  <para style="q2" vid="PSA 11:7">Dio cinto kebeneran.</para>
  <para style="q2" vid="PSA 11:7">Wong yang lórós atinyo bakal jingok rai-Nyo.<verse eid="PSA 11:7" /></para>
  <chapter eid="PSA 11" />
  <chapter number="12" style="c" sid="PSA 12" />
  <para style="s2">Doa mintak tolong ngadepi kejahatan dunio</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 12:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót syeminit<note caller="+" style="f"><char style="fr" closed="false">12:1 </char><char style="fq" closed="false">syeminit: </char><char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén nónjókke nada, alat musik, apo dak tu namo lagu.</char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 12:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 12:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, selametkela!</para>
  <para style="q2" vid="PSA 12:2">Soalnyo wong além la abés;</para>
  <para style="q2" vid="PSA 12:2">wong-wong stio la ilang dari antaro anak-anak manusio.<verse eid="PSA 12:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 12:3" />Dio wong saléng ngotak'i;</para>
  <para style="q2" vid="PSA 12:3">dio wong ngomong dengen bébér manis jugo ati yang becabang.<verse eid="PSA 12:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 12:4" />Kironyo <char style="nd">ALLAHyhwh</char> netak slóró bébér manis</para>
  <para style="q2" vid="PSA 12:4">jugo lida yang besak omong,<verse eid="PSA 12:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 12:5" />iola dio wong yang ngomong, “Dengen lida kami, kami menang!</para>
  <para style="q2" vid="PSA 12:5">Bébér kami iola kepunyoan kami! Siapo nian yang jadi tuan kami?”<verse eid="PSA 12:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 12:6" />
    <char style="nd">ALLAHyhwh</char> ngomong,</para>
  <para style="q1" vid="PSA 12:6">“Karno penindesan wong saro</para>
  <para style="q2" vid="PSA 12:6">jugo karno réntéan wong méskén,</para>
  <para style="q2" vid="PSA 12:6">sekarang Aku bakal bangkét!</para>
  <para style="q1" vid="PSA 12:6">Aku bakal narok dio wong di tempat aman yang dio wong arepke.”<verse eid="PSA 12:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 12:7" />Omongan <char style="nd">ALLAHyhwh</char> iola omongan yang murni,</para>
  <para style="q2" vid="PSA 12:7">pecak perak yang dilebór di jeró tungku di tana, tójó kali dimurnike.<verse eid="PSA 12:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 12:8" />Ya <char style="nd">ALLAHyhwh</char>, Kau bakal nyago wong-wong tu.</para>
  <para style="q2" vid="PSA 12:8">Kau bakal ngeléndóngi dio wong dari angkatan jaman ni óntók selamo-lamonyo.<verse eid="PSA 12:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 12:9" />
    <char style="add">Soalnyo</char> wong jahat ado di mano-mano</para>
  <para style="q2" vid="PSA 12:9">karno kehinoan disanjóng-sanjóng di antaro anak-anak manusio.<verse eid="PSA 12:9" /></para>
  <chapter eid="PSA 12" />
  <chapter number="13" style="c" sid="PSA 13" />
  <para style="s2">Doa wong yang pecayo samo kasé stio Allah dalem kesaroan</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 13:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 13:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 13:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, sampe kapan Kau terós-terósan ngelupoke aku?</para>
  <para style="q1" vid="PSA 13:2">Sampe kapan Kau nyingiti rai Kau dari aku?<verse eid="PSA 13:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 13:3" />Sampe kapan aku harós nyimpen kekuatéran di dalem diri aku,</para>
  <para style="q2" vid="PSA 13:3">kesedéan di jeró ati aku siang malem?</para>
  <para style="q1" vid="PSA 13:3">Sampe kapan mósó aku ditinggike di pócók aku?<verse eid="PSA 13:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 13:4" />Ya <char style="nd">ALLAHyhwh</char>, ya Tuhan aku, peratikela trós simbatila aku.</para>
  <para style="q1" vid="PSA 13:4">Pólékela <char style="add">tenago aku sampe</char> mato aku terang,</para>
  <para style="q2" vid="PSA 13:4">supayo aku jangan sampe tetédók dalem kematian,<verse eid="PSA 13:4" /></para>
  <para style="q2">
    <verse number="5" style="v" sid="PSA 13:5" />supayo mósó aku jangan sampe ngomong, “Aku la nguasoi dio!”</para>
  <para style="q3" vid="PSA 13:5">trós lawan-lawan aku besorak-sorak pas aku tecampak.<verse eid="PSA 13:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 13:6" />Tapi aku, samo kasé stio Kaula aku pecayo;</para>
  <para style="q2" vid="PSA 13:6">ati aku besorak-sorak karno keselametan dari Kau.</para>
  <para style="q1" vid="PSA 13:6">Aku bakal nyanyi óntók <char style="nd">ALLAHyhwh</char></para>
  <para style="q2" vid="PSA 13:6">karno Dio la bebuat baék samo aku.<verse eid="PSA 13:6" /></para>
  <chapter eid="PSA 13" />
  <chapter number="14" style="c" sid="PSA 14" />
  <para style="s2">Kebórókan manusio</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 14:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Nyanyian ni</char> dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 14:1" />
  <para style="q1" vid="PSA 14:1">Wong tekak ngomong di dalem atinyo,</para>
  <para style="q2" vid="PSA 14:1">“Katek Tuhan.”</para>
  <para style="q1" vid="PSA 14:1">Dio wong busuk ati. Kelakuannyo kejem.</para>
  <para style="q2" vid="PSA 14:1">Katek yang bebuat baék.<verse eid="PSA 14:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 14:2" />
    <char style="nd">
      <char style="w">ALLAHyhwh</char>
    </char> masati dari surgo,</para>
  <para style="q2" vid="PSA 14:2">ke anak-anak manusio,</para>
  <para style="q1" vid="PSA 14:2">óntók jingok kalu bae ado wong yang bijak,</para>
  <para style="q2" vid="PSA 14:2">yang nyari Allah.<verse eid="PSA 14:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 14:3" />Galo-galo wong la melenceng,</para>
  <para style="q2" vid="PSA 14:3">samo-samo rusak.</para>
  <para style="q1" vid="PSA 14:3">Katek yang bebuat baék,</para>
  <para style="q2" vid="PSA 14:3">sikok wong bae idak.<note caller="-" style="x"><char style="xo" closed="false">14:3 </char><char style="xt" closed="false"><ref loc="ROM 3:10-12">Roma 3:10-12</ref></char></note><verse eid="PSA 14:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 14:4" />Idak sadar apo slóró wong yang bebuat jahat tu?</para>
  <para style="q2" vid="PSA 14:4">Dio wong tu makani umat aku pecak makan roti,</para>
  <para style="q2" vid="PSA 14:4">jugo idak bejerét samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 14:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 14:5" />Di sano dio wong bakal ketakótan nian.</para>
  <para style="q2" vid="PSA 14:5">Soalnyo Allah nyertoi angkatan wong bener.<verse eid="PSA 14:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 14:6" />Kamu nak ngalangi rencano wong yang saro,</para>
  <para style="q2" vid="PSA 14:6">tapi <char style="nd">ALLAHyhwh</char> iola tempat peléndóngannyo.<verse eid="PSA 14:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 14:7" />Kironyo keselametan wong-wong <char style="w">Israel</char> dateng dari <char style="w">Sion</char>!</para>
  <para style="q1" vid="PSA 14:7">Pas <char style="nd">ALLAHyhwh</char> balékke keadaan umat-Nyo tu,</para>
  <para style="q2" vid="PSA 14:7">
    <char style="w">Yakób</char> bakal besorak-sorak jugo Israel bakal seneng.<verse eid="PSA 14:7" /></para>
  <chapter eid="PSA 14" />
  <chapter number="15" style="c" sid="PSA 15" />
  <para style="s2">Siapo bae yang bole dateng ke Allah?</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 15:1" />Nyanyian <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 15:1" />
  <para style="q1" vid="PSA 15:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, siapo bae yang bole nginep dalem <char style="w" lemma="Kemah Petemuan">kemah Kau</char>?</para>
  <para style="q2" vid="PSA 15:1">Siapo bae yang bole netep di <char style="w" lemma="Sion">bókét Kau</char> yang suci?<verse eid="PSA 15:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 15:2" />Wong yang bejalan dalem ketólósan,</para>
  <para style="q2" vid="PSA 15:2">trós yang bebuat keadélan,</para>
  <para style="q2" vid="PSA 15:2">jugo yang ngomongke kebeneran di jeró atinyo.<verse eid="PSA 15:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 15:3" />Dio idak mitna pakek lidanyo,</para>
  <para style="q2" vid="PSA 15:3">idak bebuat jahat samo kawan-kawannyo,</para>
  <para style="q2" vid="PSA 15:3">trós idak ngatoi tetanggonyo.<verse eid="PSA 15:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 15:4" />Dio mandang hino wong yang ditolak Allah</para>
  <para style="q2" vid="PSA 15:4">tapi ngormati wong yang takót samo <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q1" vid="PSA 15:4">Dio dak ngoba janjinyo mugola dirugike.<verse eid="PSA 15:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 15:5" />Dio dak minjemke dóétnyo dengen nganakkenyo,</para>
  <para style="q2" vid="PSA 15:5">trós dak nerimo sogokan óntók ngelawan wong yang dak besala.</para>
  <para style="b" vid="PSA 15:5" />
  <para style="q1" vid="PSA 15:5">Wong yang bebuat cak itu dak bakal tegoyake sampe selamo-lamonyo.<verse eid="PSA 15:5" /></para>
  <chapter eid="PSA 15" />
  <chapter number="16" style="c" sid="PSA 16" />
  <para style="s2">Kesenengan wong além ado samo Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 16:1" />
    <char style="tl">Miktam</char>
    <note caller="+" style="f">
      <char style="fr" closed="false">16:1 </char>
      <char style="fq" closed="false">Miktam: </char>
      <char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char>
    </note> Daód.</para>
  <para style="b" vid="PSA 16:1" />
  <para style="q1" vid="PSA 16:1">Ya Allah, jagola aku, karno samo Kaula aku beléndóng.<verse eid="PSA 16:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 16:2" />Aku ngomong samo <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 16:2">“Kaula Tuan aku.</para>
  <para style="q2" vid="PSA 16:2">Dak katek yang baék óntók aku selaén Kau.”<verse eid="PSA 16:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 16:3" />Wong-wong suci yang ado di bumi ni</para>
  <para style="q2" vid="PSA 16:3">iola wong-wong yang mulyo yang jadi kesenengan aku.<verse eid="PSA 16:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 16:4" />Kesaroan wong-wong yang nyemba dewo bakal betamba banyak<note caller="+" style="f"><char style="fr" closed="false">16:3-4 </char><char style="fq" closed="false">Wong-wong suci … bakal betamba banyak: </char><char style="ft" closed="false">Teks asli dari ayat 3–4a ni dak pulok jelas.</char></note>.</para>
  <para style="q1" vid="PSA 16:4">Aku dak bakal melok dio wong nuangke pesembahan minuman yang dari dara,</para>
  <para style="q2" vid="PSA 16:4">apo manggél namo dewo-dewo di bébér aku.<verse eid="PSA 16:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 16:5" />Ya <char style="nd">ALLAHyhwh</char>, Kaula bagéan aku jugo takdér<note caller="+" style="f"><char style="fr" closed="false">16:5 </char><char style="fq" closed="false">takdér: </char><char style="ft" closed="false">Teks asli iola “cangkér”. Ini ni peumpamoan Ibrani pasal apo yang la Allah tentuke óntók keédópan wong. Di sini, Allah dewek yang jadi bagéan jugo takdér yang diterimo wong ni óntók édópnyo.</char></note> aku.</para>
  <para style="q2" vid="PSA 16:5">Kau nyekel undi aku.<verse eid="PSA 16:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 16:6" />Tali pengókór nyampak ke aku di tempat-tempat yang lemak.</para>
  <para style="q2" vid="PSA 16:6">Iyo nian, mélék warésan aku nyenengke aku.<verse eid="PSA 16:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 16:7" />Aku bakal muji <char style="nd">ALLAHyhwh</char>, yang la nasehati aku.</para>
  <para style="q2" vid="PSA 16:7">Iyo, pas malem ari, batén aku ngajari aku.<verse eid="PSA 16:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 16:8" />Aku la narok <char style="nd">ALLAHyhwh</char> di adepan aku terós.</para>
  <para style="q2" vid="PSA 16:8">Karno Dio ado di sebela kanan aku, aku dak bakal tegoncang.<verse eid="PSA 16:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 16:9" />Mangkonyo, ati aku seneng jugo jiwo aku besorak!</para>
  <para style="q2" vid="PSA 16:9">Iyo, badan aku bakal netep dengen aman.<verse eid="PSA 16:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 16:10" />Soalnyo Kau dak bakal nyerake jiwo aku ke dunio wong mati,</para>
  <para style="q2" vid="PSA 16:10">jugo dak bakal mbiarke wong além Kau jingok alam kóbór.<verse eid="PSA 16:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 16:11" />Kau ngenjóktauke samo aku jalan keédópan.</para>
  <para style="q1" vid="PSA 16:11">Di adepan Kau ado kepuasan yang penu.</para>
  <para style="q2" vid="PSA 16:11">Di sebela kanan Kau ado kesenengan selamo-lamonyo.<verse eid="PSA 16:11" /></para>
  <chapter eid="PSA 16" />
  <chapter number="17" style="c" sid="PSA 17" />
  <para style="s2">Doa mintak diagók'i Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 17:1" />Doa Daód.</para>
  <para style="b" vid="PSA 17:1" />
  <para style="q1" vid="PSA 17:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, dengerkela pekaro yang bener.</para>
  <para style="q2" vid="PSA 17:1">Peratikela jerétan aku!</para>
  <para style="q1" vid="PSA 17:1">Pasangla kópéng óntók doa aku,</para>
  <para style="q2" vid="PSA 17:1">yang metu dari bébér yang dak ngolai.<verse eid="PSA 17:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 17:2" />Dari hadérat Kaula sekironyo dateng pengakéman,</para>
  <para style="q2" vid="PSA 17:2">trós mato Kau sekironyo jingok apo yang adél.<verse eid="PSA 17:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 17:3" />Kau selédéki ati aku;</para>
  <para style="q1" vid="PSA 17:3">Kau merikso aku pas malem ari;</para>
  <para style="q1" vid="PSA 17:3">Kau nguji aku;</para>
  <para style="q1" vid="PSA 17:3">tapi Kau idak nemuke apo-apo.</para>
  <para style="q1" vid="PSA 17:3">Aku la mótóske</para>
  <para style="q2" vid="PSA 17:3">supayo mólót aku idak kelewatan.<verse eid="PSA 17:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 17:4" />Pasal pebuatan manusio:</para>
  <para style="q2" vid="PSA 17:4">Aku ni la jago diri aku dari jalan-jalan kekejeman</para>
  <para style="q2" vid="PSA 17:4">sesuai dengen prénto yang Kau sampeke.<verse eid="PSA 17:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 17:5" />Sekel aku tetep di jalór Kau,</para>
  <para style="q2" vid="PSA 17:5">langka aku dak tegoyake.<verse eid="PSA 17:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 17:6" />Aku ni mekék samo Kau</para>
  <para style="q2" vid="PSA 17:6">karno Kau bakal nyawab aku, ya Allah.</para>
  <para style="q1" vid="PSA 17:6">Pasangla kópéng óntók aku,</para>
  <para style="q2" vid="PSA 17:6">dengerkela omongan aku.<verse eid="PSA 17:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 17:7" />Nyatokela kasé stio Kau yang ajaéb tu!</para>
  <para style="q2" vid="PSA 17:7">Kaula penyelamet wong-wong yang beléndóng di tangan kanan Kau</para>
  <para style="q2" vid="PSA 17:7">dari mósó-mósó dio wong.<verse eid="PSA 17:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 17:8" />Jagola aku pecak biji mato Kau,</para>
  <para style="q2" vid="PSA 17:8">trós singitila aku di bawa dekepan sayap Kau<verse eid="PSA 17:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 17:9" />dari wong-wong jahat yang nak mbinasoke aku,</para>
  <para style="q2" vid="PSA 17:9">iola mósó-mósó aku yang ngepóng aku.<verse eid="PSA 17:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 17:10" />Dio wong ngeraske ati sampe katek raso kesian<note caller="+" style="f"><char style="fr" closed="false">17:10 </char><char style="fq" closed="false">ngeraske ati sampe katek raso kesian: </char><char style="ft" closed="false">Teks asli iola “nótóp lemaknyo”. Pecaknyo ini ni peumpamoan bingen yang maksódnyo dio dak punyo raso belas kesian.</char></note>;</para>
  <para style="q2" vid="PSA 17:10">mólót dio wong ngomong dengen sombong.<verse eid="PSA 17:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 17:11" />Sekarang dio wong ngepóng langka aku.</para>
  <para style="q2" vid="PSA 17:11">Dio wong ngéntép óntók ngempaske aku ke tana.<verse eid="PSA 17:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 17:12" />Dio wong pecak singo yang péngén nyabék-nyabék,</para>
  <para style="q2" vid="PSA 17:12">pecak singo mudo yang dódók di tempat singitannyo.<verse eid="PSA 17:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 17:13" />Ya <char style="nd">ALLAHyhwh</char>, bangkétla!</para>
  <para style="q2" vid="PSA 17:13">Adangla dio wong trós kalakela dio wong!</para>
  <para style="q1" vid="PSA 17:13">Lepaskela jiwo aku dari wong jahat dengen pedang Kau,<verse eid="PSA 17:13" /></para>
  <para style="q2">
    <verse number="14" style="v" sid="PSA 17:14" />dari manusio dengen tangan Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 17:14">iola wong-wong dunio, yang bagéannyo cuman ado dalem édóp ini.</para>
  <para style="q1" vid="PSA 17:14">Kau penui perót dio wong dengen apo yang Kau simpen,</para>
  <para style="q2" vid="PSA 17:14">anak-anak dio wong kenyang</para>
  <para style="q2" vid="PSA 17:14">trós dio wong ninggalke sisonyo óntók kupek-kupeknyo<note caller="+" style="f"><char style="fr" closed="false">17:14 </char><char style="fq" closed="false">Kau penui perót … kupek-kupeknyo: </char><char style="ft" closed="false">Makno teks asli dari ketigo barés ni dak pulok jelas.</char></note>.<verse eid="PSA 17:14" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="15" style="v" sid="PSA 17:15" />Tapi aku, dalem kebeneran aku bakal jingok rai Kau,</para>
  <para style="q2" vid="PSA 17:15">trós pas aku bangón, aku bakal seneng jingok rupo Kau<note caller="+" style="f"><char style="fr" closed="false">17:15 </char><char style="fq" closed="false">pas aku bangón, aku bakal seneng jingok rupo Kau: </char><char style="ft" closed="false">Barés ni pacak duo arti, 1) ado hóbóngan deket samo Allah pas bangón dari tédók, jugo 2) nian-nian jingok rupo Allah pas masók surgo seabés kematian.</char></note>.<verse eid="PSA 17:15" /></para>
  <chapter eid="PSA 17" />
  <chapter number="18" style="c" sid="PSA 18" />
  <para style="s2">Nyanyian sókór Rajo Daód karno kemenangan jugo keselametan dari Allah <note caller="+" style="f"><char style="fr" closed="false">18:1 </char><char style="ft" closed="false">Saér ni ampér samo dengen </char><char style="xt" closed="false"><ref loc="2SA 22">2 Samuel 22</ref></char><char style="ft" closed="false">.</char></note></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 18:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>, hamba <char style="nd"><char style="w">ALLAHyhwh</char></char>. Dio nyampekenyo samo <char style="nd">ALLAHyhwh</char> pas waktu <char style="nd">ALLAHyhwh</char> ngelepaskenyo dari cengkeman slóró mósónyo jugo dari tangan rajo Saól<note caller="+" style="f"><char style="fr" closed="false">18:1 </char><char style="fq" closed="false">rajo Saól: </char><char style="ft" closed="false">Dio ni iola rajo Israel yang petamo, sebelóm Daód.</char></note>. <verse eid="PSA 18:1" /><verse number="2" style="v" sid="PSA 18:2" />Dio ngomong cak ini:</para>
  <para style="b" vid="PSA 18:2" />
  <para style="q1" vid="PSA 18:2">Aku ngaséhi Kau, ya <char style="nd">ALLAHyhwh</char>, kekuatan aku!<verse eid="PSA 18:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 18:3" />
    <char style="nd">ALLAHyhwh</char> iola bókét batu aku, benteng petahanan aku, jugo penyelamet aku.</para>
  <para style="q2" vid="PSA 18:3">Diola Tuhan aku, gónóng batu aku; samo Diola aku beléndóng.</para>
  <para style="q2" vid="PSA 18:3">Diola tameng aku, penyelamet aku yang perkasa<note caller="+" style="f"><char style="fr" closed="false">18:3 </char><char style="fq" closed="false">penyelamet aku yang perkasa: </char><char style="ft" closed="false">Teks asli iola “tandók keselametan”. Dalem budayo Ibrani, “tandók” iola kiasan yang nónjókke kekuatan jugo kekuasoan. Jadi “tandók keselametan” artinyo ‘penyelamet yang perkasa’.</char></note>, jugo kota benteng aku.<verse eid="PSA 18:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 18:4" />
    <char style="nd">ALLAHyhwh</char> pantes dipuji! Aku bejerét samo Dio,</para>
  <para style="q2" vid="PSA 18:4">trós aku diselametke dari mósó-mósó.<verse eid="PSA 18:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 18:5" />Tali-tali maót ngelélét aku,</para>
  <para style="q1" vid="PSA 18:5">Arós deres kematian mbanjéri aku.<verse eid="PSA 18:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 18:6" />Tali-tali alam kóbór mbelét aku;</para>
  <para style="q1" vid="PSA 18:6">jebakan-jebakan maót ngadang aku.<verse eid="PSA 18:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 18:7" />Dalem kesesekan aku bejerét samo <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 18:7">trós mekék mintak tolong samo Tuhan aku.</para>
  <para style="q1" vid="PSA 18:7">Dari jeró Ruma-Nyo, Dio ndenger suaro aku,</para>
  <para style="q2" vid="PSA 18:7">trós pekékan aku mintak tolong ke Dio sampe ke kópéng-Nyo.<verse eid="PSA 18:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 18:8" />Laju bumi begoyang jugo begoncang;</para>
  <para style="q2" vid="PSA 18:8">trós dasar-dasar gónóng begeter.</para>
  <para style="q2" vid="PSA 18:8">Slórónyo begoyang karno kemarahan-Nyo.<verse eid="PSA 18:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 18:9" />Asep naék dari édóng-Nyo,</para>
  <para style="q2" vid="PSA 18:9">trós api yang mbinasoke metu dari mólót-Nyo;</para>
  <para style="q2" vid="PSA 18:9">baro yang mbakar metu dari Dio.<verse eid="PSA 18:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 18:10" />Dio nyibakke langét, trós tórón,</para>
  <para style="q2" vid="PSA 18:10">awan gelep ado di bawa sekel-Nyo.<verse eid="PSA 18:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 18:11" />Dio naék mahlók kerób<note caller="+" style="f"><char style="fr" closed="false">18:11 </char><char style="fq" closed="false">kerób: </char><char style="ft" closed="false">Ini ni semacem mahlók surgawi yang besayap yang diciptoke Allah óntók ngelayani Dio. Tugasnyo iola nyagoi apo bae yang dipréntoke Allah. Mahlók ni idak samo dengen <char style="w">malekat</char> laénnyo. </char></note> trós terbang,</para>
  <para style="q2" vid="PSA 18:11">melayang di sayap-sayap angin.<verse eid="PSA 18:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 18:12" />Dio narok kegelepan di sekeléléng Dio jadi tempat singitan-Nyo;</para>
  <para style="q2" vid="PSA 18:12">pondok-Nyo dari awan-awan gelep yang penu banyu.<verse eid="PSA 18:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 18:13" />Dari cahayo di depan-Nyo</para>
  <para style="q2" vid="PSA 18:13">metu awan-Nyo samo ujan es jugo baro api.<verse eid="PSA 18:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 18:14" />
    <char style="nd">ALLAHyhwh</char> begemóró di langét,</para>
  <para style="q2" vid="PSA 18:14">trós Yang Mahabesak metuke suaro-Nyo di antaro ujan es jugo baro api<note caller="+" style="f"><char style="fr" closed="false">18:14 </char><char style="fq" closed="false">di antaro ujan es jugo baro api: </char><char style="ft" closed="false">Di beberapo naska kuno dari kitab ni, kato-kato “di antaro ujan es jugo baro api” katek di ayat ni.</char></note>.<verse eid="PSA 18:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 18:15" />Dio ngelepaske anak-anak pana-Nyo trós mbubarke dio wong;</para>
  <para style="q2" vid="PSA 18:15">Dio mancarke kilat trós ngacauke dio wong.<verse eid="PSA 18:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 18:16" />Ahérnyo, arós-arós laótan dalem tejingok,</para>
  <para style="q2" vid="PSA 18:16">trós dasar-dasar bumi tebukak,</para>
  <para style="q1" vid="PSA 18:16">karno tegoran Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 18:16">jugo karno embósan napas dari édóng Kau.<verse eid="PSA 18:16" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="17" style="v" sid="PSA 18:17" />Dio ngeraé dari tempat tinggi trós ngambék aku;</para>
  <para style="q2" vid="PSA 18:17">Dio narék aku dari <char style="add">bahayo maót pecak dari</char> banyu yang dalem.<verse eid="PSA 18:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 18:18" />Dio ngelepaske aku dari mósó aku yang gagah,</para>
  <para style="q2" vid="PSA 18:18">dari dio wong yang mbenci aku.</para>
  <para style="q2" vid="PSA 18:18">Soalnyo dio wong keliwat kuat óntók aku.<verse eid="PSA 18:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 18:19" />Dio wong ngadang aku pas ari sial aku,</para>
  <para style="q2" vid="PSA 18:19">tapi <char style="nd">ALLAHyhwh</char> iola penopang aku.<verse eid="PSA 18:19" /></para>
  <para style="q1">
    <verse number="20" style="v" sid="PSA 18:20" />Dio gawak aku metu ke tempat yang lapang;</para>
  <para style="q2" vid="PSA 18:20">Dio nyelametke aku karno Dio seneng samo aku.<verse eid="PSA 18:20" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="21" style="v" sid="PSA 18:21" />
    <char style="nd">ALLAHyhwh</char> bebuat baék samo aku sesuai kebeneran aku;</para>
  <para style="q2" vid="PSA 18:21">sesuai kesucian tangan aku, Dio mbales aku.<verse eid="PSA 18:21" /></para>
  <para style="q1">
    <verse number="22" style="v" sid="PSA 18:22" />Soalnyo aku melok'i jalan <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 18:22">trós aku idak bebuat jahat dengen bebalék dari Tuhan aku.<verse eid="PSA 18:22" /></para>
  <para style="q1">
    <verse number="23" style="v" sid="PSA 18:23" />Iyo! Soalnyo slóró hókóm-Nyo tu ado nian di adepan aku;</para>
  <para style="q2" vid="PSA 18:23">aku idak nyimpang dari peratóran-peratóran-Nyo.<verse eid="PSA 18:23" /></para>
  <para style="q1">
    <verse number="24" style="v" sid="PSA 18:24" />Aku sempurno di adepan-Nyo,</para>
  <para style="q2" vid="PSA 18:24">trós aku nyago diri aku dari kesalahan.<verse eid="PSA 18:24" /></para>
  <para style="q1">
    <verse number="25" style="v" sid="PSA 18:25" />Laju <char style="nd">ALLAHyhwh</char> mbales aku sesuai kebeneran aku,</para>
  <para style="q2" vid="PSA 18:25">sesuai kesucian tangan aku di depan mato-Nyo.<verse eid="PSA 18:25" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="26" style="v" sid="PSA 18:26" />Samo wong além, Kau tónjókke amen Kau dewek além.</para>
  <para style="q1" vid="PSA 18:26">Samo wong yang tólós, Kau tónjókke amen Kau dewek tólós.<verse eid="PSA 18:26" /></para>
  <para style="q1">
    <verse number="27" style="v" sid="PSA 18:27" />Samo wong yang suci, Kau tónjókke amen Kau dewek suci.</para>
  <para style="q1" vid="PSA 18:27">Tapi samo wong yang bengkok ati, Kau jugo bebelét-belét.<verse eid="PSA 18:27" /></para>
  <para style="q1">
    <verse number="28" style="v" sid="PSA 18:28" />Soalnyo Kaula yang nyelametke wong yang saro,</para>
  <para style="q2" vid="PSA 18:28">tapi wong yang tinggi ati<note caller="+" style="f"><char style="fr" closed="false">18:28 </char><char style="fq" closed="false">ati: </char><char style="ft" closed="false">Teks asli iola “mato”. Dalem baso Ibrani kiasan “mato yang tinggi” artinyo kesombongan. </char></note> Kau rendake.<verse eid="PSA 18:28" /></para>
  <para style="q1">
    <verse number="29" style="v" sid="PSA 18:29" />Kaula yang ngédópke pelito aku.</para>
  <para style="q2" vid="PSA 18:29">
    <char style="nd">ALLAHyhwh</char>, Tuhanku, nyinari kegelepan <char style="add">di sekeléléng</char> aku.<verse eid="PSA 18:29" /></para>
  <para style="q1">
    <verse number="30" style="v" sid="PSA 18:30" />Samo Kau aku pacak belari nerobos pasókan,</para>
  <para style="q2" vid="PSA 18:30">trós samo Tuhanku, aku pacak nguasoi kota<note caller="+" style="f"><char style="fr" closed="false">18:30 </char><char style="fq" closed="false">pacak nguasoi kota: </char><char style="ft" closed="false">Teks asli iola “ngeloncati tembok”. Maksódnyo ngeloncati tembok kota óntók naklókkenyo.</char></note>.<verse eid="PSA 18:30" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="31" style="v" sid="PSA 18:31" />Allah tu, pebuatan-Nyo sempurno;</para>
  <para style="q2" vid="PSA 18:31">omongan <char style="nd">ALLAHyhwh</char> tu teuji.</para>
  <para style="q1" vid="PSA 18:31">Diola tameng óntók slóró wong yang beléndóng samo Dio.<verse eid="PSA 18:31" /></para>
  <para style="q1">
    <verse number="32" style="v" sid="PSA 18:32" />Soalnyo, siapo lagi Tuhan, selaén <char style="nd">ALLAHyhwh</char>?</para>
  <para style="q2" vid="PSA 18:32">Siapo lagi gónóng batu, selaén Tuhan kito?<verse eid="PSA 18:32" /></para>
  <para style="q1">
    <verse number="33" style="v" sid="PSA 18:33" />Allah yang ngelengkapi aku dengen kekuatan.</para>
  <para style="q1" vid="PSA 18:33">Dio mbékén jalan aku sempurno.<verse eid="PSA 18:33" /></para>
  <para style="q1">
    <verse number="34" style="v" sid="PSA 18:34" />Dio mbékén sekel aku pecak sekel ruso,</para>
  <para style="q2" vid="PSA 18:34">trós mbékén aku tegak <char style="add">dengen aman</char> di tempat tinggi.<verse eid="PSA 18:34" /></para>
  <para style="q1">
    <verse number="35" style="v" sid="PSA 18:35" />Dio ngelaté aku óntók beperang</para>
  <para style="q2" vid="PSA 18:35">supayo tangan aku pacak ngelengkóngke bósór perunggu.<verse eid="PSA 18:35" /></para>
  <para style="q1">
    <verse number="36" style="v" sid="PSA 18:36" />Kau ngenjók aku tameng keselametan Kau,</para>
  <para style="q2" vid="PSA 18:36">tangan kanan Kau nopang aku;</para>
  <para style="q2" vid="PSA 18:36">kemurahan Kau mbékén aku bekuaso.<verse eid="PSA 18:36" /></para>
  <para style="q1">
    <verse number="37" style="v" sid="PSA 18:37" />Kau ngelebarke jalan di bawa langka aku,</para>
  <para style="q2" vid="PSA 18:37">supayo sekel aku idak tepleset.<verse eid="PSA 18:37" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="38" style="v" sid="PSA 18:38" />Aku ngejer mósó-mósó aku, trós nangkep dio wong;</para>
  <para style="q2" vid="PSA 18:38">aku idak bebalék sampe dio wong dibinasoke.<verse eid="PSA 18:38" /></para>
  <para style="q1">
    <verse number="39" style="v" sid="PSA 18:39" />Aku ngancórke dio wong, trós dio wong idak pacak bangkét lagi;</para>
  <para style="q2" vid="PSA 18:39">dio wong nyampak di bawa sekel aku.<verse eid="PSA 18:39" /></para>
  <para style="q1">
    <verse number="40" style="v" sid="PSA 18:40" />Kau ngelengkapi aku dengen kekuatan óntók beperang;</para>
  <para style="q2" vid="PSA 18:40">Kau nóndókke wong-wong yang bangkét ngelawan aku ke bawa <char style="add">kuaso</char> aku.<verse eid="PSA 18:40" /></para>
  <para style="q1">
    <verse number="41" style="v" sid="PSA 18:41" />Kau mbékén mósó-mósó aku lari dari aku<note caller="+" style="f"><char style="fr" closed="false">18:41 </char><char style="fq" closed="false">Kau mbékén mósó-mósó aku lari dari aku: </char><char style="ft" closed="false">Teks asli pacak jugo diartike “Kau ngenjók ke aku leher mósó-mósó aku”.</char></note>,</para>
  <para style="q2" vid="PSA 18:41">trós aku ngancórke dio wong yang mbenci aku.<verse eid="PSA 18:41" /></para>
  <para style="q1">
    <verse number="42" style="v" sid="PSA 18:42" />Dio wong mekék mintak tolong, tapi dak katek penyelamet;</para>
  <para style="q2" vid="PSA 18:42">dio wong mekék samo <char style="nd">ALLAHyhwh</char>, tapi Dio idak nyimbat.<verse eid="PSA 18:42" /></para>
  <para style="q1">
    <verse number="43" style="v" sid="PSA 18:43" />Aku mérék dio wong jadi pecak debu diterbangke angin;</para>
  <para style="q2" vid="PSA 18:43">aku nggiles dio wong pecak lómpór di jalanan.<verse eid="PSA 18:43" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="44" style="v" sid="PSA 18:44" />Kau ngelepaske aku dari kerébótan rakyat.</para>
  <para style="q1" vid="PSA 18:44">Kau ngangkat aku jadi kepalak mócók'i bangso-bangso;</para>
  <para style="q2" vid="PSA 18:44">rakyat yang idak aku kenal tóndók samo aku.<verse eid="PSA 18:44" /></para>
  <para style="q1">
    <verse number="45" style="v" sid="PSA 18:45" />Pas kópéng dio wong ndenger, dio wong nórót samo aku;</para>
  <para style="q2" vid="PSA 18:45">wong-wong aséng nyera samo aku.<verse eid="PSA 18:45" /></para>
  <para style="q1">
    <verse number="46" style="v" sid="PSA 18:46" />Wong-wong aséng jadi layu,</para>
  <para style="q2" vid="PSA 18:46">trós metu dengen gemeter dari benteng-bentengnyo.<verse eid="PSA 18:46" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="47" style="v" sid="PSA 18:47" />
    <char style="nd">ALLAHyhwh</char> édóp!</para>
  <para style="q2" vid="PSA 18:47">Pujila bókét batu aku!</para>
  <para style="q2" vid="PSA 18:47">Tinggikela Tuhan, penyelamet aku!<verse eid="PSA 18:47" /></para>
  <para style="q1">
    <verse number="48" style="v" sid="PSA 18:48" />Allah yang ngenjók pembalesan óntók aku</para>
  <para style="q2" vid="PSA 18:48">trós nóndókke bangso-bangso ke bawa <char style="add">kuaso</char> aku;<verse eid="PSA 18:48" /></para>
  <para style="q1">
    <verse number="49" style="v" sid="PSA 18:49" />Dio yang mbebaske aku dari mósó-mósó aku</para>
  <para style="q2" vid="PSA 18:49">trós ngangkat aku mócók'i wong-wong yang bangkét ngelawan aku.</para>
  <para style="q1" vid="PSA 18:49">Kau ngelepaske aku dari wong kejem.<verse eid="PSA 18:49" /></para>
  <para style="q1">
    <verse number="50" style="v" sid="PSA 18:50" />Karno tu, aku bakal ngucap sókór ke Kau, di antaro bangso-bangso, ya <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 18:50">Aku bakal nyanyike pujian óntók namo Kau.<verse eid="PSA 18:50" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="51" style="v" sid="PSA 18:51" />Dio ngenjók keselametan yang besak samo rajo-Nyo,</para>
  <para style="q2" vid="PSA 18:51">trós nyatoke kasé stio-Nyo samo wong yang dilanték-Nyo,</para>
  <para style="q2" vid="PSA 18:51">samo Daód jugo ketórónannyo sampe selamonyo.<verse eid="PSA 18:51" /></para>
  <chapter eid="PSA 18" />
  <chapter number="19" style="c" sid="PSA 19" />
  <para style="s2">Alam semesto jugo hókóm Allah jadi saksi kemulyoan-Nyo</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 19:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 19:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 19:2" />Semesto alam nyeritoke kemulyoan Allah,</para>
  <para style="q2" vid="PSA 19:2">jugo langét nyatoke pebuatan tangan-Nyo.<verse eid="PSA 19:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 19:3" />Ari neróske brito tu ke ari berékótnyo,</para>
  <para style="q2" vid="PSA 19:3">jugo malem nyampeke pengetauan tu ke malem berékótnyo.<verse eid="PSA 19:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 19:4" />Katek omongan, katek kato-kato;</para>
  <para style="q2" vid="PSA 19:4">suaronyo jugo idak tedenger.<verse eid="PSA 19:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 19:5" />Tapi kabarnyo tesebar ke slóró bumi,</para>
  <para style="q2" vid="PSA 19:5">trós pesennyo sampe ke ójóng dunio.</para>
  <para style="b" vid="PSA 19:5" />
  <para style="q1" vid="PSA 19:5">Di langét, Dio negakke kemah óntók matoari,<verse eid="PSA 19:5" /></para>
  <para style="q2">
    <verse number="6" style="v" sid="PSA 19:6" />trós matoari móncól, pecak pengantén lanang yang metu dari kamarnyo,</para>
  <para style="q2" vid="PSA 19:6">semangat pecak atlet<note caller="+" style="f"><char style="fr" closed="false">19:6 </char><char style="fq" closed="false">atlet: </char><char style="ft" closed="false">Kato asli iola “wong kuat”. Ini ni gambaran matoari besiap óntók belari nyebrangi langét pecak wong besiap óntók belari di lomba lari.</char></note> yang nak mulai larinyo.<verse eid="PSA 19:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 19:7" />Terbétnyo dari ójóng langét</para>
  <para style="q2" vid="PSA 19:7">trós belari sampe ke ójóng laénnyo;</para>
  <para style="q2" vid="PSA 19:7">katek yang teléndóng dari panasnyo.<verse eid="PSA 19:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 19:8" />Hókóm <char style="nd"><char style="w">ALLAHyhwh</char></char> tu sempurno,</para>
  <para style="q2" vid="PSA 19:8">nyegerke jiwo.</para>
  <para style="q1" vid="PSA 19:8">Peringetan <char style="nd">ALLAHyhwh</char> tu tegu,</para>
  <para style="q2" vid="PSA 19:8">mbékén wong polos jadi behikmah.<verse eid="PSA 19:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 19:9" />Petónjók <char style="nd">ALLAHyhwh</char> tu pacak dipecayo,</para>
  <para style="q2" vid="PSA 19:9">nyenengke ati.</para>
  <para style="q1" vid="PSA 19:9">Prénto <char style="nd">ALLAHyhwh</char> tu murni,</para>
  <para style="q2" vid="PSA 19:9">jadi penerang óntók mato.<verse eid="PSA 19:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 19:10" />Takót samo <char style="nd">ALLAHyhwh</char> tu suci,</para>
  <para style="q2" vid="PSA 19:10">ado óntók selamo-lamonyo.</para>
  <para style="q1" vid="PSA 19:10">Peratóran-peratóran <char style="nd">ALLAHyhwh</char> tu bener,</para>
  <para style="q2" vid="PSA 19:10">adél slórónyo,<verse eid="PSA 19:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 19:11" />lebé berego daripado emas,</para>
  <para style="q2" vid="PSA 19:11">ngelebéi banyak emas murni.</para>
  <para style="q1" vid="PSA 19:11">Lebé manis daripado madu,</para>
  <para style="q2" vid="PSA 19:11">ngelebéi tetesan madu dari sarang lebah.<verse eid="PSA 19:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 19:12" />Lebé-lebé lagi, aku, hamba Kau ni, diperingetke ole slórónyo tu;</para>
  <para style="q2" vid="PSA 19:12">dengen nyagonyo ado pahalo yang besak.<verse eid="PSA 19:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 19:13" />Siapo nian yang pacak tau kesalahannyo dewek?</para>
  <para style="q2" vid="PSA 19:13">Bersékela aku dari kesalahan yang tesingit tu.<verse eid="PSA 19:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 19:14" />Tahanla hamba Kau dari kesombongan;</para>
  <para style="q2" vid="PSA 19:14">jangan biarke pasal tu nguasoi aku.</para>
  <para style="q1" vid="PSA 19:14">Mangko aku jadi idak becacat,</para>
  <para style="q2" vid="PSA 19:14">trós bersé dari pelanggaran yang besak.<verse eid="PSA 19:14" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="15" style="v" sid="PSA 19:15" />Kironyo omongan mólót aku jugo renóngan ati aku</para>
  <para style="q2" vid="PSA 19:15">disenengi ole Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 19:15">gónóng batu jugo penebós aku.<verse eid="PSA 19:15" /></para>
  <chapter eid="PSA 19" />
  <chapter number="20" style="c" sid="PSA 20" />
  <para style="s2">Doa mintak kemenangan óntók rajo Israel</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 20:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 20:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 20:2" />Kironyo <char style="nd"><char style="w">ALLAHyhwh</char></char> nyawab kau<note caller="+" style="f"><char style="fr" closed="false">20:2 </char><char style="fq" closed="false">kau: </char><char style="ft" closed="false">Kato “kau” di saér ni sebenernyo ditujuke óntók rajo Israel. Pasal ni pacak tejingok di ayat 7, dalem kato-kato “wong yang dilanték-Nyo”. Saér ni digunoke bangso Israel óntók mberkahi rajonyo, jadi yang ngomong di ayat 2-6 jugo 10 iola masyarakat Israel.</char></note> pas ari kesaroan;</para>
  <para style="q2" vid="PSA 20:2">kironyo namo Tuhannyo <char style="w">Yakób</char> ngeléndóngi kau.<verse eid="PSA 20:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 20:3" />Kironyo Dio ngenjók petolongan dari tempat suci,</para>
  <para style="q2" vid="PSA 20:3">trós nopang kau dari <char style="w">Sion</char>.<verse eid="PSA 20:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 20:4" />Kironyo Dio nginget slóró pesembahan kau,</para>
  <para style="q2" vid="PSA 20:4">trós seneng samo kórban bakaran kau. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 20:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 20:5" />Kironyo Dio ngarunioke samo kau sesuai dengen kendak ati kau,</para>
  <para style="q2" vid="PSA 20:5">trós mbékén slóró rencano kau berasél.<verse eid="PSA 20:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 20:6" />Kami bakal besorak karno kemenangan kau,</para>
  <para style="q2" vid="PSA 20:6">trós ngangkat bendera-bendera dalem namo Tuhan kito.</para>
  <para style="q1" vid="PSA 20:6">Kironyo <char style="nd">ALLAHyhwh</char> ngabólke slóró pintak'an kau.<verse eid="PSA 20:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 20:7" />Sekarang aku tau amen <char style="nd">ALLAHyhwh</char> bakal nyelametke</para>
  <para style="q2" vid="PSA 20:7">wong yang dilanték-Nyo.</para>
  <para style="q1" vid="PSA 20:7">Dio bakal nyawab dari surgo-Nyo yang suci</para>
  <para style="q2" vid="PSA 20:7">dengen kuaso keselametan dari tangan kanan-Nyo.<verse eid="PSA 20:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 20:8" />Ado wong yang ngandalke kreto-kreto perangnyo,</para>
  <para style="q2" vid="PSA 20:8">ado jugo yang ngandalke kudo-kudonyo,</para>
  <para style="q2" vid="PSA 20:8">tapi kito ngandalke namo <char style="nd">ALLAHyhwh</char>, Tuhan kito.<verse eid="PSA 20:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 20:9" />Dio wong bakal betekók lótót trós nyampak,</para>
  <para style="q2" vid="PSA 20:9">tapi kito bangkét trós tegak dengen tegu.<verse eid="PSA 20:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 20:10" />Ya <char style="nd">ALLAHyhwh</char>, selametkela rajo!</para>
  <para style="q2" vid="PSA 20:10">Jawabla kami pas waktu kami bejerét!<verse eid="PSA 20:10" /></para>
  <chapter eid="PSA 20" />
  <chapter number="21" style="c" sid="PSA 21" />
  <para style="s2">Nyanyian sókór karno rajo diberkahi Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 21:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 21:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 21:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, dalem kekuatan Kau rajo beseneng;</para>
  <para style="q2" vid="PSA 21:2">dalem keselametan Kau dio besorak nian!<verse eid="PSA 21:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 21:3" />Kau la ngenjók ke dio kendak atinyo,</para>
  <para style="q2" vid="PSA 21:3">trós Kau idak nahan pintak'an bébérnyo. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 21:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 21:4" />Iyo, Kau nyambót dio dengen berkah-berkah yang baék;</para>
  <para style="q2" vid="PSA 21:4">Kau masangke mahkota emas murni di pócók palaknyo.<verse eid="PSA 21:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 21:5" />Dio mintak keédópan dari Kau,</para>
  <para style="q2" vid="PSA 21:5">trós Kau ngenjók ke dio ómór panjang sampe selamo-lamonyo.<verse eid="PSA 21:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 21:6" />Besak kemulyoannyo karno keselametan dari Kau;</para>
  <para style="q2" vid="PSA 21:6">kehormatan jugo keagóngan, Kau karunioke samo dio.<verse eid="PSA 21:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 21:7" />Iyo, Kau ngarunioke berkah ke dio óntók selamonyo,</para>
  <para style="q2" vid="PSA 21:7">trós Kau mbékén dio besorak kesenengan karno hadérat Kau.<verse eid="PSA 21:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 21:8" />Soalnyo rajo pecayo samo <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 21:8">trós ole karno kasé stio dari Yang Mahabesak,</para>
  <para style="q2" vid="PSA 21:8">dio dak bakal goya.<verse eid="PSA 21:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 21:9" />Tangan kau<note caller="+" style="f"><char style="fr" closed="false">21:9 </char><char style="fq" closed="false">kau: </char><char style="ft" closed="false">Dalem teks asli ayat 9–13, dak pulok jelas amen kato “kau” iola rajo apo Allah. Amen “kau” di sini iola Allah, artinyo Allah bakal ngelakuke slórónyo tu ke wong-wong jahat. Tapi amen “kau” di sini iola rajo, artinyo rajo tu yang bakal ngelakukenyo ke mósó-mósónyo dengen petolongan dari Allah. Rajo bakal bekuaso karno Allah ado besamo dio.</char></note> bakal nangkep slóró mósó kau,</para>
  <para style="q2" vid="PSA 21:9">tangan kanan kau bakal nangkep wong-wong yang mbenci kau.<verse eid="PSA 21:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 21:10" />Kau bakal mbékén dio wong pecak tungku api pas kau móncól.</para>
  <para style="q2" vid="PSA 21:10">
    <char style="nd">ALLAHyhwh</char> bakal negok dio wong dalem kemarahan-Nyo,</para>
  <para style="q2" vid="PSA 21:10">trós api bakal matike dio wong.<verse eid="PSA 21:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 21:11" />Kau bakal mbinasoke ketórónan dio wong dari bumi,</para>
  <para style="q2" vid="PSA 21:11">jugo penerós dio wong dari antaro anak-anak manusio.<verse eid="PSA 21:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 21:12" />Mugola dio wong nyiapke kejahatan óntók <char style="add">ngelawan</char> kau,</para>
  <para style="q2" vid="PSA 21:12">mugola dio wong beniat bórók,</para>
  <para style="q2" vid="PSA 21:12">dio wong dak bakal berasél.<verse eid="PSA 21:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 21:13" />Iyo! Kau bakal mbékén dio wong lari balék</para>
  <para style="q2" vid="PSA 21:13">pas kau ngarake tali-tali bósór kau ke dio wong.<verse eid="PSA 21:13" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="14" style="v" sid="PSA 21:14" />Ya <char style="nd">ALLAHyhwh</char>, ditinggikela Kau dalem kekuatan Kau!</para>
  <para style="q2" vid="PSA 21:14">Kami bakal nyanyi trós muji pasal kuaso Kau.<verse eid="PSA 21:14" /></para>
  <chapter eid="PSA 21" />
  <chapter number="22" style="c" sid="PSA 22" />
  <para style="s2">Doa pas kesaroan samo pujian pas diselametke</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 22:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> pecak lagu ‘Ruso pas pajar’. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 22:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 22:2" />Ya Tuhanku! Ya Tuhanku! Ngapo Kau ninggalke aku?</para>
  <para style="q2" vid="PSA 22:2">Petolongan Kau jaó dari aku,</para>
  <para style="q3" vid="PSA 22:2">jaó dari pekékan-pekékan aku.<verse eid="PSA 22:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 22:3" />Ya Tuhanku! Aku bejerét pas siang ari</para>
  <para style="q2" vid="PSA 22:3">tapi Kau idak nyawab,</para>
  <para style="q1" vid="PSA 22:3">trós pas malem ari,</para>
  <para style="q2" vid="PSA 22:3">tapi katek ketenangan óntók aku.<verse eid="PSA 22:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 22:4" />Tapi Kau suci,</para>
  <para style="q2" vid="PSA 22:4">yang tinggal dalem puji-pujian Israel.<verse eid="PSA 22:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 22:5" />Samo Kaula nenek moyang kami pecayo;</para>
  <para style="q2" vid="PSA 22:5">dio wong pecayo, trós Kau ngelepaske dio wong.<verse eid="PSA 22:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 22:6" />Samo Kaula dio wong bejerét, trós dibebaske.</para>
  <para style="q2" vid="PSA 22:6">Samo Kau dio wong pecayo, trós dio wong idak dikecewake.<verse eid="PSA 22:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 22:7" />Tapi aku ni ulet, bukan wong,</para>
  <para style="q2" vid="PSA 22:7">yang dihino manusio, trós direndake wong banyak.<verse eid="PSA 22:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 22:8" />Slóró wong yang jingok aku ngato-ngatoi aku;</para>
  <para style="q2" vid="PSA 22:8">dio wong cébérke bébér, gelengke palak.<verse eid="PSA 22:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 22:9" />Uji dio wong, “Dio kan besera samo <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 22:9">mangko biarkela Dio yang ngelepaskenyo!</para>
  <para style="q1" vid="PSA 22:9">Biarkela Dio nyelametkenyo,</para>
  <para style="q2" vid="PSA 22:9">Dio kan seneng samo wong tu!”<verse eid="PSA 22:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 22:10" />Tapi, Kaula yang metuke aku dari kandóngan.</para>
  <para style="q2" vid="PSA 22:10">Kau mbékén aku aman<note caller="+" style="f"><char style="fr" closed="false">22:10 </char><char style="fq" closed="false">aman: </char><char style="ft" closed="false">Kato asli di sini ado duo makno, ‘aman’ samo ‘pecayo’.</char></note>, di dado emak aku.<verse eid="PSA 22:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 22:11" />Sejak dari rahém, aku la dienjókke ke Kau.</para>
  <para style="q2" vid="PSA 22:11">Sejak dari perót emak aku, Kaula Tuhan aku.<verse eid="PSA 22:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 22:12" />Janganla jaó dari aku,</para>
  <para style="q2" vid="PSA 22:12">karno kesaroan la parak,</para>
  <para style="q3" vid="PSA 22:12">trós katek yang nolong.<verse eid="PSA 22:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 22:13" />Banyak sapi lanang ngeléléngi aku;</para>
  <para style="q2" vid="PSA 22:13">sapi-sapi kuat dari Basan<note caller="+" style="f"><char style="fr" closed="false">22:13 </char><char style="fq" closed="false">Basan: </char><char style="ft" closed="false">Sikok daera di sebela timur dari Sungi Yordan (sungi besak di Palestina). Daera tu tekenal karno sapinyo yang bagós nian.</char></note> ngepóng aku.<verse eid="PSA 22:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 22:14" />Dio wong bukak mólótnyo ngadepi aku,</para>
  <para style="q2" vid="PSA 22:14">pecak singo yang nerkem trós ngaóm.<verse eid="PSA 22:14" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="15" style="v" sid="PSA 22:15" />Kekuatan aku tekuras pecak banyu yang tumpa;<note caller="+" style="f"><char style="fr" closed="false">22:15 </char><char style="fq" closed="false">Kekuatan aku tekuras pecak banyu yang tumpa: </char><char style="ft" closed="false">Teks asli iola, “Pecak banyu aku tetumpa.”</char></note></para>
  <para style="q2" vid="PSA 22:15">slóró tulang aku pecól dari sendinyo.</para>
  <para style="q1" vid="PSA 22:15">Ati aku pecak lélén,</para>
  <para style="q2" vid="PSA 22:15">melele di jeró dado aku.<verse eid="PSA 22:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 22:16" />Tenago aku abés, tekeréng pecak beléng.<note caller="+" style="f"><char style="fr" closed="false">22:16 </char><char style="fq" closed="false">Tenago aku abés, tekeréng pecak beléng: </char><char style="ft" closed="false">Teks asli iola, “Kekuatan aku keréng pecak beléng.”</char></note></para>
  <para style="q2" vid="PSA 22:16">Jugo lida aku keréng nian sampe saro negok.<note caller="+" style="f"><char style="fr" closed="false">22:16 </char><char style="fq" closed="false">lida aku keréng nian sampe saro negok: </char><char style="ft" closed="false">Teks asli di sini iola, “lida aku nempel di langét-langét mólót aku”. Maksódnyo dio aós nian sampe-sampe banyu ludanyo keréng.</char></note></para>
  <para style="q3" vid="PSA 22:16">Di jeró liang kóbór<note caller="+" style="f"><char style="fr" closed="false">22:16 </char><char style="fq" closed="false">liang kóbór: </char><char style="ft" closed="false">Teks asli iola “lahan kematian”. Ide barés ni iola wong ni disiapke óntók kematian, karno denget lagi dio bakal mati.</char></note>, Kau narok aku.<verse eid="PSA 22:16" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="17" style="v" sid="PSA 22:17" />
    <char style="add">Pecak</char> anjéng-anjéng <char style="add">yang</char> ngeróbóngi aku,</para>
  <para style="q2" vid="PSA 22:17">gerombolan wong jahat ngepóng aku.</para>
  <para style="q1" vid="PSA 22:17">Dio wong ngelukoi<note caller="+" style="f"><char style="fr" closed="false">22:17 </char><char style="fq" closed="false">Dio wong ngelukoi: </char><char style="ft" closed="false">Makno teks asli di sini kurang pasti.</char></note> tangan samo sekel aku.<verse eid="PSA 22:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 22:18" />Aku pacak étóng slóró tulang-tulang aku.</para>
  <para style="q2" vid="PSA 22:18">Dio wong jingok trós masati aku.<verse eid="PSA 22:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 22:19" />Dio wong mbagéke pakean aku di antaro dio wong dewek,</para>
  <para style="q2" vid="PSA 22:19">trós ngoncang undi óntók baju aku.<verse eid="PSA 22:19" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="20" style="v" sid="PSA 22:20" />Tapi Kau, ya <char style="nd">ALLAHyhwh</char>, janganla jaó!</para>
  <para style="q2" vid="PSA 22:20">Ya kekuatan aku, gancangla tolong aku!<verse eid="PSA 22:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="PSA 22:21" />Selametkela nyawo aku dari pedang,</para>
  <para style="q2" vid="PSA 22:21">édóp aku dari cengkeman anjéng.<verse eid="PSA 22:21" /></para>
  <para style="q1">
    <verse number="22" style="v" sid="PSA 22:22" />Selametkela aku dari mólót singo,</para>
  <para style="q2" vid="PSA 22:22">dari tandók banteng.</para>
  <para style="q1" vid="PSA 22:22">Kau la mbebaske aku!<verse eid="PSA 22:22" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="23" style="v" sid="PSA 22:23" />Aku bakal nyeritoke namo baék Kau samo dólór-dólór <char style="add">seiman</char> aku.</para>
  <para style="q2" vid="PSA 22:23">Di tenga-tenga jemaah, aku bakal muji Kau.<verse eid="PSA 22:23" /></para>
  <para style="q1">
    <verse number="24" style="v" sid="PSA 22:24" />Ói wong-wong yang takót samo <char style="nd">ALLAHyhwh</char>, pujila Dio!</para>
  <para style="q2" vid="PSA 22:24">Ói slóró ketórónan <char style="w">Yakób</char>, mulyokela Dio!</para>
  <para style="q2" vid="PSA 22:24">Segenla samo Dio, ói slóró anak-anak <char style="w">Israel</char>!<verse eid="PSA 22:24" /></para>
  <para style="q1">
    <verse number="25" style="v" sid="PSA 22:25" />Dio idak ngerendake trós idak nganggep najés pendritoan wong yang saro,</para>
  <para style="q2" vid="PSA 22:25">jugo Dio idak nyingitke rai-Nyo dari wong tu.</para>
  <para style="q3" vid="PSA 22:25">Trós Dio ndenger pas wong tu bejerét mintak tolong samo Dio.<verse eid="PSA 22:25" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="26" style="v" sid="PSA 22:26" />Karno Kau aku muji-muji dalem jemaah yang besak.</para>
  <para style="q2" vid="PSA 22:26">Trós aku nak mbayar najar aku di adepan wong-wong yang takót samo Dio.<verse eid="PSA 22:26" /></para>
  <para style="q1">
    <verse number="27" style="v" sid="PSA 22:27" />Wong yang mendrito bakal makan, trós jadi kenyang.</para>
  <para style="q2" vid="PSA 22:27">Wong yang nyari <char style="nd">ALLAHyhwh</char> bakal muji Dio.</para>
  <para style="q1" vid="PSA 22:27">Biarla ati kau benyalo-nyalo selamonyo!<verse eid="PSA 22:27" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="28" style="v" sid="PSA 22:28" />Sampe ójóng bumi bakal teinget trós bebalék ke <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 22:28">Slóró kaóm bangso-bangso bakal sójód nyemba di adepan-Nyo.<verse eid="PSA 22:28" /></para>
  <para style="q1">
    <verse number="29" style="v" sid="PSA 22:29" />Karno <char style="nd">ALLAHyhwh</char> bae yang bekuaso,</para>
  <para style="q2" vid="PSA 22:29">trós Dio mrénto bangso-bangso.<verse eid="PSA 22:29" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="30" style="v" sid="PSA 22:30" />Slóró wong yang makmór di dunio ni bakal makan trós sójód nyemba Dio.</para>
  <para style="q1" vid="PSA 22:30">Slóró wong yang tórón ke jeró liang kóbór<note caller="+" style="f"><char style="fr" closed="false">22:30 </char><char style="fq" closed="false">liang kóbór: </char><char style="ft" closed="false">Teks asli iola “lahan kematian”. Ide barés ni iola wong ni disiapke óntók kematian, karno denget lagi dio bakal mati.</char></note> bakal tóndók di adepan-Nyo,</para>
  <para style="q2" vid="PSA 22:30">iola wong-wong yang dak pacak nyambóng édóp.<verse eid="PSA 22:30" /></para>
  <para style="q1">
    <verse number="31" style="v" sid="PSA 22:31" />Anak cócóng bakal beibada samo Dio,</para>
  <para style="q2" vid="PSA 22:31">trós bakal nyeritoke pasal Tuan samo tórónan yang bakal dateng.<verse eid="PSA 22:31" /></para>
  <para style="q1">
    <verse number="32" style="v" sid="PSA 22:32" />Dio wong bakal dateng trós bakal ngabarke kebeneran-Nyo</para>
  <para style="q2" vid="PSA 22:32">samo bangso yang bakal laér kagek,</para>
  <para style="q3" vid="PSA 22:32">amen Diola yang ngelakukenyo.<verse eid="PSA 22:32" /></para>
  <chapter eid="PSA 22" />
  <chapter number="23" style="c" sid="PSA 23" />
  <para style="s2">Allah miaro aku</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 23:1" />Nyanyian <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 23:1" />
  <para style="q1" vid="PSA 23:1">
    <char style="nd">
      <char style="w">ALLAHyhwh</char>
    </char> iola gembala aku;</para>
  <para style="q2" vid="PSA 23:1">dak bakal kekurangan aku.<verse eid="PSA 23:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 23:2" />Di padang yang berómpót ijo, Dio baréngke aku;</para>
  <para style="q2" vid="PSA 23:2">ke banyu yang tenang, Dio nóntón aku.<verse eid="PSA 23:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 23:3" />Jiwo aku Dio segerke.</para>
  <para style="b" vid="PSA 23:3" />
  <para style="q1" vid="PSA 23:3">Dio mémpén aku di jalan kebeneran,</para>
  <para style="q2" vid="PSA 23:3">óntók namo-Nyo.<verse eid="PSA 23:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 23:4" />Mugola aku bejalan di bawa jurang yang surem,</para>
  <para style="q2" vid="PSA 23:4">aku dak takót bahayo, karno Kau ado besamo aku.</para>
  <para style="q1" vid="PSA 23:4">Tongkat samo pemókól Kau, itula yang ngébór aku.<verse eid="PSA 23:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 23:5" />Kau nyiapke pesta óntók aku di adepan mósó aku.</para>
  <para style="q2" vid="PSA 23:5">Kau sambót aku pecak tamu agóng.<note caller="+" style="f"><char style="fr" closed="false">23:5 </char><char style="fq" closed="false">Kau sambót aku pecak tamu agóng: </char><char style="ft" closed="false">Teks aslinyo iola, “Kau ngusap palak aku pakek minyak”. Dalem budayo Ibrani, ngusap palak makek minyak wangi iola caro nyambót tamu agóng.</char></note></para>
  <para style="q2" vid="PSA 23:5">Cangkér aku penu terós.<note caller="+" style="f"><char style="fr" closed="false">23:5 </char><char style="fq" closed="false">Cangkér aku penu terós: </char><char style="ft" closed="false">Kiasan ini maksódnyo Allah iola tuan ruma yang idak pelét.</char></note><verse eid="PSA 23:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 23:6" />Pastila kebaék'an jugo kasé stio <char style="add">Kau</char> bakal ngejer aku</para>
  <para style="q2" vid="PSA 23:6">seómór édóp aku.</para>
  <para style="q1" vid="PSA 23:6">Trós aku bakal netep di jeró <char style="w" lemma="Ruma Agóng Allah">Ruma Agóng <char style="nd">ALLAHyhwh</char></char></para>
  <para style="q2" vid="PSA 23:6">selamonyo.<verse eid="PSA 23:6" /></para>
  <chapter eid="PSA 23" />
  <chapter number="24" style="c" sid="PSA 24" />
  <para style="s2">Kedatengan Allah ke jeró Ruma Agóng-Nyo di bumi</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 24:1" />Nyanyian <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 24:1" />
  <para style="q1" vid="PSA 24:1">Bumi jugo slóró isinyo iola kepunyoan <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 24:1">dunio jugo slóró yang tinggal di dalemnyo.<verse eid="PSA 24:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 24:2" />Soalnyo Dio yang la mbangón bumi tu</para>
  <para style="q2" vid="PSA 24:2">di pócók laótan,</para>
  <para style="q2" vid="PSA 24:2">trós negakkenyo di pócók arós-arós yang dalem.<verse eid="PSA 24:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 24:3" />Siapo yang bole naék ke <char style="w" lemma="Sion">bókét <char style="nd">ALLAHyhwh</char></char>?</para>
  <para style="q2" vid="PSA 24:3">Siapo yang bole tegak di tempat-Nyo yang suci?<verse eid="PSA 24:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 24:4" />Wong yang tangannyo bersé jugo atinyo murni,</para>
  <para style="q2" vid="PSA 24:4">yang idak ngenjókke dirinyo óntók penipuan,</para>
  <para style="q2" vid="PSA 24:4">trós yang idak besumpa palsu.<verse eid="PSA 24:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 24:5" />Dio bakal nerimo berkah dari <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 24:5">trós pembelaan dari Tuhan, penyelametnyo.<verse eid="PSA 24:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 24:6" />Inila angkatan wong-wong yang nyari Dio,</para>
  <para style="q2" vid="PSA 24:6">yang nyari hadérat Tuhannyo Yakób. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 24:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 24:7" />Angkatla palak kau, ói lawang-lawang gerbang<note caller="+" style="f"><char style="fr" closed="false">24:7 </char><char style="fq" closed="false">lawang-lawang gerbang: </char><char style="ft" closed="false">Lawang gerbang yang dimaksód di sini iola lawang gerbang <char style="w">Ruma Agóng Allah</char> di Yerusalem. Lawang ni disóró bukak óntók nerimo kedatengan Allah.</char></note>!</para>
  <para style="q2" vid="PSA 24:7">Teangkatla, ói lawang-lawang yang la beabad-abad!</para>
  <para style="q2" vid="PSA 24:7">Supayo Rajo Yang Mahamulyo masók!<verse eid="PSA 24:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 24:8" />Siapo Rajo Yang Mahamulyo tu?</para>
  <para style="q2" vid="PSA 24:8">
    <char style="nd">ALLAHyhwh</char> yang kuat jugo perkasa!</para>
  <para style="q2" vid="PSA 24:8">
    <char style="nd">ALLAHyhwh</char> yang perkasa dalem peperangan!<verse eid="PSA 24:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 24:9" />Angkatla palak kau, ói lawang-lawang gerbang!</para>
  <para style="q2" vid="PSA 24:9">Teangkatla, ói lawang-lawang yang la beabad-abad!</para>
  <para style="q2" vid="PSA 24:9">Supayo Rajo Yang Mahamulyo masók!<verse eid="PSA 24:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 24:10" />Siapo Rajo Yang Mahamulyo tu?</para>
  <para style="q2" vid="PSA 24:10">
    <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
  <para style="q2" vid="PSA 24:10">Diola Rajo Yang Mahamulyo! <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 24:10" /></para>
  <chapter eid="PSA 24" />
  <chapter number="25" style="c" sid="PSA 25" />
  <para style="s2">Doa mintak peléndóngan jugo bémbéngan Allah<note caller="+" style="f"><char style="fr" closed="false">25:1 </char><char style="ft" closed="false">Di teks asli, óróp petamo tiap pemuloan ayat di S. Ny. 25 ni disósón nórót abjad baso Ibrani.</char></note></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 25:1" />Dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 25:1" />
  <para style="q1" vid="PSA 25:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, aku ngangkat doa<note caller="+" style="f"><char style="fr" closed="false">25:1 </char><char style="fq" closed="false">ngangkat doa: </char><char style="ft" closed="false">Teks asli iola “ngangkat jiwo”. Ini ni kiasan Ibrani óntók bedoa.</char></note> aku ke Kau.<verse eid="PSA 25:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 25:2" />Ya Tuhan aku, samo Kaula aku pecayo.</para>
  <para style="q1" vid="PSA 25:2">Jangan biarke aku dipermaluke.</para>
  <para style="q2" vid="PSA 25:2">Jangan biarke mósó-mósó aku beseneng-seneng karno aku,<verse eid="PSA 25:2" /></para>
  <para style="q2">
    <verse number="3" style="v" sid="PSA 25:3" />jugo jangan biarke wong-wong yang nunggui Kau dipermaluke,</para>
  <para style="q2" vid="PSA 25:3">tapi biarkela wong yang behianat dengen dak bealesan dipermaluke.<verse eid="PSA 25:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 25:4" />Ya <char style="nd">ALLAHyhwh</char>, enjóktaukela jalan-jalan <char style="add">yang nyenengke</char> Kau.</para>
  <para style="q2" vid="PSA 25:4">Ajari aku caro-caro Kau.<verse eid="PSA 25:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 25:5" />Pémpénla aku dalem kebeneran Kau trós ajarke Aku,</para>
  <para style="q2" vid="PSA 25:5">karno Kaula Tuhan yang nyelametke aku.</para>
  <para style="q2" vid="PSA 25:5">Aku nunggu-nunggui Kau siang malem.<verse eid="PSA 25:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 25:6" />Ya <char style="nd">ALLAHyhwh</char>, ingetla pasal belas kesian Kau jugo kasé stio Kau,</para>
  <para style="q2" vid="PSA 25:6">karno pasal-pasal tu la ado dari jaman bingen.<verse eid="PSA 25:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 25:7" />Janganla Kau inget kesalahan-kesalahan aku,</para>
  <para style="q2" vid="PSA 25:7">jugo duso-duso aku pas masé mudo,</para>
  <para style="q1" vid="PSA 25:7">tapi ingetla aku sesuai dengen kasé stio Kau</para>
  <para style="q2" vid="PSA 25:7">karno kebaék'an Kau, ya <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 25:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 25:8" />
    <char style="nd">ALLAHyhwh</char> tu baék jugo lórós,</para>
  <para style="q2" vid="PSA 25:8">mangkonyo Dio ngajarke jalan-Nyo ke wong beduso.<verse eid="PSA 25:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 25:9" />Dio mbémbéng wong yang renda ati dalem keadélan,</para>
  <para style="q2" vid="PSA 25:9">trós Dio ngajarke jalan-Nyo ke wong yang renda ati.<verse eid="PSA 25:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 25:10" />Slóró jalan <char style="nd">ALLAHyhwh</char> iola kasé stio jugo kebeneran</para>
  <para style="q2" vid="PSA 25:10">óntók wong-wong yang nyekel pejanjian-Nyo jugo peratóran-Nyo.<verse eid="PSA 25:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 25:11" />Ya <char style="nd">ALLAHyhwh</char>, karno namo baék Kau, ampónila kesalahan aku,</para>
  <para style="q2" vid="PSA 25:11">soalnyo besak kesalahan tu.<verse eid="PSA 25:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 25:12" />Siapo bae yang takót samo <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 25:12">Allah bakal nónjókke jalan yang harós dipélényo.<verse eid="PSA 25:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 25:13" />Wong tu bakal tinggal dalem kemakmóran,</para>
  <para style="q2" vid="PSA 25:13">trós ketórónannyo bakal ngewarési bumi.<verse eid="PSA 25:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 25:14" />
    <char style="nd">ALLAHyhwh</char> bekawan baék samo wong yang takót samo Dio,</para>
  <para style="q2" vid="PSA 25:14">trós pejanjian-Nyo dienjóktauke-Nyo ke dio wong.<verse eid="PSA 25:14" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="15" style="v" sid="PSA 25:15" />Mato aku terós-terósan jingok <char style="nd">ALLAHyhwh</char></para>
  <para style="q2" vid="PSA 25:15">karno Dio bakal metuke sekel aku dari jaréng.<verse eid="PSA 25:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 25:16" />Tolela aku trós mura atila samo aku</para>
  <para style="q2" vid="PSA 25:16">karno aku saro jugo dewek'an.<verse eid="PSA 25:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 25:17" />Pendritoan di ati aku makén besak.</para>
  <para style="q1" vid="PSA 25:17">Gawakla aku metu dari kesesekan aku.<verse eid="PSA 25:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 25:18" />Jingokla kesaroan samo kesusahan aku,</para>
  <para style="q2" vid="PSA 25:18">trós ampónila slóró duso aku.<verse eid="PSA 25:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 25:19" />Jingokla mósó aku, karno banyak nian.</para>
  <para style="q2" vid="PSA 25:19">Dio wong mbenci aku dengen kebencian yang kejem.<verse eid="PSA 25:19" /></para>
  <para style="q1">
    <verse number="20" style="v" sid="PSA 25:20" />Jagola jiwo aku, trós lepaskela aku.</para>
  <para style="q1" vid="PSA 25:20">Jangan biarke aku dipermaluke,</para>
  <para style="q2" vid="PSA 25:20">soalnyo aku beléndóng samo Kau.<verse eid="PSA 25:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="PSA 25:21" />Biarla ketólósan jugo kebeneran nyagoi aku,</para>
  <para style="q2" vid="PSA 25:21">soalnyo aku nunggui Kau.<verse eid="PSA 25:21" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="22" style="v" sid="PSA 25:22" />Ya Allah, tebósla wong Israel dari segalo kesaroan.<verse eid="PSA 25:22" /></para>
  <chapter eid="PSA 25" />
  <chapter number="26" style="c" sid="PSA 26" />
  <para style="s2">Doa mintak keadélan dari <char style="nd">ALLAHyhwh</char></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 26:1" />Dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 26:1" />
  <para style="q1" vid="PSA 26:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, enjókla keadélan ke aku,</para>
  <para style="q2" vid="PSA 26:1">karno aku ni la bejalan dengen ketólósan ati.</para>
  <para style="q2" vid="PSA 26:1">Samo <char style="nd">ALLAHyhwh</char> aku pecayo; aku dak ragu.<verse eid="PSA 26:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 26:2" />Selédékila aku, ya <char style="nd">ALLAHyhwh</char>, trós coboila aku.</para>
  <para style="q2" vid="PSA 26:2">Ujila batén samo ati aku,<verse eid="PSA 26:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 26:3" />karno kasé stio Kau ado di adepan mato aku,</para>
  <para style="q2" vid="PSA 26:3">trós aku bakal bejalan dalem kebeneran Kau.<verse eid="PSA 26:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 26:4" />Aku idak dódók samo wong yang galak ngolai,</para>
  <para style="q2" vid="PSA 26:4">jugo idak melok samo wong yang munapék.<verse eid="PSA 26:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 26:5" />Aku benci kómpólan wong yang bebuat jahat,</para>
  <para style="q2" vid="PSA 26:5">aku jugo idak dódók samo wong bejat.<verse eid="PSA 26:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 26:6" />Aku basó tangan aku tando idak besala,</para>
  <para style="q2" vid="PSA 26:6">abés tu ngeléléngi meja pesembahan<note caller="+" style="f"><char style="fr" closed="false">26:6 </char><char style="fq" closed="false">ngeléléngi meja pesembahan Kau: </char><char style="ft" closed="false">Meja pesembahan tu cuman ado di Ruma Agóng Allah. Pecaknyo ini ngambarke sikok upacara yang dilakuke wong Ibrani di Ruma Agóng Allah besamo jemaah pas ibada.</char></note> Kau, ya <char style="nd">ALLAHyhwh</char>,<verse eid="PSA 26:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 26:7" />óntók nyiarke ucapan sókór,</para>
  <para style="q2" vid="PSA 26:7">jugo nyritoke slóró pebuatan Kau yang ajaéb.<verse eid="PSA 26:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 26:8" />Ya <char style="nd">ALLAHyhwh</char>, aku cinto samo <char style="w" lemma="Ruma Agóng Allah">Ruma tempat Kau tinggal</char>,</para>
  <para style="q2" vid="PSA 26:8">iola Kemah di mano kemulyoan Kau netep.<verse eid="PSA 26:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 26:9" />Janganla ambék nyawo aku besamo dengen wong-wong beduso tu,</para>
  <para style="q2" vid="PSA 26:9">apo dak tu édóp aku besamo dengen pembunu,<verse eid="PSA 26:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 26:10" />yang dalem tangannyo ado niat jahat,</para>
  <para style="q2" vid="PSA 26:10">trós yang tangan kanannyo penu dengen sogokan.<verse eid="PSA 26:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 26:11" />Tapi aku ni bakal bejalan dengen ketólósan ati.</para>
  <para style="q1" vid="PSA 26:11">Selametkela aku jugo mura atila samo aku.<verse eid="PSA 26:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 26:12" />Sekel aku tegak di tempat yang rato.</para>
  <para style="q1" vid="PSA 26:12">Dalem jemaah aku bakal muji <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 26:12" /></para>
  <chapter eid="PSA 26" />
  <chapter number="27" style="c" sid="PSA 27" />
  <para style="s2">Aman Dalem Léndóngan <char style="nd">ALLAHyhwh</char></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 27:1" />Dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 27:1" />
  <para style="q1" vid="PSA 27:1">
    <char style="nd">
      <char style="w">ALLAHyhwh</char>
    </char> iola terang aku jugo keselametan aku;</para>
  <para style="q2" vid="PSA 27:1">samo siapo aku harós takót?</para>
  <para style="q1" vid="PSA 27:1">
    <char style="nd">ALLAHyhwh</char> iola benteng édóp aku;</para>
  <para style="q2" vid="PSA 27:1">samo siapo aku harós gemeter?<verse eid="PSA 27:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 27:2" />Pas wong-wong jahat dateng nyerang aku óntók makan dagéng aku,</para>
  <para style="q2" vid="PSA 27:2">iola lawan-lawan aku jugo mósó-mósó aku,</para>
  <para style="q2" vid="PSA 27:2">dio wong tula yang tebentor trós nyampak.<verse eid="PSA 27:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 27:3" />Mugola bekemah sikok pasókan nempóri aku,</para>
  <para style="q2" vid="PSA 27:3">ati aku dak lokak takót.</para>
  <para style="q1" vid="PSA 27:3">Mugola móncól perang ngelawan aku,</para>
  <para style="q2" vid="PSA 27:3">cak itu jugo aku tetep pecayo.<verse eid="PSA 27:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 27:4" />Sikok pasal yang aku mintak dari <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 27:4">itula yang aku kendak'i:</para>
  <para style="q1" vid="PSA 27:4">iola netep di jeró <char style="w" lemma="Ruma Agóng Allah">Ruma Agóng <char style="nd">ALLAHyhwh</char></char> seómór édóp aku,</para>
  <para style="q2" vid="PSA 27:4">óntók nyaksike keindahan <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 27:4">jugo óntók nyari <char style="add">Dio</char> di jeró Kemah Suci-Nyo.<verse eid="PSA 27:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 27:5" />Soalnyo Dio bakal ngeléndóngi aku di tempat tedó-Nyo pas ari saro,</para>
  <para style="q2" vid="PSA 27:5">Dio bakal nyingitke aku dalem léndóngan Kemah Suci-Nyo,</para>
  <para style="q2" vid="PSA 27:5">trós Dio naékke aku ke pócók batu karang, <char style="add">tempat yang aman</char>.<verse eid="PSA 27:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 27:6" />Mangko tu, palak aku teangkat di pócók mósó-mósó yang ngepóng aku.</para>
  <para style="q1" vid="PSA 27:6">Trós di Kemah Suci-Nyo,</para>
  <para style="q2" vid="PSA 27:6">aku bakal ngenjók kórban sembeléhan dengen besorak-sorak.</para>
  <para style="q2" vid="PSA 27:6">Aku bakal nyanyike jugo ngelantónke puji-pujian óntók <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 27:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 27:7" />Ya <char style="nd">ALLAHyhwh</char>, dengerla suaro aku pas aku bejerét!</para>
  <para style="q2" vid="PSA 27:7">Mura atila samo aku trós jawabla aku!<verse eid="PSA 27:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 27:8" />Pasal Kau ati aku ngomong,</para>
  <para style="q2" vid="PSA 27:8">“Carila hadérat-Nyo.”</para>
  <para style="q2" vid="PSA 27:8">Hadérat Kau, ya <char style="nd">ALLAHyhwh</char>, bakal aku cari.<verse eid="PSA 27:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 27:9" />Janganla nyingitke hadérat Kau dari aku.</para>
  <para style="q2" vid="PSA 27:9">Dalem kemarahan Kau, janganla nolak hamba Kau ni.</para>
  <para style="q1" vid="PSA 27:9">Kaula penolong aku,</para>
  <para style="q2" vid="PSA 27:9">janganla nalakke aku apo ninggalke aku,</para>
  <para style="q2" vid="PSA 27:9">ya Tuhan penyelamet aku!<verse eid="PSA 27:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 27:10" />Mugola aba samo emak ninggalke aku,</para>
  <para style="q2" vid="PSA 27:10">
    <char style="nd">ALLAHyhwh</char> bakal nyambót aku.<verse eid="PSA 27:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 27:11" />Ya <char style="nd">ALLAHyhwh</char>, ajarkela aku jalan Kau,</para>
  <para style="q2" vid="PSA 27:11">trós pémpénla aku di jalan yang rato, karno mósó-mósó aku.<verse eid="PSA 27:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 27:12" />Janganla nyerake aku ke kendak lawan-lawan aku,</para>
  <para style="q2" vid="PSA 27:12">karno saksi-saksi palsu tu la bangkét nentang aku,</para>
  <para style="q2" vid="PSA 27:12">iola saksi-saksi yang kejem<note caller="+" style="f"><char style="fr" closed="false">27:12 </char><char style="fq" closed="false">saksi-saksi yang kejem: </char><char style="ft" closed="false">Ado jugo tradisi yang napsérke kato-kato asli di sini óntók jadi “wong-wong yang ngembóske kekejeman”.</char></note>.<verse eid="PSA 27:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 27:13" />Aku tetep pecayo kalu aku bakal jingok kebaék'an <char style="nd">ALLAHyhwh</char></para>
  <para style="q2" vid="PSA 27:13">di negri wong-wong yang édóp.<verse eid="PSA 27:13" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="14" style="v" sid="PSA 27:14" />
    <char style="add">Ói dólórku</char>, ngarepla samo <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 27:14">Kuatkela jugo mantepkela ati kau!</para>
  <para style="q2" vid="PSA 27:14">Iyo, ngarepla samo <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 27:14" /></para>
  <chapter eid="PSA 27" />
  <chapter number="28" style="c" sid="PSA 28" />
  <para style="s2">Allah denger doa pemohonan umat-Nyo yang mintak tolong samo Dio</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 28:1" />Dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 28:1" />
  <para style="q1" vid="PSA 28:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, samo Kaula aku bejerét!</para>
  <para style="q2" vid="PSA 28:1">Ói gónóng batu aku, janganla Kau nótóp kópéng dari aku!</para>
  <para style="q1" vid="PSA 28:1">Soalnyo amen Kau diem,</para>
  <para style="q2" vid="PSA 28:1">aku jadi pecak wong yang tórón ke jeró liang kóbór.<verse eid="PSA 28:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 28:2" />Dengerkela suaro pemohonan aku</para>
  <para style="q2" vid="PSA 28:2">pas aku bejerét mintak tolong samo Kau,</para>
  <para style="q2" vid="PSA 28:2">pas aku ngangkat tangan <char style="add">bedoa</char></para>
  <para style="q3" vid="PSA 28:2">ke ara Ruang Mahasuci<note caller="+" style="f"><char style="fr" closed="false">28:2 </char><char style="fq" closed="false">Ruang Mahasuci: </char><char style="ft" closed="false">Ini ni ruangan yang paléng dalem di jeró </char><char style="w">Ruma Agóng Allah</char>. Waktu tu, ruangan ni iola tempat hadérat Allah dewek.</note> Kau.<verse eid="PSA 28:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 28:3" />Jangan nyeret aku besamo-samo dengen wong beduso,</para>
  <para style="q2" vid="PSA 28:3">dengen wong-wong yang bebuat jahat,</para>
  <para style="q2" vid="PSA 28:3">yang ngomongnyo manis dengen sesamonyo,</para>
  <para style="q3" vid="PSA 28:3">padahal di jeró atinyo ado kejahatan.<verse eid="PSA 28:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 28:4" />Lakukela ke dio wong sesuai dengen apo yang digawekenyo,</para>
  <para style="q2" vid="PSA 28:4">sesuai dengen kelakuan jahatnyo.</para>
  <para style="q1" vid="PSA 28:4">Lakukela ke dio wong sesuai dengen pebuatan tangannyo.</para>
  <para style="q1" vid="PSA 28:4">Enjókkela balesan ke dio wong.<verse eid="PSA 28:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 28:5" />Karno dio wong idak nganggep apo yang digaweke <char style="nd">ALLAHyhwh</char></para>
  <para style="q2" vid="PSA 28:5">jugo pebuatan tangan-Nyo,</para>
  <para style="q1" vid="PSA 28:5">Dio bakal ngancórke dio wong</para>
  <para style="q2" vid="PSA 28:5">trós idak mbangónnyo lagi.<verse eid="PSA 28:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 28:6" />Pujila <char style="nd">ALLAHyhwh</char></para>
  <para style="q2" vid="PSA 28:6">karno Dio la ndengerke suaro pemohonan aku.<verse eid="PSA 28:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 28:7" />
    <char style="nd">ALLAHyhwh</char> iola kekuatan jugo tameng aku.</para>
  <para style="q2" vid="PSA 28:7">Aku pecayo samo Dio di jeró ati aku, trós aku ditolong.</para>
  <para style="q1" vid="PSA 28:7">Ati aku beseneng,</para>
  <para style="q2" vid="PSA 28:7">trós dengen nyanyian aku, aku nak besókór samo Dio.<verse eid="PSA 28:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 28:8" />
    <char style="nd">ALLAHyhwh</char> iola kekuatan umat-Nyo.</para>
  <para style="q2" vid="PSA 28:8">Diola benteng keselametan óntók rajo yang dilanték-Nyo.<verse eid="PSA 28:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 28:9" />Selametkela umat Kau,</para>
  <para style="q2" vid="PSA 28:9">trós berkahila pusako kepunyoan Kau tu;</para>
  <para style="q1" vid="PSA 28:9">gembalakela dio wong, trós gawakla dio wong <char style="add">dalem tangan Kau</char></para>
  <para style="q2" vid="PSA 28:9">sampe selamo-lamonyo.<verse eid="PSA 28:9" /></para>
  <chapter eid="PSA 28" />
  <chapter number="29" style="c" sid="PSA 29" />
  <para style="s2">Akuila kekuasoan Allah!</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 29:1" />Nyanyian <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 29:1" />
  <para style="q1" vid="PSA 29:1">Akuila <char style="nd"><char style="w">ALLAHyhwh</char></char>, ói mahlók-mahlók surgawi<note caller="+" style="f"><char style="fr" closed="false">29:1 </char><char style="fq" closed="false">mahlók-mahlók surgawi: </char><char style="ft" closed="false">Ini ni maksódnyo nyóró slóró mahlók surgawi pecak malekat jugo dewo-dewo bangso laén óntók ngakui kehebatan Allah. (Jingok jugo catetan sekel pasal “Gónóng Sirion” di ayat 6.)</char></note>,</para>
  <para style="q2" vid="PSA 29:1">akuila <char style="nd">ALLAHyhwh</char> karno kemulyoan jugo kekuatan-Nyo!<verse eid="PSA 29:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 29:2" />Akuila <char style="nd">ALLAHyhwh</char> karno kemulyoan namo-Nyo!</para>
  <para style="q1" vid="PSA 29:2">Sójódla samo <char style="nd">ALLAHyhwh</char> dengen behiaske kesucian!<verse eid="PSA 29:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 29:3" />Suaro <char style="nd">ALLAHyhwh</char> <char style="add">pecak góntór</char> di pócók laótan;</para>
  <para style="q2" vid="PSA 29:3">Tuhan Yang Mahamulyo begemóró,</para>
  <para style="q2" vid="PSA 29:3">
    <char style="nd">ALLAHyhwh</char> di pócók laótan luas.<verse eid="PSA 29:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 29:4" />Suaro <char style="nd">ALLAHyhwh</char> tu bekuaso.</para>
  <para style="q1" vid="PSA 29:4">Suaro <char style="nd">ALLAHyhwh</char> tu mulyo.<verse eid="PSA 29:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 29:5" />Suaro <char style="nd">ALLAHyhwh</char> matake pohon-pohon besak<note caller="+" style="f"><char style="fr" closed="false">29:5 </char><char style="fq" closed="false">pohon-pohon besak: </char><char style="ft" closed="false">Teks asli iola “pohon-pohon aras”.</char></note>;</para>
  <para style="q2" vid="PSA 29:5">iyo, <char style="nd">ALLAHyhwh</char> matake pohon-pohon aras Lebanon<note caller="+" style="f"><char style="fr" closed="false">29:5 </char><char style="fq" closed="false">pohon-pohon aras Lebanon: </char><char style="ft" closed="false">Pas jaman tu, pegónóngan Lebanon tekenal karno pohon-pohon arasnyo yang besak nian jugo kuat.</char></note>.<verse eid="PSA 29:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 29:6" />Dio mbékén pegónóngan Lebanon kocar-kacér pecak anak sapi<note caller="+" style="f"><char style="fr" closed="false">29:6 </char><char style="fq" closed="false">pegónóngan Lebanon kocar-kacér pecak anak sapi: </char><char style="ft" closed="false">Ini ni maksódnyo pegónóngan Lebanon tegoncang pecak gempa bumi pas Allah metuke suaro-Nyo.</char></note>,</para>
  <para style="q2" vid="PSA 29:6">jugo Gónóng Sirion<note caller="+" style="f"><char style="fr" closed="false">29:6 </char><char style="fq" closed="false">Gónóng Sirion: </char><char style="ft" closed="false">Ini ni namo laén óntók Gónóng Hermon, sala sikok gónóng besak yang ado di Lebanon. Gónóng ni dianggep tempat tinggalnyo dewo Baal, yang iola dewo besak wong Kanaan. Jadi amen gónóng ni tegoncang karno suaro Allah, artinyo Allah lebé kuat daripado dewo Baal tu.</char></note> pecak anak banteng.<verse eid="PSA 29:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 29:7" />Suaro <char style="nd">ALLAHyhwh</char> mancarke kilatan api yang benyalo-nyalo.<verse eid="PSA 29:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 29:8" />Suaro <char style="nd">ALLAHyhwh</char> geterke padang górón,</para>
  <para style="q2" vid="PSA 29:8">
    <char style="nd">ALLAHyhwh</char> geterke padang górón Kadesh.<verse eid="PSA 29:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 29:9" />Suaro <char style="nd">ALLAHyhwh</char> mbékén ruso beranak,</para>
  <para style="q2" vid="PSA 29:9">trós nelanjangi utan.</para>
  <para style="q1" vid="PSA 29:9">Di jeró Ruma Agóng-Nyo</para>
  <para style="q2" vid="PSA 29:9">tiap wong bejerét, “Mulyo!”<verse eid="PSA 29:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 29:10" />
    <char style="nd">ALLAHyhwh</char> bekuaso di pócók segalo banyu<note caller="+" style="f"><char style="fr" closed="false">29:10 </char><char style="fq" closed="false">segalo banyu: </char><char style="ft" closed="false">Yang dimaksód di sini iola segalo banyu yang ado di bumi jugo di langét, pecak laót, sungi, ujan, badai, sampe banyu banjér jugo. Jadi Allah bukan cuman nguasoi banyu di bumi bae tapi jugo banyu yang ado di surgo.</char></note>,</para>
  <para style="q2" vid="PSA 29:10">
    <char style="nd">ALLAHyhwh</char> bekuaso jadi Rajo óntók selamo-lamonyo.<verse eid="PSA 29:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 29:11" />
    <char style="nd">ALLAHyhwh</char> ngenjók kekuatan samo bangso-Nyo,</para>
  <para style="q2" vid="PSA 29:11">
    <char style="nd">ALLAHyhwh</char> mberkahi bangso-Nyo dengen damai sentoso.<verse eid="PSA 29:11" /></para>
  <chapter eid="PSA 29" />
  <chapter number="30" style="c" sid="PSA 30" />
  <para style="s2">Ucapan sókór pas diselametke dari kematian</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 30:1" />Saér nyanyian. Nyanyian ni <char style="add">perna dipakek</char> pas ngeresmike Ruma Agóng Allah<note caller="+" style="f"><char style="fr" closed="false">30:1 </char><char style="fq" closed="false">ngeresmike Ruma Agóng Allah: </char><char style="ft" closed="false">Upacara peresmian <char style="w">Ruma Agóng Allah</char> ni iola pecak yang diceritoke di </char><char style="xt" closed="false"><ref loc="1KI 8">1 Rajo-Rajo 8</ref></char><char style="ft" closed="false">samo </char><char style="xt" closed="false"><ref loc="EZR 6:16-18">Esra 6:16-18</ref></char><char style="ft" closed="false">.</char></note>. Dari <char style="w">Daód</char>.<verse eid="PSA 30:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 30:2" />Aku bakal ngagóngke Kau, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 30:2">karno Kau narék aku naék,</para>
  <para style="q2" vid="PSA 30:2">trós idak mbiarke mósó-mósó nyorak'i aku.<verse eid="PSA 30:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 30:3" />Ya <char style="nd">ALLAHyhwh</char>, ya Tuhan aku, samo Kaula aku bejerét,</para>
  <para style="q2" vid="PSA 30:3">trós Kau nyembóke aku.<verse eid="PSA 30:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 30:4" />Ya <char style="nd">ALLAHyhwh</char>, Kau la ngangkat jiwo aku dari dunio wong mati.</para>
  <para style="q2" vid="PSA 30:4">Kau nyelametke édóp aku dari antaro wong-wong yang tórón ke liang kóbór.<verse eid="PSA 30:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 30:5" />Nyanyikela pujian óntók <char style="nd">ALLAHyhwh</char>, ói kamu wong-wong além-Nyo!</para>
  <para style="q2" vid="PSA 30:5">Besókórla óntók namo-Nyo yang suci!<verse eid="PSA 30:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 30:6" />Soalnyo kemarahan-Nyo cuman denget bae,</para>
  <para style="q2" vid="PSA 30:6">tapi kemurahan-Nyo óntók seómór édóp.</para>
  <para style="q1" vid="PSA 30:6">Sepanjang malem ado tangisan,</para>
  <para style="q2" vid="PSA 30:6">tapi pas pagi ari ado sorak'an.<verse eid="PSA 30:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 30:7" />Tapi aku, pas édóp lapang, aku <char style="add">dengen sombong</char> ngomong cak ini,</para>
  <para style="q2" vid="PSA 30:7">“Aku dak bakal perna tegoyake!”<verse eid="PSA 30:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 30:8" />Ya <char style="nd">ALLAHyhwh</char>, pas kemurahan Kau,</para>
  <para style="q2" vid="PSA 30:8">Kau tegakke aku pecak gónóng yang kuat;</para>
  <para style="q1" vid="PSA 30:8">tapi pas Kau nyingiti rai Kau,</para>
  <para style="q2" vid="PSA 30:8">aku ketakótan.<verse eid="PSA 30:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 30:9" />Samo Kau, ya <char style="nd">ALLAHyhwh</char>, aku bejerét;</para>
  <para style="q2" vid="PSA 30:9">samo Tuan aku mintak kemurahan. <char style="add">Uji aku</char>,<verse eid="PSA 30:9" /></para>
  <para style="q2">
    <verse number="10" style="v" sid="PSA 30:10" />“Apo óntóngnyo amen dara aku <char style="add">tetumpa</char>,</para>
  <para style="q3" vid="PSA 30:10">amen aku tórón ke liang kóbór?</para>
  <para style="q2" vid="PSA 30:10">Apo debu manusio bakal muji Kau,</para>
  <para style="q3" vid="PSA 30:10">jugo bakal mbritoke kestioan Kau?<verse eid="PSA 30:10" /></para>
  <para style="q2">
    <verse number="11" style="v" sid="PSA 30:11" />Dengerla, ya <char style="nd">ALLAHyhwh</char>, trós mura atila samo aku!</para>
  <para style="q3" vid="PSA 30:11">Ya <char style="nd">ALLAHyhwh</char>, jadila penolong aku!”<verse eid="PSA 30:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 30:12" />Kau la ngoba ratepan aku jadi tarian,</para>
  <para style="q2" vid="PSA 30:12">Kau la ngelepaske kaén kabóng aku,</para>
  <para style="q2" vid="PSA 30:12">trós makekke kesenengan ke aku,<verse eid="PSA 30:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 30:13" />sampe-sampe jiwo aku nyanyike pujian óntók Kau</para>
  <para style="q2" vid="PSA 30:13">trós idak diem bae.</para>
  <para style="q1" vid="PSA 30:13">Ya <char style="nd">ALLAHyhwh</char>, ya Tuhan aku, aku bakal besókór samo Kau</para>
  <para style="q2" vid="PSA 30:13">óntók selamo-lamonyo.<verse eid="PSA 30:13" /></para>
  <chapter eid="PSA 30" />
  <chapter number="31" style="c" sid="PSA 31" />
  <para style="s2">Wong pecayo jadi aman dalem tangan Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 31:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 31:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 31:2" />Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, samo Kaula aku beléndóng;</para>
  <para style="q2" vid="PSA 31:2">jangan perna biarke aku dipermaluke.</para>
  <para style="q1" vid="PSA 31:2">Lepaskela aku dalem keadélan Kau!<verse eid="PSA 31:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 31:3" />Pasangla kópéng Kau óntók aku!</para>
  <para style="q1" vid="PSA 31:3">Gancangla bebaske aku!</para>
  <para style="q1" vid="PSA 31:3">Jadila gónóng batu peléndóngan aku,</para>
  <para style="q2" vid="PSA 31:3">jugo benteng óntók nyelametke aku!<verse eid="PSA 31:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 31:4" />Karno Kaula batu karang jugo benteng aku,</para>
  <para style="q2" vid="PSA 31:4">jugo karno namo Kau, pémpénla trós tóntónla aku!<verse eid="PSA 31:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 31:5" />Metukela aku dari jaréng</para>
  <para style="q2" vid="PSA 31:5">yang diem-diem dipasang óntók aku,</para>
  <para style="q2" vid="PSA 31:5">karno Kaula tempat peléndóngan aku.<verse eid="PSA 31:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 31:6" />Ke dalem tangan Kaula aku serake diri<note caller="+" style="f"><char style="fr" closed="false">31:6 </char><char style="fq" closed="false">diri: </char><char style="ft" closed="false">Teks asli iola “ro”. Maksód barés ni bukan artinyo penyaér ni la nak mati, tapi maksódnyo tu iola penyaér nyerake dirinyo dalem léndóngan Allah.</char></note> aku;</para>
  <para style="q2" vid="PSA 31:6">Kau la nebós aku, ya <char style="nd">ALLAHyhwh</char>, Tuhan yang stio.<verse eid="PSA 31:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 31:7" />Aku benci wong yang nyemba berhalo yang sio-sio;</para>
  <para style="q2" vid="PSA 31:7">tapi samo <char style="nd">ALLAHyhwh</char>, aku pecayo.<verse eid="PSA 31:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 31:8" />Aku bakal besorak jugo beseneng dalem kasé stio Kau,</para>
  <para style="q2" vid="PSA 31:8">karno Kau nyingok kesaroan aku</para>
  <para style="q2" vid="PSA 31:8">jugo tau kesesekan jiwo aku.<verse eid="PSA 31:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 31:9" />Kau idak nyerake aku ke tangan mósó,</para>
  <para style="q2" vid="PSA 31:9">tapi Kau negakke sekel aku di tempat yang lapang.<verse eid="PSA 31:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 31:10" />Mura atila samo aku, ya <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 31:10">karno aku dalem kesesekan.</para>
  <para style="q1" vid="PSA 31:10">Mato aku lesu karno sengsaro,</para>
  <para style="q2" vid="PSA 31:10">cak itu jugo jiwo samo badan aku.<verse eid="PSA 31:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 31:11" />Soalnyo édóp aku abés dengen kesedéan,</para>
  <para style="q2" vid="PSA 31:11">jugo taón-taón aku dengen réntéan.</para>
  <para style="q1" vid="PSA 31:11">Kekuatan aku róntó karno kesalahan aku,</para>
  <para style="q2" vid="PSA 31:11">jugo tulang-tulang aku jadi keropos.<verse eid="PSA 31:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 31:12" />Ole karno slóró mósó aku, aku dihino,</para>
  <para style="q3" vid="PSA 31:12">dihino nian ole sesamo aku.</para>
  <para style="q2" vid="PSA 31:12">Aku jadi kengerian óntók kawan-kawan aku.</para>
  <para style="q2" vid="PSA 31:12">Wong-wong yang nyingok aku di jalan ngelarike diri dari aku.<verse eid="PSA 31:12" /></para>
  <para style="q2">
    <verse number="13" style="v" sid="PSA 31:13" />Aku la dilupoke, pecak wong mati.</para>
  <para style="q2" vid="PSA 31:13">Aku la jadi pecak guci yang ancór.<verse eid="PSA 31:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 31:14" />Soalnyo aku denger bésékan dari banyak <char style="add">mósó</char>.</para>
  <para style="q2" vid="PSA 31:14">Ado kengerian di mano-mano!</para>
  <para style="q1" vid="PSA 31:14">Pas dio wong besamo-samo beróndéng ngelawan aku,</para>
  <para style="q2" vid="PSA 31:14">dio wong beniat ngambék nyawo aku.<verse eid="PSA 31:14" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="15" style="v" sid="PSA 31:15" />Tapi aku pecayo samo Kau, ya <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 31:15">Uji aku, “Kaula Tuhan aku!”<verse eid="PSA 31:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 31:16" />Takdér aku ado dalem tangan Kau.</para>
  <para style="q1" vid="PSA 31:16">Lepaskela aku dari tangan mósó-mósó aku,</para>
  <para style="q2" vid="PSA 31:16">dari wong-wong yang ngejer aku!<verse eid="PSA 31:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 31:17" />Biarla cahayo rai Kau nyinari hamba Kau ni,</para>
  <para style="q2" vid="PSA 31:17">trós selametkela aku karno kasé stio Kau.<verse eid="PSA 31:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 31:18" />Ya <char style="nd">ALLAHyhwh</char>, janganla biarke aku dipermaluke,</para>
  <para style="q2" vid="PSA 31:18">karno aku bejerét samo Kau.</para>
  <para style="q1" vid="PSA 31:18">Biarla wong-wong jahat dipermaluke;</para>
  <para style="q2" vid="PSA 31:18">biarla dio wong tórón ke dunio wong mati trós tediem.<verse eid="PSA 31:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 31:19" />Biarla bébér yang ngolai dikebet,</para>
  <para style="q2" vid="PSA 31:19">yang ngomong dengen sombong ke wong bener,</para>
  <para style="q2" vid="PSA 31:19">dengen ngesok jugo ngino.<verse eid="PSA 31:19" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="20" style="v" sid="PSA 31:20" />Alangke belimpanyo kebaék'an Kau</para>
  <para style="q2" vid="PSA 31:20">yang la Kau siapke óntók wong-wong yang takót samo Kau,</para>
  <para style="q2" vid="PSA 31:20">yang la Kau lakuke óntók wong-wong yang beléndóng samo Kau,</para>
  <para style="q3" vid="PSA 31:20">di adepan anak-anak manusio!<verse eid="PSA 31:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="PSA 31:21" />Di jeró léndóngan hadérat Kau, Kau nyingiti dio wong</para>
  <para style="q2" vid="PSA 31:21">dari pesekongkolan manusio.</para>
  <para style="q1" vid="PSA 31:21">Di tempat tedó, Kau ngeléndóngi dio wong</para>
  <para style="q2" vid="PSA 31:21">dari adu mólót.<verse eid="PSA 31:21" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="22" style="v" sid="PSA 31:22" />Pujila <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 31:22">Karno Dio la nónjókke kasé stio-Nyo yang ajaéb samo aku</para>
  <para style="q2" vid="PSA 31:22">pas aku ado di jeró kota yang tekepóng.<verse eid="PSA 31:22" /></para>
  <para style="q1">
    <verse number="23" style="v" sid="PSA 31:23" />Aku ngomong dalem ketakótan aku,</para>
  <para style="q2" vid="PSA 31:23">“Aku dibuang dari adepan mato Kau.”</para>
  <para style="q1" vid="PSA 31:23">Tapi, Kau ndenger suaro pintak'an aku</para>
  <para style="q2" vid="PSA 31:23">pas aku bejerét mintak tolong samo Kau.<verse eid="PSA 31:23" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="24" style="v" sid="PSA 31:24" />Kaséhila <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 31:24">ói kamu wong-wong além-Nyo!</para>
  <para style="q1" vid="PSA 31:24">
    <char style="nd">ALLAHyhwh</char> ngeléndóngi wong-wong yang stio,</para>
  <para style="q2" vid="PSA 31:24">tapi mbales wong yang sombong dengen dak tanggóng-tanggóng.<verse eid="PSA 31:24" /></para>
  <para style="q1">
    <verse number="25" style="v" sid="PSA 31:25" />Kuatkela trós tegukela ati kau,</para>
  <para style="q2" vid="PSA 31:25">ói kamu wong-wong yang bearep samo <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 31:25" /></para>
  <chapter eid="PSA 31" />
  <chapter number="32" style="c" sid="PSA 32" />
  <para style="s2">Kesenengan wong yang diampóni dusonyo</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 32:1" />Dari <char style="w">Daód</char>. Maskil<note caller="+" style="f"><char style="fr" closed="false">32:1 </char><char style="fq" closed="false">Maskil: </char><char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char></note>.</para>
  <para style="b" vid="PSA 32:1" />
  <para style="q1" vid="PSA 32:1">Senengla ati wong yang diampóni pelanggarannyo,</para>
  <para style="q2" vid="PSA 32:1">yang dusonyo ditótópi.<verse eid="PSA 32:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 32:2" />Senengla ati wong yang kesalahannyo idak diétóng <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 32:2">yang dalem jiwonyo katek penipuan.<verse eid="PSA 32:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 32:3" />Pas aku diem <char style="add">pasal duso aku</char>,</para>
  <para style="q2" vid="PSA 32:3">tulang-tulang aku jadi keropos karno jerétan aku sepanjang ari.<verse eid="PSA 32:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 32:4" />Soalnyo siang jugo malem, tangan Kau neken aku,</para>
  <para style="q2" vid="PSA 32:4">kekuatan<note caller="+" style="f"><char style="fr" closed="false">32:4 </char><char style="fq" closed="false">kekuatan: </char><char style="ft" closed="false">Makno teks asli dari kato ni dak pulok jelas.</char></note> aku tekeréng pecak dalem panasnyo mósém kemaró. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 32:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 32:5" />Aku ngakui duso aku samo Kau,</para>
  <para style="q2" vid="PSA 32:5">trós aku idak nyingiti kesalahan aku.</para>
  <para style="q1" vid="PSA 32:5">Uji aku, “Aku bakal ngakui pelanggaran-pelanggaran aku samo <char style="nd">ALLAHyhwh</char>.”</para>
  <para style="q1" vid="PSA 32:5">Trós Kau ngambék kesalahan <char style="add">aku dengen ngampóni</char> duso aku. <char style="qs">Selah</char><verse eid="PSA 32:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 32:6" />Karno tu, biarla slóró wong além bedoa samo Kau pas kesesekan<note caller="+" style="f"><char style="fr" closed="false">32:6 </char><char style="fq" closed="false">pas kesesekan: </char><char style="ft" closed="false">Teks asli dari barés ni dak pulok jelas. Selaén “pas kesesekan”, arti dari teks asli pacak jugo jadi “pas Kau pacak ditemui” apo dak tu “pas aku nyadari duso aku”.</char></note>.</para>
  <para style="q1" vid="PSA 32:6">Sebenernyo, pas banjér besak dateng,</para>
  <para style="q2" vid="PSA 32:6">dio wong idak bakal keno.<verse eid="PSA 32:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 32:7" />Kaula peléndóngan aku,</para>
  <para style="q2" vid="PSA 32:7">Kau nyago aku dari kesaroan,</para>
  <para style="q2" vid="PSA 32:7">Kau ngeléléngi aku dengen sorak'an karno keselametan. <char style="qs">Selah</char><verse eid="PSA 32:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 32:8" />
    <char style="add">Uji Allah,</char></para>
  <para style="q2" vid="PSA 32:8">“Aku bakal ngajar trós nónjókke samo kau</para>
  <para style="q3" vid="PSA 32:8">jalan yang harós kau jalani.</para>
  <para style="q2" vid="PSA 32:8">Aku bakal nasehati kau</para>
  <para style="q3" vid="PSA 32:8">dengen mato Aku tetójó ke kau.<verse eid="PSA 32:8" /></para>
  <para style="q2">
    <verse number="9" style="v" sid="PSA 32:9" />Jangan jadi pecak kudo apo keledai yang katek akal,</para>
  <para style="q3" vid="PSA 32:9">yang harós dikendalike dengen kekang jugo tali,</para>
  <para style="q3" vid="PSA 32:9">
    <char style="add">amen dak tu, binatang tu</char> dak bakal marak'i kau<note caller="+" style="f"><char style="fr" closed="false">32:9 </char><char style="fq" closed="false">yang harós dikendalike … dak bakal marak'i kau: </char><char style="ft" closed="false">Makno teks asli dari keduo barés ni dak pulok jelas.</char></note>.”<verse eid="PSA 32:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 32:10" />Banyak kesaroan óntók wong jahat,</para>
  <para style="q2" vid="PSA 32:10">tapi kasé stio <char style="nd">ALLAHyhwh</char></para>
  <para style="q2" vid="PSA 32:10">ngeléléngi wong yang pecayo samo Dio.<verse eid="PSA 32:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 32:11" />Besenengla dalem <char style="nd">ALLAHyhwh</char> trós pujila,</para>
  <para style="q2" vid="PSA 32:11">ói kamu wong-wong bener!</para>
  <para style="q2" vid="PSA 32:11">Besorakla, ói slóró wong yang lórós ati!<verse eid="PSA 32:11" /></para>
  <chapter eid="PSA 32" />
  <chapter number="33" style="c" sid="PSA 33" />
  <para style="s2">Puji-pujian óntók Allah, pencipto jugo penguaso dunio</para>
  <para style="b" />
  <para style="q1">
    <verse number="1" style="v" sid="PSA 33:1" />Besorak-sorakla karno <char style="nd"><char style="w">ALLAHyhwh</char></char>, ói wong-wong bener!</para>
  <para style="q2" vid="PSA 33:1">Pantesla wong yang lórós naékke puji-pujian.<verse eid="PSA 33:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 33:2" />Ngucap sókórla samo <char style="nd">ALLAHyhwh</char> dengen kecapi!</para>
  <para style="q2" vid="PSA 33:2">Dengen gambós sepóló senar, maénkela óntók Dio!<verse eid="PSA 33:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 33:3" />Nyanyikela nyanyian yang baru óntók Dio!</para>
  <para style="q2" vid="PSA 33:3">Maénkela kecapi dengen lihai, trós besorakla!<verse eid="PSA 33:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 33:4" />Soalnyo, pirman <char style="nd">ALLAHyhwh</char> tu bener,</para>
  <para style="q2" vid="PSA 33:4">jugo galo-galo pebuatan Dio digaweke-Nyo dengen kestioan.<verse eid="PSA 33:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 33:5" />Dio cinto kebeneran jugo keadélan;</para>
  <para style="q2" vid="PSA 33:5">bumi penu dengen kasé stio <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 33:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 33:6" />Dengen omongan <char style="nd">ALLAHyhwh</char>, alam semesto dibékén,</para>
  <para style="q2" vid="PSA 33:6">trós dengen napas dari mólót-Nyo dewek, Dio mbékén segalo yang ado di langét.<verse eid="PSA 33:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 33:7" />Dio ngómpólke banyu laót pecak bendóngan,</para>
  <para style="q2" vid="PSA 33:7">ditarok-Nyo laótan di jeró gudang-Nyo <char style="add">di pócók langét</char><note caller="+" style="f"><char style="fr" closed="false">33:7 </char><char style="fq" closed="false">gudang-Nyo di pócók langét: </char><char style="ft" closed="false">Pas Allah nyiptoke bumi, Dio misake banyu yang ado di bumi samo banyu yang ado di pócók langét (</char><char style="xt" closed="false"><ref loc="GEN 1:6-8">Asal Mulo Dunio 1:6-8</ref></char><char style="ft" closed="false">). Banyu yang di pócók langét jadi sumber ujan, trós secaro puitis tempat banyu tu disebót gudang Allah (jingok </char><char style="xt" closed="false"><ref loc="DEU 28:12">Ulangan 28:12</ref> </char><char style="ft" closed="false">samo </char><char style="xt" closed="false"><ref loc="JOB 38:22">Ayób 38:22</ref></char><char style="ft" closed="false">).</char></note>.<verse eid="PSA 33:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 33:8" />Biarla slóró bumi takót samo <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 33:8">trós biarla slóró pendódók dunio kagóm samo Dio.<verse eid="PSA 33:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 33:9" />Soalnyo, <char style="add">waktu tu</char> Dio ngomong, trós galonyo ado;</para>
  <para style="q2" vid="PSA 33:9">Dio mrénto, trós galonyo ditetepke.<verse eid="PSA 33:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 33:10" />
    <char style="nd">ALLAHyhwh</char> ngancórke nasehat bangso-bangso,</para>
  <para style="q2" vid="PSA 33:10">trós Dio ngalangi rencano suku-suku bangso.<verse eid="PSA 33:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 33:11" />Tapi nasehat <char style="nd">ALLAHyhwh</char> tetep sampe selamo-lamonyo,</para>
  <para style="q2" vid="PSA 33:11">trós rencano ati-Nyo sampe tórón-temórón.<verse eid="PSA 33:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 33:12" />Senengla bangso yang Tuhannyo tu <char style="nd">ALLAHyhwh</char>;</para>
  <para style="q2" vid="PSA 33:12">suku bangso yang la dipélé-Nyo dewek jadi pusako kepunyoan-Nyo.<verse eid="PSA 33:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 33:13" />
    <char style="nd">ALLAHyhwh</char> nyingok dari surgo;</para>
  <para style="q2" vid="PSA 33:13">Dio nyingok galo-galo manusio.<verse eid="PSA 33:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 33:14" />Dari tempat Dio dódók, Dio masati galo-galo yang tinggal di bumi.<verse eid="PSA 33:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 33:15" />Diola yang mbentók ati dio wong galo,</para>
  <para style="q2" vid="PSA 33:15">yang meratike segalo pebuatan dio wong.<verse eid="PSA 33:15" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="16" style="v" sid="PSA 33:16" />Rajo idak diselametke ole besaknyo pasókan.</para>
  <para style="q2" vid="PSA 33:16">Tentra idak dibebaske ole besaknyo kekuatan.<verse eid="PSA 33:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 33:17" />Kudo iola arepan yang sio-sio óntók kemenangan.</para>
  <para style="q2" vid="PSA 33:17">Mugola kekuatannyo besak, dio dak pacak nyelametke.<verse eid="PSA 33:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 33:18" />Jingokla, mato <char style="nd">ALLAHyhwh</char> nuju ke wong-wong yang takót samo Dio,</para>
  <para style="q2" vid="PSA 33:18">jugo ke wong-wong yang ngarep kasé stio-Nyo,<verse eid="PSA 33:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 33:19" />óntók ngelepaske jiwo dio wong dari maót,</para>
  <para style="q2" vid="PSA 33:19">trós óntók miaro nyawo dio wong pas kelaperan.<verse eid="PSA 33:19" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="20" style="v" sid="PSA 33:20" />Jiwo kito nunggu-nunggui <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 33:20">Diola penolong jugo tameng kito.<verse eid="PSA 33:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="PSA 33:21" />Soalnyo dalem Dio ati kito seneng</para>
  <para style="q2" vid="PSA 33:21">karno kito pecayo samo namo-Nyo yang suci.<verse eid="PSA 33:21" /></para>
  <para style="q1">
    <verse number="22" style="v" sid="PSA 33:22" />Ya <char style="nd">ALLAHyhwh</char>, biarla kasé stio Kau tetep samo kami,</para>
  <para style="q2" vid="PSA 33:22">pecak kami ngarep samo Kau.<verse eid="PSA 33:22" /></para>
  <chapter eid="PSA 33" />
  <chapter number="34" style="c" sid="PSA 34" />
  <para style="s2">Berkah wong yang beléndóng samo Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 34:1" />Saér Daód, pas dio ecak-ecak gilo di adepan Abimelek sampe-sampe dio diósér, trós pegi.<note caller="-" style="x"><char style="xo" closed="false">34:1 </char><char style="xt" closed="false"><ref loc="1SA 21:13-15">1 Samuel 21:13-15</ref></char></note><verse eid="PSA 34:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 34:2" />Aku bakal besókór samo <char style="nd"><char style="w">ALLAHyhwh</char></char> tiap ari,</para>
  <para style="q2" vid="PSA 34:2">jugo pujian-Nyo bakal ado terós di mólót aku.<verse eid="PSA 34:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 34:3" />Jiwo aku bakal ngagóngke <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 34:3">Biarla wong yang saro ndengernyo trós beseneng-seneng.<verse eid="PSA 34:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 34:4" />Ói mulyokela <char style="nd">ALLAHyhwh</char> besamo aku!</para>
  <para style="q2" vid="PSA 34:4">Payó kito ninggike namo-Nyo besamo-samo!<verse eid="PSA 34:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 34:5" />Aku nyari <char style="nd">ALLAHyhwh</char>, trós Dio nyawab aku.</para>
  <para style="q2" vid="PSA 34:5">Dio mbebaske aku dari segalo ketakótan aku.<verse eid="PSA 34:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 34:6" />Wong-wong nyingok'i Dio, trós jadi besinar.</para>
  <para style="q2" vid="PSA 34:6">Rai dio wong dak bakal malu.<verse eid="PSA 34:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 34:7" />Wong yang saro ni mekék, trós <char style="nd">ALLAHyhwh</char> ndenger dio.</para>
  <para style="q2" vid="PSA 34:7">Dio nyelametkenyo dari segalo kesesekannyo.<verse eid="PSA 34:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 34:8" />Malekat <char style="nd">ALLAHyhwh</char> bekemah di sekeléléng wong-wong yang takót samo Dio,</para>
  <para style="q2" vid="PSA 34:8">trós ngelepaske dio wong.<verse eid="PSA 34:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 34:9" />Rasokela trós jingokla <char style="add">dewek</char> amen <char style="nd">ALLAHyhwh</char> tu baék!<note caller="-" style="x"><char style="xo" closed="false">34:9 </char><char style="xt" closed="false"><ref loc="1PE 2:3">1 Petrus 2:3</ref></char></note></para>
  <para style="q2" vid="PSA 34:9">Senengla wong yang beléndóng samo Dio.<verse eid="PSA 34:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 34:10" />Takótla samo <char style="nd">ALLAHyhwh</char>, ói wong-wong suci-Nyo!</para>
  <para style="q2" vid="PSA 34:10">Karno wong yang takót samo Dio dak bakal kekurangan.<verse eid="PSA 34:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 34:11" />
    <char style="add">Mugola</char> singo-singo mudo kekurangan jugo kelaperan,</para>
  <para style="q2" vid="PSA 34:11">tapi wong-wong yang nyari <char style="nd">ALLAHyhwh</char> dak bakal kekurangan apo bae yang baék.<verse eid="PSA 34:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 34:12" />Datengla móréd-móréd<note caller="+" style="f"><char style="fr" closed="false">34:12 </char><char style="fq" closed="false">móréd-móréd: </char><char style="ft" closed="false">Teks asli iola “anak-anak”. Di budayo Ibrani kuno, guru manggél móréd-mórédnyo dengen sebótan “anak-anak”, mugola wong tu la besak. (Jingok </char><char style="xt"><ref loc="PRO 1:8">Pribahaso 1:8</ref>; <ref loc="PRO 2:1">2:1</ref>,</char> jugo <char style="xt" link-href="PRO 3:1"><ref loc="PRO 3:1">3:1</ref></char> )</note>, dengerkela aku!</para>
  <para style="q1" vid="PSA 34:12">Aku bakal ngajari kau óntók takót samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 34:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 34:13" />Siapo yang galak édóp?</para>
  <para style="q2" vid="PSA 34:13">Siapo yang seneng amen dio pacak jingok ari-ari yang baék?<verse eid="PSA 34:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 34:14" />Jagola lida kau dari kejahatan,</para>
  <para style="q2" vid="PSA 34:14">jugo bébér kau dari omongan yang ngotak'i.<verse eid="PSA 34:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 34:15" />Bebalékla dari kejahatan, trós békénla yang baék.</para>
  <para style="q1" vid="PSA 34:15">Carila kedamaian trós kejerla itu.<verse eid="PSA 34:15" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="16" style="v" sid="PSA 34:16" />Mato <char style="nd">ALLAHyhwh</char> ngara ke wong-wong yang bener,</para>
  <para style="q2" vid="PSA 34:16">trós kópéng Dio tebukak óntók wong-wong yang mekék mintak tolong.<verse eid="PSA 34:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 34:17" />Rai <char style="nd">ALLAHyhwh</char> nentang wong-wong yang mbékén kejahatan,</para>
  <para style="q2" vid="PSA 34:17">óntók ngelenyepke dio wong sampe-sampe idak diinget lagi di bumi<note caller="+" style="f"><char style="fr" closed="false">34:17 </char><char style="fq" closed="false">óntók ngelenyepke dio wong sampe-sampe idak diinget lagi di bumi: </char><char style="ft" closed="false">Teks asli iola “óntók ngapóske ingetan pasal dio wong dari bumi”.</char></note>.<note caller="-" style="x"><char style="xo" closed="false">34:13-17 </char><char style="xt" closed="false"><ref loc="1PE 3:10-12">1 Petrus 3:10-12</ref></char></note><verse eid="PSA 34:17" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="18" style="v" sid="PSA 34:18" />Wong-wong bener mekék, trós <char style="nd">ALLAHyhwh</char> denger.</para>
  <para style="q2" vid="PSA 34:18">Dio mbebaske dio wong dari segalo kesesekannyo.<verse eid="PSA 34:18" /></para>
  <para style="q1">
    <verse number="19" style="v" sid="PSA 34:19" />
    <char style="nd">ALLAHyhwh</char> tu parak samo wong yang atinyo pata,</para>
  <para style="q2" vid="PSA 34:19">trós Dio nyelametke wong-wong yang jiwonyo ancór.<verse eid="PSA 34:19" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="20" style="v" sid="PSA 34:20" />Kesaroan wong bener banyak,</para>
  <para style="q2" vid="PSA 34:20">tapi <char style="nd">ALLAHyhwh</char> mbebaske dio dari galonyo tu.<verse eid="PSA 34:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="PSA 34:21" />Dio nyago galo-galo tulang wong tu,</para>
  <para style="q2" vid="PSA 34:21">dak katek sikok bae yang pata.<note caller="-" style="x"><char style="xo" closed="false">34:21 </char><char style="xt" closed="false"><ref loc="JHN 19:36">Yahya 19:36</ref></char></note><verse eid="PSA 34:21" /></para>
  <para style="q1">
    <verse number="22" style="v" sid="PSA 34:22" />Kejahatan bakal mbunu wong jahat,</para>
  <para style="q2" vid="PSA 34:22">trós siapo bae yang benci wong bener bakal dihókóm.<verse eid="PSA 34:22" /></para>
  <para style="q1">
    <verse number="23" style="v" sid="PSA 34:23" />
    <char style="nd">ALLAHyhwh</char> nebós jiwo hamba-hamba-Nyo,</para>
  <para style="q2" vid="PSA 34:23">trós galo-galo yang beléndóng samo Dio</para>
  <para style="q2" vid="PSA 34:23">idak bakal dihókóm-Nyo.<verse eid="PSA 34:23" /></para>
  <chapter eid="PSA 34" />
