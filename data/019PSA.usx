  <chapter eid="PSA 83" />
  <chapter number="84" style="c" sid="PSA 84" />
  <para style="s2" vid="PSA 83:19">Kangen Ruma Agóng Allah di Yerusalem<verse eid="PSA 83:19" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 84:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót gitit<note caller="+" style="f"><char style="fr" closed="false">84:1 </char><char style="fq" closed="false">gitit: </char><char style="ft" closed="false">Kato ni iola kato di teks asli. Maknonyo dak pulok jelas. Móngkén namo nyanyian apo dak tu alat musik.</char></note>. Nyanyian dari ketórónan Korah.<verse eid="PSA 84:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 84:2" />Alangke nyenengkenyo tempat Kau tinggal,</para>
  <para style="q2" vid="PSA 84:2">ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, Tuan semesto alam!<verse eid="PSA 84:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 84:3" />Jiwo aku kangen samo halaman <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 84:3">sampe telesu karnonyo.</para>
  <para style="q1" vid="PSA 84:3">Jiwo rago aku nyorak-nyorak'i Tuhan yang édóp.<verse eid="PSA 84:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 84:4" />Mala bóróng pépét la dapet ruma,</para>
  <para style="q2" vid="PSA 84:4">trós bóróng layang-layang dapet sikok sarang óntók dirinyo,</para>
  <para style="q2" vid="PSA 84:4">tempat narok anak-anaknyo parak meja-meja pesembahan Kau,</para>
  <para style="q3" vid="PSA 84:4">ya <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
  <para style="q3" vid="PSA 84:4">ya Rajo aku jugo Tuhan aku!<verse eid="PSA 84:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 84:5" />Senengla wong-wong yang ado terós di ruma Kau!</para>
  <para style="q2" vid="PSA 84:5">Dio wong terós-terósan muji Kau. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 84:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 84:6" />Senengla wong-wong yang ndapetke kekuatannyo dari Kau,</para>
  <para style="q2" vid="PSA 84:6">yang atinyo kangen óntók bejiara<note caller="+" style="f"><char style="fr" closed="false">84:6 </char><char style="fq" closed="false">yang atinyo kangen óntók bejiara: </char><char style="ft" closed="false">Teks asli iola “jalan-jalan besak ado di atinyo”. Arti “jalan-jalan besak” iola jalan-jalan yang ngara ke <char style="w">Yerusalem</char> trós diliwati wong-wong yang nak bejiara ke <char style="w">Ruma Agóng Allah</char>.</char></note> <char style="add">ke ruma Kau</char>.<verse eid="PSA 84:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 84:7" />Sementaro dio wong ngeliwati Lemba Bakka<note caller="+" style="f"><char style="fr" closed="false">84:7 </char><char style="fq" closed="false">Lemba Bakka: </char><char style="ft" closed="false">Pecaknyo ini ni iola namo tempat yang diliwati pas bejiara ke Yerusalem. Bukan nónjókke alam baka. </char></note>,</para>
  <para style="q2" vid="PSA 84:7">dio wong mbékénnyo<note caller="+" style="f"><char style="fr" closed="false">84:7 </char><char style="fq" closed="false">dio wong mbékénnyo: </char><char style="ft" closed="false">Dalem beberapo naska laénnyo tetólés cak ni, “Dio [Allah] mbékénnyo jadi tempat bemato banyu óntók dio wong”.</char></note> jadi tempat yang bemato banyu.</para>
  <para style="q2" vid="PSA 84:7">Mala ujan pas awal mósém nyelimutinyo dengen berkah.<verse eid="PSA 84:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 84:8" />Dio wong bejalan dalem kekuatan yang dak abés-abés,</para>
  <para style="q2" vid="PSA 84:8">ngadep Allah di <char style="w">Sion</char>.<verse eid="PSA 84:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 84:9" />Ya <char style="nd">ALLAHyhwh</char>, Tuan semesto alam, dengerkela doa aku.</para>
  <para style="q2" vid="PSA 84:9">Peratikela, ya Tuhannyo Yakób! <char style="qs">Selah</char><verse eid="PSA 84:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 84:10" />Jingokla tameng kami<note caller="+" style="f"><char style="fr" closed="false">84:10 </char><char style="fq" closed="false">tameng kami: </char><char style="ft" closed="false">Ini ni biasonyo dianggep kiasan óntók rajo, karno rajo ngeléndóngi rakyatnyo. Di barés selanjótnyo, “wong yang Kau lanték” jugo nónjókke rajo.</char></note> <char style="add">dengen kebaék'an Kau</char>, ya Allah,</para>
  <para style="q2" vid="PSA 84:10">pasatila rai wong yang Kau lanték.<verse eid="PSA 84:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 84:11" />Sebenernyo lebé baék seari bae di halaman Kau</para>
  <para style="q2" vid="PSA 84:11">daripado seribu <char style="add">ari di tempat laén</char>.</para>
  <para style="q1" vid="PSA 84:11">Aku lebé galak tegak di lawang ruma Tuhan aku</para>
  <para style="q2" vid="PSA 84:11">daripado tinggal di ruma wong jahat.<verse eid="PSA 84:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 84:12" />Soalnyo Tuhan <char style="nd">ALLAHyhwh</char> iola matoari jugo tameng<note caller="+" style="f"><char style="fr" closed="false">84:12 </char><char style="fq" closed="false">matoari jugo tameng: </char><char style="ft" closed="false">Ini ni kiasan óntók bémbéngan jugo peléndóngan pecak yang disedioke ole rajo yang baék óntók rakyatnyo.</char></note>;</para>
  <para style="q2" vid="PSA 84:12">
    <char style="nd">ALLAHyhwh</char> ngenjók karunio jugo kemulyoan;</para>
  <para style="q2" vid="PSA 84:12">Dio dak nahan kebaék'an dari wong yang bejalan dalem ketólósan.<verse eid="PSA 84:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 84:13" />Ya <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
  <para style="q2" vid="PSA 84:13">senengla wong yang pecayo samo Kau!<verse eid="PSA 84:13" /></para>
  <chapter eid="PSA 84" />
