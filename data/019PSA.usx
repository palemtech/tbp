  <chapter eid="PSA 107" />
  <chapter number="108" style="c" sid="PSA 108" />
  <para style="s2" vid="PSA 107:43">Doa sókór jugo mintak petolongan Allah ngelawan mósó<verse eid="PSA 107:43" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 108:1" />Nyanyian. Saér Daód.<verse eid="PSA 108:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 108:2" />
    <note caller="-" style="x">
      <char style="xo" closed="false">108:2-6 </char>
      <char style="xt" closed="false">
        <ref loc="PSA 57:8-12">Saér Nyanyian 57:8-12</ref> </char>
    </note>Ati aku tegu, ya Allah!</para>
  <para style="q1" vid="PSA 108:2">Aku nak nyanyi trós maén musik,</para>
  <para style="q2" vid="PSA 108:2">dengen jiwo aku jugo!<verse eid="PSA 108:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 108:3" />Ói gambós samo kecapi, nyanyila!</para>
  <para style="q2" vid="PSA 108:3">Aku nak nyambót pajar!<verse eid="PSA 108:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 108:4" />Aku nak ngucap sókór samo Kau di antaro bangso-bangso, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>!</para>
  <para style="q2" vid="PSA 108:4">Aku nak nyanyike pujian óntók Kau di antaro suku-suku bangso!<verse eid="PSA 108:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 108:5" />Soalnyo kasé Kau besak ngelebéi langét,</para>
  <para style="q2" vid="PSA 108:5">trós kestioan Kau sampe ke awan-awan.<verse eid="PSA 108:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 108:6" />Ya Allah, tinggikela diri Kau ngelebéi langét,</para>
  <para style="q2" vid="PSA 108:6">trós biarla kemulyoan Kau nótópi slóró bumi.<verse eid="PSA 108:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 108:7" />
    <note caller="-" style="x">
      <char style="xo" closed="false">108:7-14 </char>
      <char style="xt" closed="false">
        <ref loc="PSA 60:7-14">Saér Nyanyian 60:7-14</ref>
      </char>
    </note>Supayo wong-wong yang Kau kaséhi pacak dilepaske,</para>
  <para style="q2" vid="PSA 108:7">selametkela dengen tangan kanan Kau,</para>
  <para style="q2" vid="PSA 108:7">trós jawabla aku.<verse eid="PSA 108:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 108:8" />Allah la bepirman di tempat suci-Nyo, uji-Nyo,</para>
  <para style="q2" vid="PSA 108:8">“Aku bakal besorak,</para>
  <para style="q2" vid="PSA 108:8">Aku bakal mbagé-bagéke Sikem,</para>
  <para style="q3" vid="PSA 108:8">trós Aku bakal ngókór Lemba Sukot<note caller="+" style="f"><char style="fr" closed="false">108:8 </char><char style="fq" closed="false">Sikem … Lemba Sukot: </char><char style="ft" closed="false">Sikem iola namo daera di sebela barat Sungi Yordan di Israel, trós Lemba Sukot iola namo daera di sebela timur sungi tu.</char></note>.<verse eid="PSA 108:8" /></para>
  <para style="q2">
    <verse number="9" style="v" sid="PSA 108:9" />Gilead punyo Aku,</para>
  <para style="q2" vid="PSA 108:9">Manasye jugo punyo Aku,</para>
  <para style="q3" vid="PSA 108:9">trós Epraém iola tameng palak Aku.</para>
  <para style="q2" vid="PSA 108:9">Yehuda<note caller="+" style="f"><char style="fr" closed="false">108:9 </char><char style="fq" closed="false">Gilead … Manasye … Epraém … Yehuda: </char><char style="ft" closed="false">Ini ni namo beberapo daera besak di Israel.</char></note> iola tongkat kerajaan Aku.<verse eid="PSA 108:9" /></para>
  <para style="q2">
    <verse number="10" style="v" sid="PSA 108:10" />Moab iola wada pembasóan Aku;</para>
  <para style="q3" vid="PSA 108:10">Di Edom, Aku bakal nguntalke selop Aku<note caller="+" style="f"><char style="fr" closed="false">108:10 </char><char style="fq" closed="false">Di Edom, Aku bakal nguntalke selop Aku: </char><char style="ft" closed="false">Pecaknyo ini ni jadi gambaran amen Edom iola kepunyoan Allah.</char></note>;</para>
  <para style="q3" vid="PSA 108:10">Di Pilistea<note caller="+" style="f"><char style="fr" closed="false">108:10 </char><char style="fq" closed="false">Moab … Edom … Pilistea: </char><char style="ft" closed="false">Ini ni namo bangso-bangso yang bemósóan samo bangso Israel.</char></note>, Aku bakal besorak <char style="add">dalem kemenangan</char>.”<verse eid="PSA 108:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 108:11" />Siapo yang bakal gawak aku ke kota yang bebenteng?</para>
  <para style="q2" vid="PSA 108:11">Siapo yang pacak mémpén aku sampe ke Edom?<verse eid="PSA 108:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 108:12" />Ya Allah, bukannyo Kau la mbuang kami,</para>
  <para style="q2" vid="PSA 108:12">trós idak maju besamo tentra kami, ya Allah?<verse eid="PSA 108:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 108:13" />Enjókla kami petolongan óntók ngadepi mósó,</para>
  <para style="q2" vid="PSA 108:13">karno sio-siola keselametan yang dari manusio.<verse eid="PSA 108:13" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="14" style="v" sid="PSA 108:14" />Besamo Allah, kito bakal ngelakuke pebuatan yang gagah.</para>
  <para style="q2" vid="PSA 108:14">Diola yang bakal mijak-mijak slóró lawan kito.<verse eid="PSA 108:14" /></para>
  <chapter eid="PSA 108" />
  <chapter number="109" style="c" sid="PSA 109" />
