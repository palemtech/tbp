  <verse number="6" style="v" sid="PSA 140:6" />
  <verse eid="PSA 140:6" />
  <verse number="7" style="v" sid="PSA 140:7" />
  <verse eid="PSA 140:7" />
  <verse number="8" style="v" sid="PSA 140:8" />
  <verse eid="PSA 140:8" />
  <verse number="9" style="v" sid="PSA 140:9" />
  <verse eid="PSA 140:9" />
  <verse number="10" style="v" sid="PSA 140:10" />
  <verse eid="PSA 140:10" />
  <verse number="11" style="v" sid="PSA 140:11" />
