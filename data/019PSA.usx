  <chapter number="46" style="c" sid="PSA 46" />
  <para style="s2" vid="PSA 45:18">Allah, kota benteng kito<verse eid="PSA 45:18" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 46:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni</char> dari ketórónan Korah. <char style="add">Dinyanyike </char> nórót alamot<note caller="+" style="f"><char style="fr" closed="false">46:1 </char><char style="fq" closed="false">alamot: </char><char style="ft" closed="false">Kato Ibrani ni biasonyo digunoke óntók sebótan sekelompok betino, tapi di sini digunoke pecak istila kósós óntók musik. Maknonyo di sini kurang jelas, tapi móngkén nónjókke nada tinggi.</char></note>. Saér nyanyian.<verse eid="PSA 46:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 46:2" />Allah iola tempat peléndóngan jugo kekuatan kito,</para>
  <para style="q2" vid="PSA 46:2">penolong yang hadér terós dalem kesaroan.<verse eid="PSA 46:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 46:3" />Karno tu kito dak bakal takót, mugola bumi dirombak</para>
  <para style="q2" vid="PSA 46:3">jugo gónóng-gónóng róntó di tenga-tenga laótan;<verse eid="PSA 46:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 46:4" />mugola banyunyo begolak jugo bebóé,</para>
  <para style="q2" vid="PSA 46:4">trós gónóng-gónóng tegoncang ole keganasan banyu tu. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 46:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 46:5" />Ado sungi.</para>
  <para style="q2" vid="PSA 46:5">Aléran-alérannyo nyenengke kota Allah<note caller="+" style="f"><char style="fr" closed="false">46:5 </char><char style="fq" closed="false">kota Allah: </char><char style="ft" closed="false">Yang dimaksód di sini iola kota <char style="w">Yerusalem</char>.</char></note>,</para>
  <para style="q3" vid="PSA 46:5">iola tempat suci, tempat tinggal Yang Mahabesak.<verse eid="PSA 46:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 46:6" />Allah ado di tenga kota tu.</para>
  <para style="q2" vid="PSA 46:6">Kota tu dak bakal róntó.</para>
  <para style="q2" vid="PSA 46:6">Allah bakal nolongnyo pas pagi ari.<verse eid="PSA 46:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 46:7" />Bangso-bangso begolak;</para>
  <para style="q2" vid="PSA 46:7">kerajaan-kerajaan róntó.</para>
  <para style="q1" vid="PSA 46:7">Dio metuke suaro-Nyo;</para>
  <para style="q2" vid="PSA 46:7">bumi ancór.<verse eid="PSA 46:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 46:8" />
    <char style="nd">ALLAHyhwh</char>, Tuan semesto alam besamo kito,</para>
  <para style="q2" vid="PSA 46:8">kota benteng kito iola Tuhannyo <char style="w">Yakób</char>. <char style="qs">Selah</char><verse eid="PSA 46:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 46:9" />Payó! Jingokla pebuatan <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 46:9">yang mbékén keancóran di bumi!<verse eid="PSA 46:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 46:10" />Dio berentike petempóran sampe ke ójóng bumi.</para>
  <para style="q2" vid="PSA 46:10">Bósór pana Dio patake;</para>
  <para style="q2" vid="PSA 46:10">tombak Dio tetak'i;</para>
  <para style="q2" vid="PSA 46:10">tameng-tameng<note caller="+" style="f"><char style="fr" closed="false">46:10 </char><char style="fq" closed="false">tameng-tameng: </char><char style="ft" closed="false">Teks asli kato ni pacak jugo diartike “kreto-kreto”. </char></note> Dio tunu dengen api.<verse eid="PSA 46:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 46:11" />
    <char style="add">Uji-Nyo,</char> “Diemla! Trós sadarila amen Akula Allah!</para>
  <para style="q2" vid="PSA 46:11">Aku bakal diagóngke di antaro bangso-bangso,</para>
  <para style="q2" vid="PSA 46:11">Aku bakal diagóngke di bumi!”<verse eid="PSA 46:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 46:12" />
    <char style="nd">ALLAHyhwh</char>, Tuan semesto alam besamo kito,</para>
  <para style="q2" vid="PSA 46:12">kota benteng kito iola Tuhannyo Yakób. <char style="qs">Selah</char><verse eid="PSA 46:12" /></para>
  <chapter eid="PSA 46" />
  <chapter number="47" style="c" sid="PSA 47" />
  <para style="s2">Allah, Rajo slóró bumi</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 47:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni</char> dari ketórónan Korah. Saér nyanyian.<verse eid="PSA 47:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 47:2" />Ói slóró bangso, betepók tanganla!</para>
  <para style="q2" vid="PSA 47:2">Besorak-sorakla óntók Allah dengen suaro yang seneng.<verse eid="PSA 47:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 47:3" />Soalnyo <char style="nd"><char style="w">ALLAHyhwh</char></char> Yang Mahabesak tu ditakóti,</para>
  <para style="q2" vid="PSA 47:3">Rajo Besak di slóró bumi.<verse eid="PSA 47:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 47:4" />Dio narok bangso-bangso di bawa <char style="add">kuaso</char> kito,</para>
  <para style="q2" vid="PSA 47:4">trós suku-suku bangso di bawa sekel kito.<verse eid="PSA 47:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 47:5" />Dio nentuke óntók kito tana warésan kito<note caller="+" style="f"><char style="fr" closed="false">47:5 </char><char style="fq" closed="false">tana warésan kito: </char><char style="ft" closed="false">Yang dimaksód tana warésan di sini iola Tana Pejanjian.</char></note>,</para>
  <para style="q2" vid="PSA 47:5">iola kebanggaan <char style="w">Yakób</char> yang Dio kaséhi. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 47:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 47:6" />Allah la naék <char style="add">ke korsi kekuasoan-Nyo</char> diéréngi sorak'an;</para>
  <para style="q2" vid="PSA 47:6">
    <char style="nd">ALLAHyhwh</char> <char style="add">la naék</char>, diéréngi bunyi sangkakala<note caller="+" style="f"><char style="fr" closed="false">47:6 </char><char style="fq" closed="false">sangkakala: </char><char style="ft" closed="false">Ini ni jenis alat musik tiup, pecak terompet besak tebuat dari tandók. Dalem budayo Ibrani, sangkakala dibunyike pas nyambót rajo.</char></note>.<verse eid="PSA 47:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 47:7" />Nyanyikela puji-pujian óntók Allah! Nyanyikela!</para>
  <para style="q2" vid="PSA 47:7">Nyanyikela puji-pujian óntók Rajo kito! Nyanyikela!<verse eid="PSA 47:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 47:8" />Soalnyo Allah iola Rajo slóró bumi.</para>
  <para style="q2" vid="PSA 47:8">Nyanyikela saér nyanyian!<verse eid="PSA 47:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 47:9" />Allah mrénto bangso-bangso.</para>
  <para style="q2" vid="PSA 47:9">Allah dódók di pócók korsi-Nyo yang suci.<verse eid="PSA 47:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 47:10" />Wong-wong besak bangso-bangso bekómpól</para>
  <para style="q2" vid="PSA 47:10">besamo umat Tuhannyo Ibrahim<note caller="+" style="f"><char style="fr" closed="false">47:10 </char><char style="fq" closed="false">besamo umat Tuhannyo Ibrahim: </char><char style="ft" closed="false">Barés ni pacak jugo ditejemake cak ini, “jadi umat Tuhannyo Ibrahim”.</char></note>.</para>
  <para style="q1" vid="PSA 47:10">Soalnyo Allah bae yang punyo tameng-tameng bumi.</para>
  <para style="q1" vid="PSA 47:10">Dio diagóngke nian!<verse eid="PSA 47:10" /></para>
  <chapter eid="PSA 47" />
  <chapter number="48" style="c" sid="PSA 48" />
  <para style="s2">Sion, kota Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 48:1" />Nyanyian. Saér dari ketórónan Korah.<verse eid="PSA 48:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 48:2" />Besakla <char style="nd"><char style="w">ALLAHyhwh</char></char> jugo tepuji nian</para>
  <para style="q2" vid="PSA 48:2">di kota Tuhan kito, bókét-Nyo yang suci.<verse eid="PSA 48:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 48:3" />Cindó menjulang, kesenengan óntók slóró bumi,</para>
  <para style="q2" vid="PSA 48:3">itula bókét <char style="w">Sion</char>, kota Rajo Besak,</para>
  <para style="q2" vid="PSA 48:3">yang ado di ójóng sebela utara!<verse eid="PSA 48:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 48:4" />Allah ado di jeró benteng-bentengnyo.</para>
  <para style="q2" vid="PSA 48:4">Dio la ngenalke diri jadi tempat peléndóngan yang tinggi.<verse eid="PSA 48:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 48:5" />Soalnyo jingokla! Rajo-rajo bekómpól.</para>
  <para style="q2" vid="PSA 48:5">Dio wong nyerbu serempak.<verse eid="PSA 48:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 48:6" />Dio wong jingok, abés tu tepelongok.</para>
  <para style="q2" vid="PSA 48:6">Dio wong panik,</para>
  <para style="q3" vid="PSA 48:6">trós lari ketakótan<note caller="+" style="f"><char style="fr" closed="false">48:5-6 </char><char style="fq" closed="false">Rajo-rajo bekómpól.… trós lari ketakótan: </char><char style="ft" closed="false">Di sini rajo-rajo mósó Israel dateng óntók nyerbu kota Sion (iola Yerusalem, ibu kota Israel pas jaman tu). Tapi pas dio wong nyingok Allah ngeléndóngi kota tu, dio wong lari ketakótan. </char></note>.<verse eid="PSA 48:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 48:7" />Dio wong gemeter ketakótan di sano,</para>
  <para style="q2" vid="PSA 48:7">trós kesakétan nian pecak betino yang nak beranak.<verse eid="PSA 48:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 48:8" />Dengen angin timur</para>
  <para style="q2" vid="PSA 48:8">Kau ngancórke kapal-kapal Tarsis<note caller="+" style="f"><char style="fr" closed="false">48:8 </char><char style="fq" closed="false">Tarsis: </char><char style="ft" closed="false">Sikok kota di Laót Tenga yang tekenal pas jaman tu karno kapal-kapalnyo yang besak. Letak kota tu jaó dari Israel, tapi kapalnyo dikenal di mano-mano karno pedagangan.</char></note>.<verse eid="PSA 48:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 48:9" />Pecak yang la kito denger, pecak itu jugo yang kito jingok,</para>
  <para style="q2" vid="PSA 48:9">di kota <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
  <para style="q2" vid="PSA 48:9">di kota Tuhan kito.</para>
  <para style="q1" vid="PSA 48:9">Allah negóke kota tu óntók selamo-lamonyo. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 48:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 48:10" />Ya Allah, kami nginget kasé stio Kau</para>
  <para style="q2" vid="PSA 48:10">di jeró <char style="w" lemma="Ruma Agóng Allah">Ruma Agóng Kau</char>.<verse eid="PSA 48:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 48:11" />Samo pecak namo baék Kau, ya Allah,</para>
  <para style="q2" vid="PSA 48:11">cak itu jugo puji-pujian óntók Kau sampe ke ójóng-ójóng bumi.</para>
  <para style="q1" vid="PSA 48:11">Kau penu keadélan<note caller="+" style="f"><char style="fr" closed="false">48:11 </char><char style="fq" closed="false">Kau penu keadélan: </char><char style="ft" closed="false">Teks aslinyo iola, “Tangan kanan Kau penu keadélan”, yang artinyo slóró kepótósan Allah tu bener.</char></note>.<verse eid="PSA 48:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 48:12" />Biarkela bókét Sion beseneng;</para>
  <para style="q2" vid="PSA 48:12">biarkela dósón-dósón Yehuda<note caller="+" style="f"><char style="fr" closed="false">48:12 </char><char style="fq" closed="false">dósón-dósón Yehuda: </char><char style="ft" closed="false">Teks aslinyo iola “anak-anak (betino) Yehuda”. “Anak betino” di sini jadi gambaran dósón yang pecak anak dari propinsi/kerajaan Yehuda. Kota Yerusalem/Sion iola ibu kota Yehuda.</char></note> besorak-sorak</para>
  <para style="q2" vid="PSA 48:12">karno kepótósan pengadélan Kau<note caller="+" style="f"><char style="fr" closed="false">48:12 </char><char style="fq" closed="false">besorak-sorak karno kepótósan pengadélan Kau: </char><char style="ft" closed="false">Dio wong besorak-sorak karno Allah ngakémi mósó-mósó dio wong.</char></note>.<verse eid="PSA 48:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 48:13" />Payó! Bejalanla muteri Sion, trós keléléngila dio.</para>
  <para style="q2" vid="PSA 48:13">Étóngla menara-menaranyo.<verse eid="PSA 48:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 48:14" />Pasatila tembok-temboknyo,</para>
  <para style="q2" vid="PSA 48:14">liwatla di antaro benteng-bentengnyo,</para>
  <para style="q2" vid="PSA 48:14">supayo kamu pacak nyeritokenyo samo angkatan berékótnyo.<verse eid="PSA 48:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 48:15" />Sebenernyo, inila Allah,</para>
  <para style="q2" vid="PSA 48:15">Tuhan kito óntók seterósnyo jugo selamo-lamonyo!</para>
  <para style="q2" vid="PSA 48:15">Diola yang bakal mémpén kito sampe selesai<note caller="+" style="f"><char style="fr" closed="false">48:15 </char><char style="fq" closed="false">sampe selesai: </char><char style="ft" closed="false">Makno keduo kato ni di teks aslinyo kurang jelas.</char></note>!<verse eid="PSA 48:15" /></para>
  <chapter eid="PSA 48" />
  <chapter number="49" style="c" sid="PSA 49" />
