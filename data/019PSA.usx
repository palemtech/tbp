  <chapter number="143" style="c" sid="PSA 143" />
  <para style="s2" vid="PSA 142:8">Doa mintak petolongan jugo pémpénan Allah<verse eid="PSA 142:8" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 143:1" />Nyanyian <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 143:1" />
  <para style="q1" vid="PSA 143:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, dengerkela doa aku!</para>
  <para style="q2" vid="PSA 143:1">Peratikela pemohonan aku yang mintak kemurahan Kau;</para>
  <para style="q2" vid="PSA 143:1">jawabla aku dalem kestioan Kau,</para>
  <para style="q3" vid="PSA 143:1">dalem kebeneran Kau.<verse eid="PSA 143:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 143:2" />Janganla gawak hamba Kau ni ke pengadélan,</para>
  <para style="q2" vid="PSA 143:2">soalnyo katek yang bener di adepan Kau</para>
  <para style="q3" vid="PSA 143:2">di antaro slóró yang édóp.<verse eid="PSA 143:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 143:3" />Soalnyo mósó mburu aku,</para>
  <para style="q2" vid="PSA 143:3">trós ngeremókke édóp aku sampe ke tana.</para>
  <para style="q1" vid="PSA 143:3">Dio makso aku tinggal dalem kegelepan</para>
  <para style="q2" vid="PSA 143:3">pecak wong yang la lamo mati.<verse eid="PSA 143:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 143:4" />Laju semangat aku jadi lema lesu di dalem aku,</para>
  <para style="q2" vid="PSA 143:4">trós ati aku remók di dalem badan aku.<verse eid="PSA 143:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 143:5" />Aku inget pasal-pasal jaman bingen.</para>
  <para style="q2" vid="PSA 143:5">Aku ngerenungke slóró gawean Kau,</para>
  <para style="q2" vid="PSA 143:5">jugo mékérke slóró pebuatan tangan Kau.<verse eid="PSA 143:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 143:6" />Aku nadake tangan <char style="add">bedoa</char> ke Kau;</para>
  <para style="q2" vid="PSA 143:6">jiwo aku ngerinduke Kau pecak tana yang tandós. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 143:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 143:7" />Gancangla jawab aku, ya <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 143:7">Semangat aku la abés!</para>
  <para style="q1" vid="PSA 143:7">Janganla nyingiti rai Kau dari aku</para>
  <para style="q2" vid="PSA 143:7">supayo aku idak jadi pecak wong yang tórón ke liang kóbór.<verse eid="PSA 143:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 143:8" />Biarla aku denger kabar kasé stio Kau pas pagi ari,</para>
  <para style="q2" vid="PSA 143:8">karno samo Kaula aku pecayo.</para>
  <para style="q1" vid="PSA 143:8">Enjóktaukela aku jalan yang harós aku liwati</para>
  <para style="q2" vid="PSA 143:8">karno samo Kaula aku gantóngke édóp<note caller="+" style="f"><char style="fr" closed="false">143:8 </char><char style="fq" closed="false">gantóngke édóp: </char><char style="ft" closed="false">Teks asli iola “ngangkat jiwo”. Ini ni kiasan Ibrani óntók ngandalke.</char></note> aku.<verse eid="PSA 143:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 143:9" />Ya <char style="nd">ALLAHyhwh</char>, lepaskela aku dari mósó-mósó aku,</para>
  <para style="q2" vid="PSA 143:9">
    <char style="add">karno</char> samo Kaula aku beléndóng.<verse eid="PSA 143:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 143:10" />Ajarila aku ngelakuke pasal yang nyenengke Kau,</para>
  <para style="q2" vid="PSA 143:10">karno Kaula Tuhan aku.</para>
  <para style="q1" vid="PSA 143:10">Biarla Ro Kau yang baék tu mémpén aku</para>
  <para style="q2" vid="PSA 143:10">di tana yang rato.<verse eid="PSA 143:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 143:11" />Ya <char style="nd">ALLAHyhwh</char>, selametkela nyawo aku karno namo baék Kau!</para>
  <para style="q2" vid="PSA 143:11">Dalem kebeneran Kau, gawakla édóp aku metu dari kesaroan!<verse eid="PSA 143:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 143:12" />Karno kasé stio Kau, binasokela mósó-mósó aku,</para>
  <para style="q2" vid="PSA 143:12">trós musnakela slóró wong yang nyaroke édóp aku,</para>
  <para style="q2" vid="PSA 143:12">karno aku ni hamba Kau.<verse eid="PSA 143:12" /></para>
  <chapter eid="PSA 143" />
