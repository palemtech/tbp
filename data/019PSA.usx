  <chapter eid="PSA 35" />
  <chapter number="36" style="c" sid="PSA 36" />
  <para style="s2" vid="PSA 35:28">Kejahatan wong beduso jugo kasé stio Allah<verse eid="PSA 35:28" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 36:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>, hamba <char style="nd"><char style="w">ALLAHyhwh</char></char>.<verse eid="PSA 36:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 36:2" />Duso bebésék di jeró ati wong jahat<note caller="+" style="f"><char style="fr" closed="false">36:2 </char><char style="fq" closed="false">Duso bebésék di jeró ati wong jahat: </char><char style="ft" closed="false">Makno teks asli barés ni idak pulok jelas.</char></note>;</para>
  <para style="q2" vid="PSA 36:2">katek raso takót samo Allah di depan matonyo<note caller="-" style="x"><char style="xo" closed="false">36:2 </char><char style="xt" closed="false"><ref loc="ROM 3:18">Roma 3:18</ref></char></note>.<verse eid="PSA 36:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 36:3" />Soalnyo kehebatannyo dewek yang ditinggike di matonyo tu,</para>
  <para style="q2" vid="PSA 36:3">sampe-sampe dio dak pacak nyingok kesalahannyo</para>
  <para style="q2" vid="PSA 36:3">apolagi mbencinyo.<verse eid="PSA 36:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 36:4" />Omongan mólótnyo iola kejahatan jugo tipuan;</para>
  <para style="q2" vid="PSA 36:4">dio idak lagi bebuat bijak jugo baék.<verse eid="PSA 36:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 36:5" />Kejahatan direncanokenyo di tempat tédók.</para>
  <para style="q2" vid="PSA 36:5">Dio nempatke dirinyo di jalan yang idak baék,</para>
  <para style="q2" vid="PSA 36:5">trós kekejeman idak ditolaknyo.<verse eid="PSA 36:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 36:6" />Ya <char style="nd">ALLAHyhwh</char>, kasé Kau sampe ke langét;</para>
  <para style="q2" vid="PSA 36:6">kestioan Kau sampe ke awan-awan.<verse eid="PSA 36:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 36:7" />Kebeneran Kau pecak gónóng-gónóng tetinggi;</para>
  <para style="q2" vid="PSA 36:7">keadélan Kau pecak laótan tedalem.</para>
  <para style="q1" vid="PSA 36:7">Manusio samo binatang Kau piaro, Ya <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 36:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 36:8" />Alangke beregonyo kasé stio Kau, ya Tuhan!</para>
  <para style="q2" vid="PSA 36:8">Anak-anak manusio beléndóng di bawa dekepan sayap Kau.<verse eid="PSA 36:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 36:9" />Dio wong kenyang dengen pajóan mewa dari Ruma Kau,</para>
  <para style="q2" vid="PSA 36:9">trós Kau ngenjók dio wong minum dari sungi kebaék'an Kau.<verse eid="PSA 36:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 36:10" />Soalnyo mato banyu keédópan ado samo Kau,</para>
  <para style="q2" vid="PSA 36:10">trós dalem cahayo Kau kami nyingok terang.<verse eid="PSA 36:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 36:11" />Alérkela kasé stio Kau ke wong yang ngenal Kau,</para>
  <para style="q2" vid="PSA 36:11">jugo kebeneran Kau ke wong yang lórós ati.<verse eid="PSA 36:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 36:12" />Jangan biarke sekel wong sombong nginjek aku,</para>
  <para style="q2" vid="PSA 36:12">apo tangan wong jahat ngósér aku.<verse eid="PSA 36:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 36:13" />Jingokla! Wong-wong yang bebuat jahat tu nyampak;</para>
  <para style="q2" vid="PSA 36:13">dio wong dibanténg trós idak pacak bangón lagi.<verse eid="PSA 36:13" /></para>
  <chapter eid="PSA 36" />
