<?xml version="1.0" encoding="utf-8"?>
<usx version="3.0">
<book code="PSA" style="id">- Palembang: Tejemahan Basó Plembang</book>
<para style="toc3">S.Ny.</para>
<para style="toc2">Saér Nyanyian</para>
<para style="toc1">Saér Nyanyian</para>
<para style="mt1">SAÉR NYANYIAN</para>
<para style="mt2">[VERSI AWAL]</para>
<chapter number="1" sid="PSA 1" style="c"/>
<para style="s2">Jalan kebeneran itula yang mbékén seneng</para>
<para style="q1">
<verse number="1" sid="PSA 1:1" style="v"/>Senengla wong yang</para>
<para style="q2" vid="PSA 1:1">idak bejalan dalem anjóran wong jahat,</para>
<para style="q2" vid="PSA 1:1">idak tegak dalem jalan wong beduso,</para>
<para style="q2" vid="PSA 1:1">trós idak dódók dalem kómpólan wong yang galak ngino kebeneran;<verse eid="PSA 1:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 1:2" style="v"/>melaénke dalem ajaran <char style="nd"><char style="w">ALLAHyhwh</char></char> iola kesenengannyo,</para>
<para style="q2" vid="PSA 1:2">trós ajaran-Nyo dio renóngke siang malem.<verse eid="PSA 1:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 1:3" style="v"/>Dio pecak pohon yang ditanem di pénggér aléran banyu,</para>
<para style="q2" vid="PSA 1:3">yang bebua pas mósémnyo,</para>
<para style="q2" vid="PSA 1:3">trós daónnyo idak layu;</para>
<para style="q1" vid="PSA 1:3">slóró yang dio gaweke berasél.<note caller="-" style="x"><char closed="false" style="xo">1:2-3 </char><char closed="false" style="xt"><ref loc="JOS 1:8">Yosua 1:8</ref> </char></note><verse eid="PSA 1:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 1:4" style="v"/>Idak cak itu dengen wong jahat,</para>
<para style="q2" vid="PSA 1:4">melaénke dio pecak kólét padi yang dibuyarke angin.<verse eid="PSA 1:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 1:5" style="v"/>Karno itula wong jahat dak bakal tahan ngadepi pengadélan <char style="add">Allah</char>,</para>
<para style="q2" vid="PSA 1:5">jugo wong beduso dalem kelompok wong bener.<verse eid="PSA 1:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 1:6" style="v"/>Soalnyo <char style="nd">ALLAHyhwh</char> nyago jalan wong bener,</para>
<para style="q2" vid="PSA 1:6">tapi jalan wong jahat nuju kematian.<verse eid="PSA 1:6"/></para>
<chapter eid="PSA 1"/>
<chapter number="2" sid="PSA 2" style="c"/>
<para style="s2">Pengangkatan rajo yang dilanték Allah<note caller="+" style="f"><char closed="false" style="fr">2:0 </char><char closed="false" style="ft">Saér 2 tebagé empat baét, iola: </char><char closed="false" style="fp">1. (ayat </char><char link-href="PSA 2:1-3" style="xt"><ref loc="PSA 2:1">1-3</ref></char>) Bangso-bangso dunio ngerencanoke pemberontakan samo Allah jugo rajo-Nyo. <char closed="false" style="fp">2. (ayat </char><char link-href="PSA 2:4-6" style="xt"><ref loc="PSA 2:4">4-6</ref></char>) Allah ngino rencano bangso-bangso tu dengen ngómómke amen Dio la ngangkat rajo-Nyo. <char closed="false" style="fp">3. (ayat </char><char link-href="PSA 2:7-9" style="xt"><ref loc="PSA 2:7">7-9</ref></char>) Rajo yang dipélé Allah bacoke isi kepótósan Allah yang ngangkat dio jadi rajo jugo janji slóró bangso dunio bakal dienjókke ke dio. <char closed="false" style="fp">4. (ayat </char><char link-href="PSA 2:10-12" style="xt"><ref loc="PSA 2:10">10-12</ref></char>) Bangso-bangso dunio diperingetke óntók nyera samo Allah supayo idak diancórke.</note></para>
<para style="q1">
<verse number="1" sid="PSA 2:1" style="v"/>Ngapo bangso-bangso ni sekongkol,</para>
<para style="q2" vid="PSA 2:1">trós ngapo suku-suku bangso ngerencanoke pasal yang sio-sio?<verse eid="PSA 2:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 2:2" style="v"/>Rajo-rajo dunio besiap-siap,</para>
<para style="q2" vid="PSA 2:2">trós pejabat-pejabat beróndéng</para>
<para style="q2" vid="PSA 2:2">ngelawan <char style="nd"><char style="w">ALLAHyhwh</char></char> samo rajo yang dilanték-Nyo, <char style="add">ujinyo, </char><verse eid="PSA 2:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 2:3" style="v"/>“Payó kito pótóske rante-rante dio wong</para>
<para style="q2" vid="PSA 2:3">trós buangke tali-tali dio wong dari kito!”<verse eid="PSA 2:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 2:4" style="v"/>Dio yang bekuaso di surgo ketawo.</para>
<para style="q2" vid="PSA 2:4">Iyo! Tuan ngino dio wong.<verse eid="PSA 2:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 2:5" style="v"/>Laju Dio ngomong dengen manas,</para>
<para style="q2" vid="PSA 2:5">trós dengen kemarahan-Nyo Dio nakótke dio wong, <char style="add">uji-Nyo,</char><verse eid="PSA 2:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 2:6" style="v"/>“Aku ni la ngangkat rajo Aku</para>
<para style="q2" vid="PSA 2:6">di <char style="w">Sion</char>, bókét Aku yang suci!”<verse eid="PSA 2:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 2:7" style="v"/>Aku nak ngómómke pasal kepótósan <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 2:7">Dio ngomong samo aku, “Kaula anak Aku.</para>
<para style="q2" vid="PSA 2:7">Ari nila Aku jadi Aba kau.<verse eid="PSA 2:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 2:8" style="v"/>Mintakla samo Aku,</para>
<para style="q2" vid="PSA 2:8">trós Aku bakal ngenjókke bangso-bangso jadi warésan kau,</para>
<para style="q2" vid="PSA 2:8">trós sampe ójóng bumi jadi punyo kau.<verse eid="PSA 2:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 2:9" style="v"/>Kau bakal ngancórke dio wong makek tongkat besi,</para>
<para style="q2" vid="PSA 2:9">trós ngeremókke dio wong pecak guci tukang keramék.”<verse eid="PSA 2:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 2:10" style="v"/>Karno itu, ói rajo-rajo, bebuatla yang bijak!</para>
<para style="q2" vid="PSA 2:10">Terimola peringetan ni, ói penguaso-penguaso dunio!<verse eid="PSA 2:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 2:11" style="v"/>Layanila <char style="nd">ALLAHyhwh</char> dengen takót,</para>
<para style="q2" vid="PSA 2:11">trós pujila dengen gemeter.<verse eid="PSA 2:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 2:12" style="v"/>Sójódla dengen tólós<note caller="+" style="f"><char closed="false" style="fr">2:12 </char><char closed="false" style="fq">Sójódla dengen tólós: </char><char closed="false" style="ft">Ado kato di teks asli di sini yang kurang jelas maknonyo. Karno tu, barés ini pacak jugo ditejemake cak ini: “Sójódla di adepan anak tu”.</char></note></para>
<para style="q2" vid="PSA 2:12">supayo Dio idak mara, trós kau idak mati ngejót<note caller="+" style="f"><char closed="false" style="fr">2:12 </char><char closed="false" style="fq">mati ngejót: </char><char closed="false" style="ft">Teks asli iola, “mati di jalan”. Maksódnyo, mati tibo-tibo pas ngelakuke gawean seari-ari.</char></note>,</para>
<para style="q2" vid="PSA 2:12">olenyo gancang nian Dio naék dara.</para>
<para style="b" vid="PSA 2:12"/>
<para style="q1" vid="PSA 2:12">Senengla slóró wong yang beléndóng samo Dio!<verse eid="PSA 2:12"/></para>
<chapter eid="PSA 2"/>
<chapter number="3" sid="PSA 3" style="c"/>
<para style="s2">Nyanyian pagi ngadepi mósó</para>
<para style="d">
<verse number="1" sid="PSA 3:1" style="v"/>Nyanyian <char style="w">Daód</char>, pas dio lari dari Absalom, anaknyo.<note caller="-" style="x"><char closed="false" style="xo">3:1 </char><char closed="false" style="xt"><ref loc="2SA 15-16">2 Samuel 15–16</ref></char></note><verse eid="PSA 3:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 3:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, alangke banyaknyo mósó aku ni!</para>
<para style="q2" vid="PSA 3:2">Banyak yang bangkét ngelawan aku!<verse eid="PSA 3:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 3:3" style="v"/>Banyak yang ngomongi aku,</para>
<para style="q2" vid="PSA 3:3">“Katek keselametan óntók dio dari Allah!” <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 3:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 3:4" style="v"/>Tapi Kau, ya <char style="nd">ALLAHyhwh</char>, iola tameng yang ngeléléngi aku.</para>
<para style="q2" vid="PSA 3:4">Kaula kemulyoan aku jugo yang ngangkat palak aku.<verse eid="PSA 3:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 3:5" style="v"/>Aku bejerét samo <char style="nd">ALLAHyhwh</char> dengen nyaréng,</para>
<para style="q2" vid="PSA 3:5">trós Dio nyawab aku dari <char lemma="Sion" style="w">bókét suci-Nyo</char>. <char style="qs">Selah</char><verse eid="PSA 3:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 3:6" style="v"/>Aku góléngan, tédók, trós bangón,</para>
<para style="q2" vid="PSA 3:6">karno <char style="nd">ALLAHyhwh</char> nopang aku!<verse eid="PSA 3:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 3:7" style="v"/>Aku idak takót samo pólóan ribu wong</para>
<para style="q2" vid="PSA 3:7">yang ngepóng aku.<verse eid="PSA 3:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 3:8" style="v"/>Bangkétla, ya <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 3:8">Selametkela aku, ya Tuhan aku!</para>
<para style="q1" vid="PSA 3:8">Iyo, Kau bakal goco rahang slóró mósó aku</para>
<para style="q2" vid="PSA 3:8">trós matake gigi wong-wong jahat.<verse eid="PSA 3:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 3:9" style="v"/>Keselametan dateng dari <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 3:9">Berkah Kau óntók umat Kau! <char style="qs">Selah</char><verse eid="PSA 3:9"/></para>
<chapter eid="PSA 3"/>
<chapter number="4" sid="PSA 4" style="c"/>
<para style="s2">Nyanyian pecayo samo Allah dalem iman</para>
<para style="d">
<verse number="1" sid="PSA 4:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi</char> kecapi. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 4:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 4:2" style="v"/>Ya Allah, pembelaku,</para>
<para style="q2" vid="PSA 4:2">jawabla aku pas aku bejerét.</para>
<para style="q1" vid="PSA 4:2">Pas aku dalem kesesekan, Kau mbékén aku lego.</para>
<para style="q1" vid="PSA 4:2">Mura atila samo aku trós dengerkela doa aku!<verse eid="PSA 4:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 4:3" style="v"/>Ói wong-wong besak<note caller="+" style="f"><char closed="false" style="fr">4:3 </char><char closed="false" style="fq">wong-wong besak: </char><char closed="false" style="ft">Teks asli iola “anak-anak dari lanang”. Dalem baso asli, kato-kato ni jadi sebótan óntók wong-wong besak.</char></note>, sampe kapan kamu ngino kehormatan aku?</para>
<para style="q2" vid="PSA 4:3">Sampe kapan kamu nyenengi pasal yang sio-sio</para>
<para style="q2" vid="PSA 4:3">trós nyari kebohongan? <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 4:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 4:4" style="v"/>Ketauila amen <char style="nd"><char style="w">ALLAHyhwh</char></char> la ngósóske wong além óntók Dio dewek!</para>
<para style="q2" vid="PSA 4:4">
<char style="nd">ALLAHyhwh</char> bakal ndenger pas aku bejerét samo Dio.<verse eid="PSA 4:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 4:5" style="v"/>Gemeterla kamu, trós janganla bebuat duso!</para>
<para style="q2" vid="PSA 4:5">Ngerenungla di jeró ati kau di tempat tédók kau,</para>
<para style="q2" vid="PSA 4:5">trós tetepla diem. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 4:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 4:6" style="v"/>Sembakela kórban sembeléhan yang bener,</para>
<para style="q2" vid="PSA 4:6">trós pecayola samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 4:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 4:7" style="v"/>Banyak wong ngomong, “Siapo bakal nónjókke kebaék'an samo kito?”</para>
<para style="q2" vid="PSA 4:7">Ya <char style="nd">ALLAHyhwh</char>, biarla cahayo rai Kau nyinari kami!<verse eid="PSA 4:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 4:8" style="v"/>Kau la ngenjókke kesenengan di jeró ati aku,</para>
<para style="q2" vid="PSA 4:8">lebé daripado kesenengan wong pas gendóm jugo anggór melimpa.<verse eid="PSA 4:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 4:9" style="v"/>Dengen tenang aku bakal bególéng trós tédók,</para>
<para style="q2" vid="PSA 4:9">soalnyo cuman Kaula, ya <char style="nd">ALLAHyhwh</char>, yang mbékén aku netep dengen aman.<verse eid="PSA 4:9"/></para>
<chapter eid="PSA 4"/>
<chapter number="5" sid="PSA 5" style="c"/>
<para style="s2">Doa mintak peléndóngan pas pagi ari</para>
<para style="d">
<verse number="1" sid="PSA 5:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi</char> soléng. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 5:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 5:2" style="v"/>Dengerkela omongan aku, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>;</para>
<para style="q2" vid="PSA 5:2">peratikela réntéan aku!<verse eid="PSA 5:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 5:3" style="v"/>Dengerkela suaro aku mintak tolong,</para>
<para style="q2" vid="PSA 5:3">ya Rajo aku jugo Tuhan aku,</para>
<para style="q2" vid="PSA 5:3">karno samo Kaula aku bedoa.<verse eid="PSA 5:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 5:4" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, pas pagi ari Kau denger suaro aku.</para>
<para style="q2" vid="PSA 5:4">Pas pagi ari aku ngatór óntók Kau</para>
<para style="q3" vid="PSA 5:4">trós nunggu.<verse eid="PSA 5:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 5:5" style="v"/>Soalnyo Kau tu bukan Tuhan yang seneng dengen kejahatan.</para>
<para style="q2" vid="PSA 5:5">Wong jahat dak pacak tinggal dengen Kau.<verse eid="PSA 5:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 5:6" style="v"/>Wong sombong dak bakal tahan pas diselédék'i Kau<note caller="+" style="f"><char closed="false" style="fr">5:6 </char><char closed="false" style="fq">pas diselédék'i Kau: </char><char closed="false" style="ft">Teks asli iola “di adepan mato Kau”, yang artinyo Allah nyelédék'i wong sombong tadi.</char></note>.</para>
<para style="q2" vid="PSA 5:6">Kau mbenci galo-galo wong yang bebuat jahat.<verse eid="PSA 5:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 5:7" style="v"/>Kau ngancórke wong-wong yang bebohong.</para>
<para style="q2" vid="PSA 5:7">
<char style="nd">ALLAHyhwh</char> nganggep kejem penumpa dara jugo penipu.<verse eid="PSA 5:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 5:8" style="v"/>Tapi aku, karno sangkéng banyaknyo kasé stio Kau,</para>
<para style="q2" vid="PSA 5:8">aku bakal masók ke jeró ruma Kau,</para>
<para style="q2" vid="PSA 5:8">trós sójód ke ara <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng Kau</char> yang suci, dengen takót samo Kau.<verse eid="PSA 5:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 5:9" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, pémpénla aku dalem kebeneran Kau ole karno mósó-mósó aku;</para>
<para style="q2" vid="PSA 5:9">arakela aku di jalan Kau<note caller="+" style="f"><char closed="false" style="fr">5:9 </char><char closed="false" style="fq">arakela aku di jalan Kau: </char><char closed="false" style="ft">Teks asli iola “lóróskela jalan Kau di adepan aku”, yang artinyo dio mintak Allah óntók ngarake dio mangko jalan Allah jadi lórós di adepannyo.</char></note>.<verse eid="PSA 5:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 5:10" style="v"/>Soalnyo, katek yang bener di mólót dio wong;</para>
<para style="q2" vid="PSA 5:10">ati dio wong penu kebósókan.</para>
<para style="q1" vid="PSA 5:10">Tenggorokan dio wong pecak kóbóran yang temangap;</para>
<para style="q2" vid="PSA 5:10">lida dio wong licik.<verse eid="PSA 5:10"/></para>
<para style="b"/>
<para style="q1">
<verse number="11" sid="PSA 5:11" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, hókómla dio wong;</para>
<para style="q2" vid="PSA 5:11">biarla dio wong nyampak karno rencano dio wong dewek!</para>
<para style="q1" vid="PSA 5:11">Ósérla dio wong, karno sangkéng banyaknyo pelanggaran dio wong,</para>
<para style="q2" vid="PSA 5:11">karno dio wong la durhako samo Kau.<verse eid="PSA 5:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 5:12" style="v"/>Tapi sekironyo galo-galo wong yang beléndóng samo Kau beseneng,</para>
<para style="q2" vid="PSA 5:12">trós biarkela dio wong besorak-sorak selamo-lamonyo!</para>
<para style="q1" vid="PSA 5:12">Tódóngila dio wong,</para>
<para style="q2" vid="PSA 5:12">supayo wong-wong yang ngaséhi namo Kau</para>
<para style="q2" vid="PSA 5:12">pacak beseneng-seneng karno Kau.<verse eid="PSA 5:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 5:13" style="v"/>Soalnyo Kau mberkahi wong bener, ya <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 5:13">Pecak tameng, Kau ngeléndóngi dio wong dengen kebaék'an Kau.<verse eid="PSA 5:13"/></para>
<chapter eid="PSA 5"/>
<chapter number="6" sid="PSA 6" style="c"/>
<para style="s2">Doa pas kesaroan</para>
<para style="d">
<verse number="1" sid="PSA 6:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi </char> kecapi. <char style="add">Dinyanyike </char>nórót syeminit<note caller="+" style="f"><char closed="false" style="fr">6:1 </char><char closed="false" style="fq">Nórót syeminit: </char><char closed="false" style="ft">Biasonyo kato Ibrani ni maksódnyo ‘yang kelapan’, tapi di sini digunoke pecak istila kósós óntók musik. Maknonyo di sini kurang jelas, tapi móngkén nónjókke nada. </char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 6:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 6:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, janganla Kau hókóm aku dalem kemarahan Kau,</para>
<para style="q2" vid="PSA 6:2">trós jangan hajar aku dalem kegereman Kau.<verse eid="PSA 6:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 6:3" style="v"/>Mura atila samo aku, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 6:3">karno aku lemes.</para>
<para style="q1" vid="PSA 6:3">Sembókela aku, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 6:3">karno tulang-tulang aku gemeter,<verse eid="PSA 6:3"/></para>
<para style="q2">
<verse number="4" sid="PSA 6:4" style="v"/>jugo jiwo aku ketakótan nian.</para>
<para style="q1" vid="PSA 6:4">Trós Kau, ya <char style="nd">ALLAHyhwh</char>, berapo lamo lagi?<verse eid="PSA 6:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 6:5" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, balékla trós selametkela jiwo aku!</para>
<para style="q2" vid="PSA 6:5">Bebaskela aku karno kasé stio Kau.<verse eid="PSA 6:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 6:6" style="v"/>Soalnyo dalem kematian idak ado lagi ingetan pasal Kau,</para>
<para style="q2" vid="PSA 6:6">trós dalem alam kóbór, siapo nian yang pacak ngucapke sókór samo Kau?<verse eid="PSA 6:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 6:7" style="v"/>Aku loyo dalem réntéan aku.</para>
<para style="q2" vid="PSA 6:7">Sepanjang malem aku mbanjéri tempat tédók aku,</para>
<para style="q2" vid="PSA 6:7">trós dengen banyu mato, aku mbasahi kasór aku.<verse eid="PSA 6:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 6:8" style="v"/>Mato aku sembeb karno sedé,</para>
<para style="q2" vid="PSA 6:8">trós jadi rabón karno banyaknyo mósó <char style="add">yang nyerang</char> aku.<verse eid="PSA 6:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 6:9" style="v"/>Njaóla dari aku, ói galo-galo yang bebuat jahat,</para>
<para style="q2" vid="PSA 6:9">karno <char style="nd">ALLAHyhwh</char> la ndenger suaro tangisan aku.<verse eid="PSA 6:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 6:10" style="v"/>
<char style="nd">ALLAHyhwh</char> la ndenger pintak'an aku.</para>
<para style="q2" vid="PSA 6:10">
<char style="nd">ALLAHyhwh</char> nerimo doa aku.<verse eid="PSA 6:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 6:11" style="v"/>Galo-galo mósó aku bakal dipermaluke trós bakal ketakótan nian;</para>
<para style="q2" vid="PSA 6:11">dio wong bakal balék trós dipermaluke dalem sekejep.<verse eid="PSA 6:11"/></para>
<chapter eid="PSA 6"/>
<chapter number="7" sid="PSA 7" style="c"/>
<para style="s2">Doa mintak keadélan dari Allah, Hakém yang bener</para>
<para style="d">
<verse number="1" sid="PSA 7:1" style="v"/>
<char style="it">Syigayon</char>
<note caller="+" style="f">
<char closed="false" style="fr">7:1 </char>
<char closed="false" style="fq">Syigayon: </char>
<char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén namo jenis nyanyian. </char>
</note> <char style="w">Daód</char>, yang dinyanyikenyo óntók <char style="nd"><char style="w">ALLAHyhwh</char></char> pasal Kus<note caller="+" style="f"><char closed="false" style="fr">7:1 </char><char closed="false" style="fq">Kus: </char><char closed="false" style="ft">Caknyo ini ni sala sikok mósó Daód.</char></note>, wong Benyamin.<verse eid="PSA 7:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 7:2" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ya Tuhanku, samo Kaula aku beléndóng.</para>
<para style="q1" vid="PSA 7:2">Selametkela aku dari slóró wong yang ngejer aku;</para>
<para style="q2" vid="PSA 7:2">bebaske aku,<verse eid="PSA 7:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 7:3" style="v"/>supayo dio wong dak nyakar aku pecak singo</para>
<para style="q2" vid="PSA 7:3">trós ngoyak-ngoyak aku, sementaro dak katek yang bebaske.<verse eid="PSA 7:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 7:4" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ya Tuhanku, amen aku lakuke ini,</para>
<para style="q2" vid="PSA 7:4">amen ado pebuatan yang dak adél dalem tangan aku,<verse eid="PSA 7:4"/></para>
<para style="q2">
<verse number="5" sid="PSA 7:5" style="v"/>amen aku bebuat jahat samo wong yang édóp damai dengen aku,</para>
<para style="q2" vid="PSA 7:5">apo aku ngerampasi mósó aku tanpa alesan<note caller="+" style="f"><char closed="false" style="fr">7:5 </char><char closed="false" style="fq">apo aku ngerampasi mósó aku tanpa alesan: </char><char closed="false" style="ft">Makno teks asli dari barés ni dak pulok jelas. </char></note>,<verse eid="PSA 7:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 7:6" style="v"/>biarla mósó aku ngejer trós nangkep aku,</para>
<para style="q2" vid="PSA 7:6">nginjek-nginjek édóp aku sampe ke tana,</para>
<para style="q2" vid="PSA 7:6">trós némbón kehormatan aku di dalem debu. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 7:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 7:7" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, bangkétla dalem kemarahan Kau!</para>
<para style="q2" vid="PSA 7:7">Tegakla adepi amókan mósó-mósó aku!</para>
<para style="q2" vid="PSA 7:7">Bangkétla óntók aku!</para>
<para style="q2" vid="PSA 7:7">Kau la mrénto keadélan.<verse eid="PSA 7:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 7:8" style="v"/>Biarla kómpólan bangso dateng ngadep Kau,</para>
<para style="q2" vid="PSA 7:8">trós bekuasola di pócók dio wong di tempat yang tinggi.<verse eid="PSA 7:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 7:9" style="v"/>
<char style="nd">ALLAHyhwh</char> ngadéli bangso-bangso.</para>
<para style="q1" vid="PSA 7:9">Ya <char style="nd">ALLAHyhwh</char>, hakémila aku</para>
<para style="q2" vid="PSA 7:9">sesuai dengen kebeneran aku jugo ketólósan ati aku.<verse eid="PSA 7:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 7:10" style="v"/>Kironyo kejahatan wong jahat beahér,</para>
<para style="q2" vid="PSA 7:10">trós tegakkela wong bener,</para>
<para style="q2" vid="PSA 7:10">
<char style="add">ya Kau</char> yang nguji ati jugo batén, Allah Yang Mahabener.<verse eid="PSA 7:10"/></para>
<para style="b"/>
<para style="q1">
<verse number="11" sid="PSA 7:11" style="v"/>Tameng aku iola Allah,</para>
<para style="q2" vid="PSA 7:11">yang nyelametke wong yang lórós ati.<verse eid="PSA 7:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 7:12" style="v"/>Allah iola hakém yang bener,</para>
<para style="q2" vid="PSA 7:12">trós Dio iola Tuhan yang tiap ari nónjókke kemarahan-Nyo.<verse eid="PSA 7:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 7:13" style="v"/>Amen wong dak betobat, Allah bakal ngasa pedang-Nyo,</para>
<para style="q2" vid="PSA 7:13">Dio la ngelentórke bósór-Nyo trós mbékénnyo siap.<verse eid="PSA 7:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 7:14" style="v"/>Dio la nyiapke diri-Nyo dengen senjato-senjato yang mematike,</para>
<para style="q2" vid="PSA 7:14">jugo mbékén anak-anak pana-Nyo beapi-api.<verse eid="PSA 7:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 7:15" style="v"/>Jingokla! Wong tu bónténg kejahatan,</para>
<para style="q2" vid="PSA 7:15">ngandóng kekejeman,</para>
<para style="q2" vid="PSA 7:15">trós ngelaérke kebohongan.<verse eid="PSA 7:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 7:16" style="v"/>Dio gali lobang trós dikedóknyo,</para>
<para style="q2" vid="PSA 7:16">trós dio nyampak dewek ke jeró lobang yang la dibékénnyo.<verse eid="PSA 7:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 7:17" style="v"/>Kekejemannyo bakal bebalék nimpo palaknyo dewek,</para>
<para style="q2" vid="PSA 7:17">trós kekerasannyo bakal tórón ke pócók óbón-óbónnyo.<verse eid="PSA 7:17"/></para>
<para style="b"/>
<para style="q1">
<verse number="18" sid="PSA 7:18" style="v"/>Aku bakal ngucap sókór samo <char style="nd">ALLAHyhwh</char> karno kebeneran-Nyo,</para>
<para style="q2" vid="PSA 7:18">trós aku bakal nyanyike puji-pujian óntók namo <char style="nd">ALLAHyhwh</char> Yang Mahabesak.<verse eid="PSA 7:18"/></para>
<chapter eid="PSA 7"/>
<chapter number="8" sid="PSA 8" style="c"/>
<para style="s2">Allah yang mulyo nyadike manusio nguasoi ciptoan-Nyo</para>
<para style="d">
<verse number="1" sid="PSA 8:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Dinyanyike nórót gitit<note caller="+" style="f"><char closed="false" style="fr">8:1 </char><char closed="false" style="fq">gitit: </char><char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén namo alat, nada, apo dak tu jenis musik.</char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 8:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 8:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, ya Tuan kami,</para>
<para style="q2" vid="PSA 8:2">alangke mulyo namo Kau di slóró bumi!</para>
<para style="q2" vid="PSA 8:2">Kau tarokke<note caller="+" style="f"><char closed="false" style="fr">8:2 </char><char closed="false" style="fq">Kau tarokke: </char><char closed="false" style="ft">Teks asli dari kato ni dak pulok jelas.</char></note> keagóngan Kau di pócók langét.<verse eid="PSA 8:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 8:3" style="v"/>Dari mólót budak jugo kupek yang netek, Kau bangón kekuatan<note caller="+" style="f"><char closed="false" style="fr">8:3 </char><char closed="false" style="fq">Dari mólót budak … Kau bangón kekuatan: </char><char closed="false" style="ft">Makno barés ni dak pulok jelas. Móngkén maksódnyo Allah makek wong yang lema óntók mbékén malu wong jahat, karno budak kecik lebé pecayo jugo muji Allah.</char></note></para>
<para style="q2" vid="PSA 8:3">karno mósó-mósó Kau, óntók mbungkem lawan jugo pendendem.<verse eid="PSA 8:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 8:4" style="v"/>Amen aku meratike langét Kau, békénan jari Kau,</para>
<para style="q2" vid="PSA 8:4">bulan samo bintang yang la Kau tétépke,<verse eid="PSA 8:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 8:5" style="v"/>apola manusio sampe-sampe Kau ngingetnyo,</para>
<para style="q2" vid="PSA 8:5">jugo ketórónan Adam sampe-sampe Kau meratikenyo?<verse eid="PSA 8:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 8:6" style="v"/>Kau mbékén dio wong sedikit lebé renda dari Allah<note caller="+" style="f"><char closed="false" style="fr">8:6 </char><char closed="false" style="fq">Allah: </char><char closed="false" style="ft">Teks asli pacak jugo diartike “malekat”. </char></note>,</para>
<para style="q2" vid="PSA 8:6">trós ngenjók kemulyoan jugo kehormatan jadi mahkotanyo.<verse eid="PSA 8:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 8:7" style="v"/>Kau mbékén dio wong nguasoi ciptoan tangan Kau.</para>
<para style="q2" vid="PSA 8:7">Slórónyo Kau tarok di bawa sekelnyo:<verse eid="PSA 8:7"/></para>
<para style="q3">
<verse number="8" sid="PSA 8:8" style="v"/>slóró kambéng domba samo sapi,</para>
<para style="q3" vid="PSA 8:8">jugo binatang-binatang liar di darat,<verse eid="PSA 8:8"/></para>
<para style="q3">
<verse number="9" sid="PSA 8:9" style="v"/>bóróng-bóróng di langét samo iwak-iwak di laót,</para>
<para style="q3" vid="PSA 8:9">jugo mahlók-mahlók yang melok'i arós laótan.<verse eid="PSA 8:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 8:10" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ya Tuan kami,</para>
<para style="q2" vid="PSA 8:10">alangke mulyo namo Kau di slóró bumi!<verse eid="PSA 8:10"/></para>
<chapter eid="PSA 8"/>
<chapter number="9" sid="PSA 9" style="c"/>
<para style="s2">Ucapan sókór samo Allah, Hakém yang bener<note caller="+" style="f"><char closed="false" style="fr">9:1 </char><char closed="false" style="ft">Ado kemóngkénan besak amen awal mulo S. Ny. 9-10 ni jadi sikok pas jaman bingen.</char></note></para>
<para style="d">
<verse number="1" sid="PSA 9:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót mut-laben<note caller="+" style="f"><char closed="false" style="fr">9:1 </char><char closed="false" style="fq">mut-laben: </char><char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén namo nyanyian apo dak tu petónjók musik.</char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 9:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 9:2" style="v"/>Aku nak ngucap sókór samo <char style="nd"><char style="w">ALLAHyhwh</char></char> dengen segenep ati.</para>
<para style="q1" vid="PSA 9:2">Aku nak nyeritoke pebuatan Kau yang ajaéb.<verse eid="PSA 9:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 9:3" style="v"/>Aku nak besorak-sorak trós beseneng-seneng karno Kau.</para>
<para style="q1" vid="PSA 9:3">Aku nak nyanyike puji-pujian óntók namo Kau, ya Yang Mahabesak.<verse eid="PSA 9:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 9:4" style="v"/>Pas mósó-mósó aku móndór,</para>
<para style="q2" vid="PSA 9:4">dio wong kesandóng trós binaso di adepan Kau.<verse eid="PSA 9:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 9:5" style="v"/>Soalnyo Kau mbela keadélan óntók pekaro aku.</para>
<para style="q1" vid="PSA 9:5">Kau dódók di korsi kekuasoan trós ngakémi dengen bener.<verse eid="PSA 9:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 9:6" style="v"/>Kau nyegak bangso-bangso trós mbinasoke wong jahat.</para>
<para style="q2" vid="PSA 9:6">Namo dio wong Kau apóske óntók seterósnyo jugo selamo-lamonyo.<verse eid="PSA 9:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 9:7" style="v"/>Mósó-mósó la abés, jadi póéng-póéng selamonyo.</para>
<para style="q2" vid="PSA 9:7">Kota-kota dio wong la Kau tumbangke.</para>
<para style="q3" vid="PSA 9:7">Katek yang inget lagi pasal dio wong.<verse eid="PSA 9:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 9:8" style="v"/>Tapi <char style="nd">ALLAHyhwh</char> tinggal óntók selamo-lamonyo,</para>
<para style="q2" vid="PSA 9:8">Dio la negakke korsi kekuasoan-Nyo óntók ngakémi.<verse eid="PSA 9:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 9:9" style="v"/>Diola yang ngakémi dunio ni dengen keadélan,</para>
<para style="q2" vid="PSA 9:9">ngakémi bangso-bangso dengen kebeneran.<verse eid="PSA 9:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 9:10" style="v"/>
<char style="nd">ALLAHyhwh</char> iola tempat peléndóngan óntók wong yang tetindes,</para>
<para style="q2" vid="PSA 9:10">tempat beléndóng pas dalem kesaroan.<verse eid="PSA 9:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 9:11" style="v"/>Wong-wong yang tau namo baék Kau pecayo samo Kau,</para>
<para style="q2" vid="PSA 9:11">karno Kau dak perna ninggalke wong yang nyari Kau, ya <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 9:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 9:12" style="v"/>Nyanyikela puji-pujian óntók <char style="nd">ALLAHyhwh</char>, yang dódók di bókét <char style="w">Sion</char>!</para>
<para style="q2" vid="PSA 9:12">Britokela samo bangso-bangso pasal pebuatan-pebuatan-Nyo!<verse eid="PSA 9:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 9:13" style="v"/>Soalnyo Dio yang mbaleske penumpahan dara pasti nginget wong yang saro;</para>
<para style="q2" vid="PSA 9:13">Dio idak lupo jerétan dio wong.<verse eid="PSA 9:13"/></para>
<para style="b"/>
<para style="q1">
<verse number="14" sid="PSA 9:14" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, mura atila samo aku.</para>
<para style="q1" vid="PSA 9:14">Jingokila kesaroan aku dari wong-wong yang mbenci aku,</para>
<para style="q2" vid="PSA 9:14">ya <char style="add">Tuhan</char> yang ngangkat aku dari gerbang maót,<verse eid="PSA 9:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 9:15" style="v"/>supayo aku pacak nyeritoke slóró kemulyoan Kau</para>
<para style="q2" vid="PSA 9:15">di jeró gerbang Sion, yang iola anak gadés Kau.</para>
<para style="q1" vid="PSA 9:15">Aku bakal besorak-sorak karno keselametan dari Kau.<verse eid="PSA 9:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 9:16" style="v"/>Bangso-bangso tejeblos ke jeró lobang yang la dio wong mbékén.</para>
<para style="q2" vid="PSA 9:16">Sekel dio wong tejiret jeró jaréng yang dio wong pasang dewek.<verse eid="PSA 9:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 9:17" style="v"/>
<char style="nd">ALLAHyhwh</char> la nyatoke diri-Nyo dengen nyalanke pengakéman.</para>
<para style="q2" vid="PSA 9:17">Wong jahat tejiret dalem pebuatan tangannyo dewek. <char style="qs">Higayon. Selah.</char><note caller="+" style="f"><char closed="false" style="fr">9:17 </char><char closed="false" style="fq">Higayon. Selah: </char><char closed="false" style="ft">Keduo kato ni dari baso asli. Idak diartike karno idak jelas maknonyo, tapi móngkén digunoke jadi petónjók musik.</char></note><verse eid="PSA 9:17"/></para>
<para style="b"/>
<para style="q1">
<verse number="18" sid="PSA 9:18" style="v"/>Wong-wong jahat bakal balék ke alam kóbór,</para>
<para style="q2" vid="PSA 9:18">iyo, segalo bangso yang ngelupoke Allah.<verse eid="PSA 9:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 9:19" style="v"/>Tapi, wong méskén dak bakal dilupoke óntók seterósnyo,</para>
<para style="q2" vid="PSA 9:19">trós arepan wong yang saro dak bakal ilang selamonyo.<verse eid="PSA 9:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 9:20" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, bangkétla!</para>
<para style="q2" vid="PSA 9:20">Jangan biarke manusio menang!</para>
<para style="q1" vid="PSA 9:20">Békénla bangso-bangso diakémi di adepan Kau.<verse eid="PSA 9:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 9:21" style="v"/>Békénla dio wong takót, ya <char style="nd">ALLAHyhwh</char>!</para>
<para style="q1" vid="PSA 9:21">Békénla bangso-bangso tau</para>
<para style="q2" vid="PSA 9:21">amen dio wong cuman manusio. <char style="qs">Selah.</char><verse eid="PSA 9:21"/></para>
<chapter eid="PSA 9"/>
<chapter number="10" sid="PSA 10" style="c"/>
<para style="s2">Doa óntók wong yang saro<note caller="+" style="f"><char closed="false" style="fr">10:1 </char><char closed="false" style="ft">Saér ni kemóngkénan besak iola lanjótan dari saér 9.</char></note></para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 10:1" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, ngapo Kau tegak jaó-jaó?</para>
<para style="q2" vid="PSA 10:1">Ngapo Kau nyingitke diri Kau pas <char style="add">kami</char> saro?<verse eid="PSA 10:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 10:2" style="v"/>Dengen sombong wong jahat ngejer wong yang saro.</para>
<para style="q2" vid="PSA 10:2">Biarkela wong <char style="add">jahat</char> ketangkep dalem rencano yang la dio wong mbékén dewek<note caller="+" style="f"><char closed="false" style="fr">10:2 </char><char closed="false" style="fq">Biarkela wong jahat … dio wong mbékén dewek: </char><char closed="false" style="ft">Teks asli barés ni pacak jugo diartike “wong <char style="add">saro</char> ketangkep dalem rencano yang la dibékén wong <char style="add">jahat</char>”.</char></note>.<verse eid="PSA 10:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 10:3" style="v"/>Iyo, wong jahat nyombongke napsu atinyo.</para>
<para style="q2" vid="PSA 10:3">Wong rakós ngótók'i trós ngino <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 10:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 10:4" style="v"/>Uji wong jahat dengen rai tecungak, “Dio dak bakal nóntót!”</para>
<para style="q2" vid="PSA 10:4">Pékérannyo cuman, “Dak katek Tuhan!”<note caller="+" style="sf"><char closed="false" style="fr">10:4 </char><char closed="false" style="fq">Uji wong jahat … “Dak katek Tuhan!”: </char><char closed="false" style="ft">Makno teks asli dari ayat ni dak pulok jelas.</char></note><verse eid="PSA 10:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 10:5" style="v"/>Jalan-jalannyo berasél terós.</para>
<para style="q1" vid="PSA 10:5">Hókóm-hókóm Kau ado di tempat tinggi, jaó dari <char style="add">pemékéran</char> dio.</para>
<para style="q2" vid="PSA 10:5">Dio nganggep enteng galo-galo mósónyo.<verse eid="PSA 10:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 10:6" style="v"/>Di jeró atinyo dio ngomong, “Aku dak bakal tegoyake!</para>
<para style="q2" vid="PSA 10:6">Aku dak bakal perna keno kesaroan!”<verse eid="PSA 10:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 10:7" style="v"/>Mólótnyo penu dengen kótók, kecalakan, jugo penindesan.</para>
<para style="q2" vid="PSA 10:7">Di bawa lidanyo ado kesaroan jugo kejahatan.<verse eid="PSA 10:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 10:8" style="v"/>Dio dódók nyegat di dósón-dósón.</para>
<para style="q2" vid="PSA 10:8">Di tempat yang tesingit dio mbunu wong yang dak besala.</para>
<para style="q2" vid="PSA 10:8">Matonyo ngintei wong yang sial.<verse eid="PSA 10:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 10:9" style="v"/>Dio nyegat di tempat yang tesingit pecak singo di semak-semak.</para>
<para style="q2" vid="PSA 10:9">Dio nyegat óntók nangkep wong yang saro.</para>
<para style="q2" vid="PSA 10:9">Dio nangkep wong yang saro tu dengen naréknyo ke jeró jaréngnyo.<verse eid="PSA 10:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 10:10" style="v"/>Dio mbóngkók trós ngendep-ngendep,</para>
<para style="q2" vid="PSA 10:10">laju, dengen kekuatannyo, dio nyampakke wong yang sial tu<note caller="+" style="sf"><char closed="false" style="fr">10:10 </char><char closed="false" style="fq">Dio mbóngkók … wong yang sial tu: </char><char closed="false" style="ft">Makno teks asli dari ayat ni dak pulok jelas.</char></note>.<verse eid="PSA 10:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 10:11" style="v"/>Uji <char style="add">wong jahat</char> di jeró atinyo,</para>
<para style="q2" vid="PSA 10:11">“<char style="add">Nah</char>! Allah la lupo!</para>
<para style="q2" vid="PSA 10:11">Dio la nyingitke rai-Nyo,</para>
<para style="q2" vid="PSA 10:11">trós Dio dak bakal nyingoknyo!”<verse eid="PSA 10:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 10:12" style="v"/>
<char style="add">Jadi</char>, bangkétla, ya <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 10:12">Tórónla tangan Kau, Ya Tuhan!</para>
<para style="q2" vid="PSA 10:12">Janganla ngelupoke wong yang saro.<verse eid="PSA 10:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 10:13" style="v"/>Kok wong jahat ngino Allah?</para>
<para style="q2" vid="PSA 10:13">Kok dio ngomong di jeró atinyo, “Allah<note caller="+" style="f"><char closed="false" style="fr">10:13 </char><char closed="false" style="fq">Allah: </char><char closed="false" style="ft">Teks asli iola “Kau”.</char></note> dak bakal nóntót!”?<verse eid="PSA 10:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 10:14" style="v"/>Kau memang nyingoknyo!</para>
<para style="q2" vid="PSA 10:14">Iyo, Kau meratike kesaroan jugo kesedéan.</para>
<para style="q2" vid="PSA 10:14">Kau ngambéknyo ke dalem tangan Kau dewek.</para>
<para style="q1" vid="PSA 10:14">Wong yang sial pasra samo Kau.</para>
<para style="q2" vid="PSA 10:14">Kaula penolong anak yatém.<verse eid="PSA 10:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 10:15" style="v"/>Patakela tangan wong yang beduso jugo wong jahat!</para>
<para style="q2" vid="PSA 10:15">Tóntótla dusonyo sampe Kau dak nemukenyo lagi!<verse eid="PSA 10:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 10:16" style="v"/>
<char style="nd">ALLAHyhwh</char> iola Rajo óntók seterósnyo jugo selamo-lamonyo;</para>
<para style="q2" vid="PSA 10:16">bangso-bangso <char style="add">yang jahat</char> bakal dimusnake dari tana-Nyo.<verse eid="PSA 10:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 10:17" style="v"/>Kepéngénan ati wong yang saro Kau dengerke, ya <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 10:17">Kau bakal nguatke ati dio wong.</para>
<para style="q1" vid="PSA 10:17">Kau bakal nyiapke kópéng Kau<verse eid="PSA 10:17"/></para>
<para style="q2">
<verse number="18" sid="PSA 10:18" style="v"/>óntók mbela anak yatém jugo wong yang tetindes,</para>
<para style="q2" vid="PSA 10:18">sampe dak katek lagi wong yang nakótke di bumi.<verse eid="PSA 10:18"/></para>
<chapter eid="PSA 10"/>
<chapter number="11" sid="PSA 11" style="c"/>
<para style="s2">Allah tempat peléndóngan wong bener</para>
<para style="d">
<verse number="1" sid="PSA 11:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Nyanyian ni</char> dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 11:1"/>
<para style="q1" vid="PSA 11:1">
<char style="add">Ói mósóku!</char> Samo <char style="nd"><char style="w">ALLAHyhwh</char></char> aku beléndóng.</para>
<para style="q1" vid="PSA 11:1">Cakmano nian kau pacak ngomong samo aku cak ini,</para>
<para style="q2" vid="PSA 11:1">“Terbangla <char style="add">gancang</char> ke gónóng kau, pecak bóróng!<verse eid="PSA 11:1"/></para>
<para style="q2">
<verse number="2" sid="PSA 11:2" style="v"/>Jingokla! Wong jahat ngelentórke bósórnyo</para>
<para style="q3" vid="PSA 11:2">trós masang pana di tali bósórnyo</para>
<para style="q3" vid="PSA 11:2">óntók meci dalem kegelepan wong yang lórós atinyo.<verse eid="PSA 11:2"/></para>
<para style="q2">
<verse number="3" sid="PSA 11:3" style="v"/>Amen dasar-dasar <char style="add">masyarakat</char> la diancórke,</para>
<para style="q3" vid="PSA 11:3">apo yang pacak wong bener lakuke?”<verse eid="PSA 11:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 11:4" style="v"/>
<char style="nd">ALLAHyhwh</char> ado di jeró Ruma Agóng-Nyo yang suci.</para>
<para style="q2" vid="PSA 11:4">
<char style="nd">ALLAHyhwh</char>! Korsi kekuasoan-Nyo ado di surgo!</para>
<para style="q1" vid="PSA 11:4">Mato-Nyo masati;</para>
<para style="q2" vid="PSA 11:4">sorotan mato-Nyo nyoboi anak-anak manusio.<verse eid="PSA 11:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 11:5" style="v"/>
<char style="nd">ALLAHyhwh</char> nyoboi wong bener samo wong jahat.</para>
<para style="q2" vid="PSA 11:5">Dio benci wong yang cinto samo kekejeman.<verse eid="PSA 11:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 11:6" style="v"/>Dio bakal ngujani wong jahat dengen baro areng.</para>
<para style="q2" vid="PSA 11:6">Api, belerang, jugo angin panas iola bagéan takdér<note caller="+" style="f"><char closed="false" style="fr">11:6 </char><char closed="false" style="fq">takdér: </char><char closed="false" style="ft">Teks asli iola “cangkér”. Ini ni peumpamoan Ibrani pasal apo yang la Allah tentuke óntók keédópan wong.</char></note> dio wong.<verse eid="PSA 11:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 11:7" style="v"/>
<char style="nd">ALLAHyhwh</char> tu bener;</para>
<para style="q2" vid="PSA 11:7">Dio cinto kebeneran.</para>
<para style="q2" vid="PSA 11:7">Wong yang lórós atinyo bakal jingok rai-Nyo.<verse eid="PSA 11:7"/></para>
<chapter eid="PSA 11"/>
<chapter number="12" sid="PSA 12" style="c"/>
<para style="s2">Doa mintak tolong ngadepi kejahatan dunio</para>
<para style="d">
<verse number="1" sid="PSA 12:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót syeminit<note caller="+" style="f"><char closed="false" style="fr">12:1 </char><char closed="false" style="fq">syeminit: </char><char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Móngkén nónjókke nada, alat musik, apo dak tu namo lagu.</char></note>. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 12:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 12:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, selametkela!</para>
<para style="q2" vid="PSA 12:2">Soalnyo wong além la abés;</para>
<para style="q2" vid="PSA 12:2">wong-wong stio la ilang dari antaro anak-anak manusio.<verse eid="PSA 12:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 12:3" style="v"/>Dio wong saléng ngotak'i;</para>
<para style="q2" vid="PSA 12:3">dio wong ngomong dengen bébér manis jugo ati yang becabang.<verse eid="PSA 12:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 12:4" style="v"/>Kironyo <char style="nd">ALLAHyhwh</char> netak slóró bébér manis</para>
<para style="q2" vid="PSA 12:4">jugo lida yang besak omong,<verse eid="PSA 12:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 12:5" style="v"/>iola dio wong yang ngomong, “Dengen lida kami, kami menang!</para>
<para style="q2" vid="PSA 12:5">Bébér kami iola kepunyoan kami! Siapo nian yang jadi tuan kami?”<verse eid="PSA 12:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 12:6" style="v"/>
<char style="nd">ALLAHyhwh</char> ngomong,</para>
<para style="q1" vid="PSA 12:6">“Karno penindesan wong saro</para>
<para style="q2" vid="PSA 12:6">jugo karno réntéan wong méskén,</para>
<para style="q2" vid="PSA 12:6">sekarang Aku bakal bangkét!</para>
<para style="q1" vid="PSA 12:6">Aku bakal narok dio wong di tempat aman yang dio wong arepke.”<verse eid="PSA 12:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 12:7" style="v"/>Omongan <char style="nd">ALLAHyhwh</char> iola omongan yang murni,</para>
<para style="q2" vid="PSA 12:7">pecak perak yang dilebór di jeró tungku di tana, tójó kali dimurnike.<verse eid="PSA 12:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 12:8" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, Kau bakal nyago wong-wong tu.</para>
<para style="q2" vid="PSA 12:8">Kau bakal ngeléndóngi dio wong dari angkatan jaman ni óntók selamo-lamonyo.<verse eid="PSA 12:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 12:9" style="v"/>
<char style="add">Soalnyo</char> wong jahat ado di mano-mano</para>
<para style="q2" vid="PSA 12:9">karno kehinoan disanjóng-sanjóng di antaro anak-anak manusio.<verse eid="PSA 12:9"/></para>
<chapter eid="PSA 12"/>
<chapter number="13" sid="PSA 13" style="c"/>
<para style="s2">Doa wong yang pecayo samo kasé stio Allah dalem kesaroan</para>
<para style="d">
<verse number="1" sid="PSA 13:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 13:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 13:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, sampe kapan Kau terós-terósan ngelupoke aku?</para>
<para style="q1" vid="PSA 13:2">Sampe kapan Kau nyingiti rai Kau dari aku?<verse eid="PSA 13:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 13:3" style="v"/>Sampe kapan aku harós nyimpen kekuatéran di dalem diri aku,</para>
<para style="q2" vid="PSA 13:3">kesedéan di jeró ati aku siang malem?</para>
<para style="q1" vid="PSA 13:3">Sampe kapan mósó aku ditinggike di pócók aku?<verse eid="PSA 13:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 13:4" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ya Tuhan aku, peratikela trós simbatila aku.</para>
<para style="q1" vid="PSA 13:4">Pólékela <char style="add">tenago aku sampe</char> mato aku terang,</para>
<para style="q2" vid="PSA 13:4">supayo aku jangan sampe tetédók dalem kematian,<verse eid="PSA 13:4"/></para>
<para style="q2">
<verse number="5" sid="PSA 13:5" style="v"/>supayo mósó aku jangan sampe ngomong, “Aku la nguasoi dio!”</para>
<para style="q3" vid="PSA 13:5">trós lawan-lawan aku besorak-sorak pas aku tecampak.<verse eid="PSA 13:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 13:6" style="v"/>Tapi aku, samo kasé stio Kaula aku pecayo;</para>
<para style="q2" vid="PSA 13:6">ati aku besorak-sorak karno keselametan dari Kau.</para>
<para style="q1" vid="PSA 13:6">Aku bakal nyanyi óntók <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 13:6">karno Dio la bebuat baék samo aku.<verse eid="PSA 13:6"/></para>
<chapter eid="PSA 13"/>
<chapter number="14" sid="PSA 14" style="c"/>
<para style="s2">Kebórókan manusio</para>
<para style="d">
<verse number="1" sid="PSA 14:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Nyanyian ni</char> dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 14:1"/>
<para style="q1" vid="PSA 14:1">Wong tekak ngomong di dalem atinyo,</para>
<para style="q2" vid="PSA 14:1">“Katek Tuhan.”</para>
<para style="q1" vid="PSA 14:1">Dio wong busuk ati. Kelakuannyo kejem.</para>
<para style="q2" vid="PSA 14:1">Katek yang bebuat baék.<verse eid="PSA 14:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 14:2" style="v"/>
<char style="nd">
<char style="w">ALLAHyhwh</char>
</char> masati dari surgo,</para>
<para style="q2" vid="PSA 14:2">ke anak-anak manusio,</para>
<para style="q1" vid="PSA 14:2">óntók jingok kalu bae ado wong yang bijak,</para>
<para style="q2" vid="PSA 14:2">yang nyari Allah.<verse eid="PSA 14:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 14:3" style="v"/>Galo-galo wong la melenceng,</para>
<para style="q2" vid="PSA 14:3">samo-samo rusak.</para>
<para style="q1" vid="PSA 14:3">Katek yang bebuat baék,</para>
<para style="q2" vid="PSA 14:3">sikok wong bae idak.<note caller="-" style="x"><char closed="false" style="xo">14:3 </char><char closed="false" style="xt"><ref loc="ROM 3:10-12">Roma 3:10-12</ref></char></note><verse eid="PSA 14:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 14:4" style="v"/>Idak sadar apo slóró wong yang bebuat jahat tu?</para>
<para style="q2" vid="PSA 14:4">Dio wong tu makani umat aku pecak makan roti,</para>
<para style="q2" vid="PSA 14:4">jugo idak bejerét samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 14:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 14:5" style="v"/>Di sano dio wong bakal ketakótan nian.</para>
<para style="q2" vid="PSA 14:5">Soalnyo Allah nyertoi angkatan wong bener.<verse eid="PSA 14:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 14:6" style="v"/>Kamu nak ngalangi rencano wong yang saro,</para>
<para style="q2" vid="PSA 14:6">tapi <char style="nd">ALLAHyhwh</char> iola tempat peléndóngannyo.<verse eid="PSA 14:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 14:7" style="v"/>Kironyo keselametan wong-wong <char style="w">Israel</char> dateng dari <char style="w">Sion</char>!</para>
<para style="q1" vid="PSA 14:7">Pas <char style="nd">ALLAHyhwh</char> balékke keadaan umat-Nyo tu,</para>
<para style="q2" vid="PSA 14:7">
<char style="w">Yakób</char> bakal besorak-sorak jugo Israel bakal seneng.<verse eid="PSA 14:7"/></para>
<chapter eid="PSA 14"/>
<chapter number="15" sid="PSA 15" style="c"/>
<para style="s2">Siapo bae yang bole dateng ke Allah?</para>
<para style="d">
<verse number="1" sid="PSA 15:1" style="v"/>Nyanyian <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 15:1"/>
<para style="q1" vid="PSA 15:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, siapo bae yang bole nginep dalem <char lemma="Kemah Petemuan" style="w">kemah Kau</char>?</para>
<para style="q2" vid="PSA 15:1">Siapo bae yang bole netep di <char lemma="Sion" style="w">bókét Kau</char> yang suci?<verse eid="PSA 15:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 15:2" style="v"/>Wong yang bejalan dalem ketólósan,</para>
<para style="q2" vid="PSA 15:2">trós yang bebuat keadélan,</para>
<para style="q2" vid="PSA 15:2">jugo yang ngomongke kebeneran di jeró atinyo.<verse eid="PSA 15:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 15:3" style="v"/>Dio idak mitna pakek lidanyo,</para>
<para style="q2" vid="PSA 15:3">idak bebuat jahat samo kawan-kawannyo,</para>
<para style="q2" vid="PSA 15:3">trós idak ngatoi tetanggonyo.<verse eid="PSA 15:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 15:4" style="v"/>Dio mandang hino wong yang ditolak Allah</para>
<para style="q2" vid="PSA 15:4">tapi ngormati wong yang takót samo <char style="nd">ALLAHyhwh</char>.</para>
<para style="q1" vid="PSA 15:4">Dio dak ngoba janjinyo mugola dirugike.<verse eid="PSA 15:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 15:5" style="v"/>Dio dak minjemke dóétnyo dengen nganakkenyo,</para>
<para style="q2" vid="PSA 15:5">trós dak nerimo sogokan óntók ngelawan wong yang dak besala.</para>
<para style="b" vid="PSA 15:5"/>
<para style="q1" vid="PSA 15:5">Wong yang bebuat cak itu dak bakal tegoyake sampe selamo-lamonyo.<verse eid="PSA 15:5"/></para>
<chapter eid="PSA 15"/>
<chapter number="16" sid="PSA 16" style="c"/>
<para style="s2">Kesenengan wong além ado samo Allah</para>
<para style="d">
<verse number="1" sid="PSA 16:1" style="v"/>
<char style="tl">Miktam</char>
<note caller="+" style="f">
<char closed="false" style="fr">16:1 </char>
<char closed="false" style="fq">Miktam: </char>
<char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char>
</note> Daód.</para>
<para style="b" vid="PSA 16:1"/>
<para style="q1" vid="PSA 16:1">Ya Allah, jagola aku, karno samo Kaula aku beléndóng.<verse eid="PSA 16:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 16:2" style="v"/>Aku ngomong samo <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 16:2">“Kaula Tuan aku.</para>
<para style="q2" vid="PSA 16:2">Dak katek yang baék óntók aku selaén Kau.”<verse eid="PSA 16:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 16:3" style="v"/>Wong-wong suci yang ado di bumi ni</para>
<para style="q2" vid="PSA 16:3">iola wong-wong yang mulyo yang jadi kesenengan aku.<verse eid="PSA 16:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 16:4" style="v"/>Kesaroan wong-wong yang nyemba dewo bakal betamba banyak<note caller="+" style="f"><char closed="false" style="fr">16:3-4 </char><char closed="false" style="fq">Wong-wong suci … bakal betamba banyak: </char><char closed="false" style="ft">Teks asli dari ayat 3–4a ni dak pulok jelas.</char></note>.</para>
<para style="q1" vid="PSA 16:4">Aku dak bakal melok dio wong nuangke pesembahan minuman yang dari dara,</para>
<para style="q2" vid="PSA 16:4">apo manggél namo dewo-dewo di bébér aku.<verse eid="PSA 16:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 16:5" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, Kaula bagéan aku jugo takdér<note caller="+" style="f"><char closed="false" style="fr">16:5 </char><char closed="false" style="fq">takdér: </char><char closed="false" style="ft">Teks asli iola “cangkér”. Ini ni peumpamoan Ibrani pasal apo yang la Allah tentuke óntók keédópan wong. Di sini, Allah dewek yang jadi bagéan jugo takdér yang diterimo wong ni óntók édópnyo.</char></note> aku.</para>
<para style="q2" vid="PSA 16:5">Kau nyekel undi aku.<verse eid="PSA 16:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 16:6" style="v"/>Tali pengókór nyampak ke aku di tempat-tempat yang lemak.</para>
<para style="q2" vid="PSA 16:6">Iyo nian, mélék warésan aku nyenengke aku.<verse eid="PSA 16:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 16:7" style="v"/>Aku bakal muji <char style="nd">ALLAHyhwh</char>, yang la nasehati aku.</para>
<para style="q2" vid="PSA 16:7">Iyo, pas malem ari, batén aku ngajari aku.<verse eid="PSA 16:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 16:8" style="v"/>Aku la narok <char style="nd">ALLAHyhwh</char> di adepan aku terós.</para>
<para style="q2" vid="PSA 16:8">Karno Dio ado di sebela kanan aku, aku dak bakal tegoncang.<verse eid="PSA 16:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 16:9" style="v"/>Mangkonyo, ati aku seneng jugo jiwo aku besorak!</para>
<para style="q2" vid="PSA 16:9">Iyo, badan aku bakal netep dengen aman.<verse eid="PSA 16:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 16:10" style="v"/>Soalnyo Kau dak bakal nyerake jiwo aku ke dunio wong mati,</para>
<para style="q2" vid="PSA 16:10">jugo dak bakal mbiarke wong além Kau jingok alam kóbór.<verse eid="PSA 16:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 16:11" style="v"/>Kau ngenjóktauke samo aku jalan keédópan.</para>
<para style="q1" vid="PSA 16:11">Di adepan Kau ado kepuasan yang penu.</para>
<para style="q2" vid="PSA 16:11">Di sebela kanan Kau ado kesenengan selamo-lamonyo.<verse eid="PSA 16:11"/></para>
<chapter eid="PSA 16"/>
<chapter number="17" sid="PSA 17" style="c"/>
<para style="s2">Doa mintak diagók'i Allah</para>
<para style="d">
<verse number="1" sid="PSA 17:1" style="v"/>Doa Daód.</para>
<para style="b" vid="PSA 17:1"/>
<para style="q1" vid="PSA 17:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, dengerkela pekaro yang bener.</para>
<para style="q2" vid="PSA 17:1">Peratikela jerétan aku!</para>
<para style="q1" vid="PSA 17:1">Pasangla kópéng óntók doa aku,</para>
<para style="q2" vid="PSA 17:1">yang metu dari bébér yang dak ngolai.<verse eid="PSA 17:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 17:2" style="v"/>Dari hadérat Kaula sekironyo dateng pengakéman,</para>
<para style="q2" vid="PSA 17:2">trós mato Kau sekironyo jingok apo yang adél.<verse eid="PSA 17:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 17:3" style="v"/>Kau selédéki ati aku;</para>
<para style="q1" vid="PSA 17:3">Kau merikso aku pas malem ari;</para>
<para style="q1" vid="PSA 17:3">Kau nguji aku;</para>
<para style="q1" vid="PSA 17:3">tapi Kau idak nemuke apo-apo.</para>
<para style="q1" vid="PSA 17:3">Aku la mótóske</para>
<para style="q2" vid="PSA 17:3">supayo mólót aku idak kelewatan.<verse eid="PSA 17:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 17:4" style="v"/>Pasal pebuatan manusio:</para>
<para style="q2" vid="PSA 17:4">Aku ni la jago diri aku dari jalan-jalan kekejeman</para>
<para style="q2" vid="PSA 17:4">sesuai dengen prénto yang Kau sampeke.<verse eid="PSA 17:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 17:5" style="v"/>Sekel aku tetep di jalór Kau,</para>
<para style="q2" vid="PSA 17:5">langka aku dak tegoyake.<verse eid="PSA 17:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 17:6" style="v"/>Aku ni mekék samo Kau</para>
<para style="q2" vid="PSA 17:6">karno Kau bakal nyawab aku, ya Allah.</para>
<para style="q1" vid="PSA 17:6">Pasangla kópéng óntók aku,</para>
<para style="q2" vid="PSA 17:6">dengerkela omongan aku.<verse eid="PSA 17:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 17:7" style="v"/>Nyatokela kasé stio Kau yang ajaéb tu!</para>
<para style="q2" vid="PSA 17:7">Kaula penyelamet wong-wong yang beléndóng di tangan kanan Kau</para>
<para style="q2" vid="PSA 17:7">dari mósó-mósó dio wong.<verse eid="PSA 17:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 17:8" style="v"/>Jagola aku pecak biji mato Kau,</para>
<para style="q2" vid="PSA 17:8">trós singitila aku di bawa dekepan sayap Kau<verse eid="PSA 17:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 17:9" style="v"/>dari wong-wong jahat yang nak mbinasoke aku,</para>
<para style="q2" vid="PSA 17:9">iola mósó-mósó aku yang ngepóng aku.<verse eid="PSA 17:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 17:10" style="v"/>Dio wong ngeraske ati sampe katek raso kesian<note caller="+" style="f"><char closed="false" style="fr">17:10 </char><char closed="false" style="fq">ngeraske ati sampe katek raso kesian: </char><char closed="false" style="ft">Teks asli iola “nótóp lemaknyo”. Pecaknyo ini ni peumpamoan bingen yang maksódnyo dio dak punyo raso belas kesian.</char></note>;</para>
<para style="q2" vid="PSA 17:10">mólót dio wong ngomong dengen sombong.<verse eid="PSA 17:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 17:11" style="v"/>Sekarang dio wong ngepóng langka aku.</para>
<para style="q2" vid="PSA 17:11">Dio wong ngéntép óntók ngempaske aku ke tana.<verse eid="PSA 17:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 17:12" style="v"/>Dio wong pecak singo yang péngén nyabék-nyabék,</para>
<para style="q2" vid="PSA 17:12">pecak singo mudo yang dódók di tempat singitannyo.<verse eid="PSA 17:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 17:13" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, bangkétla!</para>
<para style="q2" vid="PSA 17:13">Adangla dio wong trós kalakela dio wong!</para>
<para style="q1" vid="PSA 17:13">Lepaskela jiwo aku dari wong jahat dengen pedang Kau,<verse eid="PSA 17:13"/></para>
<para style="q2">
<verse number="14" sid="PSA 17:14" style="v"/>dari manusio dengen tangan Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 17:14">iola wong-wong dunio, yang bagéannyo cuman ado dalem édóp ini.</para>
<para style="q1" vid="PSA 17:14">Kau penui perót dio wong dengen apo yang Kau simpen,</para>
<para style="q2" vid="PSA 17:14">anak-anak dio wong kenyang</para>
<para style="q2" vid="PSA 17:14">trós dio wong ninggalke sisonyo óntók kupek-kupeknyo<note caller="+" style="f"><char closed="false" style="fr">17:14 </char><char closed="false" style="fq">Kau penui perót … kupek-kupeknyo: </char><char closed="false" style="ft">Makno teks asli dari ketigo barés ni dak pulok jelas.</char></note>.<verse eid="PSA 17:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 17:15" style="v"/>Tapi aku, dalem kebeneran aku bakal jingok rai Kau,</para>
<para style="q2" vid="PSA 17:15">trós pas aku bangón, aku bakal seneng jingok rupo Kau<note caller="+" style="f"><char closed="false" style="fr">17:15 </char><char closed="false" style="fq">pas aku bangón, aku bakal seneng jingok rupo Kau: </char><char closed="false" style="ft">Barés ni pacak duo arti, 1) ado hóbóngan deket samo Allah pas bangón dari tédók, jugo 2) nian-nian jingok rupo Allah pas masók surgo seabés kematian.</char></note>.<verse eid="PSA 17:15"/></para>
<chapter eid="PSA 17"/>
<chapter number="18" sid="PSA 18" style="c"/>
<para style="s2">Nyanyian sókór Rajo Daód karno kemenangan jugo keselametan dari Allah <note caller="+" style="f"><char closed="false" style="fr">18:1 </char><char closed="false" style="ft">Saér ni ampér samo dengen </char><char closed="false" style="xt"><ref loc="2SA 22">2 Samuel 22</ref></char><char closed="false" style="ft">.</char></note></para>
<para style="d">
<verse number="1" sid="PSA 18:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>, hamba <char style="nd"><char style="w">ALLAHyhwh</char></char>. Dio nyampekenyo samo <char style="nd">ALLAHyhwh</char> pas waktu <char style="nd">ALLAHyhwh</char> ngelepaskenyo dari cengkeman slóró mósónyo jugo dari tangan rajo Saól<note caller="+" style="f"><char closed="false" style="fr">18:1 </char><char closed="false" style="fq">rajo Saól: </char><char closed="false" style="ft">Dio ni iola rajo Israel yang petamo, sebelóm Daód.</char></note>. <verse eid="PSA 18:1"/><verse number="2" sid="PSA 18:2" style="v"/>Dio ngomong cak ini:</para>
<para style="b" vid="PSA 18:2"/>
<para style="q1" vid="PSA 18:2">Aku ngaséhi Kau, ya <char style="nd">ALLAHyhwh</char>, kekuatan aku!<verse eid="PSA 18:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 18:3" style="v"/>
<char style="nd">ALLAHyhwh</char> iola bókét batu aku, benteng petahanan aku, jugo penyelamet aku.</para>
<para style="q2" vid="PSA 18:3">Diola Tuhan aku, gónóng batu aku; samo Diola aku beléndóng.</para>
<para style="q2" vid="PSA 18:3">Diola tameng aku, penyelamet aku yang perkasa<note caller="+" style="f"><char closed="false" style="fr">18:3 </char><char closed="false" style="fq">penyelamet aku yang perkasa: </char><char closed="false" style="ft">Teks asli iola “tandók keselametan”. Dalem budayo Ibrani, “tandók” iola kiasan yang nónjókke kekuatan jugo kekuasoan. Jadi “tandók keselametan” artinyo ‘penyelamet yang perkasa’.</char></note>, jugo kota benteng aku.<verse eid="PSA 18:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 18:4" style="v"/>
<char style="nd">ALLAHyhwh</char> pantes dipuji! Aku bejerét samo Dio,</para>
<para style="q2" vid="PSA 18:4">trós aku diselametke dari mósó-mósó.<verse eid="PSA 18:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 18:5" style="v"/>Tali-tali maót ngelélét aku,</para>
<para style="q1" vid="PSA 18:5">Arós deres kematian mbanjéri aku.<verse eid="PSA 18:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 18:6" style="v"/>Tali-tali alam kóbór mbelét aku;</para>
<para style="q1" vid="PSA 18:6">jebakan-jebakan maót ngadang aku.<verse eid="PSA 18:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 18:7" style="v"/>Dalem kesesekan aku bejerét samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 18:7">trós mekék mintak tolong samo Tuhan aku.</para>
<para style="q1" vid="PSA 18:7">Dari jeró Ruma-Nyo, Dio ndenger suaro aku,</para>
<para style="q2" vid="PSA 18:7">trós pekékan aku mintak tolong ke Dio sampe ke kópéng-Nyo.<verse eid="PSA 18:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 18:8" style="v"/>Laju bumi begoyang jugo begoncang;</para>
<para style="q2" vid="PSA 18:8">trós dasar-dasar gónóng begeter.</para>
<para style="q2" vid="PSA 18:8">Slórónyo begoyang karno kemarahan-Nyo.<verse eid="PSA 18:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 18:9" style="v"/>Asep naék dari édóng-Nyo,</para>
<para style="q2" vid="PSA 18:9">trós api yang mbinasoke metu dari mólót-Nyo;</para>
<para style="q2" vid="PSA 18:9">baro yang mbakar metu dari Dio.<verse eid="PSA 18:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 18:10" style="v"/>Dio nyibakke langét, trós tórón,</para>
<para style="q2" vid="PSA 18:10">awan gelep ado di bawa sekel-Nyo.<verse eid="PSA 18:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 18:11" style="v"/>Dio naék mahlók kerób<note caller="+" style="f"><char closed="false" style="fr">18:11 </char><char closed="false" style="fq">kerób: </char><char closed="false" style="ft">Ini ni semacem mahlók surgawi yang besayap yang diciptoke Allah óntók ngelayani Dio. Tugasnyo iola nyagoi apo bae yang dipréntoke Allah. Mahlók ni idak samo dengen <char style="w">malekat</char> laénnyo. </char></note> trós terbang,</para>
<para style="q2" vid="PSA 18:11">melayang di sayap-sayap angin.<verse eid="PSA 18:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 18:12" style="v"/>Dio narok kegelepan di sekeléléng Dio jadi tempat singitan-Nyo;</para>
<para style="q2" vid="PSA 18:12">pondok-Nyo dari awan-awan gelep yang penu banyu.<verse eid="PSA 18:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 18:13" style="v"/>Dari cahayo di depan-Nyo</para>
<para style="q2" vid="PSA 18:13">metu awan-Nyo samo ujan es jugo baro api.<verse eid="PSA 18:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 18:14" style="v"/>
<char style="nd">ALLAHyhwh</char> begemóró di langét,</para>
<para style="q2" vid="PSA 18:14">trós Yang Mahabesak metuke suaro-Nyo di antaro ujan es jugo baro api<note caller="+" style="f"><char closed="false" style="fr">18:14 </char><char closed="false" style="fq">di antaro ujan es jugo baro api: </char><char closed="false" style="ft">Di beberapo naska kuno dari kitab ni, kato-kato “di antaro ujan es jugo baro api” katek di ayat ni.</char></note>.<verse eid="PSA 18:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 18:15" style="v"/>Dio ngelepaske anak-anak pana-Nyo trós mbubarke dio wong;</para>
<para style="q2" vid="PSA 18:15">Dio mancarke kilat trós ngacauke dio wong.<verse eid="PSA 18:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 18:16" style="v"/>Ahérnyo, arós-arós laótan dalem tejingok,</para>
<para style="q2" vid="PSA 18:16">trós dasar-dasar bumi tebukak,</para>
<para style="q1" vid="PSA 18:16">karno tegoran Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 18:16">jugo karno embósan napas dari édóng Kau.<verse eid="PSA 18:16"/></para>
<para style="b"/>
<para style="q1">
<verse number="17" sid="PSA 18:17" style="v"/>Dio ngeraé dari tempat tinggi trós ngambék aku;</para>
<para style="q2" vid="PSA 18:17">Dio narék aku dari <char style="add">bahayo maót pecak dari</char> banyu yang dalem.<verse eid="PSA 18:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 18:18" style="v"/>Dio ngelepaske aku dari mósó aku yang gagah,</para>
<para style="q2" vid="PSA 18:18">dari dio wong yang mbenci aku.</para>
<para style="q2" vid="PSA 18:18">Soalnyo dio wong keliwat kuat óntók aku.<verse eid="PSA 18:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 18:19" style="v"/>Dio wong ngadang aku pas ari sial aku,</para>
<para style="q2" vid="PSA 18:19">tapi <char style="nd">ALLAHyhwh</char> iola penopang aku.<verse eid="PSA 18:19"/></para>
<para style="q1">
<verse number="20" sid="PSA 18:20" style="v"/>Dio gawak aku metu ke tempat yang lapang;</para>
<para style="q2" vid="PSA 18:20">Dio nyelametke aku karno Dio seneng samo aku.<verse eid="PSA 18:20"/></para>
<para style="b"/>
<para style="q1">
<verse number="21" sid="PSA 18:21" style="v"/>
<char style="nd">ALLAHyhwh</char> bebuat baék samo aku sesuai kebeneran aku;</para>
<para style="q2" vid="PSA 18:21">sesuai kesucian tangan aku, Dio mbales aku.<verse eid="PSA 18:21"/></para>
<para style="q1">
<verse number="22" sid="PSA 18:22" style="v"/>Soalnyo aku melok'i jalan <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 18:22">trós aku idak bebuat jahat dengen bebalék dari Tuhan aku.<verse eid="PSA 18:22"/></para>
<para style="q1">
<verse number="23" sid="PSA 18:23" style="v"/>Iyo! Soalnyo slóró hókóm-Nyo tu ado nian di adepan aku;</para>
<para style="q2" vid="PSA 18:23">aku idak nyimpang dari peratóran-peratóran-Nyo.<verse eid="PSA 18:23"/></para>
<para style="q1">
<verse number="24" sid="PSA 18:24" style="v"/>Aku sempurno di adepan-Nyo,</para>
<para style="q2" vid="PSA 18:24">trós aku nyago diri aku dari kesalahan.<verse eid="PSA 18:24"/></para>
<para style="q1">
<verse number="25" sid="PSA 18:25" style="v"/>Laju <char style="nd">ALLAHyhwh</char> mbales aku sesuai kebeneran aku,</para>
<para style="q2" vid="PSA 18:25">sesuai kesucian tangan aku di depan mato-Nyo.<verse eid="PSA 18:25"/></para>
<para style="b"/>
<para style="q1">
<verse number="26" sid="PSA 18:26" style="v"/>Samo wong além, Kau tónjókke amen Kau dewek além.</para>
<para style="q1" vid="PSA 18:26">Samo wong yang tólós, Kau tónjókke amen Kau dewek tólós.<verse eid="PSA 18:26"/></para>
<para style="q1">
<verse number="27" sid="PSA 18:27" style="v"/>Samo wong yang suci, Kau tónjókke amen Kau dewek suci.</para>
<para style="q1" vid="PSA 18:27">Tapi samo wong yang bengkok ati, Kau jugo bebelét-belét.<verse eid="PSA 18:27"/></para>
<para style="q1">
<verse number="28" sid="PSA 18:28" style="v"/>Soalnyo Kaula yang nyelametke wong yang saro,</para>
<para style="q2" vid="PSA 18:28">tapi wong yang tinggi ati<note caller="+" style="f"><char closed="false" style="fr">18:28 </char><char closed="false" style="fq">ati: </char><char closed="false" style="ft">Teks asli iola “mato”. Dalem baso Ibrani kiasan “mato yang tinggi” artinyo kesombongan. </char></note> Kau rendake.<verse eid="PSA 18:28"/></para>
<para style="q1">
<verse number="29" sid="PSA 18:29" style="v"/>Kaula yang ngédópke pelito aku.</para>
<para style="q2" vid="PSA 18:29">
<char style="nd">ALLAHyhwh</char>, Tuhanku, nyinari kegelepan <char style="add">di sekeléléng</char> aku.<verse eid="PSA 18:29"/></para>
<para style="q1">
<verse number="30" sid="PSA 18:30" style="v"/>Samo Kau aku pacak belari nerobos pasókan,</para>
<para style="q2" vid="PSA 18:30">trós samo Tuhanku, aku pacak nguasoi kota<note caller="+" style="f"><char closed="false" style="fr">18:30 </char><char closed="false" style="fq">pacak nguasoi kota: </char><char closed="false" style="ft">Teks asli iola “ngeloncati tembok”. Maksódnyo ngeloncati tembok kota óntók naklókkenyo.</char></note>.<verse eid="PSA 18:30"/></para>
<para style="b"/>
<para style="q1">
<verse number="31" sid="PSA 18:31" style="v"/>Allah tu, pebuatan-Nyo sempurno;</para>
<para style="q2" vid="PSA 18:31">omongan <char style="nd">ALLAHyhwh</char> tu teuji.</para>
<para style="q1" vid="PSA 18:31">Diola tameng óntók slóró wong yang beléndóng samo Dio.<verse eid="PSA 18:31"/></para>
<para style="q1">
<verse number="32" sid="PSA 18:32" style="v"/>Soalnyo, siapo lagi Tuhan, selaén <char style="nd">ALLAHyhwh</char>?</para>
<para style="q2" vid="PSA 18:32">Siapo lagi gónóng batu, selaén Tuhan kito?<verse eid="PSA 18:32"/></para>
<para style="q1">
<verse number="33" sid="PSA 18:33" style="v"/>Allah yang ngelengkapi aku dengen kekuatan.</para>
<para style="q1" vid="PSA 18:33">Dio mbékén jalan aku sempurno.<verse eid="PSA 18:33"/></para>
<para style="q1">
<verse number="34" sid="PSA 18:34" style="v"/>Dio mbékén sekel aku pecak sekel ruso,</para>
<para style="q2" vid="PSA 18:34">trós mbékén aku tegak <char style="add">dengen aman</char> di tempat tinggi.<verse eid="PSA 18:34"/></para>
<para style="q1">
<verse number="35" sid="PSA 18:35" style="v"/>Dio ngelaté aku óntók beperang</para>
<para style="q2" vid="PSA 18:35">supayo tangan aku pacak ngelengkóngke bósór perunggu.<verse eid="PSA 18:35"/></para>
<para style="q1">
<verse number="36" sid="PSA 18:36" style="v"/>Kau ngenjók aku tameng keselametan Kau,</para>
<para style="q2" vid="PSA 18:36">tangan kanan Kau nopang aku;</para>
<para style="q2" vid="PSA 18:36">kemurahan Kau mbékén aku bekuaso.<verse eid="PSA 18:36"/></para>
<para style="q1">
<verse number="37" sid="PSA 18:37" style="v"/>Kau ngelebarke jalan di bawa langka aku,</para>
<para style="q2" vid="PSA 18:37">supayo sekel aku idak tepleset.<verse eid="PSA 18:37"/></para>
<para style="b"/>
<para style="q1">
<verse number="38" sid="PSA 18:38" style="v"/>Aku ngejer mósó-mósó aku, trós nangkep dio wong;</para>
<para style="q2" vid="PSA 18:38">aku idak bebalék sampe dio wong dibinasoke.<verse eid="PSA 18:38"/></para>
<para style="q1">
<verse number="39" sid="PSA 18:39" style="v"/>Aku ngancórke dio wong, trós dio wong idak pacak bangkét lagi;</para>
<para style="q2" vid="PSA 18:39">dio wong nyampak di bawa sekel aku.<verse eid="PSA 18:39"/></para>
<para style="q1">
<verse number="40" sid="PSA 18:40" style="v"/>Kau ngelengkapi aku dengen kekuatan óntók beperang;</para>
<para style="q2" vid="PSA 18:40">Kau nóndókke wong-wong yang bangkét ngelawan aku ke bawa <char style="add">kuaso</char> aku.<verse eid="PSA 18:40"/></para>
<para style="q1">
<verse number="41" sid="PSA 18:41" style="v"/>Kau mbékén mósó-mósó aku lari dari aku<note caller="+" style="f"><char closed="false" style="fr">18:41 </char><char closed="false" style="fq">Kau mbékén mósó-mósó aku lari dari aku: </char><char closed="false" style="ft">Teks asli pacak jugo diartike “Kau ngenjók ke aku leher mósó-mósó aku”.</char></note>,</para>
<para style="q2" vid="PSA 18:41">trós aku ngancórke dio wong yang mbenci aku.<verse eid="PSA 18:41"/></para>
<para style="q1">
<verse number="42" sid="PSA 18:42" style="v"/>Dio wong mekék mintak tolong, tapi dak katek penyelamet;</para>
<para style="q2" vid="PSA 18:42">dio wong mekék samo <char style="nd">ALLAHyhwh</char>, tapi Dio idak nyimbat.<verse eid="PSA 18:42"/></para>
<para style="q1">
<verse number="43" sid="PSA 18:43" style="v"/>Aku mérék dio wong jadi pecak debu diterbangke angin;</para>
<para style="q2" vid="PSA 18:43">aku nggiles dio wong pecak lómpór di jalanan.<verse eid="PSA 18:43"/></para>
<para style="b"/>
<para style="q1">
<verse number="44" sid="PSA 18:44" style="v"/>Kau ngelepaske aku dari kerébótan rakyat.</para>
<para style="q1" vid="PSA 18:44">Kau ngangkat aku jadi kepalak mócók'i bangso-bangso;</para>
<para style="q2" vid="PSA 18:44">rakyat yang idak aku kenal tóndók samo aku.<verse eid="PSA 18:44"/></para>
<para style="q1">
<verse number="45" sid="PSA 18:45" style="v"/>Pas kópéng dio wong ndenger, dio wong nórót samo aku;</para>
<para style="q2" vid="PSA 18:45">wong-wong aséng nyera samo aku.<verse eid="PSA 18:45"/></para>
<para style="q1">
<verse number="46" sid="PSA 18:46" style="v"/>Wong-wong aséng jadi layu,</para>
<para style="q2" vid="PSA 18:46">trós metu dengen gemeter dari benteng-bentengnyo.<verse eid="PSA 18:46"/></para>
<para style="b"/>
<para style="q1">
<verse number="47" sid="PSA 18:47" style="v"/>
<char style="nd">ALLAHyhwh</char> édóp!</para>
<para style="q2" vid="PSA 18:47">Pujila bókét batu aku!</para>
<para style="q2" vid="PSA 18:47">Tinggikela Tuhan, penyelamet aku!<verse eid="PSA 18:47"/></para>
<para style="q1">
<verse number="48" sid="PSA 18:48" style="v"/>Allah yang ngenjók pembalesan óntók aku</para>
<para style="q2" vid="PSA 18:48">trós nóndókke bangso-bangso ke bawa <char style="add">kuaso</char> aku;<verse eid="PSA 18:48"/></para>
<para style="q1">
<verse number="49" sid="PSA 18:49" style="v"/>Dio yang mbebaske aku dari mósó-mósó aku</para>
<para style="q2" vid="PSA 18:49">trós ngangkat aku mócók'i wong-wong yang bangkét ngelawan aku.</para>
<para style="q1" vid="PSA 18:49">Kau ngelepaske aku dari wong kejem.<verse eid="PSA 18:49"/></para>
<para style="q1">
<verse number="50" sid="PSA 18:50" style="v"/>Karno tu, aku bakal ngucap sókór ke Kau, di antaro bangso-bangso, ya <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 18:50">Aku bakal nyanyike pujian óntók namo Kau.<verse eid="PSA 18:50"/></para>
<para style="b"/>
<para style="q1">
<verse number="51" sid="PSA 18:51" style="v"/>Dio ngenjók keselametan yang besak samo rajo-Nyo,</para>
<para style="q2" vid="PSA 18:51">trós nyatoke kasé stio-Nyo samo wong yang dilanték-Nyo,</para>
<para style="q2" vid="PSA 18:51">samo Daód jugo ketórónannyo sampe selamonyo.<verse eid="PSA 18:51"/></para>
<chapter eid="PSA 18"/>
<chapter number="19" sid="PSA 19" style="c"/>
<para style="s2">Alam semesto jugo hókóm Allah jadi saksi kemulyoan-Nyo</para>
<para style="d">
<verse number="1" sid="PSA 19:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 19:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 19:2" style="v"/>Semesto alam nyeritoke kemulyoan Allah,</para>
<para style="q2" vid="PSA 19:2">jugo langét nyatoke pebuatan tangan-Nyo.<verse eid="PSA 19:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 19:3" style="v"/>Ari neróske brito tu ke ari berékótnyo,</para>
<para style="q2" vid="PSA 19:3">jugo malem nyampeke pengetauan tu ke malem berékótnyo.<verse eid="PSA 19:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 19:4" style="v"/>Katek omongan, katek kato-kato;</para>
<para style="q2" vid="PSA 19:4">suaronyo jugo idak tedenger.<verse eid="PSA 19:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 19:5" style="v"/>Tapi kabarnyo tesebar ke slóró bumi,</para>
<para style="q2" vid="PSA 19:5">trós pesennyo sampe ke ójóng dunio.</para>
<para style="b" vid="PSA 19:5"/>
<para style="q1" vid="PSA 19:5">Di langét, Dio negakke kemah óntók matoari,<verse eid="PSA 19:5"/></para>
<para style="q2">
<verse number="6" sid="PSA 19:6" style="v"/>trós matoari móncól, pecak pengantén lanang yang metu dari kamarnyo,</para>
<para style="q2" vid="PSA 19:6">semangat pecak atlet<note caller="+" style="f"><char closed="false" style="fr">19:6 </char><char closed="false" style="fq">atlet: </char><char closed="false" style="ft">Kato asli iola “wong kuat”. Ini ni gambaran matoari besiap óntók belari nyebrangi langét pecak wong besiap óntók belari di lomba lari.</char></note> yang nak mulai larinyo.<verse eid="PSA 19:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 19:7" style="v"/>Terbétnyo dari ójóng langét</para>
<para style="q2" vid="PSA 19:7">trós belari sampe ke ójóng laénnyo;</para>
<para style="q2" vid="PSA 19:7">katek yang teléndóng dari panasnyo.<verse eid="PSA 19:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 19:8" style="v"/>Hókóm <char style="nd"><char style="w">ALLAHyhwh</char></char> tu sempurno,</para>
<para style="q2" vid="PSA 19:8">nyegerke jiwo.</para>
<para style="q1" vid="PSA 19:8">Peringetan <char style="nd">ALLAHyhwh</char> tu tegu,</para>
<para style="q2" vid="PSA 19:8">mbékén wong polos jadi behikmah.<verse eid="PSA 19:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 19:9" style="v"/>Petónjók <char style="nd">ALLAHyhwh</char> tu pacak dipecayo,</para>
<para style="q2" vid="PSA 19:9">nyenengke ati.</para>
<para style="q1" vid="PSA 19:9">Prénto <char style="nd">ALLAHyhwh</char> tu murni,</para>
<para style="q2" vid="PSA 19:9">jadi penerang óntók mato.<verse eid="PSA 19:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 19:10" style="v"/>Takót samo <char style="nd">ALLAHyhwh</char> tu suci,</para>
<para style="q2" vid="PSA 19:10">ado óntók selamo-lamonyo.</para>
<para style="q1" vid="PSA 19:10">Peratóran-peratóran <char style="nd">ALLAHyhwh</char> tu bener,</para>
<para style="q2" vid="PSA 19:10">adél slórónyo,<verse eid="PSA 19:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 19:11" style="v"/>lebé berego daripado emas,</para>
<para style="q2" vid="PSA 19:11">ngelebéi banyak emas murni.</para>
<para style="q1" vid="PSA 19:11">Lebé manis daripado madu,</para>
<para style="q2" vid="PSA 19:11">ngelebéi tetesan madu dari sarang lebah.<verse eid="PSA 19:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 19:12" style="v"/>Lebé-lebé lagi, aku, hamba Kau ni, diperingetke ole slórónyo tu;</para>
<para style="q2" vid="PSA 19:12">dengen nyagonyo ado pahalo yang besak.<verse eid="PSA 19:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 19:13" style="v"/>Siapo nian yang pacak tau kesalahannyo dewek?</para>
<para style="q2" vid="PSA 19:13">Bersékela aku dari kesalahan yang tesingit tu.<verse eid="PSA 19:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 19:14" style="v"/>Tahanla hamba Kau dari kesombongan;</para>
<para style="q2" vid="PSA 19:14">jangan biarke pasal tu nguasoi aku.</para>
<para style="q1" vid="PSA 19:14">Mangko aku jadi idak becacat,</para>
<para style="q2" vid="PSA 19:14">trós bersé dari pelanggaran yang besak.<verse eid="PSA 19:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 19:15" style="v"/>Kironyo omongan mólót aku jugo renóngan ati aku</para>
<para style="q2" vid="PSA 19:15">disenengi ole Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 19:15">gónóng batu jugo penebós aku.<verse eid="PSA 19:15"/></para>
<chapter eid="PSA 19"/>
<chapter number="20" sid="PSA 20" style="c"/>
<para style="s2">Doa mintak kemenangan óntók rajo Israel</para>
<para style="d">
<verse number="1" sid="PSA 20:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 20:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 20:2" style="v"/>Kironyo <char style="nd"><char style="w">ALLAHyhwh</char></char> nyawab kau<note caller="+" style="f"><char closed="false" style="fr">20:2 </char><char closed="false" style="fq">kau: </char><char closed="false" style="ft">Kato “kau” di saér ni sebenernyo ditujuke óntók rajo Israel. Pasal ni pacak tejingok di ayat 7, dalem kato-kato “wong yang dilanték-Nyo”. Saér ni digunoke bangso Israel óntók mberkahi rajonyo, jadi yang ngomong di ayat 2-6 jugo 10 iola masyarakat Israel.</char></note> pas ari kesaroan;</para>
<para style="q2" vid="PSA 20:2">kironyo namo Tuhannyo <char style="w">Yakób</char> ngeléndóngi kau.<verse eid="PSA 20:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 20:3" style="v"/>Kironyo Dio ngenjók petolongan dari tempat suci,</para>
<para style="q2" vid="PSA 20:3">trós nopang kau dari <char style="w">Sion</char>.<verse eid="PSA 20:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 20:4" style="v"/>Kironyo Dio nginget slóró pesembahan kau,</para>
<para style="q2" vid="PSA 20:4">trós seneng samo kórban bakaran kau. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 20:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 20:5" style="v"/>Kironyo Dio ngarunioke samo kau sesuai dengen kendak ati kau,</para>
<para style="q2" vid="PSA 20:5">trós mbékén slóró rencano kau berasél.<verse eid="PSA 20:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 20:6" style="v"/>Kami bakal besorak karno kemenangan kau,</para>
<para style="q2" vid="PSA 20:6">trós ngangkat bendera-bendera dalem namo Tuhan kito.</para>
<para style="q1" vid="PSA 20:6">Kironyo <char style="nd">ALLAHyhwh</char> ngabólke slóró pintak'an kau.<verse eid="PSA 20:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 20:7" style="v"/>Sekarang aku tau amen <char style="nd">ALLAHyhwh</char> bakal nyelametke</para>
<para style="q2" vid="PSA 20:7">wong yang dilanték-Nyo.</para>
<para style="q1" vid="PSA 20:7">Dio bakal nyawab dari surgo-Nyo yang suci</para>
<para style="q2" vid="PSA 20:7">dengen kuaso keselametan dari tangan kanan-Nyo.<verse eid="PSA 20:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 20:8" style="v"/>Ado wong yang ngandalke kreto-kreto perangnyo,</para>
<para style="q2" vid="PSA 20:8">ado jugo yang ngandalke kudo-kudonyo,</para>
<para style="q2" vid="PSA 20:8">tapi kito ngandalke namo <char style="nd">ALLAHyhwh</char>, Tuhan kito.<verse eid="PSA 20:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 20:9" style="v"/>Dio wong bakal betekók lótót trós nyampak,</para>
<para style="q2" vid="PSA 20:9">tapi kito bangkét trós tegak dengen tegu.<verse eid="PSA 20:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 20:10" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, selametkela rajo!</para>
<para style="q2" vid="PSA 20:10">Jawabla kami pas waktu kami bejerét!<verse eid="PSA 20:10"/></para>
<chapter eid="PSA 20"/>
<chapter number="21" sid="PSA 21" style="c"/>
<para style="s2">Nyanyian sókór karno rajo diberkahi Allah</para>
<para style="d">
<verse number="1" sid="PSA 21:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 21:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 21:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, dalem kekuatan Kau rajo beseneng;</para>
<para style="q2" vid="PSA 21:2">dalem keselametan Kau dio besorak nian!<verse eid="PSA 21:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 21:3" style="v"/>Kau la ngenjók ke dio kendak atinyo,</para>
<para style="q2" vid="PSA 21:3">trós Kau idak nahan pintak'an bébérnyo. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 21:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 21:4" style="v"/>Iyo, Kau nyambót dio dengen berkah-berkah yang baék;</para>
<para style="q2" vid="PSA 21:4">Kau masangke mahkota emas murni di pócók palaknyo.<verse eid="PSA 21:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 21:5" style="v"/>Dio mintak keédópan dari Kau,</para>
<para style="q2" vid="PSA 21:5">trós Kau ngenjók ke dio ómór panjang sampe selamo-lamonyo.<verse eid="PSA 21:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 21:6" style="v"/>Besak kemulyoannyo karno keselametan dari Kau;</para>
<para style="q2" vid="PSA 21:6">kehormatan jugo keagóngan, Kau karunioke samo dio.<verse eid="PSA 21:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 21:7" style="v"/>Iyo, Kau ngarunioke berkah ke dio óntók selamonyo,</para>
<para style="q2" vid="PSA 21:7">trós Kau mbékén dio besorak kesenengan karno hadérat Kau.<verse eid="PSA 21:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 21:8" style="v"/>Soalnyo rajo pecayo samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 21:8">trós ole karno kasé stio dari Yang Mahabesak,</para>
<para style="q2" vid="PSA 21:8">dio dak bakal goya.<verse eid="PSA 21:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 21:9" style="v"/>Tangan kau<note caller="+" style="f"><char closed="false" style="fr">21:9 </char><char closed="false" style="fq">kau: </char><char closed="false" style="ft">Dalem teks asli ayat 9–13, dak pulok jelas amen kato “kau” iola rajo apo Allah. Amen “kau” di sini iola Allah, artinyo Allah bakal ngelakuke slórónyo tu ke wong-wong jahat. Tapi amen “kau” di sini iola rajo, artinyo rajo tu yang bakal ngelakukenyo ke mósó-mósónyo dengen petolongan dari Allah. Rajo bakal bekuaso karno Allah ado besamo dio.</char></note> bakal nangkep slóró mósó kau,</para>
<para style="q2" vid="PSA 21:9">tangan kanan kau bakal nangkep wong-wong yang mbenci kau.<verse eid="PSA 21:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 21:10" style="v"/>Kau bakal mbékén dio wong pecak tungku api pas kau móncól.</para>
<para style="q2" vid="PSA 21:10">
<char style="nd">ALLAHyhwh</char> bakal negok dio wong dalem kemarahan-Nyo,</para>
<para style="q2" vid="PSA 21:10">trós api bakal matike dio wong.<verse eid="PSA 21:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 21:11" style="v"/>Kau bakal mbinasoke ketórónan dio wong dari bumi,</para>
<para style="q2" vid="PSA 21:11">jugo penerós dio wong dari antaro anak-anak manusio.<verse eid="PSA 21:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 21:12" style="v"/>Mugola dio wong nyiapke kejahatan óntók <char style="add">ngelawan</char> kau,</para>
<para style="q2" vid="PSA 21:12">mugola dio wong beniat bórók,</para>
<para style="q2" vid="PSA 21:12">dio wong dak bakal berasél.<verse eid="PSA 21:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 21:13" style="v"/>Iyo! Kau bakal mbékén dio wong lari balék</para>
<para style="q2" vid="PSA 21:13">pas kau ngarake tali-tali bósór kau ke dio wong.<verse eid="PSA 21:13"/></para>
<para style="b"/>
<para style="q1">
<verse number="14" sid="PSA 21:14" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ditinggikela Kau dalem kekuatan Kau!</para>
<para style="q2" vid="PSA 21:14">Kami bakal nyanyi trós muji pasal kuaso Kau.<verse eid="PSA 21:14"/></para>
<chapter eid="PSA 21"/>
<chapter number="22" sid="PSA 22" style="c"/>
<para style="s2">Doa pas kesaroan samo pujian pas diselametke</para>
<para style="d">
<verse number="1" sid="PSA 22:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> pecak lagu ‘Ruso pas pajar’. Nyanyian <char style="w">Daód</char>.<verse eid="PSA 22:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 22:2" style="v"/>Ya Tuhanku! Ya Tuhanku! Ngapo Kau ninggalke aku?</para>
<para style="q2" vid="PSA 22:2">Petolongan Kau jaó dari aku,</para>
<para style="q3" vid="PSA 22:2">jaó dari pekékan-pekékan aku.<verse eid="PSA 22:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 22:3" style="v"/>Ya Tuhanku! Aku bejerét pas siang ari</para>
<para style="q2" vid="PSA 22:3">tapi Kau idak nyawab,</para>
<para style="q1" vid="PSA 22:3">trós pas malem ari,</para>
<para style="q2" vid="PSA 22:3">tapi katek ketenangan óntók aku.<verse eid="PSA 22:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 22:4" style="v"/>Tapi Kau suci,</para>
<para style="q2" vid="PSA 22:4">yang tinggal dalem puji-pujian Israel.<verse eid="PSA 22:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 22:5" style="v"/>Samo Kaula nenek moyang kami pecayo;</para>
<para style="q2" vid="PSA 22:5">dio wong pecayo, trós Kau ngelepaske dio wong.<verse eid="PSA 22:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 22:6" style="v"/>Samo Kaula dio wong bejerét, trós dibebaske.</para>
<para style="q2" vid="PSA 22:6">Samo Kau dio wong pecayo, trós dio wong idak dikecewake.<verse eid="PSA 22:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 22:7" style="v"/>Tapi aku ni ulet, bukan wong,</para>
<para style="q2" vid="PSA 22:7">yang dihino manusio, trós direndake wong banyak.<verse eid="PSA 22:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 22:8" style="v"/>Slóró wong yang jingok aku ngato-ngatoi aku;</para>
<para style="q2" vid="PSA 22:8">dio wong cébérke bébér, gelengke palak.<verse eid="PSA 22:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 22:9" style="v"/>Uji dio wong, “Dio kan besera samo <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 22:9">mangko biarkela Dio yang ngelepaskenyo!</para>
<para style="q1" vid="PSA 22:9">Biarkela Dio nyelametkenyo,</para>
<para style="q2" vid="PSA 22:9">Dio kan seneng samo wong tu!”<verse eid="PSA 22:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 22:10" style="v"/>Tapi, Kaula yang metuke aku dari kandóngan.</para>
<para style="q2" vid="PSA 22:10">Kau mbékén aku aman<note caller="+" style="f"><char closed="false" style="fr">22:10 </char><char closed="false" style="fq">aman: </char><char closed="false" style="ft">Kato asli di sini ado duo makno, ‘aman’ samo ‘pecayo’.</char></note>, di dado emak aku.<verse eid="PSA 22:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 22:11" style="v"/>Sejak dari rahém, aku la dienjókke ke Kau.</para>
<para style="q2" vid="PSA 22:11">Sejak dari perót emak aku, Kaula Tuhan aku.<verse eid="PSA 22:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 22:12" style="v"/>Janganla jaó dari aku,</para>
<para style="q2" vid="PSA 22:12">karno kesaroan la parak,</para>
<para style="q3" vid="PSA 22:12">trós katek yang nolong.<verse eid="PSA 22:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 22:13" style="v"/>Banyak sapi lanang ngeléléngi aku;</para>
<para style="q2" vid="PSA 22:13">sapi-sapi kuat dari Basan<note caller="+" style="f"><char closed="false" style="fr">22:13 </char><char closed="false" style="fq">Basan: </char><char closed="false" style="ft">Sikok daera di sebela timur dari Sungi Yordan (sungi besak di Palestina). Daera tu tekenal karno sapinyo yang bagós nian.</char></note> ngepóng aku.<verse eid="PSA 22:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 22:14" style="v"/>Dio wong bukak mólótnyo ngadepi aku,</para>
<para style="q2" vid="PSA 22:14">pecak singo yang nerkem trós ngaóm.<verse eid="PSA 22:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 22:15" style="v"/>Kekuatan aku tekuras pecak banyu yang tumpa;<note caller="+" style="f"><char closed="false" style="fr">22:15 </char><char closed="false" style="fq">Kekuatan aku tekuras pecak banyu yang tumpa: </char><char closed="false" style="ft">Teks asli iola, “Pecak banyu aku tetumpa.”</char></note></para>
<para style="q2" vid="PSA 22:15">slóró tulang aku pecól dari sendinyo.</para>
<para style="q1" vid="PSA 22:15">Ati aku pecak lélén,</para>
<para style="q2" vid="PSA 22:15">melele di jeró dado aku.<verse eid="PSA 22:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 22:16" style="v"/>Tenago aku abés, tekeréng pecak beléng.<note caller="+" style="f"><char closed="false" style="fr">22:16 </char><char closed="false" style="fq">Tenago aku abés, tekeréng pecak beléng: </char><char closed="false" style="ft">Teks asli iola, “Kekuatan aku keréng pecak beléng.”</char></note></para>
<para style="q2" vid="PSA 22:16">Jugo lida aku keréng nian sampe saro negok.<note caller="+" style="f"><char closed="false" style="fr">22:16 </char><char closed="false" style="fq">lida aku keréng nian sampe saro negok: </char><char closed="false" style="ft">Teks asli di sini iola, “lida aku nempel di langét-langét mólót aku”. Maksódnyo dio aós nian sampe-sampe banyu ludanyo keréng.</char></note></para>
<para style="q3" vid="PSA 22:16">Di jeró liang kóbór<note caller="+" style="f"><char closed="false" style="fr">22:16 </char><char closed="false" style="fq">liang kóbór: </char><char closed="false" style="ft">Teks asli iola “lahan kematian”. Ide barés ni iola wong ni disiapke óntók kematian, karno denget lagi dio bakal mati.</char></note>, Kau narok aku.<verse eid="PSA 22:16"/></para>
<para style="b"/>
<para style="q1">
<verse number="17" sid="PSA 22:17" style="v"/>
<char style="add">Pecak</char> anjéng-anjéng <char style="add">yang</char> ngeróbóngi aku,</para>
<para style="q2" vid="PSA 22:17">gerombolan wong jahat ngepóng aku.</para>
<para style="q1" vid="PSA 22:17">Dio wong ngelukoi<note caller="+" style="f"><char closed="false" style="fr">22:17 </char><char closed="false" style="fq">Dio wong ngelukoi: </char><char closed="false" style="ft">Makno teks asli di sini kurang pasti.</char></note> tangan samo sekel aku.<verse eid="PSA 22:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 22:18" style="v"/>Aku pacak étóng slóró tulang-tulang aku.</para>
<para style="q2" vid="PSA 22:18">Dio wong jingok trós masati aku.<verse eid="PSA 22:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 22:19" style="v"/>Dio wong mbagéke pakean aku di antaro dio wong dewek,</para>
<para style="q2" vid="PSA 22:19">trós ngoncang undi óntók baju aku.<verse eid="PSA 22:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 22:20" style="v"/>Tapi Kau, ya <char style="nd">ALLAHyhwh</char>, janganla jaó!</para>
<para style="q2" vid="PSA 22:20">Ya kekuatan aku, gancangla tolong aku!<verse eid="PSA 22:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 22:21" style="v"/>Selametkela nyawo aku dari pedang,</para>
<para style="q2" vid="PSA 22:21">édóp aku dari cengkeman anjéng.<verse eid="PSA 22:21"/></para>
<para style="q1">
<verse number="22" sid="PSA 22:22" style="v"/>Selametkela aku dari mólót singo,</para>
<para style="q2" vid="PSA 22:22">dari tandók banteng.</para>
<para style="q1" vid="PSA 22:22">Kau la mbebaske aku!<verse eid="PSA 22:22"/></para>
<para style="b"/>
<para style="q1">
<verse number="23" sid="PSA 22:23" style="v"/>Aku bakal nyeritoke namo baék Kau samo dólór-dólór <char style="add">seiman</char> aku.</para>
<para style="q2" vid="PSA 22:23">Di tenga-tenga jemaah, aku bakal muji Kau.<verse eid="PSA 22:23"/></para>
<para style="q1">
<verse number="24" sid="PSA 22:24" style="v"/>Ói wong-wong yang takót samo <char style="nd">ALLAHyhwh</char>, pujila Dio!</para>
<para style="q2" vid="PSA 22:24">Ói slóró ketórónan <char style="w">Yakób</char>, mulyokela Dio!</para>
<para style="q2" vid="PSA 22:24">Segenla samo Dio, ói slóró anak-anak <char style="w">Israel</char>!<verse eid="PSA 22:24"/></para>
<para style="q1">
<verse number="25" sid="PSA 22:25" style="v"/>Dio idak ngerendake trós idak nganggep najés pendritoan wong yang saro,</para>
<para style="q2" vid="PSA 22:25">jugo Dio idak nyingitke rai-Nyo dari wong tu.</para>
<para style="q3" vid="PSA 22:25">Trós Dio ndenger pas wong tu bejerét mintak tolong samo Dio.<verse eid="PSA 22:25"/></para>
<para style="b"/>
<para style="q1">
<verse number="26" sid="PSA 22:26" style="v"/>Karno Kau aku muji-muji dalem jemaah yang besak.</para>
<para style="q2" vid="PSA 22:26">Trós aku nak mbayar najar aku di adepan wong-wong yang takót samo Dio.<verse eid="PSA 22:26"/></para>
<para style="q1">
<verse number="27" sid="PSA 22:27" style="v"/>Wong yang mendrito bakal makan, trós jadi kenyang.</para>
<para style="q2" vid="PSA 22:27">Wong yang nyari <char style="nd">ALLAHyhwh</char> bakal muji Dio.</para>
<para style="q1" vid="PSA 22:27">Biarla ati kau benyalo-nyalo selamonyo!<verse eid="PSA 22:27"/></para>
<para style="b"/>
<para style="q1">
<verse number="28" sid="PSA 22:28" style="v"/>Sampe ójóng bumi bakal teinget trós bebalék ke <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 22:28">Slóró kaóm bangso-bangso bakal sójód nyemba di adepan-Nyo.<verse eid="PSA 22:28"/></para>
<para style="q1">
<verse number="29" sid="PSA 22:29" style="v"/>Karno <char style="nd">ALLAHyhwh</char> bae yang bekuaso,</para>
<para style="q2" vid="PSA 22:29">trós Dio mrénto bangso-bangso.<verse eid="PSA 22:29"/></para>
<para style="b"/>
<para style="q1">
<verse number="30" sid="PSA 22:30" style="v"/>Slóró wong yang makmór di dunio ni bakal makan trós sójód nyemba Dio.</para>
<para style="q1" vid="PSA 22:30">Slóró wong yang tórón ke jeró liang kóbór<note caller="+" style="f"><char closed="false" style="fr">22:30 </char><char closed="false" style="fq">liang kóbór: </char><char closed="false" style="ft">Teks asli iola “lahan kematian”. Ide barés ni iola wong ni disiapke óntók kematian, karno denget lagi dio bakal mati.</char></note> bakal tóndók di adepan-Nyo,</para>
<para style="q2" vid="PSA 22:30">iola wong-wong yang dak pacak nyambóng édóp.<verse eid="PSA 22:30"/></para>
<para style="q1">
<verse number="31" sid="PSA 22:31" style="v"/>Anak cócóng bakal beibada samo Dio,</para>
<para style="q2" vid="PSA 22:31">trós bakal nyeritoke pasal Tuan samo tórónan yang bakal dateng.<verse eid="PSA 22:31"/></para>
<para style="q1">
<verse number="32" sid="PSA 22:32" style="v"/>Dio wong bakal dateng trós bakal ngabarke kebeneran-Nyo</para>
<para style="q2" vid="PSA 22:32">samo bangso yang bakal laér kagek,</para>
<para style="q3" vid="PSA 22:32">amen Diola yang ngelakukenyo.<verse eid="PSA 22:32"/></para>
<chapter eid="PSA 22"/>
<chapter number="23" sid="PSA 23" style="c"/>
<para style="s2">Allah miaro aku</para>
<para style="d">
<verse number="1" sid="PSA 23:1" style="v"/>Nyanyian <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 23:1"/>
<para style="q1" vid="PSA 23:1">
<char style="nd">
<char style="w">ALLAHyhwh</char>
</char> iola gembala aku;</para>
<para style="q2" vid="PSA 23:1">dak bakal kekurangan aku.<verse eid="PSA 23:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 23:2" style="v"/>Di padang yang berómpót ijo, Dio baréngke aku;</para>
<para style="q2" vid="PSA 23:2">ke banyu yang tenang, Dio nóntón aku.<verse eid="PSA 23:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 23:3" style="v"/>Jiwo aku Dio segerke.</para>
<para style="b" vid="PSA 23:3"/>
<para style="q1" vid="PSA 23:3">Dio mémpén aku di jalan kebeneran,</para>
<para style="q2" vid="PSA 23:3">óntók namo-Nyo.<verse eid="PSA 23:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 23:4" style="v"/>Mugola aku bejalan di bawa jurang yang surem,</para>
<para style="q2" vid="PSA 23:4">aku dak takót bahayo, karno Kau ado besamo aku.</para>
<para style="q1" vid="PSA 23:4">Tongkat samo pemókól Kau, itula yang ngébór aku.<verse eid="PSA 23:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 23:5" style="v"/>Kau nyiapke pesta óntók aku di adepan mósó aku.</para>
<para style="q2" vid="PSA 23:5">Kau sambót aku pecak tamu agóng.<note caller="+" style="f"><char closed="false" style="fr">23:5 </char><char closed="false" style="fq">Kau sambót aku pecak tamu agóng: </char><char closed="false" style="ft">Teks aslinyo iola, “Kau ngusap palak aku pakek minyak”. Dalem budayo Ibrani, ngusap palak makek minyak wangi iola caro nyambót tamu agóng.</char></note></para>
<para style="q2" vid="PSA 23:5">Cangkér aku penu terós.<note caller="+" style="f"><char closed="false" style="fr">23:5 </char><char closed="false" style="fq">Cangkér aku penu terós: </char><char closed="false" style="ft">Kiasan ini maksódnyo Allah iola tuan ruma yang idak pelét.</char></note><verse eid="PSA 23:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 23:6" style="v"/>Pastila kebaék'an jugo kasé stio <char style="add">Kau</char> bakal ngejer aku</para>
<para style="q2" vid="PSA 23:6">seómór édóp aku.</para>
<para style="q1" vid="PSA 23:6">Trós aku bakal netep di jeró <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng <char style="nd">ALLAHyhwh</char></char></para>
<para style="q2" vid="PSA 23:6">selamonyo.<verse eid="PSA 23:6"/></para>
<chapter eid="PSA 23"/>
<chapter number="24" sid="PSA 24" style="c"/>
<para style="s2">Kedatengan Allah ke jeró Ruma Agóng-Nyo di bumi</para>
<para style="d">
<verse number="1" sid="PSA 24:1" style="v"/>Nyanyian <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 24:1"/>
<para style="q1" vid="PSA 24:1">Bumi jugo slóró isinyo iola kepunyoan <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 24:1">dunio jugo slóró yang tinggal di dalemnyo.<verse eid="PSA 24:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 24:2" style="v"/>Soalnyo Dio yang la mbangón bumi tu</para>
<para style="q2" vid="PSA 24:2">di pócók laótan,</para>
<para style="q2" vid="PSA 24:2">trós negakkenyo di pócók arós-arós yang dalem.<verse eid="PSA 24:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 24:3" style="v"/>Siapo yang bole naék ke <char lemma="Sion" style="w">bókét <char style="nd">ALLAHyhwh</char></char>?</para>
<para style="q2" vid="PSA 24:3">Siapo yang bole tegak di tempat-Nyo yang suci?<verse eid="PSA 24:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 24:4" style="v"/>Wong yang tangannyo bersé jugo atinyo murni,</para>
<para style="q2" vid="PSA 24:4">yang idak ngenjókke dirinyo óntók penipuan,</para>
<para style="q2" vid="PSA 24:4">trós yang idak besumpa palsu.<verse eid="PSA 24:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 24:5" style="v"/>Dio bakal nerimo berkah dari <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 24:5">trós pembelaan dari Tuhan, penyelametnyo.<verse eid="PSA 24:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 24:6" style="v"/>Inila angkatan wong-wong yang nyari Dio,</para>
<para style="q2" vid="PSA 24:6">yang nyari hadérat Tuhannyo Yakób. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 24:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 24:7" style="v"/>Angkatla palak kau, ói lawang-lawang gerbang<note caller="+" style="f"><char closed="false" style="fr">24:7 </char><char closed="false" style="fq">lawang-lawang gerbang: </char><char closed="false" style="ft">Lawang gerbang yang dimaksód di sini iola lawang gerbang <char style="w">Ruma Agóng Allah</char> di Yerusalem. Lawang ni disóró bukak óntók nerimo kedatengan Allah.</char></note>!</para>
<para style="q2" vid="PSA 24:7">Teangkatla, ói lawang-lawang yang la beabad-abad!</para>
<para style="q2" vid="PSA 24:7">Supayo Rajo Yang Mahamulyo masók!<verse eid="PSA 24:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 24:8" style="v"/>Siapo Rajo Yang Mahamulyo tu?</para>
<para style="q2" vid="PSA 24:8">
<char style="nd">ALLAHyhwh</char> yang kuat jugo perkasa!</para>
<para style="q2" vid="PSA 24:8">
<char style="nd">ALLAHyhwh</char> yang perkasa dalem peperangan!<verse eid="PSA 24:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 24:9" style="v"/>Angkatla palak kau, ói lawang-lawang gerbang!</para>
<para style="q2" vid="PSA 24:9">Teangkatla, ói lawang-lawang yang la beabad-abad!</para>
<para style="q2" vid="PSA 24:9">Supayo Rajo Yang Mahamulyo masók!<verse eid="PSA 24:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 24:10" style="v"/>Siapo Rajo Yang Mahamulyo tu?</para>
<para style="q2" vid="PSA 24:10">
<char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
<para style="q2" vid="PSA 24:10">Diola Rajo Yang Mahamulyo! <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 24:10"/></para>
<chapter eid="PSA 24"/>
<chapter number="25" sid="PSA 25" style="c"/>
<para style="s2">Doa mintak peléndóngan jugo bémbéngan Allah<note caller="+" style="f"><char closed="false" style="fr">25:1 </char><char closed="false" style="ft">Di teks asli, óróp petamo tiap pemuloan ayat di S. Ny. 25 ni disósón nórót abjad baso Ibrani.</char></note></para>
<para style="d">
<verse number="1" sid="PSA 25:1" style="v"/>Dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 25:1"/>
<para style="q1" vid="PSA 25:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, aku ngangkat doa<note caller="+" style="f"><char closed="false" style="fr">25:1 </char><char closed="false" style="fq">ngangkat doa: </char><char closed="false" style="ft">Teks asli iola “ngangkat jiwo”. Ini ni kiasan Ibrani óntók bedoa.</char></note> aku ke Kau.<verse eid="PSA 25:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 25:2" style="v"/>Ya Tuhan aku, samo Kaula aku pecayo.</para>
<para style="q1" vid="PSA 25:2">Jangan biarke aku dipermaluke.</para>
<para style="q2" vid="PSA 25:2">Jangan biarke mósó-mósó aku beseneng-seneng karno aku,<verse eid="PSA 25:2"/></para>
<para style="q2">
<verse number="3" sid="PSA 25:3" style="v"/>jugo jangan biarke wong-wong yang nunggui Kau dipermaluke,</para>
<para style="q2" vid="PSA 25:3">tapi biarkela wong yang behianat dengen dak bealesan dipermaluke.<verse eid="PSA 25:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 25:4" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, enjóktaukela jalan-jalan <char style="add">yang nyenengke</char> Kau.</para>
<para style="q2" vid="PSA 25:4">Ajari aku caro-caro Kau.<verse eid="PSA 25:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 25:5" style="v"/>Pémpénla aku dalem kebeneran Kau trós ajarke Aku,</para>
<para style="q2" vid="PSA 25:5">karno Kaula Tuhan yang nyelametke aku.</para>
<para style="q2" vid="PSA 25:5">Aku nunggu-nunggui Kau siang malem.<verse eid="PSA 25:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 25:6" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ingetla pasal belas kesian Kau jugo kasé stio Kau,</para>
<para style="q2" vid="PSA 25:6">karno pasal-pasal tu la ado dari jaman bingen.<verse eid="PSA 25:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 25:7" style="v"/>Janganla Kau inget kesalahan-kesalahan aku,</para>
<para style="q2" vid="PSA 25:7">jugo duso-duso aku pas masé mudo,</para>
<para style="q1" vid="PSA 25:7">tapi ingetla aku sesuai dengen kasé stio Kau</para>
<para style="q2" vid="PSA 25:7">karno kebaék'an Kau, ya <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 25:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 25:8" style="v"/>
<char style="nd">ALLAHyhwh</char> tu baék jugo lórós,</para>
<para style="q2" vid="PSA 25:8">mangkonyo Dio ngajarke jalan-Nyo ke wong beduso.<verse eid="PSA 25:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 25:9" style="v"/>Dio mbémbéng wong yang renda ati dalem keadélan,</para>
<para style="q2" vid="PSA 25:9">trós Dio ngajarke jalan-Nyo ke wong yang renda ati.<verse eid="PSA 25:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 25:10" style="v"/>Slóró jalan <char style="nd">ALLAHyhwh</char> iola kasé stio jugo kebeneran</para>
<para style="q2" vid="PSA 25:10">óntók wong-wong yang nyekel pejanjian-Nyo jugo peratóran-Nyo.<verse eid="PSA 25:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 25:11" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, karno namo baék Kau, ampónila kesalahan aku,</para>
<para style="q2" vid="PSA 25:11">soalnyo besak kesalahan tu.<verse eid="PSA 25:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 25:12" style="v"/>Siapo bae yang takót samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 25:12">Allah bakal nónjókke jalan yang harós dipélényo.<verse eid="PSA 25:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 25:13" style="v"/>Wong tu bakal tinggal dalem kemakmóran,</para>
<para style="q2" vid="PSA 25:13">trós ketórónannyo bakal ngewarési bumi.<verse eid="PSA 25:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 25:14" style="v"/>
<char style="nd">ALLAHyhwh</char> bekawan baék samo wong yang takót samo Dio,</para>
<para style="q2" vid="PSA 25:14">trós pejanjian-Nyo dienjóktauke-Nyo ke dio wong.<verse eid="PSA 25:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 25:15" style="v"/>Mato aku terós-terósan jingok <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 25:15">karno Dio bakal metuke sekel aku dari jaréng.<verse eid="PSA 25:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 25:16" style="v"/>Tolela aku trós mura atila samo aku</para>
<para style="q2" vid="PSA 25:16">karno aku saro jugo dewek'an.<verse eid="PSA 25:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 25:17" style="v"/>Pendritoan di ati aku makén besak.</para>
<para style="q1" vid="PSA 25:17">Gawakla aku metu dari kesesekan aku.<verse eid="PSA 25:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 25:18" style="v"/>Jingokla kesaroan samo kesusahan aku,</para>
<para style="q2" vid="PSA 25:18">trós ampónila slóró duso aku.<verse eid="PSA 25:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 25:19" style="v"/>Jingokla mósó aku, karno banyak nian.</para>
<para style="q2" vid="PSA 25:19">Dio wong mbenci aku dengen kebencian yang kejem.<verse eid="PSA 25:19"/></para>
<para style="q1">
<verse number="20" sid="PSA 25:20" style="v"/>Jagola jiwo aku, trós lepaskela aku.</para>
<para style="q1" vid="PSA 25:20">Jangan biarke aku dipermaluke,</para>
<para style="q2" vid="PSA 25:20">soalnyo aku beléndóng samo Kau.<verse eid="PSA 25:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 25:21" style="v"/>Biarla ketólósan jugo kebeneran nyagoi aku,</para>
<para style="q2" vid="PSA 25:21">soalnyo aku nunggui Kau.<verse eid="PSA 25:21"/></para>
<para style="b"/>
<para style="q1">
<verse number="22" sid="PSA 25:22" style="v"/>Ya Allah, tebósla wong Israel dari segalo kesaroan.<verse eid="PSA 25:22"/></para>
<chapter eid="PSA 25"/>
<chapter number="26" sid="PSA 26" style="c"/>
<para style="s2">Doa mintak keadélan dari <char style="nd">ALLAHyhwh</char></para>
<para style="d">
<verse number="1" sid="PSA 26:1" style="v"/>Dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 26:1"/>
<para style="q1" vid="PSA 26:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, enjókla keadélan ke aku,</para>
<para style="q2" vid="PSA 26:1">karno aku ni la bejalan dengen ketólósan ati.</para>
<para style="q2" vid="PSA 26:1">Samo <char style="nd">ALLAHyhwh</char> aku pecayo; aku dak ragu.<verse eid="PSA 26:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 26:2" style="v"/>Selédékila aku, ya <char style="nd">ALLAHyhwh</char>, trós coboila aku.</para>
<para style="q2" vid="PSA 26:2">Ujila batén samo ati aku,<verse eid="PSA 26:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 26:3" style="v"/>karno kasé stio Kau ado di adepan mato aku,</para>
<para style="q2" vid="PSA 26:3">trós aku bakal bejalan dalem kebeneran Kau.<verse eid="PSA 26:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 26:4" style="v"/>Aku idak dódók samo wong yang galak ngolai,</para>
<para style="q2" vid="PSA 26:4">jugo idak melok samo wong yang munapék.<verse eid="PSA 26:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 26:5" style="v"/>Aku benci kómpólan wong yang bebuat jahat,</para>
<para style="q2" vid="PSA 26:5">aku jugo idak dódók samo wong bejat.<verse eid="PSA 26:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 26:6" style="v"/>Aku basó tangan aku tando idak besala,</para>
<para style="q2" vid="PSA 26:6">abés tu ngeléléngi meja pesembahan<note caller="+" style="f"><char closed="false" style="fr">26:6 </char><char closed="false" style="fq">ngeléléngi meja pesembahan Kau: </char><char closed="false" style="ft">Meja pesembahan tu cuman ado di Ruma Agóng Allah. Pecaknyo ini ngambarke sikok upacara yang dilakuke wong Ibrani di Ruma Agóng Allah besamo jemaah pas ibada.</char></note> Kau, ya <char style="nd">ALLAHyhwh</char>,<verse eid="PSA 26:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 26:7" style="v"/>óntók nyiarke ucapan sókór,</para>
<para style="q2" vid="PSA 26:7">jugo nyritoke slóró pebuatan Kau yang ajaéb.<verse eid="PSA 26:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 26:8" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, aku cinto samo <char lemma="Ruma Agóng Allah" style="w">Ruma tempat Kau tinggal</char>,</para>
<para style="q2" vid="PSA 26:8">iola Kemah di mano kemulyoan Kau netep.<verse eid="PSA 26:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 26:9" style="v"/>Janganla ambék nyawo aku besamo dengen wong-wong beduso tu,</para>
<para style="q2" vid="PSA 26:9">apo dak tu édóp aku besamo dengen pembunu,<verse eid="PSA 26:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 26:10" style="v"/>yang dalem tangannyo ado niat jahat,</para>
<para style="q2" vid="PSA 26:10">trós yang tangan kanannyo penu dengen sogokan.<verse eid="PSA 26:10"/></para>
<para style="b"/>
<para style="q1">
<verse number="11" sid="PSA 26:11" style="v"/>Tapi aku ni bakal bejalan dengen ketólósan ati.</para>
<para style="q1" vid="PSA 26:11">Selametkela aku jugo mura atila samo aku.<verse eid="PSA 26:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 26:12" style="v"/>Sekel aku tegak di tempat yang rato.</para>
<para style="q1" vid="PSA 26:12">Dalem jemaah aku bakal muji <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 26:12"/></para>
<chapter eid="PSA 26"/>
<chapter number="27" sid="PSA 27" style="c"/>
<para style="s2">Aman Dalem Léndóngan <char style="nd">ALLAHyhwh</char></para>
<para style="d">
<verse number="1" sid="PSA 27:1" style="v"/>Dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 27:1"/>
<para style="q1" vid="PSA 27:1">
<char style="nd">
<char style="w">ALLAHyhwh</char>
</char> iola terang aku jugo keselametan aku;</para>
<para style="q2" vid="PSA 27:1">samo siapo aku harós takót?</para>
<para style="q1" vid="PSA 27:1">
<char style="nd">ALLAHyhwh</char> iola benteng édóp aku;</para>
<para style="q2" vid="PSA 27:1">samo siapo aku harós gemeter?<verse eid="PSA 27:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 27:2" style="v"/>Pas wong-wong jahat dateng nyerang aku óntók makan dagéng aku,</para>
<para style="q2" vid="PSA 27:2">iola lawan-lawan aku jugo mósó-mósó aku,</para>
<para style="q2" vid="PSA 27:2">dio wong tula yang tebentor trós nyampak.<verse eid="PSA 27:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 27:3" style="v"/>Mugola bekemah sikok pasókan nempóri aku,</para>
<para style="q2" vid="PSA 27:3">ati aku dak lokak takót.</para>
<para style="q1" vid="PSA 27:3">Mugola móncól perang ngelawan aku,</para>
<para style="q2" vid="PSA 27:3">cak itu jugo aku tetep pecayo.<verse eid="PSA 27:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 27:4" style="v"/>Sikok pasal yang aku mintak dari <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 27:4">itula yang aku kendak'i:</para>
<para style="q1" vid="PSA 27:4">iola netep di jeró <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng <char style="nd">ALLAHyhwh</char></char> seómór édóp aku,</para>
<para style="q2" vid="PSA 27:4">óntók nyaksike keindahan <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 27:4">jugo óntók nyari <char style="add">Dio</char> di jeró Kemah Suci-Nyo.<verse eid="PSA 27:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 27:5" style="v"/>Soalnyo Dio bakal ngeléndóngi aku di tempat tedó-Nyo pas ari saro,</para>
<para style="q2" vid="PSA 27:5">Dio bakal nyingitke aku dalem léndóngan Kemah Suci-Nyo,</para>
<para style="q2" vid="PSA 27:5">trós Dio naékke aku ke pócók batu karang, <char style="add">tempat yang aman</char>.<verse eid="PSA 27:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 27:6" style="v"/>Mangko tu, palak aku teangkat di pócók mósó-mósó yang ngepóng aku.</para>
<para style="q1" vid="PSA 27:6">Trós di Kemah Suci-Nyo,</para>
<para style="q2" vid="PSA 27:6">aku bakal ngenjók kórban sembeléhan dengen besorak-sorak.</para>
<para style="q2" vid="PSA 27:6">Aku bakal nyanyike jugo ngelantónke puji-pujian óntók <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 27:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 27:7" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, dengerla suaro aku pas aku bejerét!</para>
<para style="q2" vid="PSA 27:7">Mura atila samo aku trós jawabla aku!<verse eid="PSA 27:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 27:8" style="v"/>Pasal Kau ati aku ngomong,</para>
<para style="q2" vid="PSA 27:8">“Carila hadérat-Nyo.”</para>
<para style="q2" vid="PSA 27:8">Hadérat Kau, ya <char style="nd">ALLAHyhwh</char>, bakal aku cari.<verse eid="PSA 27:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 27:9" style="v"/>Janganla nyingitke hadérat Kau dari aku.</para>
<para style="q2" vid="PSA 27:9">Dalem kemarahan Kau, janganla nolak hamba Kau ni.</para>
<para style="q1" vid="PSA 27:9">Kaula penolong aku,</para>
<para style="q2" vid="PSA 27:9">janganla nalakke aku apo ninggalke aku,</para>
<para style="q2" vid="PSA 27:9">ya Tuhan penyelamet aku!<verse eid="PSA 27:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 27:10" style="v"/>Mugola aba samo emak ninggalke aku,</para>
<para style="q2" vid="PSA 27:10">
<char style="nd">ALLAHyhwh</char> bakal nyambót aku.<verse eid="PSA 27:10"/></para>
<para style="b"/>
<para style="q1">
<verse number="11" sid="PSA 27:11" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ajarkela aku jalan Kau,</para>
<para style="q2" vid="PSA 27:11">trós pémpénla aku di jalan yang rato, karno mósó-mósó aku.<verse eid="PSA 27:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 27:12" style="v"/>Janganla nyerake aku ke kendak lawan-lawan aku,</para>
<para style="q2" vid="PSA 27:12">karno saksi-saksi palsu tu la bangkét nentang aku,</para>
<para style="q2" vid="PSA 27:12">iola saksi-saksi yang kejem<note caller="+" style="f"><char closed="false" style="fr">27:12 </char><char closed="false" style="fq">saksi-saksi yang kejem: </char><char closed="false" style="ft">Ado jugo tradisi yang napsérke kato-kato asli di sini óntók jadi “wong-wong yang ngembóske kekejeman”.</char></note>.<verse eid="PSA 27:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 27:13" style="v"/>Aku tetep pecayo kalu aku bakal jingok kebaék'an <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 27:13">di negri wong-wong yang édóp.<verse eid="PSA 27:13"/></para>
<para style="b"/>
<para style="q1">
<verse number="14" sid="PSA 27:14" style="v"/>
<char style="add">Ói dólórku</char>, ngarepla samo <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 27:14">Kuatkela jugo mantepkela ati kau!</para>
<para style="q2" vid="PSA 27:14">Iyo, ngarepla samo <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 27:14"/></para>
<chapter eid="PSA 27"/>
<chapter number="28" sid="PSA 28" style="c"/>
<para style="s2">Allah denger doa pemohonan umat-Nyo yang mintak tolong samo Dio</para>
<para style="d">
<verse number="1" sid="PSA 28:1" style="v"/>Dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 28:1"/>
<para style="q1" vid="PSA 28:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, samo Kaula aku bejerét!</para>
<para style="q2" vid="PSA 28:1">Ói gónóng batu aku, janganla Kau nótóp kópéng dari aku!</para>
<para style="q1" vid="PSA 28:1">Soalnyo amen Kau diem,</para>
<para style="q2" vid="PSA 28:1">aku jadi pecak wong yang tórón ke jeró liang kóbór.<verse eid="PSA 28:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 28:2" style="v"/>Dengerkela suaro pemohonan aku</para>
<para style="q2" vid="PSA 28:2">pas aku bejerét mintak tolong samo Kau,</para>
<para style="q2" vid="PSA 28:2">pas aku ngangkat tangan <char style="add">bedoa</char></para>
<para style="q3" vid="PSA 28:2">ke ara Ruang Mahasuci<note caller="+" style="f"><char closed="false" style="fr">28:2 </char><char closed="false" style="fq">Ruang Mahasuci: </char><char closed="false" style="ft">Ini ni ruangan yang paléng dalem di jeró </char><char style="w">Ruma Agóng Allah</char>. Waktu tu, ruangan ni iola tempat hadérat Allah dewek.</note> Kau.<verse eid="PSA 28:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 28:3" style="v"/>Jangan nyeret aku besamo-samo dengen wong beduso,</para>
<para style="q2" vid="PSA 28:3">dengen wong-wong yang bebuat jahat,</para>
<para style="q2" vid="PSA 28:3">yang ngomongnyo manis dengen sesamonyo,</para>
<para style="q3" vid="PSA 28:3">padahal di jeró atinyo ado kejahatan.<verse eid="PSA 28:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 28:4" style="v"/>Lakukela ke dio wong sesuai dengen apo yang digawekenyo,</para>
<para style="q2" vid="PSA 28:4">sesuai dengen kelakuan jahatnyo.</para>
<para style="q1" vid="PSA 28:4">Lakukela ke dio wong sesuai dengen pebuatan tangannyo.</para>
<para style="q1" vid="PSA 28:4">Enjókkela balesan ke dio wong.<verse eid="PSA 28:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 28:5" style="v"/>Karno dio wong idak nganggep apo yang digaweke <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 28:5">jugo pebuatan tangan-Nyo,</para>
<para style="q1" vid="PSA 28:5">Dio bakal ngancórke dio wong</para>
<para style="q2" vid="PSA 28:5">trós idak mbangónnyo lagi.<verse eid="PSA 28:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 28:6" style="v"/>Pujila <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 28:6">karno Dio la ndengerke suaro pemohonan aku.<verse eid="PSA 28:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 28:7" style="v"/>
<char style="nd">ALLAHyhwh</char> iola kekuatan jugo tameng aku.</para>
<para style="q2" vid="PSA 28:7">Aku pecayo samo Dio di jeró ati aku, trós aku ditolong.</para>
<para style="q1" vid="PSA 28:7">Ati aku beseneng,</para>
<para style="q2" vid="PSA 28:7">trós dengen nyanyian aku, aku nak besókór samo Dio.<verse eid="PSA 28:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 28:8" style="v"/>
<char style="nd">ALLAHyhwh</char> iola kekuatan umat-Nyo.</para>
<para style="q2" vid="PSA 28:8">Diola benteng keselametan óntók rajo yang dilanték-Nyo.<verse eid="PSA 28:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 28:9" style="v"/>Selametkela umat Kau,</para>
<para style="q2" vid="PSA 28:9">trós berkahila pusako kepunyoan Kau tu;</para>
<para style="q1" vid="PSA 28:9">gembalakela dio wong, trós gawakla dio wong <char style="add">dalem tangan Kau</char></para>
<para style="q2" vid="PSA 28:9">sampe selamo-lamonyo.<verse eid="PSA 28:9"/></para>
<chapter eid="PSA 28"/>
<chapter number="29" sid="PSA 29" style="c"/>
<para style="s2">Akuila kekuasoan Allah!</para>
<para style="d">
<verse number="1" sid="PSA 29:1" style="v"/>Nyanyian <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 29:1"/>
<para style="q1" vid="PSA 29:1">Akuila <char style="nd"><char style="w">ALLAHyhwh</char></char>, ói mahlók-mahlók surgawi<note caller="+" style="f"><char closed="false" style="fr">29:1 </char><char closed="false" style="fq">mahlók-mahlók surgawi: </char><char closed="false" style="ft">Ini ni maksódnyo nyóró slóró mahlók surgawi pecak malekat jugo dewo-dewo bangso laén óntók ngakui kehebatan Allah. (Jingok jugo catetan sekel pasal “Gónóng Sirion” di ayat 6.)</char></note>,</para>
<para style="q2" vid="PSA 29:1">akuila <char style="nd">ALLAHyhwh</char> karno kemulyoan jugo kekuatan-Nyo!<verse eid="PSA 29:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 29:2" style="v"/>Akuila <char style="nd">ALLAHyhwh</char> karno kemulyoan namo-Nyo!</para>
<para style="q1" vid="PSA 29:2">Sójódla samo <char style="nd">ALLAHyhwh</char> dengen behiaske kesucian!<verse eid="PSA 29:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 29:3" style="v"/>Suaro <char style="nd">ALLAHyhwh</char> <char style="add">pecak góntór</char> di pócók laótan;</para>
<para style="q2" vid="PSA 29:3">Tuhan Yang Mahamulyo begemóró,</para>
<para style="q2" vid="PSA 29:3">
<char style="nd">ALLAHyhwh</char> di pócók laótan luas.<verse eid="PSA 29:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 29:4" style="v"/>Suaro <char style="nd">ALLAHyhwh</char> tu bekuaso.</para>
<para style="q1" vid="PSA 29:4">Suaro <char style="nd">ALLAHyhwh</char> tu mulyo.<verse eid="PSA 29:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 29:5" style="v"/>Suaro <char style="nd">ALLAHyhwh</char> matake pohon-pohon besak<note caller="+" style="f"><char closed="false" style="fr">29:5 </char><char closed="false" style="fq">pohon-pohon besak: </char><char closed="false" style="ft">Teks asli iola “pohon-pohon aras”.</char></note>;</para>
<para style="q2" vid="PSA 29:5">iyo, <char style="nd">ALLAHyhwh</char> matake pohon-pohon aras Lebanon<note caller="+" style="f"><char closed="false" style="fr">29:5 </char><char closed="false" style="fq">pohon-pohon aras Lebanon: </char><char closed="false" style="ft">Pas jaman tu, pegónóngan Lebanon tekenal karno pohon-pohon arasnyo yang besak nian jugo kuat.</char></note>.<verse eid="PSA 29:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 29:6" style="v"/>Dio mbékén pegónóngan Lebanon kocar-kacér pecak anak sapi<note caller="+" style="f"><char closed="false" style="fr">29:6 </char><char closed="false" style="fq">pegónóngan Lebanon kocar-kacér pecak anak sapi: </char><char closed="false" style="ft">Ini ni maksódnyo pegónóngan Lebanon tegoncang pecak gempa bumi pas Allah metuke suaro-Nyo.</char></note>,</para>
<para style="q2" vid="PSA 29:6">jugo Gónóng Sirion<note caller="+" style="f"><char closed="false" style="fr">29:6 </char><char closed="false" style="fq">Gónóng Sirion: </char><char closed="false" style="ft">Ini ni namo laén óntók Gónóng Hermon, sala sikok gónóng besak yang ado di Lebanon. Gónóng ni dianggep tempat tinggalnyo dewo Baal, yang iola dewo besak wong Kanaan. Jadi amen gónóng ni tegoncang karno suaro Allah, artinyo Allah lebé kuat daripado dewo Baal tu.</char></note> pecak anak banteng.<verse eid="PSA 29:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 29:7" style="v"/>Suaro <char style="nd">ALLAHyhwh</char> mancarke kilatan api yang benyalo-nyalo.<verse eid="PSA 29:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 29:8" style="v"/>Suaro <char style="nd">ALLAHyhwh</char> geterke padang górón,</para>
<para style="q2" vid="PSA 29:8">
<char style="nd">ALLAHyhwh</char> geterke padang górón Kadesh.<verse eid="PSA 29:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 29:9" style="v"/>Suaro <char style="nd">ALLAHyhwh</char> mbékén ruso beranak,</para>
<para style="q2" vid="PSA 29:9">trós nelanjangi utan.</para>
<para style="q1" vid="PSA 29:9">Di jeró Ruma Agóng-Nyo</para>
<para style="q2" vid="PSA 29:9">tiap wong bejerét, “Mulyo!”<verse eid="PSA 29:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 29:10" style="v"/>
<char style="nd">ALLAHyhwh</char> bekuaso di pócók segalo banyu<note caller="+" style="f"><char closed="false" style="fr">29:10 </char><char closed="false" style="fq">segalo banyu: </char><char closed="false" style="ft">Yang dimaksód di sini iola segalo banyu yang ado di bumi jugo di langét, pecak laót, sungi, ujan, badai, sampe banyu banjér jugo. Jadi Allah bukan cuman nguasoi banyu di bumi bae tapi jugo banyu yang ado di surgo.</char></note>,</para>
<para style="q2" vid="PSA 29:10">
<char style="nd">ALLAHyhwh</char> bekuaso jadi Rajo óntók selamo-lamonyo.<verse eid="PSA 29:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 29:11" style="v"/>
<char style="nd">ALLAHyhwh</char> ngenjók kekuatan samo bangso-Nyo,</para>
<para style="q2" vid="PSA 29:11">
<char style="nd">ALLAHyhwh</char> mberkahi bangso-Nyo dengen damai sentoso.<verse eid="PSA 29:11"/></para>
<chapter eid="PSA 29"/>
<chapter number="30" sid="PSA 30" style="c"/>
<para style="s2">Ucapan sókór pas diselametke dari kematian</para>
<para style="d">
<verse number="1" sid="PSA 30:1" style="v"/>Saér nyanyian. Nyanyian ni <char style="add">perna dipakek</char> pas ngeresmike Ruma Agóng Allah<note caller="+" style="f"><char closed="false" style="fr">30:1 </char><char closed="false" style="fq">ngeresmike Ruma Agóng Allah: </char><char closed="false" style="ft">Upacara peresmian <char style="w">Ruma Agóng Allah</char> ni iola pecak yang diceritoke di </char><char closed="false" style="xt"><ref loc="1KI 8">1 Rajo-Rajo 8</ref></char><char closed="false" style="ft">samo </char><char closed="false" style="xt"><ref loc="EZR 6:16-18">Esra 6:16-18</ref></char><char closed="false" style="ft">.</char></note>. Dari <char style="w">Daód</char>.<verse eid="PSA 30:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 30:2" style="v"/>Aku bakal ngagóngke Kau, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 30:2">karno Kau narék aku naék,</para>
<para style="q2" vid="PSA 30:2">trós idak mbiarke mósó-mósó nyorak'i aku.<verse eid="PSA 30:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 30:3" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, ya Tuhan aku, samo Kaula aku bejerét,</para>
<para style="q2" vid="PSA 30:3">trós Kau nyembóke aku.<verse eid="PSA 30:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 30:4" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, Kau la ngangkat jiwo aku dari dunio wong mati.</para>
<para style="q2" vid="PSA 30:4">Kau nyelametke édóp aku dari antaro wong-wong yang tórón ke liang kóbór.<verse eid="PSA 30:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 30:5" style="v"/>Nyanyikela pujian óntók <char style="nd">ALLAHyhwh</char>, ói kamu wong-wong além-Nyo!</para>
<para style="q2" vid="PSA 30:5">Besókórla óntók namo-Nyo yang suci!<verse eid="PSA 30:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 30:6" style="v"/>Soalnyo kemarahan-Nyo cuman denget bae,</para>
<para style="q2" vid="PSA 30:6">tapi kemurahan-Nyo óntók seómór édóp.</para>
<para style="q1" vid="PSA 30:6">Sepanjang malem ado tangisan,</para>
<para style="q2" vid="PSA 30:6">tapi pas pagi ari ado sorak'an.<verse eid="PSA 30:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 30:7" style="v"/>Tapi aku, pas édóp lapang, aku <char style="add">dengen sombong</char> ngomong cak ini,</para>
<para style="q2" vid="PSA 30:7">“Aku dak bakal perna tegoyake!”<verse eid="PSA 30:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 30:8" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, pas kemurahan Kau,</para>
<para style="q2" vid="PSA 30:8">Kau tegakke aku pecak gónóng yang kuat;</para>
<para style="q1" vid="PSA 30:8">tapi pas Kau nyingiti rai Kau,</para>
<para style="q2" vid="PSA 30:8">aku ketakótan.<verse eid="PSA 30:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 30:9" style="v"/>Samo Kau, ya <char style="nd">ALLAHyhwh</char>, aku bejerét;</para>
<para style="q2" vid="PSA 30:9">samo Tuan aku mintak kemurahan. <char style="add">Uji aku</char>,<verse eid="PSA 30:9"/></para>
<para style="q2">
<verse number="10" sid="PSA 30:10" style="v"/>“Apo óntóngnyo amen dara aku <char style="add">tetumpa</char>,</para>
<para style="q3" vid="PSA 30:10">amen aku tórón ke liang kóbór?</para>
<para style="q2" vid="PSA 30:10">Apo debu manusio bakal muji Kau,</para>
<para style="q3" vid="PSA 30:10">jugo bakal mbritoke kestioan Kau?<verse eid="PSA 30:10"/></para>
<para style="q2">
<verse number="11" sid="PSA 30:11" style="v"/>Dengerla, ya <char style="nd">ALLAHyhwh</char>, trós mura atila samo aku!</para>
<para style="q3" vid="PSA 30:11">Ya <char style="nd">ALLAHyhwh</char>, jadila penolong aku!”<verse eid="PSA 30:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 30:12" style="v"/>Kau la ngoba ratepan aku jadi tarian,</para>
<para style="q2" vid="PSA 30:12">Kau la ngelepaske kaén kabóng aku,</para>
<para style="q2" vid="PSA 30:12">trós makekke kesenengan ke aku,<verse eid="PSA 30:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 30:13" style="v"/>sampe-sampe jiwo aku nyanyike pujian óntók Kau</para>
<para style="q2" vid="PSA 30:13">trós idak diem bae.</para>
<para style="q1" vid="PSA 30:13">Ya <char style="nd">ALLAHyhwh</char>, ya Tuhan aku, aku bakal besókór samo Kau</para>
<para style="q2" vid="PSA 30:13">óntók selamo-lamonyo.<verse eid="PSA 30:13"/></para>
<chapter eid="PSA 30"/>
<chapter number="31" sid="PSA 31" style="c"/>
<para style="s2">Wong pecayo jadi aman dalem tangan Allah</para>
<para style="d">
<verse number="1" sid="PSA 31:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 31:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 31:2" style="v"/>Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, samo Kaula aku beléndóng;</para>
<para style="q2" vid="PSA 31:2">jangan perna biarke aku dipermaluke.</para>
<para style="q1" vid="PSA 31:2">Lepaskela aku dalem keadélan Kau!<verse eid="PSA 31:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 31:3" style="v"/>Pasangla kópéng Kau óntók aku!</para>
<para style="q1" vid="PSA 31:3">Gancangla bebaske aku!</para>
<para style="q1" vid="PSA 31:3">Jadila gónóng batu peléndóngan aku,</para>
<para style="q2" vid="PSA 31:3">jugo benteng óntók nyelametke aku!<verse eid="PSA 31:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 31:4" style="v"/>Karno Kaula batu karang jugo benteng aku,</para>
<para style="q2" vid="PSA 31:4">jugo karno namo Kau, pémpénla trós tóntónla aku!<verse eid="PSA 31:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 31:5" style="v"/>Metukela aku dari jaréng</para>
<para style="q2" vid="PSA 31:5">yang diem-diem dipasang óntók aku,</para>
<para style="q2" vid="PSA 31:5">karno Kaula tempat peléndóngan aku.<verse eid="PSA 31:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 31:6" style="v"/>Ke dalem tangan Kaula aku serake diri<note caller="+" style="f"><char closed="false" style="fr">31:6 </char><char closed="false" style="fq">diri: </char><char closed="false" style="ft">Teks asli iola “ro”. Maksód barés ni bukan artinyo penyaér ni la nak mati, tapi maksódnyo tu iola penyaér nyerake dirinyo dalem léndóngan Allah.</char></note> aku;</para>
<para style="q2" vid="PSA 31:6">Kau la nebós aku, ya <char style="nd">ALLAHyhwh</char>, Tuhan yang stio.<verse eid="PSA 31:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 31:7" style="v"/>Aku benci wong yang nyemba berhalo yang sio-sio;</para>
<para style="q2" vid="PSA 31:7">tapi samo <char style="nd">ALLAHyhwh</char>, aku pecayo.<verse eid="PSA 31:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 31:8" style="v"/>Aku bakal besorak jugo beseneng dalem kasé stio Kau,</para>
<para style="q2" vid="PSA 31:8">karno Kau nyingok kesaroan aku</para>
<para style="q2" vid="PSA 31:8">jugo tau kesesekan jiwo aku.<verse eid="PSA 31:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 31:9" style="v"/>Kau idak nyerake aku ke tangan mósó,</para>
<para style="q2" vid="PSA 31:9">tapi Kau negakke sekel aku di tempat yang lapang.<verse eid="PSA 31:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 31:10" style="v"/>Mura atila samo aku, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 31:10">karno aku dalem kesesekan.</para>
<para style="q1" vid="PSA 31:10">Mato aku lesu karno sengsaro,</para>
<para style="q2" vid="PSA 31:10">cak itu jugo jiwo samo badan aku.<verse eid="PSA 31:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 31:11" style="v"/>Soalnyo édóp aku abés dengen kesedéan,</para>
<para style="q2" vid="PSA 31:11">jugo taón-taón aku dengen réntéan.</para>
<para style="q1" vid="PSA 31:11">Kekuatan aku róntó karno kesalahan aku,</para>
<para style="q2" vid="PSA 31:11">jugo tulang-tulang aku jadi keropos.<verse eid="PSA 31:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 31:12" style="v"/>Ole karno slóró mósó aku, aku dihino,</para>
<para style="q3" vid="PSA 31:12">dihino nian ole sesamo aku.</para>
<para style="q2" vid="PSA 31:12">Aku jadi kengerian óntók kawan-kawan aku.</para>
<para style="q2" vid="PSA 31:12">Wong-wong yang nyingok aku di jalan ngelarike diri dari aku.<verse eid="PSA 31:12"/></para>
<para style="q2">
<verse number="13" sid="PSA 31:13" style="v"/>Aku la dilupoke, pecak wong mati.</para>
<para style="q2" vid="PSA 31:13">Aku la jadi pecak guci yang ancór.<verse eid="PSA 31:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 31:14" style="v"/>Soalnyo aku denger bésékan dari banyak <char style="add">mósó</char>.</para>
<para style="q2" vid="PSA 31:14">Ado kengerian di mano-mano!</para>
<para style="q1" vid="PSA 31:14">Pas dio wong besamo-samo beróndéng ngelawan aku,</para>
<para style="q2" vid="PSA 31:14">dio wong beniat ngambék nyawo aku.<verse eid="PSA 31:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 31:15" style="v"/>Tapi aku pecayo samo Kau, ya <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 31:15">Uji aku, “Kaula Tuhan aku!”<verse eid="PSA 31:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 31:16" style="v"/>Takdér aku ado dalem tangan Kau.</para>
<para style="q1" vid="PSA 31:16">Lepaskela aku dari tangan mósó-mósó aku,</para>
<para style="q2" vid="PSA 31:16">dari wong-wong yang ngejer aku!<verse eid="PSA 31:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 31:17" style="v"/>Biarla cahayo rai Kau nyinari hamba Kau ni,</para>
<para style="q2" vid="PSA 31:17">trós selametkela aku karno kasé stio Kau.<verse eid="PSA 31:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 31:18" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, janganla biarke aku dipermaluke,</para>
<para style="q2" vid="PSA 31:18">karno aku bejerét samo Kau.</para>
<para style="q1" vid="PSA 31:18">Biarla wong-wong jahat dipermaluke;</para>
<para style="q2" vid="PSA 31:18">biarla dio wong tórón ke dunio wong mati trós tediem.<verse eid="PSA 31:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 31:19" style="v"/>Biarla bébér yang ngolai dikebet,</para>
<para style="q2" vid="PSA 31:19">yang ngomong dengen sombong ke wong bener,</para>
<para style="q2" vid="PSA 31:19">dengen ngesok jugo ngino.<verse eid="PSA 31:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 31:20" style="v"/>Alangke belimpanyo kebaék'an Kau</para>
<para style="q2" vid="PSA 31:20">yang la Kau siapke óntók wong-wong yang takót samo Kau,</para>
<para style="q2" vid="PSA 31:20">yang la Kau lakuke óntók wong-wong yang beléndóng samo Kau,</para>
<para style="q3" vid="PSA 31:20">di adepan anak-anak manusio!<verse eid="PSA 31:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 31:21" style="v"/>Di jeró léndóngan hadérat Kau, Kau nyingiti dio wong</para>
<para style="q2" vid="PSA 31:21">dari pesekongkolan manusio.</para>
<para style="q1" vid="PSA 31:21">Di tempat tedó, Kau ngeléndóngi dio wong</para>
<para style="q2" vid="PSA 31:21">dari adu mólót.<verse eid="PSA 31:21"/></para>
<para style="b"/>
<para style="q1">
<verse number="22" sid="PSA 31:22" style="v"/>Pujila <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 31:22">Karno Dio la nónjókke kasé stio-Nyo yang ajaéb samo aku</para>
<para style="q2" vid="PSA 31:22">pas aku ado di jeró kota yang tekepóng.<verse eid="PSA 31:22"/></para>
<para style="q1">
<verse number="23" sid="PSA 31:23" style="v"/>Aku ngomong dalem ketakótan aku,</para>
<para style="q2" vid="PSA 31:23">“Aku dibuang dari adepan mato Kau.”</para>
<para style="q1" vid="PSA 31:23">Tapi, Kau ndenger suaro pintak'an aku</para>
<para style="q2" vid="PSA 31:23">pas aku bejerét mintak tolong samo Kau.<verse eid="PSA 31:23"/></para>
<para style="b"/>
<para style="q1">
<verse number="24" sid="PSA 31:24" style="v"/>Kaséhila <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 31:24">ói kamu wong-wong além-Nyo!</para>
<para style="q1" vid="PSA 31:24">
<char style="nd">ALLAHyhwh</char> ngeléndóngi wong-wong yang stio,</para>
<para style="q2" vid="PSA 31:24">tapi mbales wong yang sombong dengen dak tanggóng-tanggóng.<verse eid="PSA 31:24"/></para>
<para style="q1">
<verse number="25" sid="PSA 31:25" style="v"/>Kuatkela trós tegukela ati kau,</para>
<para style="q2" vid="PSA 31:25">ói kamu wong-wong yang bearep samo <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 31:25"/></para>
<chapter eid="PSA 31"/>
<chapter number="32" sid="PSA 32" style="c"/>
<para style="s2">Kesenengan wong yang diampóni dusonyo</para>
<para style="d">
<verse number="1" sid="PSA 32:1" style="v"/>Dari <char style="w">Daód</char>. Maskil<note caller="+" style="f"><char closed="false" style="fr">32:1 </char><char closed="false" style="fq">Maskil: </char><char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char></note>.</para>
<para style="b" vid="PSA 32:1"/>
<para style="q1" vid="PSA 32:1">Senengla ati wong yang diampóni pelanggarannyo,</para>
<para style="q2" vid="PSA 32:1">yang dusonyo ditótópi.<verse eid="PSA 32:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 32:2" style="v"/>Senengla ati wong yang kesalahannyo idak diétóng <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 32:2">yang dalem jiwonyo katek penipuan.<verse eid="PSA 32:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 32:3" style="v"/>Pas aku diem <char style="add">pasal duso aku</char>,</para>
<para style="q2" vid="PSA 32:3">tulang-tulang aku jadi keropos karno jerétan aku sepanjang ari.<verse eid="PSA 32:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 32:4" style="v"/>Soalnyo siang jugo malem, tangan Kau neken aku,</para>
<para style="q2" vid="PSA 32:4">kekuatan<note caller="+" style="f"><char closed="false" style="fr">32:4 </char><char closed="false" style="fq">kekuatan: </char><char closed="false" style="ft">Makno teks asli dari kato ni dak pulok jelas.</char></note> aku tekeréng pecak dalem panasnyo mósém kemaró. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 32:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 32:5" style="v"/>Aku ngakui duso aku samo Kau,</para>
<para style="q2" vid="PSA 32:5">trós aku idak nyingiti kesalahan aku.</para>
<para style="q1" vid="PSA 32:5">Uji aku, “Aku bakal ngakui pelanggaran-pelanggaran aku samo <char style="nd">ALLAHyhwh</char>.”</para>
<para style="q1" vid="PSA 32:5">Trós Kau ngambék kesalahan <char style="add">aku dengen ngampóni</char> duso aku. <char style="qs">Selah</char><verse eid="PSA 32:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 32:6" style="v"/>Karno tu, biarla slóró wong além bedoa samo Kau pas kesesekan<note caller="+" style="f"><char closed="false" style="fr">32:6 </char><char closed="false" style="fq">pas kesesekan: </char><char closed="false" style="ft">Teks asli dari barés ni dak pulok jelas. Selaén “pas kesesekan”, arti dari teks asli pacak jugo jadi “pas Kau pacak ditemui” apo dak tu “pas aku nyadari duso aku”.</char></note>.</para>
<para style="q1" vid="PSA 32:6">Sebenernyo, pas banjér besak dateng,</para>
<para style="q2" vid="PSA 32:6">dio wong idak bakal keno.<verse eid="PSA 32:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 32:7" style="v"/>Kaula peléndóngan aku,</para>
<para style="q2" vid="PSA 32:7">Kau nyago aku dari kesaroan,</para>
<para style="q2" vid="PSA 32:7">Kau ngeléléngi aku dengen sorak'an karno keselametan. <char style="qs">Selah</char><verse eid="PSA 32:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 32:8" style="v"/>
<char style="add">Uji Allah,</char></para>
<para style="q2" vid="PSA 32:8">“Aku bakal ngajar trós nónjókke samo kau</para>
<para style="q3" vid="PSA 32:8">jalan yang harós kau jalani.</para>
<para style="q2" vid="PSA 32:8">Aku bakal nasehati kau</para>
<para style="q3" vid="PSA 32:8">dengen mato Aku tetójó ke kau.<verse eid="PSA 32:8"/></para>
<para style="q2">
<verse number="9" sid="PSA 32:9" style="v"/>Jangan jadi pecak kudo apo keledai yang katek akal,</para>
<para style="q3" vid="PSA 32:9">yang harós dikendalike dengen kekang jugo tali,</para>
<para style="q3" vid="PSA 32:9">
<char style="add">amen dak tu, binatang tu</char> dak bakal marak'i kau<note caller="+" style="f"><char closed="false" style="fr">32:9 </char><char closed="false" style="fq">yang harós dikendalike … dak bakal marak'i kau: </char><char closed="false" style="ft">Makno teks asli dari keduo barés ni dak pulok jelas.</char></note>.”<verse eid="PSA 32:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 32:10" style="v"/>Banyak kesaroan óntók wong jahat,</para>
<para style="q2" vid="PSA 32:10">tapi kasé stio <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 32:10">ngeléléngi wong yang pecayo samo Dio.<verse eid="PSA 32:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 32:11" style="v"/>Besenengla dalem <char style="nd">ALLAHyhwh</char> trós pujila,</para>
<para style="q2" vid="PSA 32:11">ói kamu wong-wong bener!</para>
<para style="q2" vid="PSA 32:11">Besorakla, ói slóró wong yang lórós ati!<verse eid="PSA 32:11"/></para>
<chapter eid="PSA 32"/>
<chapter number="33" sid="PSA 33" style="c"/>
<para style="s2">Puji-pujian óntók Allah, pencipto jugo penguaso dunio</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 33:1" style="v"/>Besorak-sorakla karno <char style="nd"><char style="w">ALLAHyhwh</char></char>, ói wong-wong bener!</para>
<para style="q2" vid="PSA 33:1">Pantesla wong yang lórós naékke puji-pujian.<verse eid="PSA 33:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 33:2" style="v"/>Ngucap sókórla samo <char style="nd">ALLAHyhwh</char> dengen kecapi!</para>
<para style="q2" vid="PSA 33:2">Dengen gambós sepóló senar, maénkela óntók Dio!<verse eid="PSA 33:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 33:3" style="v"/>Nyanyikela nyanyian yang baru óntók Dio!</para>
<para style="q2" vid="PSA 33:3">Maénkela kecapi dengen lihai, trós besorakla!<verse eid="PSA 33:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 33:4" style="v"/>Soalnyo, pirman <char style="nd">ALLAHyhwh</char> tu bener,</para>
<para style="q2" vid="PSA 33:4">jugo galo-galo pebuatan Dio digaweke-Nyo dengen kestioan.<verse eid="PSA 33:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 33:5" style="v"/>Dio cinto kebeneran jugo keadélan;</para>
<para style="q2" vid="PSA 33:5">bumi penu dengen kasé stio <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 33:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 33:6" style="v"/>Dengen omongan <char style="nd">ALLAHyhwh</char>, alam semesto dibékén,</para>
<para style="q2" vid="PSA 33:6">trós dengen napas dari mólót-Nyo dewek, Dio mbékén segalo yang ado di langét.<verse eid="PSA 33:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 33:7" style="v"/>Dio ngómpólke banyu laót pecak bendóngan,</para>
<para style="q2" vid="PSA 33:7">ditarok-Nyo laótan di jeró gudang-Nyo <char style="add">di pócók langét</char><note caller="+" style="f"><char closed="false" style="fr">33:7 </char><char closed="false" style="fq">gudang-Nyo di pócók langét: </char><char closed="false" style="ft">Pas Allah nyiptoke bumi, Dio misake banyu yang ado di bumi samo banyu yang ado di pócók langét (</char><char closed="false" style="xt"><ref loc="GEN 1:6-8">Asal Mulo Dunio 1:6-8</ref></char><char closed="false" style="ft">). Banyu yang di pócók langét jadi sumber ujan, trós secaro puitis tempat banyu tu disebót gudang Allah (jingok </char><char closed="false" style="xt"><ref loc="DEU 28:12">Ulangan 28:12</ref> </char><char closed="false" style="ft">samo </char><char closed="false" style="xt"><ref loc="JOB 38:22">Ayób 38:22</ref></char><char closed="false" style="ft">).</char></note>.<verse eid="PSA 33:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 33:8" style="v"/>Biarla slóró bumi takót samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 33:8">trós biarla slóró pendódók dunio kagóm samo Dio.<verse eid="PSA 33:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 33:9" style="v"/>Soalnyo, <char style="add">waktu tu</char> Dio ngomong, trós galonyo ado;</para>
<para style="q2" vid="PSA 33:9">Dio mrénto, trós galonyo ditetepke.<verse eid="PSA 33:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 33:10" style="v"/>
<char style="nd">ALLAHyhwh</char> ngancórke nasehat bangso-bangso,</para>
<para style="q2" vid="PSA 33:10">trós Dio ngalangi rencano suku-suku bangso.<verse eid="PSA 33:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 33:11" style="v"/>Tapi nasehat <char style="nd">ALLAHyhwh</char> tetep sampe selamo-lamonyo,</para>
<para style="q2" vid="PSA 33:11">trós rencano ati-Nyo sampe tórón-temórón.<verse eid="PSA 33:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 33:12" style="v"/>Senengla bangso yang Tuhannyo tu <char style="nd">ALLAHyhwh</char>;</para>
<para style="q2" vid="PSA 33:12">suku bangso yang la dipélé-Nyo dewek jadi pusako kepunyoan-Nyo.<verse eid="PSA 33:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 33:13" style="v"/>
<char style="nd">ALLAHyhwh</char> nyingok dari surgo;</para>
<para style="q2" vid="PSA 33:13">Dio nyingok galo-galo manusio.<verse eid="PSA 33:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 33:14" style="v"/>Dari tempat Dio dódók, Dio masati galo-galo yang tinggal di bumi.<verse eid="PSA 33:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 33:15" style="v"/>Diola yang mbentók ati dio wong galo,</para>
<para style="q2" vid="PSA 33:15">yang meratike segalo pebuatan dio wong.<verse eid="PSA 33:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 33:16" style="v"/>Rajo idak diselametke ole besaknyo pasókan.</para>
<para style="q2" vid="PSA 33:16">Tentra idak dibebaske ole besaknyo kekuatan.<verse eid="PSA 33:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 33:17" style="v"/>Kudo iola arepan yang sio-sio óntók kemenangan.</para>
<para style="q2" vid="PSA 33:17">Mugola kekuatannyo besak, dio dak pacak nyelametke.<verse eid="PSA 33:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 33:18" style="v"/>Jingokla, mato <char style="nd">ALLAHyhwh</char> nuju ke wong-wong yang takót samo Dio,</para>
<para style="q2" vid="PSA 33:18">jugo ke wong-wong yang ngarep kasé stio-Nyo,<verse eid="PSA 33:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 33:19" style="v"/>óntók ngelepaske jiwo dio wong dari maót,</para>
<para style="q2" vid="PSA 33:19">trós óntók miaro nyawo dio wong pas kelaperan.<verse eid="PSA 33:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 33:20" style="v"/>Jiwo kito nunggu-nunggui <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 33:20">Diola penolong jugo tameng kito.<verse eid="PSA 33:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 33:21" style="v"/>Soalnyo dalem Dio ati kito seneng</para>
<para style="q2" vid="PSA 33:21">karno kito pecayo samo namo-Nyo yang suci.<verse eid="PSA 33:21"/></para>
<para style="q1">
<verse number="22" sid="PSA 33:22" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, biarla kasé stio Kau tetep samo kami,</para>
<para style="q2" vid="PSA 33:22">pecak kami ngarep samo Kau.<verse eid="PSA 33:22"/></para>
<chapter eid="PSA 33"/>
<chapter number="34" sid="PSA 34" style="c"/>
<para style="s2">Berkah wong yang beléndóng samo Allah</para>
<para style="d">
<verse number="1" sid="PSA 34:1" style="v"/>Saér Daód, pas dio ecak-ecak gilo di adepan Abimelek sampe-sampe dio diósér, trós pegi.<note caller="-" style="x"><char closed="false" style="xo">34:1 </char><char closed="false" style="xt"><ref loc="1SA 21:13-15">1 Samuel 21:13-15</ref></char></note><verse eid="PSA 34:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 34:2" style="v"/>Aku bakal besókór samo <char style="nd"><char style="w">ALLAHyhwh</char></char> tiap ari,</para>
<para style="q2" vid="PSA 34:2">jugo pujian-Nyo bakal ado terós di mólót aku.<verse eid="PSA 34:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 34:3" style="v"/>Jiwo aku bakal ngagóngke <char style="nd">ALLAHyhwh</char>.</para>
<para style="q2" vid="PSA 34:3">Biarla wong yang saro ndengernyo trós beseneng-seneng.<verse eid="PSA 34:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 34:4" style="v"/>Ói mulyokela <char style="nd">ALLAHyhwh</char> besamo aku!</para>
<para style="q2" vid="PSA 34:4">Payó kito ninggike namo-Nyo besamo-samo!<verse eid="PSA 34:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 34:5" style="v"/>Aku nyari <char style="nd">ALLAHyhwh</char>, trós Dio nyawab aku.</para>
<para style="q2" vid="PSA 34:5">Dio mbebaske aku dari segalo ketakótan aku.<verse eid="PSA 34:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 34:6" style="v"/>Wong-wong nyingok'i Dio, trós jadi besinar.</para>
<para style="q2" vid="PSA 34:6">Rai dio wong dak bakal malu.<verse eid="PSA 34:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 34:7" style="v"/>Wong yang saro ni mekék, trós <char style="nd">ALLAHyhwh</char> ndenger dio.</para>
<para style="q2" vid="PSA 34:7">Dio nyelametkenyo dari segalo kesesekannyo.<verse eid="PSA 34:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 34:8" style="v"/>Malekat <char style="nd">ALLAHyhwh</char> bekemah di sekeléléng wong-wong yang takót samo Dio,</para>
<para style="q2" vid="PSA 34:8">trós ngelepaske dio wong.<verse eid="PSA 34:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 34:9" style="v"/>Rasokela trós jingokla <char style="add">dewek</char> amen <char style="nd">ALLAHyhwh</char> tu baék!<note caller="-" style="x"><char closed="false" style="xo">34:9 </char><char closed="false" style="xt"><ref loc="1PE 2:3">1 Petrus 2:3</ref></char></note></para>
<para style="q2" vid="PSA 34:9">Senengla wong yang beléndóng samo Dio.<verse eid="PSA 34:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 34:10" style="v"/>Takótla samo <char style="nd">ALLAHyhwh</char>, ói wong-wong suci-Nyo!</para>
<para style="q2" vid="PSA 34:10">Karno wong yang takót samo Dio dak bakal kekurangan.<verse eid="PSA 34:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 34:11" style="v"/>
<char style="add">Mugola</char> singo-singo mudo kekurangan jugo kelaperan,</para>
<para style="q2" vid="PSA 34:11">tapi wong-wong yang nyari <char style="nd">ALLAHyhwh</char> dak bakal kekurangan apo bae yang baék.<verse eid="PSA 34:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 34:12" style="v"/>Datengla móréd-móréd<note caller="+" style="f"><char closed="false" style="fr">34:12 </char><char closed="false" style="fq">móréd-móréd: </char><char closed="false" style="ft">Teks asli iola “anak-anak”. Di budayo Ibrani kuno, guru manggél móréd-mórédnyo dengen sebótan “anak-anak”, mugola wong tu la besak. (Jingok </char><char style="xt"><ref loc="PRO 1:8">Pribahaso 1:8</ref>; <ref loc="PRO 2:1">2:1</ref>,</char> jugo <char link-href="PRO 3:1" style="xt"><ref loc="PRO 3:1">3:1</ref></char> )</note>, dengerkela aku!</para>
<para style="q1" vid="PSA 34:12">Aku bakal ngajari kau óntók takót samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 34:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 34:13" style="v"/>Siapo yang galak édóp?</para>
<para style="q2" vid="PSA 34:13">Siapo yang seneng amen dio pacak jingok ari-ari yang baék?<verse eid="PSA 34:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 34:14" style="v"/>Jagola lida kau dari kejahatan,</para>
<para style="q2" vid="PSA 34:14">jugo bébér kau dari omongan yang ngotak'i.<verse eid="PSA 34:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 34:15" style="v"/>Bebalékla dari kejahatan, trós békénla yang baék.</para>
<para style="q1" vid="PSA 34:15">Carila kedamaian trós kejerla itu.<verse eid="PSA 34:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 34:16" style="v"/>Mato <char style="nd">ALLAHyhwh</char> ngara ke wong-wong yang bener,</para>
<para style="q2" vid="PSA 34:16">trós kópéng Dio tebukak óntók wong-wong yang mekék mintak tolong.<verse eid="PSA 34:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 34:17" style="v"/>Rai <char style="nd">ALLAHyhwh</char> nentang wong-wong yang mbékén kejahatan,</para>
<para style="q2" vid="PSA 34:17">óntók ngelenyepke dio wong sampe-sampe idak diinget lagi di bumi<note caller="+" style="f"><char closed="false" style="fr">34:17 </char><char closed="false" style="fq">óntók ngelenyepke dio wong sampe-sampe idak diinget lagi di bumi: </char><char closed="false" style="ft">Teks asli iola “óntók ngapóske ingetan pasal dio wong dari bumi”.</char></note>.<note caller="-" style="x"><char closed="false" style="xo">34:13-17 </char><char closed="false" style="xt"><ref loc="1PE 3:10-12">1 Petrus 3:10-12</ref></char></note><verse eid="PSA 34:17"/></para>
<para style="b"/>
<para style="q1">
<verse number="18" sid="PSA 34:18" style="v"/>Wong-wong bener mekék, trós <char style="nd">ALLAHyhwh</char> denger.</para>
<para style="q2" vid="PSA 34:18">Dio mbebaske dio wong dari segalo kesesekannyo.<verse eid="PSA 34:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 34:19" style="v"/>
<char style="nd">ALLAHyhwh</char> tu parak samo wong yang atinyo pata,</para>
<para style="q2" vid="PSA 34:19">trós Dio nyelametke wong-wong yang jiwonyo ancór.<verse eid="PSA 34:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 34:20" style="v"/>Kesaroan wong bener banyak,</para>
<para style="q2" vid="PSA 34:20">tapi <char style="nd">ALLAHyhwh</char> mbebaske dio dari galonyo tu.<verse eid="PSA 34:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 34:21" style="v"/>Dio nyago galo-galo tulang wong tu,</para>
<para style="q2" vid="PSA 34:21">dak katek sikok bae yang pata.<note caller="-" style="x"><char closed="false" style="xo">34:21 </char><char closed="false" style="xt"><ref loc="JHN 19:36">Yahya 19:36</ref></char></note><verse eid="PSA 34:21"/></para>
<para style="q1">
<verse number="22" sid="PSA 34:22" style="v"/>Kejahatan bakal mbunu wong jahat,</para>
<para style="q2" vid="PSA 34:22">trós siapo bae yang benci wong bener bakal dihókóm.<verse eid="PSA 34:22"/></para>
<para style="q1">
<verse number="23" sid="PSA 34:23" style="v"/>
<char style="nd">ALLAHyhwh</char> nebós jiwo hamba-hamba-Nyo,</para>
<para style="q2" vid="PSA 34:23">trós galo-galo yang beléndóng samo Dio</para>
<para style="q2" vid="PSA 34:23">idak bakal dihókóm-Nyo.<verse eid="PSA 34:23"/></para>
<chapter eid="PSA 34"/>






<chapter number="41" sid="PSA 41" style="c"/>
<para style="s2">Doa mintak kesembóan</para>
<para style="d">
<verse number="1" sid="PSA 41:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 41:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 41:2" style="v"/>Senengla wong yang ngesiani wong méskén!</para>
<para style="q2" vid="PSA 41:2">
<char style="nd">ALLAHyhwh</char> bakal ngelepaskenyo pas ari sialnyo.<verse eid="PSA 41:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 41:3" style="v"/>
<char style="nd">ALLAHyhwh</char> bakal ngeléndóngi jugo miaro nyawonyo.</para>
<para style="q2" vid="PSA 41:3">Dio bakal disebót wong seneng di bumi,</para>
<para style="q2" vid="PSA 41:3">trós Kau dak bakal nyerake dio ke tangan mósó-mósónyo.<verse eid="PSA 41:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 41:4" style="v"/>
<char style="nd">ALLAHyhwh</char> bakal nguatke dio di ranjangnyo pas sakét,</para>
<para style="q2" vid="PSA 41:4">trós di tempat tédóknyo Kau póléke dio dari sakétnyo.<verse eid="PSA 41:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 41:5" style="v"/>Uji aku ni, “Ya <char style="nd">ALLAHyhwh</char>, mura atila samo aku!</para>
<para style="q2" vid="PSA 41:5">Sembókela aku, karno aku la beduso samo Kau.”<verse eid="PSA 41:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 41:6" style="v"/>Mósó-mósó aku ngomong jahat pasal aku, <char style="add">cak ini</char>,</para>
<para style="q2" vid="PSA 41:6">“Kapanla dio bakal mati trós namonyo ilang?”<verse eid="PSA 41:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 41:7" style="v"/>Pas dateng jingok, dio nónjókke kemunapékan.</para>
<para style="q2" vid="PSA 41:7">Atinyo nyósón pitnahan,</para>
<para style="q1" vid="PSA 41:7">abés tu dio metu trós nyeritokenyo di jalan.<verse eid="PSA 41:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 41:8" style="v"/>Slóró wong yang mbenci aku samo-samo bebésék pasal aku,</para>
<para style="q2" vid="PSA 41:8">dio wong ngerencanoke kejahatan pasal aku, <char style="add">ujinyo</char>,<verse eid="PSA 41:8"/></para>
<para style="q3">
<verse number="9" sid="PSA 41:9" style="v"/>“Penyakét yang mematike la nimpo dio.</para>
<para style="q3" vid="PSA 41:9">Pas dio tédók, dio dak bakal bangón lagi.”<verse eid="PSA 41:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 41:10" style="v"/>Sampe-sampe kawan baék yang aku pecayoi,</para>
<para style="q2" vid="PSA 41:10">yang makan roti samo-samo aku,</para>
<para style="q2" vid="PSA 41:10">la ngangkat sekelnyo ngianati aku<note caller="+" style="f"><char closed="false" style="fr">41:10 </char><char closed="false" style="fq">la ngangkat sekelnyo ngianati aku: </char><char closed="false" style="ft">Teks asli iola “la ngangkat tumitnyo ke aku”. Makno kiasan ni dalem budayo asli Ibrani dak pulok jelas, tapi pecaknyo ini ni kiasan óntók ngianati wong. Ayat ni jugo dipakek Yesus di Yahya 13:18 pasal Yudas Iskariot yang behianat.</char></note>.<verse eid="PSA 41:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 41:11" style="v"/>Tapi Kau, ya <char style="nd">ALLAHyhwh</char>, mura atila samo aku, trós bangkétkela aku,</para>
<para style="q2" vid="PSA 41:11">supayo aku pacak mbales dio wong!<verse eid="PSA 41:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 41:12" style="v"/>Inila caro aku tau Kau seneng samo aku:</para>
<para style="q2" vid="PSA 41:12">karno mósó aku dak pacak nyorak-nyorak'i aku.<verse eid="PSA 41:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 41:13" style="v"/>Aku Kau topang karno ketólósan ati aku,</para>
<para style="q2" vid="PSA 41:13">trós Kau nempatke aku di adepan Kau óntók selamo-lamonyo.<verse eid="PSA 41:13"/></para>
<para style="b"/>
<para style="q1">
<verse number="14" sid="PSA 41:14" style="v"/>Tepujila <char style="nd">ALLAHyhwh</char>, Tuhannyo Israel,</para>
<para style="q2" vid="PSA 41:14">dari selamo-lamonyo sampe selamo-lamonyo!</para>
<para style="q1" vid="PSA 41:14">“Iyo, kami ngamininyo!”<verse eid="PSA 41:14"/></para>
<chapter eid="PSA 41"/>




<chapter number="46" sid="PSA 46" style="c"/>
<para style="s2" vid="PSA 45:18">Allah, kota benteng kito<verse eid="PSA 45:18"/></para>
<para style="d">
<verse number="1" sid="PSA 46:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni</char> dari ketórónan Korah. <char style="add">Dinyanyike </char> nórót alamot<note caller="+" style="f"><char closed="false" style="fr">46:1 </char><char closed="false" style="fq">alamot: </char><char closed="false" style="ft">Kato Ibrani ni biasonyo digunoke óntók sebótan sekelompok betino, tapi di sini digunoke pecak istila kósós óntók musik. Maknonyo di sini kurang jelas, tapi móngkén nónjókke nada tinggi.</char></note>. Saér nyanyian.<verse eid="PSA 46:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 46:2" style="v"/>Allah iola tempat peléndóngan jugo kekuatan kito,</para>
<para style="q2" vid="PSA 46:2">penolong yang hadér terós dalem kesaroan.<verse eid="PSA 46:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 46:3" style="v"/>Karno tu kito dak bakal takót, mugola bumi dirombak</para>
<para style="q2" vid="PSA 46:3">jugo gónóng-gónóng róntó di tenga-tenga laótan;<verse eid="PSA 46:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 46:4" style="v"/>mugola banyunyo begolak jugo bebóé,</para>
<para style="q2" vid="PSA 46:4">trós gónóng-gónóng tegoncang ole keganasan banyu tu. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 46:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 46:5" style="v"/>Ado sungi.</para>
<para style="q2" vid="PSA 46:5">Aléran-alérannyo nyenengke kota Allah<note caller="+" style="f"><char closed="false" style="fr">46:5 </char><char closed="false" style="fq">kota Allah: </char><char closed="false" style="ft">Yang dimaksód di sini iola kota <char style="w">Yerusalem</char>.</char></note>,</para>
<para style="q3" vid="PSA 46:5">iola tempat suci, tempat tinggal Yang Mahabesak.<verse eid="PSA 46:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 46:6" style="v"/>Allah ado di tenga kota tu.</para>
<para style="q2" vid="PSA 46:6">Kota tu dak bakal róntó.</para>
<para style="q2" vid="PSA 46:6">Allah bakal nolongnyo pas pagi ari.<verse eid="PSA 46:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 46:7" style="v"/>Bangso-bangso begolak;</para>
<para style="q2" vid="PSA 46:7">kerajaan-kerajaan róntó.</para>
<para style="q1" vid="PSA 46:7">Dio metuke suaro-Nyo;</para>
<para style="q2" vid="PSA 46:7">bumi ancór.<verse eid="PSA 46:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 46:8" style="v"/>
<char style="nd">ALLAHyhwh</char>, Tuan semesto alam besamo kito,</para>
<para style="q2" vid="PSA 46:8">kota benteng kito iola Tuhannyo <char style="w">Yakób</char>. <char style="qs">Selah</char><verse eid="PSA 46:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 46:9" style="v"/>Payó! Jingokla pebuatan <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 46:9">yang mbékén keancóran di bumi!<verse eid="PSA 46:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 46:10" style="v"/>Dio berentike petempóran sampe ke ójóng bumi.</para>
<para style="q2" vid="PSA 46:10">Bósór pana Dio patake;</para>
<para style="q2" vid="PSA 46:10">tombak Dio tetak'i;</para>
<para style="q2" vid="PSA 46:10">tameng-tameng<note caller="+" style="f"><char closed="false" style="fr">46:10 </char><char closed="false" style="fq">tameng-tameng: </char><char closed="false" style="ft">Teks asli kato ni pacak jugo diartike “kreto-kreto”. </char></note> Dio tunu dengen api.<verse eid="PSA 46:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 46:11" style="v"/>
<char style="add">Uji-Nyo,</char> “Diemla! Trós sadarila amen Akula Allah!</para>
<para style="q2" vid="PSA 46:11">Aku bakal diagóngke di antaro bangso-bangso,</para>
<para style="q2" vid="PSA 46:11">Aku bakal diagóngke di bumi!”<verse eid="PSA 46:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 46:12" style="v"/>
<char style="nd">ALLAHyhwh</char>, Tuan semesto alam besamo kito,</para>
<para style="q2" vid="PSA 46:12">kota benteng kito iola Tuhannyo Yakób. <char style="qs">Selah</char><verse eid="PSA 46:12"/></para>
<chapter eid="PSA 46"/>
<chapter number="47" sid="PSA 47" style="c"/>
<para style="s2">Allah, Rajo slóró bumi</para>
<para style="d">
<verse number="1" sid="PSA 47:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni</char> dari ketórónan Korah. Saér nyanyian.<verse eid="PSA 47:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 47:2" style="v"/>Ói slóró bangso, betepók tanganla!</para>
<para style="q2" vid="PSA 47:2">Besorak-sorakla óntók Allah dengen suaro yang seneng.<verse eid="PSA 47:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 47:3" style="v"/>Soalnyo <char style="nd"><char style="w">ALLAHyhwh</char></char> Yang Mahabesak tu ditakóti,</para>
<para style="q2" vid="PSA 47:3">Rajo Besak di slóró bumi.<verse eid="PSA 47:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 47:4" style="v"/>Dio narok bangso-bangso di bawa <char style="add">kuaso</char> kito,</para>
<para style="q2" vid="PSA 47:4">trós suku-suku bangso di bawa sekel kito.<verse eid="PSA 47:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 47:5" style="v"/>Dio nentuke óntók kito tana warésan kito<note caller="+" style="f"><char closed="false" style="fr">47:5 </char><char closed="false" style="fq">tana warésan kito: </char><char closed="false" style="ft">Yang dimaksód tana warésan di sini iola Tana Pejanjian.</char></note>,</para>
<para style="q2" vid="PSA 47:5">iola kebanggaan <char style="w">Yakób</char> yang Dio kaséhi. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 47:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 47:6" style="v"/>Allah la naék <char style="add">ke korsi kekuasoan-Nyo</char> diéréngi sorak'an;</para>
<para style="q2" vid="PSA 47:6">
<char style="nd">ALLAHyhwh</char> <char style="add">la naék</char>, diéréngi bunyi sangkakala<note caller="+" style="f"><char closed="false" style="fr">47:6 </char><char closed="false" style="fq">sangkakala: </char><char closed="false" style="ft">Ini ni jenis alat musik tiup, pecak terompet besak tebuat dari tandók. Dalem budayo Ibrani, sangkakala dibunyike pas nyambót rajo.</char></note>.<verse eid="PSA 47:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 47:7" style="v"/>Nyanyikela puji-pujian óntók Allah! Nyanyikela!</para>
<para style="q2" vid="PSA 47:7">Nyanyikela puji-pujian óntók Rajo kito! Nyanyikela!<verse eid="PSA 47:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 47:8" style="v"/>Soalnyo Allah iola Rajo slóró bumi.</para>
<para style="q2" vid="PSA 47:8">Nyanyikela saér nyanyian!<verse eid="PSA 47:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 47:9" style="v"/>Allah mrénto bangso-bangso.</para>
<para style="q2" vid="PSA 47:9">Allah dódók di pócók korsi-Nyo yang suci.<verse eid="PSA 47:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 47:10" style="v"/>Wong-wong besak bangso-bangso bekómpól</para>
<para style="q2" vid="PSA 47:10">besamo umat Tuhannyo Ibrahim<note caller="+" style="f"><char closed="false" style="fr">47:10 </char><char closed="false" style="fq">besamo umat Tuhannyo Ibrahim: </char><char closed="false" style="ft">Barés ni pacak jugo ditejemake cak ini, “jadi umat Tuhannyo Ibrahim”.</char></note>.</para>
<para style="q1" vid="PSA 47:10">Soalnyo Allah bae yang punyo tameng-tameng bumi.</para>
<para style="q1" vid="PSA 47:10">Dio diagóngke nian!<verse eid="PSA 47:10"/></para>
<chapter eid="PSA 47"/>
<chapter number="48" sid="PSA 48" style="c"/>
<para style="s2">Sion, kota Allah</para>
<para style="d">
<verse number="1" sid="PSA 48:1" style="v"/>Nyanyian. Saér dari ketórónan Korah.<verse eid="PSA 48:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 48:2" style="v"/>Besakla <char style="nd"><char style="w">ALLAHyhwh</char></char> jugo tepuji nian</para>
<para style="q2" vid="PSA 48:2">di kota Tuhan kito, bókét-Nyo yang suci.<verse eid="PSA 48:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 48:3" style="v"/>Cindó menjulang, kesenengan óntók slóró bumi,</para>
<para style="q2" vid="PSA 48:3">itula bókét <char style="w">Sion</char>, kota Rajo Besak,</para>
<para style="q2" vid="PSA 48:3">yang ado di ójóng sebela utara!<verse eid="PSA 48:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 48:4" style="v"/>Allah ado di jeró benteng-bentengnyo.</para>
<para style="q2" vid="PSA 48:4">Dio la ngenalke diri jadi tempat peléndóngan yang tinggi.<verse eid="PSA 48:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 48:5" style="v"/>Soalnyo jingokla! Rajo-rajo bekómpól.</para>
<para style="q2" vid="PSA 48:5">Dio wong nyerbu serempak.<verse eid="PSA 48:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 48:6" style="v"/>Dio wong jingok, abés tu tepelongok.</para>
<para style="q2" vid="PSA 48:6">Dio wong panik,</para>
<para style="q3" vid="PSA 48:6">trós lari ketakótan<note caller="+" style="f"><char closed="false" style="fr">48:5-6 </char><char closed="false" style="fq">Rajo-rajo bekómpól.… trós lari ketakótan: </char><char closed="false" style="ft">Di sini rajo-rajo mósó Israel dateng óntók nyerbu kota Sion (iola Yerusalem, ibu kota Israel pas jaman tu). Tapi pas dio wong nyingok Allah ngeléndóngi kota tu, dio wong lari ketakótan. </char></note>.<verse eid="PSA 48:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 48:7" style="v"/>Dio wong gemeter ketakótan di sano,</para>
<para style="q2" vid="PSA 48:7">trós kesakétan nian pecak betino yang nak beranak.<verse eid="PSA 48:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 48:8" style="v"/>Dengen angin timur</para>
<para style="q2" vid="PSA 48:8">Kau ngancórke kapal-kapal Tarsis<note caller="+" style="f"><char closed="false" style="fr">48:8 </char><char closed="false" style="fq">Tarsis: </char><char closed="false" style="ft">Sikok kota di Laót Tenga yang tekenal pas jaman tu karno kapal-kapalnyo yang besak. Letak kota tu jaó dari Israel, tapi kapalnyo dikenal di mano-mano karno pedagangan.</char></note>.<verse eid="PSA 48:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 48:9" style="v"/>Pecak yang la kito denger, pecak itu jugo yang kito jingok,</para>
<para style="q2" vid="PSA 48:9">di kota <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
<para style="q2" vid="PSA 48:9">di kota Tuhan kito.</para>
<para style="q1" vid="PSA 48:9">Allah negóke kota tu óntók selamo-lamonyo. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 48:9"/></para>
<para style="b"/>
<para style="q1">
<verse number="10" sid="PSA 48:10" style="v"/>Ya Allah, kami nginget kasé stio Kau</para>
<para style="q2" vid="PSA 48:10">di jeró <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng Kau</char>.<verse eid="PSA 48:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 48:11" style="v"/>Samo pecak namo baék Kau, ya Allah,</para>
<para style="q2" vid="PSA 48:11">cak itu jugo puji-pujian óntók Kau sampe ke ójóng-ójóng bumi.</para>
<para style="q1" vid="PSA 48:11">Kau penu keadélan<note caller="+" style="f"><char closed="false" style="fr">48:11 </char><char closed="false" style="fq">Kau penu keadélan: </char><char closed="false" style="ft">Teks aslinyo iola, “Tangan kanan Kau penu keadélan”, yang artinyo slóró kepótósan Allah tu bener.</char></note>.<verse eid="PSA 48:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 48:12" style="v"/>Biarkela bókét Sion beseneng;</para>
<para style="q2" vid="PSA 48:12">biarkela dósón-dósón Yehuda<note caller="+" style="f"><char closed="false" style="fr">48:12 </char><char closed="false" style="fq">dósón-dósón Yehuda: </char><char closed="false" style="ft">Teks aslinyo iola “anak-anak (betino) Yehuda”. “Anak betino” di sini jadi gambaran dósón yang pecak anak dari propinsi/kerajaan Yehuda. Kota Yerusalem/Sion iola ibu kota Yehuda.</char></note> besorak-sorak</para>
<para style="q2" vid="PSA 48:12">karno kepótósan pengadélan Kau<note caller="+" style="f"><char closed="false" style="fr">48:12 </char><char closed="false" style="fq">besorak-sorak karno kepótósan pengadélan Kau: </char><char closed="false" style="ft">Dio wong besorak-sorak karno Allah ngakémi mósó-mósó dio wong.</char></note>.<verse eid="PSA 48:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 48:13" style="v"/>Payó! Bejalanla muteri Sion, trós keléléngila dio.</para>
<para style="q2" vid="PSA 48:13">Étóngla menara-menaranyo.<verse eid="PSA 48:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 48:14" style="v"/>Pasatila tembok-temboknyo,</para>
<para style="q2" vid="PSA 48:14">liwatla di antaro benteng-bentengnyo,</para>
<para style="q2" vid="PSA 48:14">supayo kamu pacak nyeritokenyo samo angkatan berékótnyo.<verse eid="PSA 48:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 48:15" style="v"/>Sebenernyo, inila Allah,</para>
<para style="q2" vid="PSA 48:15">Tuhan kito óntók seterósnyo jugo selamo-lamonyo!</para>
<para style="q2" vid="PSA 48:15">Diola yang bakal mémpén kito sampe selesai<note caller="+" style="f"><char closed="false" style="fr">48:15 </char><char closed="false" style="fq">sampe selesai: </char><char closed="false" style="ft">Makno keduo kato ni di teks aslinyo kurang jelas.</char></note>!<verse eid="PSA 48:15"/></para>
<chapter eid="PSA 48"/>


<chapter number="51" sid="PSA 51" style="c"/>
<para style="s2" vid="PSA 50:23">Doa mintak diampóni Allah<verse eid="PSA 50:23"/></para>
<para style="d">
<verse number="1" sid="PSA 51:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari Daód, <verse eid="PSA 51:1"/><verse number="2" sid="PSA 51:2" style="v"/>pas Nabi Natan dateng ke dio abés dio marak'i Batsyeba<note caller="+" style="f"><char closed="false" style="fr">51:2 </char><char closed="false" style="fq">Batsyeba: </char><char closed="false" style="ft">Dio ni bininyo prajórét Daód yang benamo Uria. Daód bejina samo Batsyeba trós ngerencanoke supayo Uria mati dalem perang. (Jingokla </char><char closed="false" style="xt"><ref loc="2SA 12:1-15">2 Samuel 12:1-15</ref></char><char closed="false" style="ft">.) </char></note>.<verse eid="PSA 51:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 51:3" style="v"/>Mura atila samo aku, ya Allah, nórót kasé stio Kau;</para>
<para style="q2" vid="PSA 51:3">nórót belas kesian Kau yang besak, apóskela pelanggaran-pelanggaran aku!<verse eid="PSA 51:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 51:4" style="v"/>Basóla aku nian-nian dari kesalahan aku;</para>
<para style="q2" vid="PSA 51:4">sucikela aku dari duso aku.<verse eid="PSA 51:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 51:5" style="v"/>Soalnyo aku nyadari pelanggaran-pelanggaran aku,</para>
<para style="q2" vid="PSA 51:5">trós duso aku ado terós di adepan aku.<verse eid="PSA 51:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 51:6" style="v"/>Samo Kau, samo Kau baela aku beduso,</para>
<para style="q2" vid="PSA 51:6">trós di mato Kau aku la ngelakuke kejahatan;</para>
<para style="q1" vid="PSA 51:6">mangko Kau bener pas Kau ngomong<note caller="-" style="x"><char closed="false" style="xo">51:6 </char><char closed="false" style="xt"><ref loc="2SA 12:7-12">2 Samuel 12:7-12</ref></char></note>,</para>
<para style="q2" vid="PSA 51:6">trós tólós pas Kau ngakémi.<verse eid="PSA 51:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 51:7" style="v"/>Sebenernyo, aku la besala pas dilaérke,</para>
<para style="q2" vid="PSA 51:7">trós la beduso pas dikandóng emak aku<note caller="+" style="f"><char closed="false" style="fr">51:7 </char><char closed="false" style="fq">aku la besala pas dilaérke, trós la beduso pas dikandóng emak aku: </char><char closed="false" style="ft">Dio ngomong cak ini karno dio ngeraso beduso nian. Mugola dio belóm ngelakuke duso pas di jeró kandóngan, tapi dio la nerimo sipat bawakan manusio yang beduso. Amen katek petolongan Allah, pasti kito ngelakuke duso terós. Omongan dio ni idak bemaksód amen emaknyo sala ngandóng dio.</char></note>.<verse eid="PSA 51:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 51:8" style="v"/>Sebenernyo, kestioanla yang Kau senengi di jeró batén<note caller="+" style="f"><char closed="false" style="fr">51:8 </char><char closed="false" style="fq">batén: </char><char closed="false" style="ft">Arti kato Ibrani di teks asli di sini kurang jelas.</char></note>,</para>
<para style="q2" vid="PSA 51:8">trós Kau enjóktauke hikmah samo aku di jeró bagéan yang tesingit<note caller="+" style="f"><char closed="false" style="fr">51:8 </char><char closed="false" style="fq">bagéan yang tesingit: </char><char closed="false" style="ft">Arti kato Ibrani di teks asli di sini kurang jelas.</char></note>.<verse eid="PSA 51:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 51:9" style="v"/>Apóskela duso aku dengen percékan banyu<note caller="+" style="f"><char closed="false" style="fr">51:9 </char><char closed="false" style="fq">percékan banyu: </char><char closed="false" style="ft">Teks aslinyo iola “ranténg hisop”. Di budayo Ibrani, ranténg hisop digunoke óntók nyucike wong. Ranténg hisop dicelópke ke jeró banyu, trós banyunyo dipercékke ke wong yang nak disucike.</char></note>, mangko aku jadi suci;</para>
<para style="q2" vid="PSA 51:9">basóla aku, mangko aku jadi lebé póté dari salju.<verse eid="PSA 51:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 51:10" style="v"/>Biarkela aku denger kemeriahan samo kesenengan;</para>
<para style="q2" vid="PSA 51:10">biarkela tulang-tulang yang Kau remókke besorak<note caller="+" style="f"><char closed="false" style="fr">51:10 </char><char closed="false" style="fq">biarkela tulang-tulang yang Kau remókke besorak: </char><char closed="false" style="ft">Maksódnyo wong ini mintak Allah móléke dio seabés hókómannyo diselesaike.</char></note>.<verse eid="PSA 51:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 51:11" style="v"/>Singitkela rai Kau dari duso-duso aku,</para>
<para style="q2" vid="PSA 51:11">trós apóskela slóró kesalahan aku.<verse eid="PSA 51:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 51:12" style="v"/>Ciptokela ati yang suci óntók aku, ya Allah,</para>
<para style="q2" vid="PSA 51:12">trós barukela ro yang tegu di jeró batén aku.<verse eid="PSA 51:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 51:13" style="v"/>Janganla buang aku dari hadérat Kau,</para>
<para style="q2" vid="PSA 51:13">trós janganla ambék dari aku ro Kau yang suci.<verse eid="PSA 51:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 51:14" style="v"/>Balékkela ke aku kesenengan yang dari keselametan Kau,</para>
<para style="q2" vid="PSA 51:14">trós enjókkela aku ro keridoan.<verse eid="PSA 51:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 51:15" style="v"/>Mangko aku bakal ngajarke jalan Kau samo wong-wong yang ngelakuke pelanggaran,</para>
<para style="q2" vid="PSA 51:15">trós wong-wong beduso tu bakal bebalék samo Kau.<verse eid="PSA 51:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 51:16" style="v"/>Lepaskela aku dari utang dara<note caller="+" style="f"><char closed="false" style="fr">51:16 </char><char closed="false" style="fq">utang dara: </char><char closed="false" style="ft">Teks aslinyo iola “dara-dara”. Maksód dari kato ni kurang jelas antaro duso karno mbunu samo kematian yang kejem.</char></note>,</para>
<para style="q2" vid="PSA 51:16">ya Allah, ya Tuhan keselametan aku,</para>
<para style="q2" vid="PSA 51:16">mangko lida aku bakal besorak-sorak karno kebeneran Kau.<verse eid="PSA 51:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 51:17" style="v"/>Ya Tuan, bukakkela bébér aku,</para>
<para style="q2" vid="PSA 51:17">mangko mólót aku nyatoke puji-pujian samo Kau!<verse eid="PSA 51:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 51:18" style="v"/>Soalnyo Kau idak ngendak'i kórban sembeléhan.</para>
<para style="q2" vid="PSA 51:18">Sekironyo aku nyembake kórban bakaran, Kau dak seneng.<verse eid="PSA 51:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 51:19" style="v"/>Kórban sembeléhan <char style="add">yang dikendak'i</char> Allah iola jiwo yang ancór.</para>
<para style="q2" vid="PSA 51:19">Ati yang ancór jugo remók dak bakal Kau hino, ya Allah.<verse eid="PSA 51:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 51:20" style="v"/>Bebuat baékla samo <char style="w">Sion</char> sesuai yang Kau senengi.</para>
<para style="q2" vid="PSA 51:20">Bangónla tembok-tembok <char style="w">Yerusalem</char>.<verse eid="PSA 51:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 51:21" style="v"/>Mangko Kau bakal seneng nerimo kórban-kórban sembeléhan yang bener,</para>
<para style="q2" vid="PSA 51:21">iola kórban bakaran yang ótó, yang ditunu sampe abés;</para>
<para style="q2" vid="PSA 51:21">mangko sapi-sapi lanang bakal disembake di pócók meja pesembahan Kau.<verse eid="PSA 51:21"/></para>
<chapter eid="PSA 51"/>

<chapter number="53" sid="PSA 53" style="c"/>
<para style="s2" vid="PSA 52:11">Kebórókan Manusio<verse eid="PSA 52:11"/></para>
<para style="d">
<verse number="1" sid="PSA 53:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót mahalat<note caller="+" style="f"><char closed="false" style="fr">53:1 </char><char closed="false" style="fq">mahalat: </char><char closed="false" style="ft">Kato ni iola kato di teks asli. Maknonyo kurang jelas. Móngkén namo nyanyian apo dak tu alat musik.</char></note>. Nyanyian pengajaran Daód.<verse eid="PSA 53:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 53:2" style="v"/>Wong tekak ngomong dalem atinyo,</para>
<para style="q2" vid="PSA 53:2">“Katek Tuhan!”</para>
<para style="q1" vid="PSA 53:2">Dio wong busuk ati, trós kecalakannyo kejem.</para>
<para style="q2" vid="PSA 53:2">Katek yang bebuat baék.<verse eid="PSA 53:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 53:3" style="v"/>Allah masati dari surgo,</para>
<para style="q2" vid="PSA 53:3">ke anak-anak manusio,</para>
<para style="q1" vid="PSA 53:3">óntók jingok kalu bae ado wong yang bijak,</para>
<para style="q2" vid="PSA 53:3">yang nyari Allah.<verse eid="PSA 53:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 53:4" style="v"/>Dio wong galo la nyimpang,</para>
<para style="q2" vid="PSA 53:4">samo-samo rusak.</para>
<para style="q1" vid="PSA 53:4">Katek yang bebuat baék,</para>
<para style="q2" vid="PSA 53:4">sikok wong bae idak.<verse eid="PSA 53:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 53:5" style="v"/>Idak sadar apo wong-wong yang bebuat jahat tu?</para>
<para style="q2" vid="PSA 53:5">Dio wong tu makani umat aku pecak makan roti,</para>
<para style="q2" vid="PSA 53:5">jugo idak bejerét samo Allah.<verse eid="PSA 53:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 53:6" style="v"/>Di sano dio wong bakal ketakótan nian,</para>
<para style="q2" vid="PSA 53:6">padahal katek apo-apo óntók ditakóti,</para>
<para style="q1" vid="PSA 53:6">karno Allah bakal ngambórke tulang wong-wong yang bekemah ngepóng kau.</para>
<para style="q2" vid="PSA 53:6">Kau bakal maluke dio wong karno Allah nolak dio wong.<verse eid="PSA 53:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 53:7" style="v"/>Kironyo keselametan wong-wong <char style="w">Israel</char> dateng dari <char style="w">Sion</char>!</para>
<para style="q1" vid="PSA 53:7">Pas Allah balékke keadaan umat-Nyo tu,</para>
<para style="q2" vid="PSA 53:7">
<char style="w">Yakób</char> bakal besorak-sorak jugo Israel bakal seneng.<verse eid="PSA 53:7"/></para>
<chapter eid="PSA 53"/>
<chapter number="54" sid="PSA 54" style="c"/>
<para style="s2">Doa mintak pembelaan</para>
<para style="d">
<verse number="1" sid="PSA 54:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi</char> kecapi. Maskil<note caller="+" style="f"><char closed="false" style="fr">54:1 </char><char closed="false" style="fq">Maskil: </char><char closed="false" style="ft">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char></note> <char style="w">Daód</char>, <verse eid="PSA 54:1"/><verse number="2" sid="PSA 54:2" style="v"/>pas wong Jipi dateng ngomong samo Saól cak ini, “Daód singitan di tempat kami.”<note caller="-" style="x"><char closed="false" style="xo">54:2 </char><char closed="false" style="xt"><ref loc="1SA 23:15-24">1 Samuel 23:15-24</ref>; <ref loc="1SA 26:1-5">26:1-5</ref></char></note><verse eid="PSA 54:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 54:3" style="v"/>Ya Allah, selametkela aku ole <char style="add">kehebatan</char> namo Kau,</para>
<para style="q2" vid="PSA 54:3">trós bela-la pekaro aku dengen kekuasoan Kau.<verse eid="PSA 54:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 54:4" style="v"/>Ya Allah, dengerkela doa aku;</para>
<para style="q2" vid="PSA 54:4">peratikela omongan-omongan dari mólót aku.<verse eid="PSA 54:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 54:5" style="v"/>Soalnyo wong-wong laén bangkét ngelawan aku,</para>
<para style="q2" vid="PSA 54:5">jugo wong-wong kejem ngincer nyawo aku.</para>
<para style="q2" vid="PSA 54:5">Dio wong idak nempatke Allah di adepan dirinyo. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 54:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 54:6" style="v"/>Jingokla! Allah iola penolong aku;</para>
<para style="q2" vid="PSA 54:6">Tuan aku iola penopang jiwo aku.<verse eid="PSA 54:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 54:7" style="v"/>Biarkela kejahatan bebalék nimpo mósó-mósó aku.</para>
<para style="q2" vid="PSA 54:7">Karno kestioan Kau, matikela dio wong!<verse eid="PSA 54:7"/></para>
<para style="b"/>
<para style="q1">
<verse number="8" sid="PSA 54:8" style="v"/>Dengen seneng ati aku bakal nyembake kórban samo Kau.</para>
<para style="q2" vid="PSA 54:8">Aku bakal ngucap sókór samo namo Kau, ya <char style="nd">ALLAHyhwh</char>, karno namo Kau baék.<verse eid="PSA 54:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 54:9" style="v"/>Soalnyo Kau la ngelepaske aku dari slóró kesesekan,</para>
<para style="q2" vid="PSA 54:9">jadi mato aku jingok'i bae mósó aku.<verse eid="PSA 54:9"/></para>
<chapter eid="PSA 54"/>


















<chapter number="73" sid="PSA 73" style="c"/>
<para style="s2" vid="PSA 72:20">Di tenga pegómólan iman manusio, Allah tetep baék<verse eid="PSA 72:20"/></para>
<para style="d">
<verse number="1" sid="PSA 73:1" style="v"/>Nyanyian Asaf<note caller="-" style="x"><char closed="false" style="xo">73:1</char><char closed="false" style="xt"><ref loc="1CH 16:4-37">1 Riwayat 16:4-37</ref></char></note>.</para>
<para style="b" vid="PSA 73:1"/>
<para style="q1" vid="PSA 73:1">Sebenernyo Allah tu baék óntók wong Israel,</para>
<para style="q2" vid="PSA 73:1">óntók wong-wong yang murni atinyo.<verse eid="PSA 73:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 73:2" style="v"/>Tapi aku, ampér tepleset sekel aku,</para>
<para style="q2" vid="PSA 73:2">jugo ampér tegeléncér langka aku.<verse eid="PSA 73:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 73:3" style="v"/>Soalnyo aku iri samo wong yang sombong.</para>
<para style="q2" vid="PSA 73:3">Kemakmóran wong jahat aku jingok'i.<verse eid="PSA 73:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 73:4" style="v"/>Soalnyo dio wong idak kesakétan pas mati.</para>
<para style="q1" vid="PSA 73:4">Badan dio wong gemuk.<verse eid="PSA 73:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 73:5" style="v"/>Dio wong idak ngerasoke kesaroan pecak wong laén,</para>
<para style="q2" vid="PSA 73:5">trós dio wong idak keno sial pecak manusio laén.<verse eid="PSA 73:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 73:6" style="v"/>Karno tu dio wong bekalóng kesombongan;</para>
<para style="q2" vid="PSA 73:6">dio wong makek baju kekerasan.<verse eid="PSA 73:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 73:7" style="v"/>Mato dio wong tesipit<note caller="+" style="f"><char closed="false" style="fr">73:7 </char><char closed="false" style="fq">tesipit: </char><char closed="false" style="ft">Teks asli iola “metu”, tapi makno kiasan “mato dio wong metu” dak pulok jelas. Pecaknyo ini ni peumpamoan kuno yang maknonyo la dak dikenal lagi.</char></note> karno kegemukan.</para>
<para style="q1" vid="PSA 73:7">Rencano jahat di ati dio wong belebéan.<verse eid="PSA 73:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 73:8" style="v"/>Dio wong ngolok-ngolok'i trós ngato-ngatoi wong dengen jahat;</para>
<para style="q2" vid="PSA 73:8">pasal pemeresan diomongke dio wong dengen sombong.<verse eid="PSA 73:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 73:9" style="v"/>Mólót dio wong ngomong pecak la bekuaso di surgo,</para>
<para style="q2" vid="PSA 73:9">trós lida dio wong ngerajolela di bumi<note caller="+" style="f"><char closed="false" style="fr">73:9 </char><char closed="false" style="fq">Mólót dio wong ngomong pecak la bekuaso di surgo, trós lida dio wong ngerajolela di bumi: </char><char closed="false" style="ft">Teks asli iola “dio wong narok mólótnyo di surgo, trós lida dio wong bejalan di bumi”. Maknonyo dak pulok jelas. </char></note>.<verse eid="PSA 73:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 73:10" style="v"/>Karno tu umat-Nyo bebalék ara ke dio wong,</para>
<para style="q2" vid="PSA 73:10">nganggep dio wong pecak banyu yang meluber.<note caller="+" style="f"><char closed="false" style="fr">73:10 </char><char closed="false" style="fq">Karno tu umat-Nyo … banyu yang meluber: </char><char closed="false" style="ft">Makno teks asli dari ayat ni dak pulok jelas.</char></note><verse eid="PSA 73:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 73:11" style="v"/>Dio wong ngomong, “Cakmano móngkén Allah tau?</para>
<para style="q2" vid="PSA 73:11">Memangnyo ado pengetauan samo Yang Mahabesak?”<verse eid="PSA 73:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 73:12" style="v"/>Jingok, cak inila wong-wong jahat:</para>
<para style="q2" vid="PSA 73:12">édóp tenang selamo-lamonyo,</para>
<para style="q2" vid="PSA 73:12">jugo hartonyo betamba-tamba.<verse eid="PSA 73:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 73:13" style="v"/>Sebenernyo sio-sio bae aku nyago kesucian ati aku,</para>
<para style="q2" vid="PSA 73:13">trós mbasó tangan aku tando dak besala.<verse eid="PSA 73:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 73:14" style="v"/>Siang malem aku keno sial,</para>
<para style="q2" vid="PSA 73:14">jugo tiap pagi aku keno hókóman.<verse eid="PSA 73:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 73:15" style="v"/>Seandainyo aku ngatoke, “Aku nak ngomong yang samo pecak dio wong,”</para>
<para style="q2" vid="PSA 73:15">laju aku behianat samo angkatan anak-anak Kau.<verse eid="PSA 73:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 73:16" style="v"/>Pas aku bemaksód nak mahami slórónyo tu,</para>
<para style="q2" vid="PSA 73:16">pasal tu jadi saro di mato aku,<verse eid="PSA 73:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 73:17" style="v"/>sampe aku masók ke jeró tempat suci Allah,</para>
<para style="q2" vid="PSA 73:17">trós nyingok ahér dio wong <char style="add">kagek</char>.<verse eid="PSA 73:17"/></para>
<para style="b"/>
<para style="q1">
<verse number="18" sid="PSA 73:18" style="v"/>Sebenernyo, Kau tarok dio wong di tempat-tempat yang lécén,</para>
<para style="q2" vid="PSA 73:18">trós Kau campakke dio wong sampe ancór.<verse eid="PSA 73:18"/></para>
<para style="q1">
<verse number="19" sid="PSA 73:19" style="v"/>Alangke <char style="add">gancangnyo</char> dio wong róntó dalem sekejep mato,</para>
<para style="q2" vid="PSA 73:19">abés nian ole kengerian.<verse eid="PSA 73:19"/></para>
<para style="q1">
<verse number="20" sid="PSA 73:20" style="v"/>Pecak kami mandang hino mimpi pas kami tebangón<note caller="+" style="f"><char closed="false" style="fr">73:20 </char><char closed="false" style="fq">Pecak kami mandang hino mimpi pas kami tebangón: </char><char closed="false" style="ft">Teks asli iola, “Pecak mimpi pas wong tebangón”. Maksódnyo wong-wong jahat tu samo pecak mimpi bórók yang gancang ilang pas kito tebangón.</char></note>, ya Tuan,</para>
<para style="q2" vid="PSA 73:20">Kau bakal mandang hino rupo dio wong pas <char style="add">Kau</char> tejago.<verse eid="PSA 73:20"/></para>
<para style="b"/>
<para style="q1">
<verse number="21" sid="PSA 73:21" style="v"/>Pas ati aku paét</para>
<para style="q2" vid="PSA 73:21">jugo batén aku tetósók,<verse eid="PSA 73:21"/></para>
<para style="q1">
<verse number="22" sid="PSA 73:22" style="v"/>aku ni lolo jugo idak ngerti;</para>
<para style="q2" vid="PSA 73:22">aku pecak binatang di adepan Kau.<verse eid="PSA 73:22"/></para>
<para style="b"/>
<para style="q1">
<verse number="23" sid="PSA 73:23" style="v"/>Tapi aku terós-terósan besamo Kau.</para>
<para style="q2" vid="PSA 73:23">Kau megang tangan kanan aku.<verse eid="PSA 73:23"/></para>
<para style="q1">
<verse number="24" sid="PSA 73:24" style="v"/>Kau nóntón aku dengen nasehat Kau,</para>
<para style="q2" vid="PSA 73:24">abés tu Kau gawak aku ke dalem kemulyoan.<verse eid="PSA 73:24"/></para>
<para style="q1">
<verse number="25" sid="PSA 73:25" style="v"/>Siapo lagi yang aku punyo di surgo selaén Kau?</para>
<para style="q1" vid="PSA 73:25">Di bumi ni, katek yang kupéngéni selaén Kau.<verse eid="PSA 73:25"/></para>
<para style="q1">
<verse number="26" sid="PSA 73:26" style="v"/>Jiwo samo rago aku pacak abés,</para>
<para style="q2" vid="PSA 73:26">tapi Allah iola gónóng batu óntók ati aku</para>
<para style="q2" vid="PSA 73:26">jugo bagéan aku selamo-lamonyo.<verse eid="PSA 73:26"/></para>
<para style="b"/>
<para style="q1">
<verse number="27" sid="PSA 73:27" style="v"/>Soalnyo jingokla, wong-wong yang jaó dari Kau bakal mati,</para>
<para style="q2" vid="PSA 73:27">
<char style="add">karno</char> Kau musnake slóró wong yang nduoke Kau.<verse eid="PSA 73:27"/></para>
<para style="q1">
<verse number="28" sid="PSA 73:28" style="v"/>Óntók aku, amen parak samo Allah, cuman itula yang baék.</para>
<para style="q2" vid="PSA 73:28">Aku la jadike Tuan <char style="nd">ALLAHyhwh</char> tempat peléndóngan aku,</para>
<para style="q2" vid="PSA 73:28">supayo aku pacak nyeritoke slóró pebuatan Kau!<verse eid="PSA 73:28"/></para>
<chapter eid="PSA 73"/>










<chapter number="84" sid="PSA 84" style="c"/>
<para style="s2" vid="PSA 83:19">Kangen Ruma Agóng Allah di Yerusalem<verse eid="PSA 83:19"/></para>
<para style="d">
<verse number="1" sid="PSA 84:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót gitit<note caller="+" style="f"><char closed="false" style="fr">84:1 </char><char closed="false" style="fq">gitit: </char><char closed="false" style="ft">Kato ni iola kato di teks asli. Maknonyo dak pulok jelas. Móngkén namo nyanyian apo dak tu alat musik.</char></note>. Nyanyian dari ketórónan Korah.<verse eid="PSA 84:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 84:2" style="v"/>Alangke nyenengkenyo tempat Kau tinggal,</para>
<para style="q2" vid="PSA 84:2">ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, Tuan semesto alam!<verse eid="PSA 84:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 84:3" style="v"/>Jiwo aku kangen samo halaman <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 84:3">sampe telesu karnonyo.</para>
<para style="q1" vid="PSA 84:3">Jiwo rago aku nyorak-nyorak'i Tuhan yang édóp.<verse eid="PSA 84:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 84:4" style="v"/>Mala bóróng pépét la dapet ruma,</para>
<para style="q2" vid="PSA 84:4">trós bóróng layang-layang dapet sikok sarang óntók dirinyo,</para>
<para style="q2" vid="PSA 84:4">tempat narok anak-anaknyo parak meja-meja pesembahan Kau,</para>
<para style="q3" vid="PSA 84:4">ya <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
<para style="q3" vid="PSA 84:4">ya Rajo aku jugo Tuhan aku!<verse eid="PSA 84:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 84:5" style="v"/>Senengla wong-wong yang ado terós di ruma Kau!</para>
<para style="q2" vid="PSA 84:5">Dio wong terós-terósan muji Kau. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 84:5"/></para>
<para style="b"/>
<para style="q1">
<verse number="6" sid="PSA 84:6" style="v"/>Senengla wong-wong yang ndapetke kekuatannyo dari Kau,</para>
<para style="q2" vid="PSA 84:6">yang atinyo kangen óntók bejiara<note caller="+" style="f"><char closed="false" style="fr">84:6 </char><char closed="false" style="fq">yang atinyo kangen óntók bejiara: </char><char closed="false" style="ft">Teks asli iola “jalan-jalan besak ado di atinyo”. Arti “jalan-jalan besak” iola jalan-jalan yang ngara ke <char style="w">Yerusalem</char> trós diliwati wong-wong yang nak bejiara ke <char style="w">Ruma Agóng Allah</char>.</char></note> <char style="add">ke ruma Kau</char>.<verse eid="PSA 84:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 84:7" style="v"/>Sementaro dio wong ngeliwati Lemba Bakka<note caller="+" style="f"><char closed="false" style="fr">84:7 </char><char closed="false" style="fq">Lemba Bakka: </char><char closed="false" style="ft">Pecaknyo ini ni iola namo tempat yang diliwati pas bejiara ke Yerusalem. Bukan nónjókke alam baka. </char></note>,</para>
<para style="q2" vid="PSA 84:7">dio wong mbékénnyo<note caller="+" style="f"><char closed="false" style="fr">84:7 </char><char closed="false" style="fq">dio wong mbékénnyo: </char><char closed="false" style="ft">Dalem beberapo naska laénnyo tetólés cak ni, “Dio [Allah] mbékénnyo jadi tempat bemato banyu óntók dio wong”.</char></note> jadi tempat yang bemato banyu.</para>
<para style="q2" vid="PSA 84:7">Mala ujan pas awal mósém nyelimutinyo dengen berkah.<verse eid="PSA 84:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 84:8" style="v"/>Dio wong bejalan dalem kekuatan yang dak abés-abés,</para>
<para style="q2" vid="PSA 84:8">ngadep Allah di <char style="w">Sion</char>.<verse eid="PSA 84:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 84:9" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, Tuan semesto alam, dengerkela doa aku.</para>
<para style="q2" vid="PSA 84:9">Peratikela, ya Tuhannyo Yakób! <char style="qs">Selah</char><verse eid="PSA 84:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 84:10" style="v"/>Jingokla tameng kami<note caller="+" style="f"><char closed="false" style="fr">84:10 </char><char closed="false" style="fq">tameng kami: </char><char closed="false" style="ft">Ini ni biasonyo dianggep kiasan óntók rajo, karno rajo ngeléndóngi rakyatnyo. Di barés selanjótnyo, “wong yang Kau lanték” jugo nónjókke rajo.</char></note> <char style="add">dengen kebaék'an Kau</char>, ya Allah,</para>
<para style="q2" vid="PSA 84:10">pasatila rai wong yang Kau lanték.<verse eid="PSA 84:10"/></para>
<para style="b"/>
<para style="q1">
<verse number="11" sid="PSA 84:11" style="v"/>Sebenernyo lebé baék seari bae di halaman Kau</para>
<para style="q2" vid="PSA 84:11">daripado seribu <char style="add">ari di tempat laén</char>.</para>
<para style="q1" vid="PSA 84:11">Aku lebé galak tegak di lawang ruma Tuhan aku</para>
<para style="q2" vid="PSA 84:11">daripado tinggal di ruma wong jahat.<verse eid="PSA 84:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 84:12" style="v"/>Soalnyo Tuhan <char style="nd">ALLAHyhwh</char> iola matoari jugo tameng<note caller="+" style="f"><char closed="false" style="fr">84:12 </char><char closed="false" style="fq">matoari jugo tameng: </char><char closed="false" style="ft">Ini ni kiasan óntók bémbéngan jugo peléndóngan pecak yang disedioke ole rajo yang baék óntók rakyatnyo.</char></note>;</para>
<para style="q2" vid="PSA 84:12">
<char style="nd">ALLAHyhwh</char> ngenjók karunio jugo kemulyoan;</para>
<para style="q2" vid="PSA 84:12">Dio dak nahan kebaék'an dari wong yang bejalan dalem ketólósan.<verse eid="PSA 84:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 84:13" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, Tuan semesto alam,</para>
<para style="q2" vid="PSA 84:13">senengla wong yang pecayo samo Kau!<verse eid="PSA 84:13"/></para>
<chapter eid="PSA 84"/>





<chapter number="90" sid="PSA 90" style="c"/>
<para style="s2" vid="PSA 89:53">Doa mintak Allah ngesiani manusio, yang édópnyo cuman sementaro<verse eid="PSA 89:53"/></para>
<para style="d">
<verse number="1" sid="PSA 90:1" style="v"/>Doa Musa, hamba Allah.</para>
<para style="b" vid="PSA 90:1"/>
<para style="q1" vid="PSA 90:1">Ya Tuan, Kaula tempat betedó óntók kami tórón-temórón.<verse eid="PSA 90:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 90:2" style="v"/>Sebelóm gónóng-gónóng dilaérke,</para>
<para style="q2" vid="PSA 90:2">sebelóm Kau nyadike bumi samo dunio,</para>
<para style="q2" vid="PSA 90:2">malahan dari selamo-lamonyo sampe selamo-lamonyo</para>
<para style="q3" vid="PSA 90:2">Kaula Allah.<verse eid="PSA 90:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 90:3" style="v"/>Kau balékke manusio ke debu tana</para>
<para style="q2" vid="PSA 90:3">trós ngomong, “Balékla, ói anak-anak manusio!”<verse eid="PSA 90:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 90:4" style="v"/>Sebenernyo, di mato Kau, seribu taón samo pecak</para>
<para style="q2" vid="PSA 90:4">ari kemarén yang baru liwat,</para>
<para style="q2" vid="PSA 90:4">dak tu sikok géléran jago pas malem ari.<verse eid="PSA 90:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 90:5" style="v"/>Kau nganyutke <char style="add">nyawo</char> manusio; dio wong pecak mimpi.</para>
<para style="q2" vid="PSA 90:5">Pas pagi ari, dio wong pecak rómpót yang baru tómbó,<verse eid="PSA 90:5"/></para>
<para style="q3">
<verse number="6" sid="PSA 90:6" style="v"/>pas pagi bekembang trós tómbó,</para>
<para style="q3" vid="PSA 90:6">tapi pas sorenyo, layu trós keréng.<verse eid="PSA 90:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 90:7" style="v"/>Bener nian, kami abés ole panas ati Kau,</para>
<para style="q2" vid="PSA 90:7">trós kami ketakótan ole kemarahan Kau.<verse eid="PSA 90:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 90:8" style="v"/>Kau narok kesalahan-kesalahan kami di adepan Kau,</para>
<para style="q2" vid="PSA 90:8">jugo <char style="add">merikso</char> resio-resio kami di cahayo hadérat Kau.<verse eid="PSA 90:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 90:9" style="v"/>Bener nian, slóró ari kami tebenem karno amukan Kau;</para>
<para style="q2" vid="PSA 90:9">taón-taón kami abés pecak embósan napas.<verse eid="PSA 90:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 90:10" style="v"/>Lamo édóp kami tójó póló taón,</para>
<para style="q2" vid="PSA 90:10">apo amen kami kuat, lapan póló taón,</para>
<para style="q2" vid="PSA 90:10">tapi keslóróannyo cuman kesaroan samo pendritoan;</para>
<para style="q2" vid="PSA 90:10">karno keédópan gancang belalu, trós kami melayang ilang.<verse eid="PSA 90:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 90:11" style="v"/>Siapola yang tau kekuatan kemarahan Kau?</para>
<para style="q2" vid="PSA 90:11">Karno amukan Kau, pantesla wong takót samo Kau.<note caller="+" style="f"><char closed="false" style="fr">90:11 </char><char closed="false" style="fq">Karno amukan Kau, pantesla wong takót samo Kau: </char><char closed="false" style="ft">Makno teks asli di barés ini kurang jelas.</char></note><verse eid="PSA 90:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 90:12" style="v"/>Ajarkela kami óntók ngargoi ari-ari kami yang tebates<note caller="+" style="f"><char closed="false" style="fr">90:12 </char><char closed="false" style="fq">Ngargoi ari-ari kami yang tebates: </char><char closed="false" style="ft">Teks aslinyo iola, “Ngétóng ari-ari kami”. Maksódnyo kito ngargoi édóp kito tiap arinyo karno jadi sadar amen lamo édóp kito tebates.</char></note>,</para>
<para style="q2" vid="PSA 90:12">mangko kami dapet ati yang bijak.<verse eid="PSA 90:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 90:13" style="v"/>Bebalékla <char style="add">dari kemarahan Kau</char>, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>! Berapo lamo lagi?</para>
<para style="q2" vid="PSA 90:13">Kesianila hamba-hamba Kau ni!<verse eid="PSA 90:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 90:14" style="v"/>Kenyangkela kami pas pagi ari dengen kasé stio Kau,</para>
<para style="q2" vid="PSA 90:14">mangko kami besorak-sorak trós beseneng seómór édóp kami.<verse eid="PSA 90:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 90:15" style="v"/>Buatla ati kami beseneng-seneng,</para>
<para style="q2" vid="PSA 90:15">seimbang samo ari-ari pas Kau mbékén kami sengsaro,</para>
<para style="q2" vid="PSA 90:15">seimbang samo taón-taón pas kami keno celako.<verse eid="PSA 90:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 90:16" style="v"/>Biarla tingka laku Kau dijingok ole hamba-hamba Kau,</para>
<para style="q2" vid="PSA 90:16">trós kemulyoan Kau ole anak-anak kami.<verse eid="PSA 90:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 90:17" style="v"/>Biarla kebaék'an Tuan, Tuhan kami, ado samo kami,</para>
<para style="q2" vid="PSA 90:17">trós tegukela pebuatan tangan kami tu óntók kami,</para>
<para style="q2" vid="PSA 90:17">iyo, tegukela pebuatan tangan kami tu.<verse eid="PSA 90:17"/></para>
<chapter eid="PSA 90"/>
<chapter number="91" sid="PSA 91" style="c"/>
<para style="s2">Dalem léndóngan Allah</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 91:1" style="v"/>Wong yang édóp dalem léndóngan Yang Mahabesak</para>
<para style="q2" vid="PSA 91:1">bakal tédók di bawa naongan Yang Mahakuaso.<verse eid="PSA 91:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 91:2" style="v"/>Samo <char style="nd"><char style="w">ALLAHyhwh</char></char> aku ngomong<note caller="+" style="f"><char closed="false" style="fr">91:2 </char><char closed="false" style="fq">Samo </char><char style="nd">ALLAHyhwh</char> aku ngomong: <char closed="false" style="ft">Teks asli barés ni pacak jugo ditejemake, “Pasal </char><char style="nd">ALLAHyhwh</char> aku ngomong”.</note>,</para>
<para style="q2" vid="PSA 91:2">“Tempat peléndóngan aku jugo benteng petahanan aku,</para>
<para style="q2" vid="PSA 91:2">Tuhan aku, yang aku pecayoi.”<verse eid="PSA 91:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 91:3" style="v"/>Sebenernyo Diola yang bakal ngelepaske kau dari perangkep pemburu,</para>
<para style="q2" vid="PSA 91:3">dari waba yang mematike.<verse eid="PSA 91:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 91:4" style="v"/>Dengen kepak-Nyo Dio bakal nódóngi kau,</para>
<para style="q2" vid="PSA 91:4">trós di bawa sayap-Nyo kau bakal beléndóng.</para>
<para style="q2" vid="PSA 91:4">Kestioan-Nyo bakal jadi tameng samo benteng kau.<verse eid="PSA 91:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 91:5" style="v"/>Kau dak usa takót samo kengerian malem,</para>
<para style="q2" vid="PSA 91:5">samo anak pana yang terbang pas siang ari,<verse eid="PSA 91:5"/></para>
<para style="q2">
<verse number="6" sid="PSA 91:6" style="v"/>samo waba yang dateng dalem kegelepan,</para>
<para style="q2" vid="PSA 91:6">apo, samo keancóran yang mbinasoke pas tenga ari.<verse eid="PSA 91:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 91:7" style="v"/>Mugola seribu wong bakal nyampak di sampéng kau,</para>
<para style="q2" vid="PSA 91:7">jugo sepóló ribu di sampéng kanan kau,</para>
<para style="q2" vid="PSA 91:7">tapi kau dak bakal diparak'i galo-galo tu.<verse eid="PSA 91:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 91:8" style="v"/>Kau cuman bakal jingok dengen mato kau dewek</para>
<para style="q2" vid="PSA 91:8">trós jingok balesan óntók wong-wong jahat.<verse eid="PSA 91:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 91:9" style="v"/>Karno kau la mbékén <char style="nd">ALLAHyhwh</char> jadi tempat tinggal kau,</para>
<para style="q2" vid="PSA 91:9">iola Yang Mahabesak jugo tempat peléndóngan aku,<note caller="+" style="f"><char closed="false" style="fr">91:9 </char><char closed="false" style="fq">Karno kau … peléndóngan aku: </char><char closed="false" style="ft">Teks asli di sini cókóp saro diartike. Kato demi kato, teks asli ayat ni iola, “karno kau, </char><char style="nd">ALLAHyhwh</char>, tempat peléndóngan aku, Yang Mahabesak, kau la mbékén tempat tinggal kau.” Di sini, kato “kau” nónjókke wong laén, bukan Allah. </note><verse eid="PSA 91:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 91:10" style="v"/>jadi kebórókan dak bakal nimpo kau,</para>
<para style="q2" vid="PSA 91:10">jugo bencano dak bakal marak'i ruma kau.<verse eid="PSA 91:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 91:11" style="v"/>Soalnyo, Dio bakal mrénto malekat-malekat-Nyo pasal kau</para>
<para style="q2" vid="PSA 91:11">supayo kau dijagoi di segalo jalan kau.<verse eid="PSA 91:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 91:12" style="v"/>Di tangannyo dio wong bakal ngangkat kau</para>
<para style="q2" vid="PSA 91:12">supayo sekel kau dak kesantók batu.<note caller="-" style="x"><char closed="false" style="xo">91:11-12 </char><char closed="false" style="xt"><ref loc="MAT 4:6">Matius 4:6</ref>; <ref loc="LUK 4:10-11">Lukas 4:10-11</ref></char></note><verse eid="PSA 91:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 91:13" style="v"/>Singo samo ulo bakal kau pijek;</para>
<para style="q2" vid="PSA 91:13">kau bakal nginjek-nginjek singo mudo samo ulo bebiso.<verse eid="PSA 91:13"/></para>
<para style="b"/>
<para style="q1">
<verse number="14" sid="PSA 91:14" style="v"/>
<char style="add">Uji Allah</char>,</para>
<para style="q1" vid="PSA 91:14">“Karno Akula yang dio kaséhi, mangko Aku bakal nyelametkenyo,</para>
<para style="q2" vid="PSA 91:14">trós Aku bakal ngeléndónginyo karno dio ngenal namo Aku.<verse eid="PSA 91:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 91:15" style="v"/>Pas dio mekék samo Aku, Aku bakal nyawabnyo.</para>
<para style="q2" vid="PSA 91:15">Aku bakal nyertoinyo di dalem kesesekan,</para>
<para style="q2" vid="PSA 91:15">trós Aku bakal mbebaskenyo jugo mulyokenyo.<verse eid="PSA 91:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 91:16" style="v"/>Dengen ómór panjang Aku bakal muaskenyo,</para>
<para style="q2" vid="PSA 91:16">trós Aku bakal nyatoke samo dio keselametan dari Aku.”<verse eid="PSA 91:16"/></para>
<chapter eid="PSA 91"/>





















<chapter number="113" sid="PSA 113" style="c"/>
<para style="s2">Pujila Allah, Yang Mahatinggi</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 113:1" style="v"/>Pujila <char style="nd"><char style="w">ALLAHyhwh</char></char>!</para>
<para style="q1" vid="PSA 113:1">Pujila, ói penyemba-penyemba <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 113:1">pujila namo <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 113:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 113:2" style="v"/>Biarla namo <char style="nd">ALLAHyhwh</char> dipuji</para>
<para style="q2" vid="PSA 113:2">dari sekarang sampe selamo-lamonyo!<verse eid="PSA 113:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 113:3" style="v"/>Dari tempat terbétnyo matoari sampe tempat tenggelemnyo,</para>
<para style="q2" vid="PSA 113:3">namo <char style="nd">ALLAHyhwh</char> pantes dipuji.<verse eid="PSA 113:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 113:4" style="v"/>
<char style="nd">ALLAHyhwh</char> tu Mahatinggi di pócók segalo bangso;</para>
<para style="q2" vid="PSA 113:4">kemulyoan-Nyo di pócóknyo langét.<verse eid="PSA 113:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 113:5" style="v"/>Siapo yang pecak <char style="nd">ALLAHyhwh</char>, Tuhan kito,</para>
<para style="q2" vid="PSA 113:5">yang dódók di tempat tinggi,<verse eid="PSA 113:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 113:6" style="v"/>trós yang harós mbóngkókke diri-Nyo óntók jingok</para>
<para style="q2" vid="PSA 113:6">ke langét jugo bumi?<verse eid="PSA 113:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 113:7" style="v"/>Dio narék wong yang dak bedayo naék dari debu,</para>
<para style="q2" vid="PSA 113:7">trós ngangkat wong yang méskén dari témbónan abu,<verse eid="PSA 113:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 113:8" style="v"/>óntók ndódókke dio wong besamo-samo dengen wong-wong besak,</para>
<para style="q2" vid="PSA 113:8">dengen wong-wong besak dari umat-Nyo.<verse eid="PSA 113:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 113:9" style="v"/>Dio mbékén betino yang mandól di ruma</para>
<para style="q2" vid="PSA 113:9">jadi emak budak-budak, emak yang seneng.</para>
<para style="b" vid="PSA 113:9"/>
<para style="q1" vid="PSA 113:9">Pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 113:9"/></para>
<chapter eid="PSA 113"/>
<chapter number="114" sid="PSA 114" style="c"/>
<para style="s2">Nyanyian ngagóngke keajaéban Allah óntók Israel</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 114:1" style="v"/>Pas <char style="w">Israel</char> metu dari Mesir<note caller="+" style="f"><char closed="false" style="fr">114:1 </char><char closed="false" style="fq">Pas Israel metu dari Mesir: </char><char closed="false" style="ft">Cerito pasal Allah yang makek keajaéban-Nyo óntók gawak umat Israel metu dari perbudakan di Mesir ni pacak dibaco di </char><char closed="false" style="xt"><ref loc="EXO 1-12">Pembebasan 1–12</ref></char><char closed="false" style="ft">.</char></note>,</para>
<para style="q2" vid="PSA 114:1">
<char style="add">maksódnyo pas</char> kaóm ketórónan <char style="w">Yakób</char> <char style="add">metu</char> dari bangso yang laén basonyo,<verse eid="PSA 114:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 114:2" style="v"/>
<char style="w">Yehuda</char> jadi tempat suci-Nyo,</para>
<para style="q2" vid="PSA 114:2">trós Israel jadi daera kekuasoan-Nyo.<verse eid="PSA 114:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 114:3" style="v"/>Laót nyingok, trós lari<note caller="+" style="f"><char closed="false" style="fr">114:3 </char><char closed="false" style="fq">Laót nyingok, trós lari: </char><char closed="false" style="ft">Cerito pasal Allah yang bukak jalan di tenga Laót Abang pas umat Israel metu dari Mesir ni pacak dibaco di </char><char closed="false" style="xt"><ref loc="EXO 14">Pembebasan 14</ref></char><char closed="false" style="ft">.</char></note>;</para>
<para style="q2" vid="PSA 114:3">Sungi Yordan bebalék ara<note caller="+" style="f"><char closed="false" style="fr">114:3 </char><char closed="false" style="fq">Sungi Yordan bebalék ara: </char><char closed="false" style="ft">Cerito pasal Allah yang matike denget aléran Sungi Yordan pas umat Israel dipémpén Yosua masók ke Tana Pejanjian ni pacak dibaco di </char><char closed="false" style="xt"><ref loc="JOS 3">Yosua 3</ref></char><char closed="false" style="ft">.</char></note>.<verse eid="PSA 114:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 114:4" style="v"/>Gónóng-gónóng kocar-kacér<note caller="+" style="f"><char closed="false" style="fr">114:4 </char><char closed="false" style="fq">Gónóng-gónóng kocar-kacér: </char><char closed="false" style="ft">Cerito pasal gónóng yang begoncang pas Allah nóróninyo óntók betemu samo umat Israel ni pacak dibaco di </char><char closed="false" style="xt"><ref loc="EXO 19:16-18">Pembebasan 19:16-18</ref></char><char closed="false" style="ft">.</char></note> pecak domba lanang,</para>
<para style="q2" vid="PSA 114:4">jugo bókét-bókét pecak anak domba.<verse eid="PSA 114:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 114:5" style="v"/>Ói laót, ngapo kau lari?</para>
<para style="q2" vid="PSA 114:5">Ói Yordan, ngapo kau bebalék ara?<verse eid="PSA 114:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 114:6" style="v"/>Ói gónóng-gónóng, ngapo kau kocar-kacér pecak domba lanang,</para>
<para style="q2" vid="PSA 114:6">trós kau, ói bókét-bókét, pecak anak domba?<verse eid="PSA 114:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 114:7" style="v"/>Ói bumi, gemeterla di adepan Tuan,</para>
<para style="q2" vid="PSA 114:7">di adepan Tuhannyo <char style="w">Yakób</char>,<verse eid="PSA 114:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 114:8" style="v"/>yang la ngoba gónóng batu jadi kolam banyu,</para>
<para style="q2" vid="PSA 114:8">trós batu yang keras jadi mato banyu<note caller="+" style="f"><char closed="false" style="fr">114:8 </char><char closed="false" style="fq">batu yang keras jadi mato banyu: </char><char closed="false" style="ft">Cerito pasal Allah yang mbékén banyu metu dari batu pas umat Israel dipémpén Nabi Musa di padang górón ni pacak dibaco di </char><char closed="false" style="xt"><ref loc="EXO 17:1-7">Pembebasan 17:1-7</ref> </char><char closed="false" style="ft">jugo </char><char closed="false" style="xt"><ref loc="NUM 20:2-13">Kelóyóran di Górón 20:2-13</ref></char><char closed="false" style="ft">.</char></note>.<verse eid="PSA 114:8"/></para>
<chapter eid="PSA 114"/>
<chapter number="115" sid="PSA 115" style="c"/>
<para style="s2">Pujila Allah, Tuhan yang di surgo</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 115:1" style="v"/>Karno kasé stio jugo kebeneran Kau, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 115:1">békénla namo Kau dimulyoke,</para>
<para style="q2" vid="PSA 115:1">bukan namo kami, bukan namo kami.<verse eid="PSA 115:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 115:2" style="v"/>Ngapo bangso-bangso ngomong, “Di mano Tuhan wong Israel<note caller="+" style="f"><char closed="false" style="fr">115:2 </char><char closed="false" style="fq">wong Israel: </char><char closed="false" style="ft">Teks asli iola “dio wong”.</char></note>?”<verse eid="PSA 115:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 115:3" style="v"/>Tuhan kami ado di surgo,</para>
<para style="q2" vid="PSA 115:3">trós apo bae yang dikendak'i-Nyo, digaweke-Nyo.<verse eid="PSA 115:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 115:4" style="v"/>Berhalo-berhalo dio wong dari perak jugo emas,</para>
<para style="q2" vid="PSA 115:4">békénan tangan manusio.<verse eid="PSA 115:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 115:5" style="v"/>
<char style="add">Berhalo-berhalo tu</char> punyo mólót, tapi dak pacak ngomong;</para>
<para style="q2" vid="PSA 115:5">punyo mato, tapi dak pacak jingok;<verse eid="PSA 115:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 115:6" style="v"/>punyo kópéng, tapi dak pacak ndenger;</para>
<para style="q2" vid="PSA 115:6">punyo cungur, tapi dak pacak nyium;<verse eid="PSA 115:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 115:7" style="v"/>punyo tangan, tapi dak pacak ngerabo;</para>
<para style="q2" vid="PSA 115:7">punyo sekel, tapi dak pacak bejalan;</para>
<para style="q2" vid="PSA 115:7">trós idak pulok pacak metuke suaro dari kerongkongannyo.<verse eid="PSA 115:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 115:8" style="v"/>Cak itu jugo wong-wong yang mbékénnyo,</para>
<para style="q2" vid="PSA 115:8">jugo slóró wong yang pecayo samo békénannyo tu.<verse eid="PSA 115:8"/></para>
<para style="b"/>
<para style="q1">
<verse number="9" sid="PSA 115:9" style="v"/>Ói <char style="w">Israel</char>, pecayola samo <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 115:9">Diola penolong jugo tameng dio wong.<note caller="+" style="f"><char closed="false" style="fr">115:9 </char><char closed="false" style="fq">Diola penolong jugo tameng dio wong: </char><char closed="false" style="ft">Pecaknyo ini ni balesan yang diomongke ole “wong Israel” abés pemémpén ngomong, “Ói Israel, pecayola samo </char><char style="nd">ALLAHyhwh</char>!” Cak itu jugo, di ayat 10 iola imam-imam (ketórónan Harón) yang ngomong balesannyo, trós di ayat 11 umat Israel lagi (wong-wong yang takót samo <char style="nd">ALLAHyhwh</char>).</note><verse eid="PSA 115:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 115:10" style="v"/>Ói kaóm ketórónan <char style="w">Harón</char>, pecayola samo <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 115:10">Diola penolong jugo tameng dio wong.<verse eid="PSA 115:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 115:11" style="v"/>Ói wong-wong yang takót samo <char style="nd">ALLAHyhwh</char>, pecayola samo <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 115:11">Diola penolong jugo tameng dio wong.<verse eid="PSA 115:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 115:12" style="v"/>
<char style="nd">ALLAHyhwh</char> la nginget kito;</para>
<para style="q1" vid="PSA 115:12">Dio bakal mberkahi kito.</para>
<para style="q2" vid="PSA 115:12">Dio bakal mberkahi kaóm ketórónan Israel,</para>
<para style="q2" vid="PSA 115:12">Dio bakal mberkahi kaóm ketórónan Harón,<verse eid="PSA 115:12"/></para>
<para style="q2">
<verse number="13" sid="PSA 115:13" style="v"/>jugo Dio bakal mberkahi wong-wong yang takót samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q3" vid="PSA 115:13">dari wong kecik sampe wong besak.<verse eid="PSA 115:13"/></para>
<para style="b"/>
<para style="q1">
<verse number="14" sid="PSA 115:14" style="v"/>Kironyo <char style="nd">ALLAHyhwh</char> mbékén kau belimpahan,</para>
<para style="q2" vid="PSA 115:14">baék kau jugo anak-anak kau.<verse eid="PSA 115:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 115:15" style="v"/>Kironyo kau diberkahi ole <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 115:15">yang nyadike bumi jugo alam semesto.<verse eid="PSA 115:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 115:16" style="v"/>Alam semesto iola punyo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 115:16">tapi bumi ni la dikarunioke-Nyo samo anak-anak manusio.<verse eid="PSA 115:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 115:17" style="v"/>Wong-wong mati dak bakal muji-muji <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 115:17">idak jugo slóró wong yang la tórón ke dunio yang sunyi.<verse eid="PSA 115:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 115:18" style="v"/>Tapi kito, <char style="add">wong-wong yang édóp</char>, bakal muji <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 115:18">dari sekarang sampe selamo-lamonyo.</para>
<para style="b" vid="PSA 115:18"/>
<para style="q1" vid="PSA 115:18">Pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 115:18"/></para>
<chapter eid="PSA 115"/>
<chapter number="116" sid="PSA 116" style="c"/>
<para style="s2">Dilepaske dari iketan maót</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 116:1" style="v"/>Aku ngaséhi <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 116:1">karno Dio ndengerke jerétan pemohonan aku.<verse eid="PSA 116:1"/></para>
<para style="q2">
<verse number="2" sid="PSA 116:2" style="v"/>Iyo, Dio masang kópéng-Nyo óntók aku.</para>
<para style="q1" vid="PSA 116:2">Jadi seómór édóp, aku bakal bejerét samo Dio.<verse eid="PSA 116:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 116:3" style="v"/>Tali-tali maót ngelélét aku,</para>
<para style="q2" vid="PSA 116:3">trós sengsaro alam kóbór nangkep aku.</para>
<para style="q2" vid="PSA 116:3">Kesaroan samo kesedéan aku temuke.<verse eid="PSA 116:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 116:4" style="v"/>Tapi namo <char style="nd">ALLAHyhwh</char> aku panggél,</para>
<para style="q2" vid="PSA 116:4">“Ya <char style="nd">ALLAHyhwh</char>, selametkela nyawo aku!”<verse eid="PSA 116:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 116:5" style="v"/>
<char style="nd">ALLAHyhwh</char> tu punyo belas kesian jugo kebeneran.</para>
<para style="q2" vid="PSA 116:5">Tuhan kito tu Maha Penyayang.<verse eid="PSA 116:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 116:6" style="v"/>
<char style="nd">ALLAHyhwh</char> ngeléndóngi wong-wong yang polos.</para>
<para style="q2" vid="PSA 116:6">Pas aku dak bedayo, Dio nyelametke aku.<verse eid="PSA 116:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 116:7" style="v"/>Balékla tenang, jiwoku,</para>
<para style="q2" vid="PSA 116:7">karno <char style="nd">ALLAHyhwh</char> la bebuat baék samo kau.<verse eid="PSA 116:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 116:8" style="v"/>Iyo! <char style="add">Allah</char>, Kau la ngelepaske nyawo aku dari maót,</para>
<para style="q2" vid="PSA 116:8">mato aku dari banyu mato,</para>
<para style="q2" vid="PSA 116:8">jugo sekel aku dari tesandóng.<verse eid="PSA 116:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 116:9" style="v"/>Aku bakal bejalan di jalan <char style="nd">ALLAHyhwh</char><note caller="+" style="f"><char closed="false" style="fr">116:9 </char><char closed="false" style="fq">bejalan di jalan </char><char style="nd">ALLAHyhwh</char>: <char closed="false" style="ft">Teks asli iola, “bejalan di adepan </char><char style="nd">ALLAHyhwh</char>”. Maksódnyo dio mélé édóp nórót ajaran Allah.</note></para>
<para style="q2" vid="PSA 116:9">di dunio wong-wong yang édóp.<verse eid="PSA 116:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 116:10" style="v"/>Aku masé pecayo, mugola pas aku ngomong,</para>
<para style="q2" vid="PSA 116:10">“Aku sengsaro nian,”<verse eid="PSA 116:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 116:11" style="v"/>trós dalem kebingsalan aku ngomong,</para>
<para style="q2" vid="PSA 116:11">“Slóró wong tukang ngotak'i!”<verse eid="PSA 116:11"/></para>
<para style="b"/>
<para style="q1">
<verse number="12" sid="PSA 116:12" style="v"/>Apola yang pacak aku pesembake samo <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 116:12">óntók mbales slóró kebaék'an-Nyo samo aku?<verse eid="PSA 116:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 116:13" style="v"/>Aku bakal naékke sókór<note caller="+" style="f"><char closed="false" style="fr">116:13 </char><char closed="false" style="fq">naékke sókór: </char><char closed="false" style="ft">Teks asli iola, “ngangkat cangkér keselametan”. Dalem budayo Ibrani, cangkér keselametan tu móngkén nónjókke cangkér anggór yang dituangke óntók jadi pesembahan di <char style="w">Ruma Agóng Allah</char>. Amen cak itu, dalem saér ni itu dilakuke óntók muji Allah karno keselametan yang la diterimo dari Dio.</char></note>,</para>
<para style="q2" vid="PSA 116:13">trós aku muji namo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 116:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 116:14" style="v"/>Aku bakal mbayar najar aku samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 116:14">di adepan slóró umat-Nyo, <char style="add">Israel</char>.<verse eid="PSA 116:14"/></para>
<para style="b"/>
<para style="q1">
<verse number="15" sid="PSA 116:15" style="v"/>Berat nian di mato <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 116:15">kematian wong-wong-Nyo yang além.<verse eid="PSA 116:15"/></para>
<para style="b"/>
<para style="q1">
<verse number="16" sid="PSA 116:16" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, aku ni hamba Kau.</para>
<para style="q2" vid="PSA 116:16">Sebenernyo akula hamba Kau, anak dari hamba Kau<note caller="+" style="f"><char closed="false" style="fr">116:16 </char><char closed="false" style="fq">anak dari hamba Kau: </char><char closed="false" style="ft">Maksódnyo, ini ni sikok lanang yang emaknyo jugo hamba Allah. Jadi dio ni dari kluargo yang ngelayani Allah. (Bentók kato “hamba” di teks asli di sini nónjókke sikok hamba betino, sedengke kato “hamba” yang sebelómnyo nónjókke sikok hamba lanang.)</char></note>.</para>
<para style="q1" vid="PSA 116:16">Kau la mbukak kebetan-kebetan aku.<verse eid="PSA 116:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 116:17" style="v"/>Samo Kaula aku bakal sembake kórban sókór,</para>
<para style="q2" vid="PSA 116:17">trós aku muji namo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 116:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 116:18" style="v"/>Aku bakal mbayar najar aku samo <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 116:18">di adepan slóró umat-Nyo,<verse eid="PSA 116:18"/></para>
<para style="q2">
<verse number="19" sid="PSA 116:19" style="v"/>di jabo <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng <char style="nd">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 116:19">di tenga-tenga kau, ói <char style="w">Yerusalem</char>!</para>
<para style="b" vid="PSA 116:19"/>
<para style="q1" vid="PSA 116:19">Pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 116:19"/></para>
<chapter eid="PSA 116"/>
<chapter number="117" sid="PSA 117" style="c"/>
<para style="s2">Pujila Allah, ói slóró bangso!</para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 117:1" style="v"/>Pujila <char style="nd">ALLAHyhwh</char>, ói slóró bangso!</para>
<para style="q2" vid="PSA 117:1">Agóngkela Dio, ói slóró suku bangso!<verse eid="PSA 117:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 117:2" style="v"/>Karno kasé-Nyo besak óntók kito,</para>
<para style="q2" vid="PSA 117:2">jugo kestioan <char style="nd">ALLAHyhwh</char> ado sampe selamo-lamonyo.</para>
<para style="b" vid="PSA 117:2"/>
<para style="q1" vid="PSA 117:2">Pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 117:2"/></para>
<chapter eid="PSA 117"/>
<chapter number="118" sid="PSA 118" style="c"/>
<para style="s2">Puji sókór samo Allah yang la nyelametke!<note caller="+" style="f"><char closed="false" style="fr">118:0 </char><char closed="false" style="ft">Saér 118 ni digunoke ole bangso Israel pas upacara di <char style="w">Ruma Agóng Allah</char> (contonyo móngkén pas ari rayo Pondok Daón). Dalem saér ni ado bagéan-bagéan yang móngkén diucapke ole imam, rajo, jugo umat.</char></note></para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 118:1" style="v"/>Ngucap sókórla samo <char style="nd">ALLAHyhwh</char>, karno Dio baék;</para>
<para style="q2" vid="PSA 118:1">kasé stio-Nyo sampe selamo-lamonyo.<verse eid="PSA 118:1"/></para>
<para style="b"/>
<para style="q1">
<verse number="2" sid="PSA 118:2" style="v"/>Ngomongla, ói wong Israel,</para>
<para style="q2" vid="PSA 118:2">“Kasé stio-Nyo sampe selamo-lamonyo!”<note caller="+" style="f"><char closed="false" style="fr">118:2 </char><char closed="false" style="fq">“Kasé stio-Nyo sampe selamo-lamonyo.”: </char><char closed="false" style="ft">Pecaknyo ini ni balesan yang diomongke ole “wong Israel” abés pemémpén ngomong “Ngomongla ói wong Israel.” Cak itu jugo, di ayat 3 iola imam-imam (ketórónan Harón) yang ngomong balesannyo, trós di ayat 4 umat Israel lagi.</char></note><verse eid="PSA 118:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 118:3" style="v"/>Ngomongla, ói ketórónan Harón,</para>
<para style="q2" vid="PSA 118:3">“Kasé stio-Nyo sampe selamo-lamonyo!”<verse eid="PSA 118:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 118:4" style="v"/>Ngomongla, ói wong-wong yang takót samo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 118:4">“Kasé stio-Nyo sampe selamo-lamonyo!”<verse eid="PSA 118:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 118:5" style="v"/>“Dalem kesesekan aku<note caller="+" style="f"><char closed="false" style="fr">118:5 </char><char closed="false" style="fq">aku: </char><char closed="false" style="ft">Pecaknyo di ayat 5–18, ado sikok wong (móngkén rajo Israel) yang ngomong di depan ómóm, ngenjók kesaksian pasal Allah nyelametke dio pas petempóran.</char></note> bejerét samo <char style="nd">ALLAHyhwh</char>;</para>
<para style="q2" vid="PSA 118:5">
<char style="nd">ALLAHyhwh</char> nyawab aku dengen ngenjók kelegoan.<verse eid="PSA 118:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 118:6" style="v"/>
<char style="nd">ALLAHyhwh</char> di piak aku; aku dak bakal takót.</para>
<para style="q2" vid="PSA 118:6">Apo yang pacak dilakuke manusio samo aku?<verse eid="PSA 118:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 118:7" style="v"/>
<char style="nd">ALLAHyhwh</char> di piak aku óntók nolong aku.</para>
<para style="q2" vid="PSA 118:7">
<char style="add">Mangkonyo</char> aku bakal jingok'i bae wong-wong yang mbenci aku.<verse eid="PSA 118:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 118:8" style="v"/>Lebé baék beléndóng samo <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 118:8">daripado pecayo samo manusio.<verse eid="PSA 118:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 118:9" style="v"/>Lebé baék beléndóng samo <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 118:9">daripado pecayo samo wong-wong besak.<verse eid="PSA 118:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 118:10" style="v"/>Slóró bangso ngepóng aku,</para>
<para style="q2" vid="PSA 118:10">tapi karno namo <char style="nd">ALLAHyhwh</char>, aku kalake dio wong!<verse eid="PSA 118:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 118:11" style="v"/>Dio wong ngepóng aku, iyo, dio wong ngepóng aku,</para>
<para style="q2" vid="PSA 118:11">tapi karno namo <char style="nd">ALLAHyhwh</char>, aku kalake dio wong!<verse eid="PSA 118:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 118:12" style="v"/>Dio wong ngepóng aku pecak lebah,</para>
<para style="q2" vid="PSA 118:12">tapi dio wong tepadem pecak api yang mbakar semak duri.</para>
<para style="q2" vid="PSA 118:12">Karno namo <char style="nd">ALLAHyhwh</char>, aku kalake dio wong!<verse eid="PSA 118:12"/></para>
<para style="q1">
<verse number="13" sid="PSA 118:13" style="v"/>Iyo, aku dijulak dengen kuat sampe nak nyampak,</para>
<para style="q2" vid="PSA 118:13">tapi <char style="nd">ALLAHyhwh</char> nolong aku.<verse eid="PSA 118:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 118:14" style="v"/>
<char style="nd">ALLAHyhwh</char> iola kekuatan aku jugo nyanyian aku.</para>
<para style="q2" vid="PSA 118:14">Dio la jadi keselametan aku.<verse eid="PSA 118:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 118:15" style="v"/>Ado suaro sorak keselametan</para>
<para style="q2" vid="PSA 118:15">di jeró pekemahan <char style="add">pasókan</char> wong-wong bener:<note caller="+" style="f"><char closed="false" style="fr">118:15 </char><char closed="false" style="fq">pekemahan pasókan wong-wong bener: </char><char closed="false" style="ft">Maksódnyo, pekemahan Israel pas perang di ayat 10–13.</char></note></para>
<para style="q3" vid="PSA 118:15">‘Tangan kanan <char style="nd">ALLAHyhwh</char> ngelakuke pebuatan yang gagah!<verse eid="PSA 118:15"/></para>
<para style="q3">
<verse number="16" sid="PSA 118:16" style="v"/>Tangan kanan <char style="nd">ALLAHyhwh</char> ditinggike!</para>
<para style="q3" vid="PSA 118:16">Tangan kanan <char style="nd">ALLAHyhwh</char> ngelakuke pebuatan yang gagah!’<verse eid="PSA 118:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 118:17" style="v"/>Aku dak bakal mati, tapi édóp,</para>
<para style="q2" vid="PSA 118:17">trós nyritoke pebuatan-pebuatan <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 118:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 118:18" style="v"/>
<char style="nd">ALLAHyhwh</char> la ngókóm aku dengen keras,</para>
<para style="q2" vid="PSA 118:18">tapi Dio idak nyerake aku samo maót.”<verse eid="PSA 118:18"/></para>
<para style="b"/>
<para style="q1">
<verse number="19" sid="PSA 118:19" style="v"/>“Nah, bukakkela óntók aku lawang-lawang <char style="add">Ruma Agóng Allah</char>,</para>
<para style="q2" vid="PSA 118:19">iola gerbang wong-wong bener!</para>
<para style="q1" vid="PSA 118:19">Aku nak masók ngeliwatinyo</para>
<para style="q2" vid="PSA 118:19">trós ngucap sókór samo <char style="nd">ALLAHyhwh</char>.”<verse eid="PSA 118:19"/></para>
<para style="b"/>
<para style="q1">
<verse number="20" sid="PSA 118:20" style="v"/>Inila gerbang <char style="nd">ALLAHyhwh</char>;<note caller="+" style="f"><char closed="false" style="fr">118:20 </char><char closed="false" style="fq">Inila gerbang </char><char style="nd">ALLAHyhwh</char>: <char closed="false" style="ft">Pecaknyo di sini penjago lawang Ruma Agóng Allah bales pintak'an dari ayat 19.</char></note></para>
<para style="q2" vid="PSA 118:20">wong-wong bener bakal masók ngeliwatinyo.<verse eid="PSA 118:20"/></para>
<para style="b"/>
<para style="q1">
<verse number="21" sid="PSA 118:21" style="v"/>“Aku<note caller="+" style="f"><char closed="false" style="fr">118:21 </char><char closed="false" style="fq">Aku: </char><char closed="false" style="ft">Pecaknyo di sini wong tadi nyelaske ngapo dio nak masók.</char></note> nak ngucap sókór samo Kau karno Kau la nyawab aku</para>
<para style="q2" vid="PSA 118:21">jugo la jadi keselametan aku.”<verse eid="PSA 118:21"/></para>
<para style="b"/>
<para style="q1">
<verse number="22" sid="PSA 118:22" style="v"/>Batu yang dibuang ole tukang-tukang bangónan<note caller="+" style="f"><char closed="false" style="fr">118:22 </char><char closed="false" style="fq">Batu yang dibuang ole tukang-tukang bangónan: </char><char closed="false" style="ft">Pecaknyo ayat 22–25 diomongke ole umat Israel yang bekómpól di situ. Ini ni pengertian dio wong pasal kesaksian wong tadi.</char></note></para>
<para style="q2" vid="PSA 118:22">la jadi batu pondasi.<verse eid="PSA 118:22"/></para>
<para style="q1">
<verse number="23" sid="PSA 118:23" style="v"/>Pasal ni iola pebuatan <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 118:23">ajaéb di mato kito.<verse eid="PSA 118:23"/></para>
<para style="q1">
<verse number="24" sid="PSA 118:24" style="v"/>Inila ari asél dari pebuatan <char style="nd">ALLAHyhwh</char>;</para>
<para style="q2" vid="PSA 118:24">payó kito beseneng jugo besorak karno <char style="add">slórónyo</char> tu!<verse eid="PSA 118:24"/></para>
<para style="q1">
<verse number="25" sid="PSA 118:25" style="v"/>Ya <char style="nd">ALLAHyhwh</char>, selametkela kami terós!</para>
<para style="q2" vid="PSA 118:25">Ya <char style="nd">ALLAHyhwh</char>, enjókkela kironyo keberasélan!<verse eid="PSA 118:25"/></para>
<para style="b"/>
<para style="q1">
<verse number="26" sid="PSA 118:26" style="v"/>Diberkahila dio yang dateng dalem namo <char style="nd">ALLAHyhwh</char>!</para>
<para style="q2" vid="PSA 118:26">Kami<note caller="+" style="f"><char closed="false" style="fr">118:26 </char><char closed="false" style="fq">Kami: </char><char closed="false" style="ft">Pecaknyo di ayat 26–27 ini, imam-imam ngomong ke wong tadi jugo umat Israel.</char></note> mberkahi kamu dari jeró <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng <char style="nd">ALLAHyhwh</char></char>.<verse eid="PSA 118:26"/></para>
<para style="q1">
<verse number="27" sid="PSA 118:27" style="v"/>
<char style="nd">ALLAHyhwh</char> iola Tuhan,</para>
<para style="q2" vid="PSA 118:27">trós Dio la nyinari kito.</para>
<para style="q1" vid="PSA 118:27">Kebetla kórban ari rayo dengen tali</para>
<para style="q2" vid="PSA 118:27">ke tandók-tandók di sódót <char style="w">mesba</char><note caller="+" style="f"><char closed="false" style="fr">118:27 </char><char closed="false" style="fq">Kebetla kórban … mesba: </char><char closed="false" style="ft">Makno teks asli dari keduo barés ni dak pulok jelas. Pecaknyo ini ni ritual yang digaweke pas upacara di Ruma Agóng Allah di jaman tu.</char></note>.<verse eid="PSA 118:27"/></para>
<para style="b"/>
<para style="q1">
<verse number="28" sid="PSA 118:28" style="v"/>“Kaula Tuhan aku<note caller="+" style="f"><char closed="false" style="fr">118:28 </char><char closed="false" style="fq">aku: </char><char closed="false" style="ft">Pecaknyo di sini wong tadi (jingok catetan di kato “aku” di ayat 5) muji Allah pas masók trós ngenjók pesembahan.</char></note>; aku nak ngucap sókór samo Kau!</para>
<para style="q2" vid="PSA 118:28">Kaula Tuhan aku; aku nak ngagóngke Kau!”<verse eid="PSA 118:28"/></para>
<para style="b"/>
<para style="q1">
<verse number="29" sid="PSA 118:29" style="v"/>Ngucap sókórla<note caller="+" style="f"><char closed="false" style="fr">118:29 </char><char closed="false" style="fq">Ngucap sókórla: </char><char closed="false" style="ft">Pecaknyo di sini pemémpén ngomong lagi.</char></note> samo <char style="nd">ALLAHyhwh</char>, karno Dio baék,</para>
<para style="q2" vid="PSA 118:29">kasé stio-Nyo sampe selamo-lamonyo.<verse eid="PSA 118:29"/></para>
<chapter eid="PSA 118"/>








<chapter number="127" sid="PSA 127" style="c"/>
<para style="s2" vid="PSA 126:6">Allah yang nyedioke óntók ruma tanggo<verse eid="PSA 126:6"/></para>
<para style="d">
<verse number="1" sid="PSA 127:1" style="v"/>Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>. Dari Suleiman.</para>
<para style="b" vid="PSA 127:1"/>
<para style="q1" vid="PSA 127:1">Amen bukan <char style="nd"><char style="w">ALLAHyhwh</char></char> yang mbangón ruma,</para>
<para style="q2" vid="PSA 127:1">sio-siola wong yang mbangónnyo susa paya.</para>
<para style="q1" vid="PSA 127:1">Amen bukan <char style="nd">ALLAHyhwh</char> yang nyago kota,</para>
<para style="q2" vid="PSA 127:1">sio-siola pengawal bejago-jago.<verse eid="PSA 127:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 127:2" style="v"/>Sio-siola kamu gancang bangón</para>
<para style="q2" vid="PSA 127:2">trós telat tédók,</para>
<para style="q2" vid="PSA 127:2">trós makani asél susa paya,</para>
<para style="q2" vid="PSA 127:2">karno Dio ngenjókkenyo samo yang dikaséhi-Nyo pas <char style="add">dio wong</char> tédók<note caller="+" style="f"><char closed="false" style="fr">127:2 </char><char closed="false" style="fq">karno Dio ngenjókkenyo samo yang dikaséhi-Nyo pas dio wong tédók: </char><char closed="false" style="ft">Teks asli barés ini pacak jugo diartike, “karno Dio ngenjókke tédók samo yang dikaséhi-Nyo”.</char></note>.<verse eid="PSA 127:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 127:3" style="v"/>Jingokla, budak-budak iola warésan dari <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 127:3">trós bua ati iola pahalo.<verse eid="PSA 127:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 127:4" style="v"/>Samo pecak anak-anak pana di tangan pejuang,</para>
<para style="q2" vid="PSA 127:4">pecak itula budak-budak lanang <char style="add">yang dilaérke pas</char> kito mudo.<verse eid="PSA 127:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 127:5" style="v"/>Senengla wong yang tabóng pananyo dipenui dengen dio wong tu.</para>
<para style="q1" vid="PSA 127:5">Dio dak bakal dipermaluke</para>
<para style="q2" vid="PSA 127:5">pas ngadepi lawan-lawannyo di jeró gerbang kota<note caller="+" style="f"><char closed="false" style="fr">127:5 </char><char closed="false" style="fq">di jeró gerbang kota: </char><char closed="false" style="ft">Dalem budayo Ibrani jaman tu, di jeró pintu gerbang kota ado tempat kómpólan wong yang behikmah jugo pemémpén. Wargo pegi ke sano óntók mintak nasehat jugo keadélan. Di ayat ini, wong ini ngadepi mósónyo dewek di adepan pemémpén kota óntók mintak keadélan.</char></note>.<verse eid="PSA 127:5"/></para>
<chapter eid="PSA 127"/>
<chapter number="128" sid="PSA 128" style="c"/>
<para style="s2">Berkah óntók wong yang takót samo Allah</para>
<para style="d">
<verse number="1" sid="PSA 128:1" style="v"/>Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>.</para>
<para style="b" vid="PSA 128:1"/>
<para style="q1" vid="PSA 128:1">Senengla tiap wong yang takót samo <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
<para style="q2" vid="PSA 128:1">trós yang bejalan di jalan-Nyo.<verse eid="PSA 128:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 128:2" style="v"/>Pastila kau bakal makan asél dari tangan kau.</para>
<para style="q2" vid="PSA 128:2">Kau bakal seneng, trós keadaan kau bakal baék.<verse eid="PSA 128:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 128:3" style="v"/>Bini kau bakal jadi pecak batang anggór yang bebua lebet</para>
<para style="q2" vid="PSA 128:3">di jeró ruma kau,</para>
<para style="q1" vid="PSA 128:3">trós anak-anak kau pecak tunas batang jaitun</para>
<para style="q2" vid="PSA 128:3">di sekeléléng meja kau.<verse eid="PSA 128:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 128:4" style="v"/>Sebenernyo pecak itula bakal diberkahi</para>
<para style="q2" vid="PSA 128:4">lanang yang takót samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 128:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 128:5" style="v"/>Kironyo <char style="nd">ALLAHyhwh</char> mberkahi kau dari <char style="w">Sion</char>,</para>
<para style="q2" vid="PSA 128:5">sampe-sampe kau jingok kemakmóran <char style="w">Yerusalem</char></para>
<para style="q3" vid="PSA 128:5">seómór édóp kau,<verse eid="PSA 128:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 128:6" style="v"/>trós kau jingok anak cócóng kau!</para>
<para style="b" vid="PSA 128:6"/>
<para style="q1" vid="PSA 128:6">Damai sentosa óntók <char style="w">Israel</char>!<verse eid="PSA 128:6"/></para>
<chapter eid="PSA 128"/>




<chapter number="133" sid="PSA 133" style="c"/>
<para style="s2">Keédópan yang rókón</para>
<para style="d">
<verse number="1" sid="PSA 133:1" style="v"/>Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>. Dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 133:1"/>
<para style="q1" vid="PSA 133:1">Jingokla, alangke baék jugo nyenengke</para>
<para style="q2" vid="PSA 133:1">amen dólór-dólór édóp besamo dengen rókón.<verse eid="PSA 133:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 133:2" style="v"/>Pasal tu pecak minyak yang berego di pócók palak<note caller="+" style="f"><char closed="false" style="fr">133:2 </char><char closed="false" style="fq">minyak yang berego di pócók palak: </char><char closed="false" style="ft">Dalem budayo Ibrani, nuangke minyak yang berego di pócók palak dilakuke óntók ngelanték imam besak (</char><char closed="false" style="xt"><ref loc="EXO 29:1-7">Pembebasan 29:1-7</ref></char><char closed="false" style="ft">). Óntók wong Ibrani, pelantékan imam besak tu iola upacara yang nyenengke jugo penu berkah óntók imam besak tu dewek jugo óntók slóró umatnyo.</char></note>,</para>
<para style="q2" vid="PSA 133:2">yang tórón ke jenggot,</para>
<para style="q2" vid="PSA 133:2">ke jenggot <char style="w">Harón</char>,</para>
<para style="q3" vid="PSA 133:2">trós tórón lagi sampe ke leher jubanyo<note caller="+" style="f"><char closed="false" style="fr">133:2 </char><char closed="false" style="fq">sampe ke leher jubanyo: </char><char closed="false" style="ft">Makno teks asli di sini kurang jelas.</char></note>.<verse eid="PSA 133:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 133:3" style="v"/>Pasal tu pecak embón yang tórón ke pócók bókét-bókét <char style="w">Sion</char>;</para>
<para style="q2" vid="PSA 133:3">embónnyo cak embón <char style="add">Gónóng</char> Hermon<note caller="+" style="f"><char closed="false" style="fr">133:3 </char><char closed="false" style="fq">Hermon: </char><char closed="false" style="ft">Gónóng Hermon ni tekenal di Israel karno banyak embónnyo. Di Israel, mósém kemarónyo panjang, jadi embón tu dianggep berkah yang besak.</char></note>.</para>
<para style="q1" vid="PSA 133:3">Soalnyo ke sanola <char style="nd"><char style="w">ALLAHyhwh</char></char> mréntoke berkah,</para>
<para style="q2" vid="PSA 133:3">iola keédópan óntók selamo-lamonyo.<verse eid="PSA 133:3"/></para>
<chapter eid="PSA 133"/>
<chapter number="134" sid="PSA 134" style="c"/>
<para style="s2">Puji-pujian pas malem ari</para>
<para style="d">
<verse number="1" sid="PSA 134:1" style="v"/>Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>.</para>
<para style="b" vid="PSA 134:1"/>
<para style="q1" vid="PSA 134:1">Payó, pujila <char style="nd"><char style="w">ALLAHyhwh</char></char>, ói slóró hamba <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 134:1">yang ngelayani di Ruma Agóng <char style="nd">ALLAHyhwh</char> pas malem ari!<verse eid="PSA 134:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 134:2" style="v"/>Angkatla tangan kamu ke ara tempat suci tu,</para>
<para style="q2" vid="PSA 134:2">trós pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 134:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 134:3" style="v"/>Kironyo <char style="nd">ALLAHyhwh</char> mberkahi kau dari <char style="w">Sion</char>,</para>
<para style="q2" vid="PSA 134:3">Dio yang nyadike bumi jugo alam semesto!<verse eid="PSA 134:3"/></para>
<chapter eid="PSA 134"/>



<chapter number="138" sid="PSA 138" style="c"/>
<para style="s2">Nyanyian ucapan sókór karno kasé stio Allah</para>
<para style="d">
<verse number="1" sid="PSA 138:1" style="v"/>Dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 138:1"/>
<para style="q1" vid="PSA 138:1">Aku nak ngucap sókór samo Kau dengen sepenu ati aku.</para>
<para style="q2" vid="PSA 138:1">Aku nak nyanyike puji-pujian óntók Kau di adepan mahlók-mahlók surgawi.<verse eid="PSA 138:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 138:2" style="v"/>Aku nak sójód nyemba ke ara <char lemma="Ruma Agóng Allah" style="w">Ruma Agóng Kau</char> yang suci.</para>
<para style="q1" vid="PSA 138:2">Aku ngucap sókór samo namo Kau</para>
<para style="q2" vid="PSA 138:2">karno kasé Kau jugo karno kestioan Kau,</para>
<para style="q2" vid="PSA 138:2">soalnyo Kau la nepati omongan Kau, ngelebéi namo baék Kau dewek<note caller="+" style="f"><char closed="false" style="fr">138:2 </char><char closed="false" style="fq">soalnyo Kau … namo baék Kau dewek: </char><char closed="false" style="ft">Makno teks asli dari barés ni dak pulok jelas.</char></note>.<verse eid="PSA 138:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 138:3" style="v"/>Pas ari aku bejerét, Kau nyawab aku,</para>
<para style="q2" vid="PSA 138:3">trós Kau negóke jiwo aku dengen kekuatan.<verse eid="PSA 138:3"/></para>
<para style="b"/>
<para style="q1">
<verse number="4" sid="PSA 138:4" style="v"/>Slóró rajo di bumi bakal ngucap sókór samo Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 138:4">soalnyo dio wong la ndenger omongan dari bébér Kau.<verse eid="PSA 138:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 138:5" style="v"/>Dio wong bakal nyanyi pasal pebuatan <char style="nd">ALLAHyhwh</char></para>
<para style="q2" vid="PSA 138:5">karno besak kemulyoan <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 138:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 138:6" style="v"/>Mugola <char style="nd">ALLAHyhwh</char> di tempat tinggi, Dio nyingok wong yang renda,</para>
<para style="q2" vid="PSA 138:6">trós wong yang sombong dikenal-Nyo dari jaó.<verse eid="PSA 138:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 138:7" style="v"/>Pas aku bejalan dalem kesesekan,</para>
<para style="q2" vid="PSA 138:7">Kau nopang édóp aku.</para>
<para style="q1" vid="PSA 138:7">Kau ngólórke tangan Kau ngelawan kemarahan mósó-mósó aku,</para>
<para style="q2" vid="PSA 138:7">trós tangan kanan Kau nyelametke aku.<verse eid="PSA 138:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 138:8" style="v"/>
<char style="nd">ALLAHyhwh</char> bakal nyelesaike <char style="add">slóró rencano-Nyo</char> óntók aku.</para>
<para style="q1" vid="PSA 138:8">Ya <char style="nd">ALLAHyhwh</char>, kasé stio Kau sampe selamo-lamonyo;</para>
<para style="q2" vid="PSA 138:8">jangan <char style="add">perna</char> ninggalke békénan tangan Kau.<verse eid="PSA 138:8"/></para>
<chapter eid="PSA 138"/>
<chapter number="139" sid="PSA 139" style="c"/>
<para style="s2">Doa ngagumi Allah, Tuhan Yang Mahadeket</para>
<para style="d">
<verse number="1" sid="PSA 139:1" style="v"/>
<char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.</para>
<para style="b" vid="PSA 139:1"/>
<para style="q1" vid="PSA 139:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, Kau selédék'i jugo ngenal aku.<verse eid="PSA 139:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 139:2" style="v"/>Kau tau pas aku dódók jugo pas aku tegak,</para>
<para style="q2" vid="PSA 139:2">Kau ngerti pékéran aku dari jaó.<verse eid="PSA 139:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 139:3" style="v"/>Kau prikso pas aku bejalan jugo pas aku bególéng,</para>
<para style="q2" vid="PSA 139:3">Kau ngenal slóró jalan aku.<verse eid="PSA 139:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 139:4" style="v"/>Malahan sebelóm lida aku ngucapke kato-kato,</para>
<para style="q2" vid="PSA 139:4">sebenernyo, Kau la tau slórónyo, ya <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 139:4"/></para>
<para style="p">
<verse number="5" sid="PSA 139:5" style="v"/>Kau mbentengi aku dari buri sampe depan,</para>
<para style="q2" vid="PSA 139:5">trós dari pócók tangan Kau nódóngi aku.<verse eid="PSA 139:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 139:6" style="v"/>Keliwat hebat pengetauan ni buat aku,</para>
<para style="q2" vid="PSA 139:6">keliwat tinggi, dak sanggóp aku ngeraényo.<verse eid="PSA 139:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 139:7" style="v"/>Ke mano aku pacak pegi njaói ro Kau?</para>
<para style="q2" vid="PSA 139:7">Ke mano aku pacak lari dari adepan Kau?<verse eid="PSA 139:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 139:8" style="v"/>
<char style="add">Seandainyo</char> aku naék ke langét, Kau ado di sano;</para>
<para style="q2" vid="PSA 139:8">
<char style="add">seandainyo</char> aku tórón ke<note caller="+" style="f"><char closed="false" style="fr">139:8 </char><char closed="false" style="fq">tórón ke: </char><char closed="false" style="ft">Teks asli iola, “narok ranjang di”.</char></note> dunio wong mati, Kau jugo ado di sano.<verse eid="PSA 139:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 139:9" style="v"/>
<char style="add">Seandainyo</char> aku terbang dengen sayap <char style="add">matoari</char> pajar,</para>
<para style="q2" vid="PSA 139:9">trós netep di ójóng laót<note caller="+" style="f"><char closed="false" style="fr">139:9 </char><char closed="false" style="fq">ójóng laót: </char><char closed="false" style="ft">Saér ni asalnyo dari negara Israel, yang letaknyo di pantai timur Laót Tenga. Jadi nórót sódót pandang penyaér ni, “ójóng laót” pastila di ara barat. Gambaran ayat ini iola dio naék matoari dari langét timur ke langét barat.</char></note> <char style="add">pas matoari tebenem</char>,<verse eid="PSA 139:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 139:10" style="v"/>jugo di sanola tangan Kau bakal nóntón aku;</para>
<para style="q2" vid="PSA 139:10">tangan kanan Kau bakal megangi aku.<verse eid="PSA 139:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 139:11" style="v"/>
<char style="add">Seandainyo</char> aku mintak kegelepan nódóngi aku,</para>
<para style="q2" vid="PSA 139:11">trós cahayo sekeléléng aku jadi malem,<verse eid="PSA 139:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 139:12" style="v"/>mala kegelepan tu idak gelep óntók Kau,</para>
<para style="q2" vid="PSA 139:12">trós malem besinar pecak siang;</para>
<para style="q2" vid="PSA 139:12">nak gelep nak terang samo bae.<verse eid="PSA 139:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 139:13" style="v"/>Sebenernyo Kau yang mbékén ati aku;</para>
<para style="q2" vid="PSA 139:13">Kau nenun aku di jeró kandóngan emak aku.<verse eid="PSA 139:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 139:14" style="v"/>Aku ngucap sókór samo Kau, karno hebat jugo ajaéb kejadian aku;</para>
<para style="q2" vid="PSA 139:14">ajaéb pebuatan Kau,</para>
<para style="q2" vid="PSA 139:14">jiwo aku bener-bener nyadarinyo.<verse eid="PSA 139:14"/></para>
<para style="q1">
<verse number="15" sid="PSA 139:15" style="v"/>Tulang-tulang aku idak tetótóp dari Kau</para>
<para style="q2" vid="PSA 139:15">pas aku dijadike di tempat yang resio,</para>
<para style="q2" vid="PSA 139:15">pas aku disulam di bagéan bumi paléng dalem;<verse eid="PSA 139:15"/></para>
<para style="q1">
<verse number="16" sid="PSA 139:16" style="v"/>mato Kau nyingok pas aku belóm tebentók,</para>
<para style="q2" vid="PSA 139:16">trós dalem kitab Kau, slóró ari <char style="add">aku</char> la tetólés,</para>
<para style="q2" vid="PSA 139:16">galonyo tu ditentuke,</para>
<para style="q2" vid="PSA 139:16">sebelóm ado sikok darinyo yang dimulai.<verse eid="PSA 139:16"/></para>
<para style="q1">
<verse number="17" sid="PSA 139:17" style="v"/>Óntók aku, saro nian pékéran-pékéran Kau, ya Allah!</para>
<para style="q2" vid="PSA 139:17">Besak nian jumlanyo!<verse eid="PSA 139:17"/></para>
<para style="q1">
<verse number="18" sid="PSA 139:18" style="v"/>Amen aku pacak ngétóngnyo, jumlanyo lebé banyak dari pasér.</para>
<para style="q1" vid="PSA 139:18">Aku bangón, trós aku masé besamo Kau.<verse eid="PSA 139:18"/></para>
<para style="b"/>
<para style="q1">
<verse number="19" sid="PSA 139:19" style="v"/>Kironyo Kau bunu wong-wong jahat, ya Allah!</para>
<para style="q2" vid="PSA 139:19">“Ói penumpa-penumpa dara, pegila jaó <char style="add">dari aku</char>!”<verse eid="PSA 139:19"/></para>
<para style="q1">
<verse number="20" sid="PSA 139:20" style="v"/>Dio wong ngatoi Kau dalem pesekongkolan.</para>
<para style="q2" vid="PSA 139:20">Dengen sio-sio mósó-mósó Kau ninggike suaro <char style="add">ngelawan Kau</char>.<verse eid="PSA 139:20"/></para>
<para style="q1">
<verse number="21" sid="PSA 139:21" style="v"/>Madaki aku idak benci samo wong-wong yang mbenci Kau, ya <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 139:21">trós idak ngeraso muak samo wong-wong yang bangkét ngelawan Kau?<verse eid="PSA 139:21"/></para>
<para style="q1">
<verse number="22" sid="PSA 139:22" style="v"/>Aku mbenci dio wong, benci nian!</para>
<para style="q2" vid="PSA 139:22">Dio wong jadi mósó-mósó aku.<verse eid="PSA 139:22"/></para>
<para style="q1">
<verse number="23" sid="PSA 139:23" style="v"/>Selédékila aku, ya Allah, jugo kenali ati aku;</para>
<para style="q2" vid="PSA 139:23">ujila aku trós kenali kebingsalan aku.<verse eid="PSA 139:23"/></para>
<para style="q1">
<verse number="24" sid="PSA 139:24" style="v"/>Jingokla, kalu-kalu bae ado jalan aku yang jahat,</para>
<para style="q2" vid="PSA 139:24">trós pémpénla aku di jalan <char style="add">Kau</char>, yang la beabad-abad.<verse eid="PSA 139:24"/></para>
<chapter eid="PSA 139"/>






<chapter number="146" sid="PSA 146" style="c"/>
<para style="s2" vid="PSA 145:21">Pujila Allah, sikok-sikoknyo penolong<verse eid="PSA 145:21"/></para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 146:1" style="v"/>Pujila <char style="nd"><char style="w">ALLAHyhwh</char></char>!</para>
<para style="q1" vid="PSA 146:1">Ói jiwo aku, pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 146:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 146:2" style="v"/>Aku nak muji <char style="nd">ALLAHyhwh</char> seómór édóp aku;</para>
<para style="q2" vid="PSA 146:2">aku nak nyanyi óntók Tuhanku selamo aku ado.<verse eid="PSA 146:2"/></para>
<para style="b"/>
<para style="q1">
<verse number="3" sid="PSA 146:3" style="v"/>Janganla pecayo samo pemémpén-pemémpén,</para>
<para style="q2" vid="PSA 146:3">samo manusio, yang idak pacak nyelametke.<verse eid="PSA 146:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 146:4" style="v"/>Pas napasnyo pótós, dio balék ke tana.</para>
<para style="q2" vid="PSA 146:4">Pas ari tu jugo, rencano-rencanonyo ilang.<verse eid="PSA 146:4"/></para>
<para style="b"/>
<para style="q1">
<verse number="5" sid="PSA 146:5" style="v"/>Senengla ati wong yang penolongnyo iola Tuhannyo <char style="w">Yakób</char>,</para>
<para style="q2" vid="PSA 146:5">yang arepannyo ado samo <char style="nd">ALLAHyhwh</char>, Tuhannyo.<verse eid="PSA 146:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 146:6" style="v"/>Diola yang jadike bumi, laót, jugo alam semesto, samo slóró isinyo,</para>
<para style="q2" vid="PSA 146:6">yang tetep stio óntók selamo-lamonyo.<verse eid="PSA 146:6"/></para>
<para style="q1">
<verse number="7" sid="PSA 146:7" style="v"/>Diola yang mbela hak wong-wong yang diperes,</para>
<para style="q2" vid="PSA 146:7">jugo yang ngenjók pajóan samo wong-wong yang laper.</para>
<para style="q1" vid="PSA 146:7">
<char style="nd">ALLAHyhwh</char> ngelepaske wong-wong tahanan,<verse eid="PSA 146:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 146:8" style="v"/>
<char style="nd">ALLAHyhwh</char> mbukak mato wong-wong buto,</para>
<para style="q1" vid="PSA 146:8">
<char style="nd">ALLAHyhwh</char> negakke wong-wong yang tetóndók,</para>
<para style="q1" vid="PSA 146:8">
<char style="nd">ALLAHyhwh</char> ngaséhi wong-wong bener.<verse eid="PSA 146:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 146:9" style="v"/>
<char style="nd">ALLAHyhwh</char> ngeléndóngi wong-wong pendateng.</para>
<para style="q1" vid="PSA 146:9">Dio negakke anak-anak yatém samo jando-jando,</para>
<para style="q2" vid="PSA 146:9">tapi Dio belokke jalan wong jahat.<verse eid="PSA 146:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 146:10" style="v"/>
<char style="nd">ALLAHyhwh</char> bakal mrénto jadi Rajo óntók selamo-lamonyo.</para>
<para style="q2" vid="PSA 146:10">Tuhan kau, ói <char style="w">Sion</char>, <char style="add">bakal mrénto</char> dari jaman ke jaman.</para>
<para style="b" vid="PSA 146:10"/>
<para style="q1" vid="PSA 146:10">Pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 146:10"/></para>
<chapter eid="PSA 146"/>

<chapter number="148" sid="PSA 148" style="c"/>
<para style="s2" vid="PSA 147:20">Surgo samo bumi muji Allah<verse eid="PSA 147:20"/></para>
<para style="b"/>
<para style="q1">
<verse number="1" sid="PSA 148:1" style="v"/>Pujila <char style="nd"><char style="w">ALLAHyhwh</char></char>!</para>
<para style="q1" vid="PSA 148:1">Pujila <char style="nd">ALLAHyhwh</char> dari surgo,</para>
<para style="q2" vid="PSA 148:1">pujila Dio, di tempat yang tinggi!<verse eid="PSA 148:1"/></para>
<para style="q1">
<verse number="2" sid="PSA 148:2" style="v"/>Pujila Dio, ói slóró malekat-Nyo,</para>
<para style="q2" vid="PSA 148:2">pujila Dio, ói slóró pasókan <char style="add">surgo</char>!<verse eid="PSA 148:2"/></para>
<para style="q1">
<verse number="3" sid="PSA 148:3" style="v"/>Pujila Dio, ói matoari samo bulan,</para>
<para style="q2" vid="PSA 148:3">pujila Dio, ói slóró bintang yang terang!<verse eid="PSA 148:3"/></para>
<para style="q1">
<verse number="4" sid="PSA 148:4" style="v"/>Pujila Dio, ói langét tetinggi,</para>
<para style="q2" vid="PSA 148:4">jugo banyu di langét!<note caller="-" style="x"><char closed="false" style="xo">148:4 </char><char closed="false" style="xt"><ref loc="GEN 1:6-7">Asal Mulo Dunio 1:6-7</ref></char></note><verse eid="PSA 148:4"/></para>
<para style="q1">
<verse number="5" sid="PSA 148:5" style="v"/>Biarla slórónyo muji namo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 148:5">soalnyo Dio ngenjók prénto, laju segalonyo tecipto.<verse eid="PSA 148:5"/></para>
<para style="q1">
<verse number="6" sid="PSA 148:6" style="v"/>Dio jugo yang la nentuke segalonyo óntók seterósnyo jugo selamo-lamonyo,</para>
<para style="q2" vid="PSA 148:6">trós mbékén hókóm-hókóm <char style="add">alam</char> yang dak pacak ilang.<verse eid="PSA 148:6"/></para>
<para style="b"/>
<para style="q1">
<verse number="7" sid="PSA 148:7" style="v"/>Pujila <char style="nd">ALLAHyhwh</char> dari bumi,</para>
<para style="q2" vid="PSA 148:7">ói ulo-ulo nago jugo slóró laótan;<verse eid="PSA 148:7"/></para>
<para style="q1">
<verse number="8" sid="PSA 148:8" style="v"/>ói api, ujan batu, salju, samo kabót,</para>
<para style="q2" vid="PSA 148:8">jugo angin badai yang ngelakuke prénto-Nyo;<verse eid="PSA 148:8"/></para>
<para style="q1">
<verse number="9" sid="PSA 148:9" style="v"/>gónóng-gónóng samo slóró bókét,</para>
<para style="q2" vid="PSA 148:9">pohon bua-buahan jugo slóró pohon utan<note caller="+" style="f"><char closed="false" style="fr">148:9 </char><char closed="false" style="fq">pohon utan: </char><char closed="false" style="ft">Teks asli iola “pohon aras”. Pohon aras iola pohon besak yang tómbó di utan. Pohon aras di teks ini maksódnyo ngewakéli pohon-pohon yang ado di utan, samo pecak pohon bua-buahan ngewakéli pohon-pohon yang ado di kebon.</char></note>;<verse eid="PSA 148:9"/></para>
<para style="q1">
<verse number="10" sid="PSA 148:10" style="v"/>binatang liar samo slóró ternak,</para>
<para style="q2" vid="PSA 148:10">binatang ngerayap jugo bóróng-bóróng yang besayap;<verse eid="PSA 148:10"/></para>
<para style="q1">
<verse number="11" sid="PSA 148:11" style="v"/>rajo-rajo di bumi samo segalo bangso,</para>
<para style="q2" vid="PSA 148:11">pejabat-pejabat jugo slóró pemémpén di bumi;<verse eid="PSA 148:11"/></para>
<para style="q1">
<verse number="12" sid="PSA 148:12" style="v"/>bujang-bujang samo gadés-gadés,</para>
<para style="q2" vid="PSA 148:12">wong-wong tuo jugo budak-budak kecik.<verse eid="PSA 148:12"/></para>
<para style="b"/>
<para style="q1">
<verse number="13" sid="PSA 148:13" style="v"/>Biarla segalonyo muji namo <char style="nd">ALLAHyhwh</char>,</para>
<para style="q2" vid="PSA 148:13">soalnyo cuman namo Dio baela yang pantes ditinggike!</para>
<para style="q2" vid="PSA 148:13">Keagóngan-Nyo di pócók bumi jugo langét.<verse eid="PSA 148:13"/></para>
<para style="q1">
<verse number="14" sid="PSA 148:14" style="v"/>Dio la ngangkat tandók <char style="add">kekuasoan</char> óntók umat-Nyo,</para>
<para style="q2" vid="PSA 148:14">kehormatan óntók slóró wong além-Nyo<note caller="+" style="f"><char closed="false" style="fr">148:14 </char><char closed="false" style="fq">kehormatan óntók slóró wong além-Nyo: </char><char closed="false" style="ft">Teks asli pacak jugo diartike “kehormatan dari slóró wong além-Nyo”.</char></note>,</para>
<para style="q2" vid="PSA 148:14">iola óntók anak-anak Israel, umat yang parak samo Dio.</para>
<para style="b" vid="PSA 148:14"/>
<para style="q1" vid="PSA 148:14">Pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 148:14"/></para>
<chapter eid="PSA 148"/>


</usx>