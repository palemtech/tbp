  <chapter eid="PSA 97" />
  <chapter number="98" style="c" sid="PSA 98" />
  <para style="s2" vid="PSA 97:12">Penyelametan la parak<verse eid="PSA 97:12" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 98:1" />Nyanyian.</para>
  <para style="b" vid="PSA 98:1" />
  <para style="q1" vid="PSA 98:1">Nyanyila óntók <char style="nd"><char style="w">ALLAHyhwh</char></char> sikok nyanyian baru,</para>
  <para style="q2" vid="PSA 98:1">karno Dio la ngelakuke pebuatan-pebuatan yang ajaéb.</para>
  <para style="q1" vid="PSA 98:1">Tangan kanan-Nyo jugo kuaso-Nyo yang suci la gaweke keselametan.<verse eid="PSA 98:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 98:2" />
    <char style="nd">ALLAHyhwh</char> la ngenjóktauke keselametan dari-Nyo,</para>
  <para style="q2" vid="PSA 98:2">Dio la nyatoke kebeneran-Nyo di depan mato bangso-bangso.<verse eid="PSA 98:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 98:3" />Dio nginget kasé stio-Nyo jugo kestioan-Nyo samo wong Israel,</para>
  <para style="q2" vid="PSA 98:3">slóró ójóng bumi la jingok keselametan dari Tuhan kito.<verse eid="PSA 98:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 98:4" />Besorak-sorakla óntók <char style="nd">ALLAHyhwh</char>, ói slóró bumi!</para>
  <para style="q2" vid="PSA 98:4">Besenengla, besorakla trós nyanyikela puji-pujian!<verse eid="PSA 98:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 98:5" />Nyanyikela puji-pujian óntók <char style="nd">ALLAHyhwh</char> dengen kecapi,</para>
  <para style="q2" vid="PSA 98:5">dengen kecapi jugo bunyi musik.<verse eid="PSA 98:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 98:6" />Dengen terompet jugo bunyi sangkakala<note caller="+" style="f"><char style="fr" closed="false">98:6 </char><char style="fq" closed="false">sangkakala: </char><char style="ft" closed="false">Ini ni jenis alat musik tiup, pecak terompet besak tebuat dari tandók. Dalem budayo Ibrani, sangkakala dibunyike pas nyambót rajo.</char></note>,</para>
  <para style="q2" vid="PSA 98:6">Besorakla di adepan Rajo, iola <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 98:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 98:7" />Biarla laót begemóró dengen segalo isinyo,</para>
  <para style="q2" vid="PSA 98:7">dunio dengen segalo yang tinggal di dalemnyo!<verse eid="PSA 98:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 98:8" />Biarla sungi-sungi betepók tangan,</para>
  <para style="q2" vid="PSA 98:8">trós gónóng-gónóng besorak besamo-samo<verse eid="PSA 98:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 98:9" />di adepan <char style="nd">ALLAHyhwh</char>!</para>
  <para style="q2" vid="PSA 98:9">Soalnyo Dio bakal dateng óntók ngakémi bumi.</para>
  <para style="q1" vid="PSA 98:9">Dio bakal ngakémi dunio dengen kebeneran,</para>
  <para style="q2" vid="PSA 98:9">jugo suku-suku bangso dengen keadélan.<verse eid="PSA 98:9" /></para>
