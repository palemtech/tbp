  <chapter eid="PSA 52" />
  <chapter number="53" style="c" sid="PSA 53" />
  <para style="s2" vid="PSA 52:11">Kebórókan Manusio<verse eid="PSA 52:11" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 53:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni dinyanyike</char> nórót mahalat<note caller="+" style="f"><char style="fr" closed="false">53:1 </char><char style="fq" closed="false">mahalat: </char><char style="ft" closed="false">Kato ni iola kato di teks asli. Maknonyo kurang jelas. Móngkén namo nyanyian apo dak tu alat musik.</char></note>. Nyanyian pengajaran Daód.<verse eid="PSA 53:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 53:2" />Wong tekak ngomong dalem atinyo,</para>
  <para style="q2" vid="PSA 53:2">“Katek Tuhan!”</para>
  <para style="q1" vid="PSA 53:2">Dio wong busuk ati, trós kecalakannyo kejem.</para>
  <para style="q2" vid="PSA 53:2">Katek yang bebuat baék.<verse eid="PSA 53:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 53:3" />Allah masati dari surgo,</para>
  <para style="q2" vid="PSA 53:3">ke anak-anak manusio,</para>
  <para style="q1" vid="PSA 53:3">óntók jingok kalu bae ado wong yang bijak,</para>
  <para style="q2" vid="PSA 53:3">yang nyari Allah.<verse eid="PSA 53:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 53:4" />Dio wong galo la nyimpang,</para>
  <para style="q2" vid="PSA 53:4">samo-samo rusak.</para>
  <para style="q1" vid="PSA 53:4">Katek yang bebuat baék,</para>
  <para style="q2" vid="PSA 53:4">sikok wong bae idak.<verse eid="PSA 53:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 53:5" />Idak sadar apo wong-wong yang bebuat jahat tu?</para>
  <para style="q2" vid="PSA 53:5">Dio wong tu makani umat aku pecak makan roti,</para>
  <para style="q2" vid="PSA 53:5">jugo idak bejerét samo Allah.<verse eid="PSA 53:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 53:6" />Di sano dio wong bakal ketakótan nian,</para>
  <para style="q2" vid="PSA 53:6">padahal katek apo-apo óntók ditakóti,</para>
  <para style="q1" vid="PSA 53:6">karno Allah bakal ngambórke tulang wong-wong yang bekemah ngepóng kau.</para>
  <para style="q2" vid="PSA 53:6">Kau bakal maluke dio wong karno Allah nolak dio wong.<verse eid="PSA 53:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 53:7" />Kironyo keselametan wong-wong <char style="w">Israel</char> dateng dari <char style="w">Sion</char>!</para>
  <para style="q1" vid="PSA 53:7">Pas Allah balékke keadaan umat-Nyo tu,</para>
  <para style="q2" vid="PSA 53:7">
    <char style="w">Yakób</char> bakal besorak-sorak jugo Israel bakal seneng.<verse eid="PSA 53:7" /></para>
  <chapter eid="PSA 53" />
  <chapter number="54" style="c" sid="PSA 54" />
  <para style="s2">Doa mintak pembelaan</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 54:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: <char style="add">Saér ni diéréngi</char> kecapi. Maskil<note caller="+" style="f"><char style="fr" closed="false">54:1 </char><char style="fq" closed="false">Maskil: </char><char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char></note> <char style="w">Daód</char>, <verse eid="PSA 54:1" /><verse number="2" style="v" sid="PSA 54:2" />pas wong Jipi dateng ngomong samo Saól cak ini, “Daód singitan di tempat kami.”<note caller="-" style="x"><char style="xo" closed="false">54:2 </char><char style="xt" closed="false"><ref loc="1SA 23:15-24">1 Samuel 23:15-24</ref>; <ref loc="1SA 26:1-5">26:1-5</ref></char></note><verse eid="PSA 54:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 54:3" />Ya Allah, selametkela aku ole <char style="add">kehebatan</char> namo Kau,</para>
  <para style="q2" vid="PSA 54:3">trós bela-la pekaro aku dengen kekuasoan Kau.<verse eid="PSA 54:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 54:4" />Ya Allah, dengerkela doa aku;</para>
  <para style="q2" vid="PSA 54:4">peratikela omongan-omongan dari mólót aku.<verse eid="PSA 54:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 54:5" />Soalnyo wong-wong laén bangkét ngelawan aku,</para>
  <para style="q2" vid="PSA 54:5">jugo wong-wong kejem ngincer nyawo aku.</para>
  <para style="q2" vid="PSA 54:5">Dio wong idak nempatke Allah di adepan dirinyo. <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 54:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 54:6" />Jingokla! Allah iola penolong aku;</para>
  <para style="q2" vid="PSA 54:6">Tuan aku iola penopang jiwo aku.<verse eid="PSA 54:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 54:7" />Biarkela kejahatan bebalék nimpo mósó-mósó aku.</para>
  <para style="q2" vid="PSA 54:7">Karno kestioan Kau, matikela dio wong!<verse eid="PSA 54:7" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="8" style="v" sid="PSA 54:8" />Dengen seneng ati aku bakal nyembake kórban samo Kau.</para>
  <para style="q2" vid="PSA 54:8">Aku bakal ngucap sókór samo namo Kau, ya <char style="nd">ALLAHyhwh</char>, karno namo Kau baék.<verse eid="PSA 54:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 54:9" />Soalnyo Kau la ngelepaske aku dari slóró kesesekan,</para>
  <para style="q2" vid="PSA 54:9">jadi mato aku jingok'i bae mósó aku.<verse eid="PSA 54:9" /></para>
  <chapter eid="PSA 54" />
  <chapter number="55" style="c" sid="PSA 55" />
  <verse number="1" style="v" sid="PSA 55:1" />
  <verse eid="PSA 55:1" />
  <verse number="2" style="v" sid="PSA 55:2" />
