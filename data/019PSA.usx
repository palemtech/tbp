  <chapter number="127" style="c" sid="PSA 127" />
  <para style="s2" vid="PSA 126:6">Allah yang nyedioke óntók ruma tanggo<verse eid="PSA 126:6" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 127:1" />Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>. Dari Suleiman.</para>
  <para style="b" vid="PSA 127:1" />
  <para style="q1" vid="PSA 127:1">Amen bukan <char style="nd"><char style="w">ALLAHyhwh</char></char> yang mbangón ruma,</para>
  <para style="q2" vid="PSA 127:1">sio-siola wong yang mbangónnyo susa paya.</para>
  <para style="q1" vid="PSA 127:1">Amen bukan <char style="nd">ALLAHyhwh</char> yang nyago kota,</para>
  <para style="q2" vid="PSA 127:1">sio-siola pengawal bejago-jago.<verse eid="PSA 127:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 127:2" />Sio-siola kamu gancang bangón</para>
  <para style="q2" vid="PSA 127:2">trós telat tédók,</para>
  <para style="q2" vid="PSA 127:2">trós makani asél susa paya,</para>
  <para style="q2" vid="PSA 127:2">karno Dio ngenjókkenyo samo yang dikaséhi-Nyo pas <char style="add">dio wong</char> tédók<note caller="+" style="f"><char style="fr" closed="false">127:2 </char><char style="fq" closed="false">karno Dio ngenjókkenyo samo yang dikaséhi-Nyo pas dio wong tédók: </char><char style="ft" closed="false">Teks asli barés ini pacak jugo diartike, “karno Dio ngenjókke tédók samo yang dikaséhi-Nyo”.</char></note>.<verse eid="PSA 127:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 127:3" />Jingokla, budak-budak iola warésan dari <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 127:3">trós bua ati iola pahalo.<verse eid="PSA 127:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 127:4" />Samo pecak anak-anak pana di tangan pejuang,</para>
  <para style="q2" vid="PSA 127:4">pecak itula budak-budak lanang <char style="add">yang dilaérke pas</char> kito mudo.<verse eid="PSA 127:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 127:5" />Senengla wong yang tabóng pananyo dipenui dengen dio wong tu.</para>
  <para style="q1" vid="PSA 127:5">Dio dak bakal dipermaluke</para>
  <para style="q2" vid="PSA 127:5">pas ngadepi lawan-lawannyo di jeró gerbang kota<note caller="+" style="f"><char style="fr" closed="false">127:5 </char><char style="fq" closed="false">di jeró gerbang kota: </char><char style="ft" closed="false">Dalem budayo Ibrani jaman tu, di jeró pintu gerbang kota ado tempat kómpólan wong yang behikmah jugo pemémpén. Wargo pegi ke sano óntók mintak nasehat jugo keadélan. Di ayat ini, wong ini ngadepi mósónyo dewek di adepan pemémpén kota óntók mintak keadélan.</char></note>.<verse eid="PSA 127:5" /></para>
  <chapter eid="PSA 127" />
  <chapter number="128" style="c" sid="PSA 128" />
  <para style="s2">Berkah óntók wong yang takót samo Allah</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 128:1" />Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>.</para>
  <para style="b" vid="PSA 128:1" />
  <para style="q1" vid="PSA 128:1">Senengla tiap wong yang takót samo <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 128:1">trós yang bejalan di jalan-Nyo.<verse eid="PSA 128:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 128:2" />Pastila kau bakal makan asél dari tangan kau.</para>
  <para style="q2" vid="PSA 128:2">Kau bakal seneng, trós keadaan kau bakal baék.<verse eid="PSA 128:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 128:3" />Bini kau bakal jadi pecak batang anggór yang bebua lebet</para>
  <para style="q2" vid="PSA 128:3">di jeró ruma kau,</para>
  <para style="q1" vid="PSA 128:3">trós anak-anak kau pecak tunas batang jaitun</para>
  <para style="q2" vid="PSA 128:3">di sekeléléng meja kau.<verse eid="PSA 128:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 128:4" />Sebenernyo pecak itula bakal diberkahi</para>
  <para style="q2" vid="PSA 128:4">lanang yang takót samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 128:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 128:5" />Kironyo <char style="nd">ALLAHyhwh</char> mberkahi kau dari <char style="w">Sion</char>,</para>
  <para style="q2" vid="PSA 128:5">sampe-sampe kau jingok kemakmóran <char style="w">Yerusalem</char></para>
  <para style="q3" vid="PSA 128:5">seómór édóp kau,<verse eid="PSA 128:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 128:6" />trós kau jingok anak cócóng kau!</para>
  <para style="b" vid="PSA 128:6" />
  <para style="q1" vid="PSA 128:6">Damai sentosa óntók <char style="w">Israel</char>!<verse eid="PSA 128:6" /></para>
  <chapter eid="PSA 128" />
  <chapter number="129" style="c" sid="PSA 129" />
  <verse number="1" style="v" sid="PSA 129:1" />
  <verse eid="PSA 129:1" />
