  <chapter eid="PSA 86" />
  <chapter number="87" style="c" sid="PSA 87" />
  <para style="s2" vid="PSA 86:17">Allah bakal mbékén kota Sion, iola Yerusalem, jadi tempat asal slóró bangso<verse eid="PSA 86:17" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 87:1" />Saér dari ketórónan Korah: sikok nyanyian.</para>
  <para style="b" vid="PSA 87:1" />
  <para style="q1" vid="PSA 87:1">Dasar-Nyo ado di Bókét Suci.<verse eid="PSA 87:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 87:2" />
    <char style="add">Iyo!</char> <char style="nd"><char style="w">ALLAHyhwh</char></char> paléng ngaséhi gerbang-gerbang kota <char style="w">Sion</char></para>
  <para style="q2" vid="PSA 87:2">dari slóró tempat di Israel<note caller="+" style="f"><char style="fr" closed="false">87:2 </char><char style="fq" closed="false">Israel: </char><char style="ft" closed="false">Teks asli iola “Yakób”, namo laén óntók bangso Israel.</char></note>.<verse eid="PSA 87:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 87:3" />Pekaro-pekaro mulyo diomongke pasal kau, ói Kota Allah! <char style="qs"><char style="w">Selah</char></char><verse eid="PSA 87:3" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="4" style="v" sid="PSA 87:4" />
    <char style="add">Uji Allah</char>,</para>
  <para style="q2" vid="PSA 87:4">“Aku bakal nyatoke Mesir<note caller="+" style="f"><char style="fr" closed="false">87:4 </char><char style="fq" closed="false">Mesir: </char><char style="ft" closed="false">Teks asli iola “Rahab”. Itu tu namo puitis óntók Mesir yang artinyo, ‘yang sombong’.</char></note> samo Babel</para>
  <para style="q3" vid="PSA 87:4">jadi wong-wong yang ngenal Aku.</para>
  <para style="q2" vid="PSA 87:4">Jingokla Pilistea, Tirus, samo Etiopia<note caller="+" style="f"><char style="fr" closed="false">87:4 </char><char style="fq" closed="false">Etiopia: </char><char style="ft" closed="false">Teks asli iola “Kus”. Itu tu namo kuno óntók Etiopia.</char></note>;</para>
  <para style="q3" vid="PSA 87:4">
    <char style="add">Aku nyatoke</char> dio wong <char style="add">jugo</char> laér di sano<note caller="+" style="f"><char style="fr" closed="false">87:4 </char><char style="fq" closed="false">dio wong jugo laér di sano: </char><char style="ft" closed="false">Pecaknyo “sano” tu iola Sion, jadi wong-wong dari bangso-bangso tu dianggep wargo Sion pas dio wong mulai nyemba Allah. Maksódnyo, dio wong dianggep jadi umat Allah jugo.</char></note>!”<verse eid="PSA 87:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 87:5" />
    <char style="add">Iyo</char>, pasal Sion bakal diomongke cak ini,</para>
  <para style="q2" vid="PSA 87:5">“Tiap wong laér di sano,”</para>
  <para style="q1" vid="PSA 87:5">jugo cak ini,</para>
  <para style="q2" vid="PSA 87:5">“Yang Mahabesak negóke kota tu.”<verse eid="PSA 87:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 87:6" />
    <char style="nd">ALLAHyhwh</char> bakal nyatet di daptar bangso-bangso,</para>
  <para style="q2" vid="PSA 87:6">“Wong ni laér di sano.” <char style="qs">Selah</char><verse eid="PSA 87:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 87:7" />Laju penyanyi samo penari <char style="add">bakal muji kota Sion tu cak ini</char>,</para>
  <para style="q2" vid="PSA 87:7">“Slóró mato banyu ado di dalem kau!”<verse eid="PSA 87:7" /></para>
  <chapter eid="PSA 87" />
