  <chapter number="130" style="c" sid="PSA 130" />
  <verse eid="PSA 129:8" />
  <verse number="1" style="v" sid="PSA 130:1" />
  <verse eid="PSA 130:1" />
  <verse number="2" style="v" sid="PSA 130:2" />
  <verse eid="PSA 130:2" />
  <verse number="3" style="v" sid="PSA 130:3" />
  <verse eid="PSA 130:3" />
