  <chapter number="131" style="c" sid="PSA 131" />
  <verse eid="PSA 130:8" />
  <verse number="1" style="v" sid="PSA 131:1" />
  <verse eid="PSA 131:1" />
  <verse number="2" style="v" sid="PSA 131:2" />
  <verse eid="PSA 131:2" />
  <verse number="3" style="v" sid="PSA 131:3" />
  <chapter eid="PSA 131" />
  <chapter number="132" style="c" sid="PSA 132" />
  <para style="s2" vid="PSA 131:3">Rajo Daód jugo kota Sion, péléan Allah<verse eid="PSA 131:3" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 132:1" />Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>.</para>
  <para style="b" vid="PSA 132:1" />
  <para style="q1" vid="PSA 132:1">Ya <char style="nd"><char style="w">ALLAHyhwh</char></char>, ingetla samo <char style="w">Daód</char></para>
  <para style="q2" vid="PSA 132:1">dengen slóró susa payanyo.<verse eid="PSA 132:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 132:2" />Dio besumpa ke <char style="nd">ALLAHyhwh</char>.</para>
  <para style="q2" vid="PSA 132:2">
    <char style="add">Iyo</char>, dio benajar ke Yang Mahakuat, Tuhannyo Yakób.</para>
  <para style="q1" vid="PSA 132:2">Ujinyo,<verse eid="PSA 132:2" /></para>
  <para style="q2">
    <verse number="3" style="v" sid="PSA 132:3" />“Aku idak bakal masók ke jeró kemah tempat tinggal aku,</para>
  <para style="q2" vid="PSA 132:3">idak bakal bególéng di ranjang tempat tédók aku,<verse eid="PSA 132:3" /></para>
  <para style="q2">
    <verse number="4" style="v" sid="PSA 132:4" />jugo idak bakal mbiarke mato aku tetédók</para>
  <para style="q3" vid="PSA 132:4">apo kelopak mato aku tepejem,<verse eid="PSA 132:4" /></para>
  <para style="q2">
    <verse number="5" style="v" sid="PSA 132:5" />sampe aku ndapetke tempat óntók <char style="add">hadérat</char> <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q3" vid="PSA 132:5">ruma óntók Yang Mahakuat, Tuhannyo Yakób.”<note caller="-" style="x"><char style="xo" closed="false">132:5 </char><char style="xt" closed="false"><ref loc="ACT 7:46">Cerito Rosul-Rosul 7:46</ref> </char></note><verse eid="PSA 132:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 132:6" />Jingokla, kito ndenger kabar <char style="add">peti-Nyo</char> tu di Eprata<note caller="+" style="f"><char style="fr" closed="false">132:6 </char><char style="fq" closed="false">Eprata: </char><char style="ft" closed="false">Ini ni namo laén óntók kota Betlehem, kampóngnyo Daód.</char></note>,</para>
  <para style="q2" vid="PSA 132:6">trós kito ndapetkenyo di padang Yaar<note caller="+" style="f"><char style="fr" closed="false">132:6 </char><char style="fq" closed="false">padang Yaar: </char><char style="ft" closed="false">Ini ni namo laén óntók Kiryat-Yearim yang iola sikok dósón yang tempatnyo kiro-kiro 14 km di ara barat laót kota Yerusalem. Kiryat-Yearim iola tempat sementaro óntók peti pejanjian Allah selamo duo póló taón sebelóm digawak Daód ke Yerusalem (jingok </char><char style="xt"><ref loc="1SA 6:21-7:2">1 Samuel 6:21–7:2</ref>; <ref loc="1CH 13:1-8">1 Riwayat 13:1-8</ref></char>). </note>.<verse eid="PSA 132:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 132:7" />Payó kito pegi ke tempat tinggal-Nyo!</para>
  <para style="q1" vid="PSA 132:7">Payó kito sójód nyemba di bangku alas sekel-Nyo!<verse eid="PSA 132:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 132:8" />Ya <char style="nd">ALLAHyhwh</char>, berangkatla ke tempat Kau bakal netep<note caller="+" style="f"><char style="fr" closed="false">132:8 </char><char style="fq" closed="false">berangkatla ke tempat Kau bakal netep: </char><char style="ft" closed="false">Di jaman tu, peti pejanjian iola tempat hadérat Allah. Di ayat ni, Daód gawak peti pejanjian tu dari padang Yaar ke kemah yang dio siapke di Yerusalem supayo Allah pacak netep di sano (jingok 1 Riwayat 15:1, 3; 16:1).</char></note>,</para>
  <para style="q2" vid="PSA 132:8">Kau dengen peti pejanjian, tempat kekuatan Kau!<verse eid="PSA 132:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 132:9" />Biarla imam-imam Kau bebaju kebeneran,</para>
  <para style="q2" vid="PSA 132:9">trós biarla wong-wong além Kau besorak-sorak.<verse eid="PSA 132:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 132:10" />Ole karno Daód, hamba Kau,</para>
  <para style="q2" vid="PSA 132:10">janganla Kau nolak wong yang Kau lanték.<note caller="-" style="x"><char style="xo" closed="false">132:8-10 </char><char style="xt" closed="false"><ref loc="2CH 6:41-42">2 Riwayat 6:41-42</ref></char></note><verse eid="PSA 132:10" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="11" style="v" sid="PSA 132:11" />
    <char style="nd">ALLAHyhwh</char> besumpa stio ke Daód;</para>
  <para style="q2" vid="PSA 132:11">Dio idak bakal ngelanggarnyo.</para>
  <para style="q1" vid="PSA 132:11">Uji-Nyo,</para>
  <para style="q2" vid="PSA 132:11">“Anak kandóng kau</para>
  <para style="q3" vid="PSA 132:11">bakal Aku dódókke di pócók korsi kekuasoan kau.<verse eid="PSA 132:11" /></para>
  <para style="q2">
    <verse number="12" style="v" sid="PSA 132:12" />Amen anak-anak kau megang tegu pejanjian Aku<note caller="+" style="f"><char style="fr" closed="false">132:12 </char><char style="fq" closed="false">pejanjian Aku: </char><char style="ft" closed="false">Ini ni nónjók ke pejanjian Allah dengen Israel di Gónóng Sinai (jingok </char><char style="xt"><ref loc="EXO 19-24">Pembebasan 19–24</ref></char>).</note></para>
  <para style="q3" vid="PSA 132:12">jugo peratóran-peratóran yang Aku ajarke samo dio wong,</para>
  <para style="q2" vid="PSA 132:12">anak cócóng dio wong jugo bakal dódók sampe selamo-lamonyo</para>
  <para style="q3" vid="PSA 132:12">di korsi kekuasoan kau.”<note caller="-" style="x"><char style="xo" closed="false">132:11-12 </char><char style="xt" closed="false"><ref loc="2SA 7:12-16">2 Samuel 7:12-16</ref>; <ref loc="1CH 17:11-14">1 Riwayat 17:11-14</ref>; <ref loc="PSA 89:4-5">Saér Nyanyian 89:4-5</ref>; <ref loc="ACT 2:30">Cerito Rosul-Rosul 2:30</ref></char></note><verse eid="PSA 132:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 132:13" />Sebenernyo <char style="nd">ALLAHyhwh</char> la mélé <char style="w">Sion</char>,</para>
  <para style="q2" vid="PSA 132:13">Dio ngendak'inyo jadi tempat tinggal-Nyo.<verse eid="PSA 132:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 132:14" />
    <char style="add">Uji-Nyo</char>, “Inila tempat Aku netep óntók selamo-lamonyo;</para>
  <para style="q2" vid="PSA 132:14">di sinila Aku bakal tinggal karno Aku ngendak'i tempat ni.<verse eid="PSA 132:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 132:15" />Makanannyo bakal Aku berkahi dengen melimpa;</para>
  <para style="q2" vid="PSA 132:15">wong-wong méskénnyo bakal Aku kenyangke dengen pajóan;<verse eid="PSA 132:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 132:16" />imam-imamnyo bakal Aku pakekke baju keselametan;</para>
  <para style="q2" vid="PSA 132:16">trós wong-wong alémnyo bakal besorak-sorak kesenengan.<verse eid="PSA 132:16" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="17" style="v" sid="PSA 132:17" />“Di sanola Aku bakal móncólke tandók <char style="add">kekuasoan</char> óntók Daód,</para>
  <para style="q2" vid="PSA 132:17">trós nyiapke pelito <char style="add">kerajaan</char><note caller="+" style="f"><char style="fr" closed="false">132:17 </char><char style="fq" closed="false">tandók kekuasoan … pelito kerajaan: </char><char style="ft" closed="false">Ini ni peumpamoan óntók ketórónan Daód yang bakal bekuaso. Dalem baso Ibrani, kato “pelito” seréng dijadike kiasan óntók dinasti (jingok 1 Rajo-Rajo 11:36; 15:4; 2 Rajo-Rajo 8:19; 2 Samuel 21:17; 2 Riwayat 21:9). Di sini, Allah bejanji amen Dio bakal negakke óntók Daód sikok dinasti yang bekuaso.</char></note> óntók wong yang Aku lanték.<verse eid="PSA 132:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 132:18" />Mósó-mósónyo bakal Aku pakekke raso malu,</para>
  <para style="q2" vid="PSA 132:18">tapi di pócók palak dio dewek bakal becahayo mahkotanyo.”<verse eid="PSA 132:18" /></para>
  <chapter eid="PSA 132" />
  <chapter number="133" style="c" sid="PSA 133" />
  <para style="s2">Keédópan yang rókón</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 133:1" />Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>. Dari <char style="w">Daód</char>.</para>
  <para style="b" vid="PSA 133:1" />
  <para style="q1" vid="PSA 133:1">Jingokla, alangke baék jugo nyenengke</para>
  <para style="q2" vid="PSA 133:1">amen dólór-dólór édóp besamo dengen rókón.<verse eid="PSA 133:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 133:2" />Pasal tu pecak minyak yang berego di pócók palak<note caller="+" style="f"><char style="fr" closed="false">133:2 </char><char style="fq" closed="false">minyak yang berego di pócók palak: </char><char style="ft" closed="false">Dalem budayo Ibrani, nuangke minyak yang berego di pócók palak dilakuke óntók ngelanték imam besak (</char><char style="xt" closed="false"><ref loc="EXO 29:1-7">Pembebasan 29:1-7</ref></char><char style="ft" closed="false">). Óntók wong Ibrani, pelantékan imam besak tu iola upacara yang nyenengke jugo penu berkah óntók imam besak tu dewek jugo óntók slóró umatnyo.</char></note>,</para>
  <para style="q2" vid="PSA 133:2">yang tórón ke jenggot,</para>
  <para style="q2" vid="PSA 133:2">ke jenggot <char style="w">Harón</char>,</para>
  <para style="q3" vid="PSA 133:2">trós tórón lagi sampe ke leher jubanyo<note caller="+" style="f"><char style="fr" closed="false">133:2 </char><char style="fq" closed="false">sampe ke leher jubanyo: </char><char style="ft" closed="false">Makno teks asli di sini kurang jelas.</char></note>.<verse eid="PSA 133:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 133:3" />Pasal tu pecak embón yang tórón ke pócók bókét-bókét <char style="w">Sion</char>;</para>
  <para style="q2" vid="PSA 133:3">embónnyo cak embón <char style="add">Gónóng</char> Hermon<note caller="+" style="f"><char style="fr" closed="false">133:3 </char><char style="fq" closed="false">Hermon: </char><char style="ft" closed="false">Gónóng Hermon ni tekenal di Israel karno banyak embónnyo. Di Israel, mósém kemarónyo panjang, jadi embón tu dianggep berkah yang besak.</char></note>.</para>
  <para style="q1" vid="PSA 133:3">Soalnyo ke sanola <char style="nd"><char style="w">ALLAHyhwh</char></char> mréntoke berkah,</para>
  <para style="q2" vid="PSA 133:3">iola keédópan óntók selamo-lamonyo.<verse eid="PSA 133:3" /></para>
  <chapter eid="PSA 133" />
  <chapter number="134" style="c" sid="PSA 134" />
  <para style="s2">Puji-pujian pas malem ari</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 134:1" />Nyanyian pas naék nuju ke <char style="w">Ruma Agóng Allah</char>.</para>
  <para style="b" vid="PSA 134:1" />
  <para style="q1" vid="PSA 134:1">Payó, pujila <char style="nd"><char style="w">ALLAHyhwh</char></char>, ói slóró hamba <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 134:1">yang ngelayani di Ruma Agóng <char style="nd">ALLAHyhwh</char> pas malem ari!<verse eid="PSA 134:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 134:2" />Angkatla tangan kamu ke ara tempat suci tu,</para>
  <para style="q2" vid="PSA 134:2">trós pujila <char style="nd">ALLAHyhwh</char>!<verse eid="PSA 134:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 134:3" />Kironyo <char style="nd">ALLAHyhwh</char> mberkahi kau dari <char style="w">Sion</char>,</para>
  <para style="q2" vid="PSA 134:3">Dio yang nyadike bumi jugo alam semesto!<verse eid="PSA 134:3" /></para>
  <chapter eid="PSA 134" />
  <chapter number="135" style="c" sid="PSA 135" />
  <verse number="1" style="v" sid="PSA 135:1" />
