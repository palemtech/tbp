  <chapter eid="PSA 89" />
  <chapter number="90" style="c" sid="PSA 90" />
  <para style="s2" vid="PSA 89:53">Doa mintak Allah ngesiani manusio, yang édópnyo cuman sementaro<verse eid="PSA 89:53" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 90:1" />Doa Musa, hamba Allah.</para>
  <para style="b" vid="PSA 90:1" />
  <para style="q1" vid="PSA 90:1">Ya Tuan, Kaula tempat betedó óntók kami tórón-temórón.<verse eid="PSA 90:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 90:2" />Sebelóm gónóng-gónóng dilaérke,</para>
  <para style="q2" vid="PSA 90:2">sebelóm Kau nyadike bumi samo dunio,</para>
  <para style="q2" vid="PSA 90:2">malahan dari selamo-lamonyo sampe selamo-lamonyo</para>
  <para style="q3" vid="PSA 90:2">Kaula Allah.<verse eid="PSA 90:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 90:3" />Kau balékke manusio ke debu tana</para>
  <para style="q2" vid="PSA 90:3">trós ngomong, “Balékla, ói anak-anak manusio!”<verse eid="PSA 90:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 90:4" />Sebenernyo, di mato Kau, seribu taón samo pecak</para>
  <para style="q2" vid="PSA 90:4">ari kemarén yang baru liwat,</para>
  <para style="q2" vid="PSA 90:4">dak tu sikok géléran jago pas malem ari.<verse eid="PSA 90:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 90:5" />Kau nganyutke <char style="add">nyawo</char> manusio; dio wong pecak mimpi.</para>
  <para style="q2" vid="PSA 90:5">Pas pagi ari, dio wong pecak rómpót yang baru tómbó,<verse eid="PSA 90:5" /></para>
  <para style="q3">
    <verse number="6" style="v" sid="PSA 90:6" />pas pagi bekembang trós tómbó,</para>
  <para style="q3" vid="PSA 90:6">tapi pas sorenyo, layu trós keréng.<verse eid="PSA 90:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 90:7" />Bener nian, kami abés ole panas ati Kau,</para>
  <para style="q2" vid="PSA 90:7">trós kami ketakótan ole kemarahan Kau.<verse eid="PSA 90:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 90:8" />Kau narok kesalahan-kesalahan kami di adepan Kau,</para>
  <para style="q2" vid="PSA 90:8">jugo <char style="add">merikso</char> resio-resio kami di cahayo hadérat Kau.<verse eid="PSA 90:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 90:9" />Bener nian, slóró ari kami tebenem karno amukan Kau;</para>
  <para style="q2" vid="PSA 90:9">taón-taón kami abés pecak embósan napas.<verse eid="PSA 90:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 90:10" />Lamo édóp kami tójó póló taón,</para>
  <para style="q2" vid="PSA 90:10">apo amen kami kuat, lapan póló taón,</para>
  <para style="q2" vid="PSA 90:10">tapi keslóróannyo cuman kesaroan samo pendritoan;</para>
  <para style="q2" vid="PSA 90:10">karno keédópan gancang belalu, trós kami melayang ilang.<verse eid="PSA 90:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 90:11" />Siapola yang tau kekuatan kemarahan Kau?</para>
  <para style="q2" vid="PSA 90:11">Karno amukan Kau, pantesla wong takót samo Kau.<note caller="+" style="f"><char style="fr" closed="false">90:11 </char><char style="fq" closed="false">Karno amukan Kau, pantesla wong takót samo Kau: </char><char style="ft" closed="false">Makno teks asli di barés ini kurang jelas.</char></note><verse eid="PSA 90:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 90:12" />Ajarkela kami óntók ngargoi ari-ari kami yang tebates<note caller="+" style="f"><char style="fr" closed="false">90:12 </char><char style="fq" closed="false">Ngargoi ari-ari kami yang tebates: </char><char style="ft" closed="false">Teks aslinyo iola, “Ngétóng ari-ari kami”. Maksódnyo kito ngargoi édóp kito tiap arinyo karno jadi sadar amen lamo édóp kito tebates.</char></note>,</para>
  <para style="q2" vid="PSA 90:12">mangko kami dapet ati yang bijak.<verse eid="PSA 90:12" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="13" style="v" sid="PSA 90:13" />Bebalékla <char style="add">dari kemarahan Kau</char>, ya <char style="nd"><char style="w">ALLAHyhwh</char></char>! Berapo lamo lagi?</para>
  <para style="q2" vid="PSA 90:13">Kesianila hamba-hamba Kau ni!<verse eid="PSA 90:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 90:14" />Kenyangkela kami pas pagi ari dengen kasé stio Kau,</para>
  <para style="q2" vid="PSA 90:14">mangko kami besorak-sorak trós beseneng seómór édóp kami.<verse eid="PSA 90:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 90:15" />Buatla ati kami beseneng-seneng,</para>
  <para style="q2" vid="PSA 90:15">seimbang samo ari-ari pas Kau mbékén kami sengsaro,</para>
  <para style="q2" vid="PSA 90:15">seimbang samo taón-taón pas kami keno celako.<verse eid="PSA 90:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 90:16" />Biarla tingka laku Kau dijingok ole hamba-hamba Kau,</para>
  <para style="q2" vid="PSA 90:16">trós kemulyoan Kau ole anak-anak kami.<verse eid="PSA 90:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 90:17" />Biarla kebaék'an Tuan, Tuhan kami, ado samo kami,</para>
  <para style="q2" vid="PSA 90:17">trós tegukela pebuatan tangan kami tu óntók kami,</para>
  <para style="q2" vid="PSA 90:17">iyo, tegukela pebuatan tangan kami tu.<verse eid="PSA 90:17" /></para>
  <chapter eid="PSA 90" />
  <chapter number="91" style="c" sid="PSA 91" />
  <para style="s2">Dalem léndóngan Allah</para>
  <para style="b" />
  <para style="q1">
    <verse number="1" style="v" sid="PSA 91:1" />Wong yang édóp dalem léndóngan Yang Mahabesak</para>
  <para style="q2" vid="PSA 91:1">bakal tédók di bawa naongan Yang Mahakuaso.<verse eid="PSA 91:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 91:2" />Samo <char style="nd"><char style="w">ALLAHyhwh</char></char> aku ngomong<note caller="+" style="f"><char style="fr" closed="false">91:2 </char><char style="fq" closed="false">Samo </char><char style="nd">ALLAHyhwh</char> aku ngomong: <char style="ft" closed="false">Teks asli barés ni pacak jugo ditejemake, “Pasal </char><char style="nd">ALLAHyhwh</char> aku ngomong”.</note>,</para>
  <para style="q2" vid="PSA 91:2">“Tempat peléndóngan aku jugo benteng petahanan aku,</para>
  <para style="q2" vid="PSA 91:2">Tuhan aku, yang aku pecayoi.”<verse eid="PSA 91:2" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="3" style="v" sid="PSA 91:3" />Sebenernyo Diola yang bakal ngelepaske kau dari perangkep pemburu,</para>
  <para style="q2" vid="PSA 91:3">dari waba yang mematike.<verse eid="PSA 91:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 91:4" />Dengen kepak-Nyo Dio bakal nódóngi kau,</para>
  <para style="q2" vid="PSA 91:4">trós di bawa sayap-Nyo kau bakal beléndóng.</para>
  <para style="q2" vid="PSA 91:4">Kestioan-Nyo bakal jadi tameng samo benteng kau.<verse eid="PSA 91:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 91:5" />Kau dak usa takót samo kengerian malem,</para>
  <para style="q2" vid="PSA 91:5">samo anak pana yang terbang pas siang ari,<verse eid="PSA 91:5" /></para>
  <para style="q2">
    <verse number="6" style="v" sid="PSA 91:6" />samo waba yang dateng dalem kegelepan,</para>
  <para style="q2" vid="PSA 91:6">apo, samo keancóran yang mbinasoke pas tenga ari.<verse eid="PSA 91:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 91:7" />Mugola seribu wong bakal nyampak di sampéng kau,</para>
  <para style="q2" vid="PSA 91:7">jugo sepóló ribu di sampéng kanan kau,</para>
  <para style="q2" vid="PSA 91:7">tapi kau dak bakal diparak'i galo-galo tu.<verse eid="PSA 91:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 91:8" />Kau cuman bakal jingok dengen mato kau dewek</para>
  <para style="q2" vid="PSA 91:8">trós jingok balesan óntók wong-wong jahat.<verse eid="PSA 91:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 91:9" />Karno kau la mbékén <char style="nd">ALLAHyhwh</char> jadi tempat tinggal kau,</para>
  <para style="q2" vid="PSA 91:9">iola Yang Mahabesak jugo tempat peléndóngan aku,<note caller="+" style="f"><char style="fr" closed="false">91:9 </char><char style="fq" closed="false">Karno kau … peléndóngan aku: </char><char style="ft" closed="false">Teks asli di sini cókóp saro diartike. Kato demi kato, teks asli ayat ni iola, “karno kau, </char><char style="nd">ALLAHyhwh</char>, tempat peléndóngan aku, Yang Mahabesak, kau la mbékén tempat tinggal kau.” Di sini, kato “kau” nónjókke wong laén, bukan Allah. </note><verse eid="PSA 91:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 91:10" />jadi kebórókan dak bakal nimpo kau,</para>
  <para style="q2" vid="PSA 91:10">jugo bencano dak bakal marak'i ruma kau.<verse eid="PSA 91:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 91:11" />Soalnyo, Dio bakal mrénto malekat-malekat-Nyo pasal kau</para>
  <para style="q2" vid="PSA 91:11">supayo kau dijagoi di segalo jalan kau.<verse eid="PSA 91:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="PSA 91:12" />Di tangannyo dio wong bakal ngangkat kau</para>
  <para style="q2" vid="PSA 91:12">supayo sekel kau dak kesantók batu.<note caller="-" style="x"><char style="xo" closed="false">91:11-12 </char><char style="xt" closed="false"><ref loc="MAT 4:6">Matius 4:6</ref>; <ref loc="LUK 4:10-11">Lukas 4:10-11</ref></char></note><verse eid="PSA 91:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 91:13" />Singo samo ulo bakal kau pijek;</para>
  <para style="q2" vid="PSA 91:13">kau bakal nginjek-nginjek singo mudo samo ulo bebiso.<verse eid="PSA 91:13" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="14" style="v" sid="PSA 91:14" />
    <char style="add">Uji Allah</char>,</para>
  <para style="q1" vid="PSA 91:14">“Karno Akula yang dio kaséhi, mangko Aku bakal nyelametkenyo,</para>
  <para style="q2" vid="PSA 91:14">trós Aku bakal ngeléndónginyo karno dio ngenal namo Aku.<verse eid="PSA 91:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 91:15" />Pas dio mekék samo Aku, Aku bakal nyawabnyo.</para>
  <para style="q2" vid="PSA 91:15">Aku bakal nyertoinyo di dalem kesesekan,</para>
  <para style="q2" vid="PSA 91:15">trós Aku bakal mbebaskenyo jugo mulyokenyo.<verse eid="PSA 91:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 91:16" />Dengen ómór panjang Aku bakal muaskenyo,</para>
  <para style="q2" vid="PSA 91:16">trós Aku bakal nyatoke samo dio keselametan dari Aku.”<verse eid="PSA 91:16" /></para>
  <chapter eid="PSA 91" />
