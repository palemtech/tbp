  <verse eid="PSA 38:21" />
  <verse number="22" style="v" sid="PSA 38:22" />
  <verse eid="PSA 38:22" />
  <verse number="23" style="v" sid="PSA 38:23" />
  <chapter eid="PSA 38" />
  <chapter number="39" style="c" sid="PSA 39" />
  <verse eid="PSA 38:23" />
  <verse number="1" style="v" sid="PSA 39:1" />
  <verse eid="PSA 39:1" />
  <verse number="2" style="v" sid="PSA 39:2" />
  <verse eid="PSA 39:2" />
  <verse number="3" style="v" sid="PSA 39:3" />
  <verse eid="PSA 39:3" />
  <verse number="4" style="v" sid="PSA 39:4" />
  <verse eid="PSA 39:4" />
  <verse number="5" style="v" sid="PSA 39:5" />
  <verse eid="PSA 39:5" />
  <verse number="6" style="v" sid="PSA 39:6" />
  <verse eid="PSA 39:6" />
  <verse number="7" style="v" sid="PSA 39:7" />
  <verse eid="PSA 39:7" />
  <verse number="8" style="v" sid="PSA 39:8" />
  <verse eid="PSA 39:8" />
  <verse number="9" style="v" sid="PSA 39:9" />
  <verse eid="PSA 39:9" />
  <verse number="10" style="v" sid="PSA 39:10" />
  <verse eid="PSA 39:10" />
  <verse number="11" style="v" sid="PSA 39:11" />
  <verse eid="PSA 39:11" />
  <verse number="12" style="v" sid="PSA 39:12" />
  <verse eid="PSA 39:12" />
  <verse number="13" style="v" sid="PSA 39:13" />
  <verse eid="PSA 39:13" />
  <verse number="14" style="v" sid="PSA 39:14" />
  <chapter eid="PSA 39" />
  <chapter number="40" style="c" sid="PSA 40" />
  <para style="s2" vid="PSA 39:14">Sókór jugo doa<verse eid="PSA 39:14" /></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 40:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 40:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 40:2" />Aku nunggu-nungguke <char style="nd"><char style="w">ALLAHyhwh</char></char>,</para>
  <para style="q2" vid="PSA 40:2">trós Dio nyingok aku jugo ndenger jerétan aku mintak tolong.<verse eid="PSA 40:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 40:3" />Dio ngangkat aku dari liang kebinasoan,</para>
  <para style="q2" vid="PSA 40:3">dari lómpór rawa.</para>
  <para style="q1" vid="PSA 40:3">Dio negakke sekel aku di pócók bókét batu,</para>
  <para style="q2" vid="PSA 40:3">trós negóke langka-langka aku.<verse eid="PSA 40:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 40:4" />Dio ngenjók nyanyian baru dalem mólót aku,</para>
  <para style="q2" vid="PSA 40:4">puji-pujian óntók Tuhan kito.</para>
  <para style="q1" vid="PSA 40:4">Banyak wong bakal nyingoknyo laju jadi takót,</para>
  <para style="q2" vid="PSA 40:4">trós pecayo samo <char style="nd">ALLAHyhwh</char>.<verse eid="PSA 40:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 40:5" />Seneng atila wong</para>
  <para style="q2" vid="PSA 40:5">yang narok kepecayoannyo samo <char style="nd">ALLAHyhwh</char>,</para>
  <para style="q2" vid="PSA 40:5">yang idak bebalék ke wong-wong sombong</para>
  <para style="q3" vid="PSA 40:5">apo nyimpang ke jalan penipuan.<verse eid="PSA 40:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 40:6" />Ya <char style="nd">ALLAHyhwh</char>, ya Tuhanku, banyak pasal la Kau lakuke,</para>
  <para style="q2" vid="PSA 40:6">pebuatan Kau yang ajaéb jugo rencano Kau óntók kami!</para>
  <para style="q1" vid="PSA 40:6">Katek yang pacak nyamoi Kau!</para>
  <para style="q1" vid="PSA 40:6">Aku nak nyatoke jugo mbritokenyo,</para>
  <para style="q2" vid="PSA 40:6">tapi banyak nian jumlanyo óntók diceritoke.<verse eid="PSA 40:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 40:7" />Kau idak seneng samo kórban sembeléhan jugo pesembahan pajóan,</para>
  <para style="q2" vid="PSA 40:7">tapi Kau la mbukak kópéng aku.</para>
  <para style="q1" vid="PSA 40:7">Kórban bakaran jugo kórban pengapós duso idak Kau tóntót.<verse eid="PSA 40:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 40:8" />Laju uji aku, “Jingok! Aku dateng!</para>
  <para style="q2" vid="PSA 40:8">Dalem gólóngan kitab la tetólés pasal aku;<verse eid="PSA 40:8" /></para>
  <para style="q1">
    <verse number="9" style="v" sid="PSA 40:9" />aku seneng ngelakuke kendak Kau, ya Tuhanku,</para>
  <para style="q2" vid="PSA 40:9">trós hókóm Kau ado di jeró ati aku.”<verse eid="PSA 40:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 40:10" />Aku la mbritoke kebeneran di dalem jemaah yang besak.</para>
  <para style="q2" vid="PSA 40:10">Jingokla! Aku idak nahan bébér aku, ya <char style="nd">ALLAHyhwh</char>, Kau jugo tau!<verse eid="PSA 40:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 40:11" />Kebeneran Kau idak aku singiti di jeró ati aku,</para>
  <para style="q2" vid="PSA 40:11">aku ngomong pasal kestioan Kau jugo keselametan dari Kau.</para>
  <para style="q1" vid="PSA 40:11">Kasé stio Kau jugo kebeneran Kau idak aku resioke</para>
  <para style="q2" vid="PSA 40:11">di adepan jemaah yang besak.<verse eid="PSA 40:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 40:12" />Ya <char style="nd">ALLAHyhwh</char>, janganla Kau tahan belas kesian Kau dari aku,</para>
  <para style="q2" vid="PSA 40:12">biarla kasé stio Kau jugo kebeneran Kau nyagoi aku terós.<verse eid="PSA 40:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 40:13" />Karno banyak nian musiba ngepóng aku.</para>
  <para style="q1" vid="PSA 40:13">Kesalahan-kesalahan aku nangkep aku</para>
  <para style="q2" vid="PSA 40:13">sampe-sampe aku dak pacak nyingok;</para>
  <para style="q2" vid="PSA 40:13">jumlanyo lebé banyak dari rambót di palak aku,</para>
  <para style="q3" vid="PSA 40:13">jadi aku ilang arepan.<verse eid="PSA 40:13" /></para>
  <para style="q1">
    <verse number="14" style="v" sid="PSA 40:14" />Ya <char style="nd">ALLAHyhwh</char>, aku mintak nian lepaskela aku,</para>
  <para style="q2" vid="PSA 40:14">Ya <char style="nd">ALLAHyhwh</char>, gancangla tolong aku!<verse eid="PSA 40:14" /></para>
  <para style="q1">
    <verse number="15" style="v" sid="PSA 40:15" />Biarla wong-wong yang nyobo ngincer nyawo aku</para>
  <para style="q2" vid="PSA 40:15">dipermaluke trós dihino.</para>
  <para style="q1" vid="PSA 40:15">Biarla wong-wong yang nak nyelakoke aku,</para>
  <para style="q2" vid="PSA 40:15">móndór trós direndake.<verse eid="PSA 40:15" /></para>
  <para style="q1">
    <verse number="16" style="v" sid="PSA 40:16" />Biarla wong-wong yang ngatoi aku, “Sókórla, sókórla!”</para>
  <para style="q2" vid="PSA 40:16">tediem karno malu.<verse eid="PSA 40:16" /></para>
  <para style="q1">
    <verse number="17" style="v" sid="PSA 40:17" />Biarla slóró wong yang nyari Kau</para>
  <para style="q2" vid="PSA 40:17">beseneng trós besorak karno Kau,</para>
  <para style="q1" vid="PSA 40:17">Biarla wong-wong yang ngaséhi keselametan dari Kau tetep ngomong,</para>
  <para style="q2" vid="PSA 40:17">“Mahabesak <char style="nd">ALLAHyhwh</char>!”<verse eid="PSA 40:17" /></para>
  <para style="q1">
    <verse number="18" style="v" sid="PSA 40:18" />Aku ni saro jugo méskén,</para>
  <para style="q2" vid="PSA 40:18">kironyo Tuhan meratike aku.</para>
  <para style="q1" vid="PSA 40:18">Kaula penolong aku jugo pembebas aku,</para>
  <para style="q2" vid="PSA 40:18">janganla belembet-lembet, ya Tuhanku!<verse eid="PSA 40:18" /></para>
  <chapter eid="PSA 40" />
  <chapter number="41" style="c" sid="PSA 41" />
  <para style="s2">Doa mintak kesembóan</para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 41:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Nyanyian ni dari <char style="w">Daód</char>.<verse eid="PSA 41:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 41:2" />Senengla wong yang ngesiani wong méskén!</para>
  <para style="q2" vid="PSA 41:2">
    <char style="nd">ALLAHyhwh</char> bakal ngelepaskenyo pas ari sialnyo.<verse eid="PSA 41:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 41:3" />
    <char style="nd">ALLAHyhwh</char> bakal ngeléndóngi jugo miaro nyawonyo.</para>
  <para style="q2" vid="PSA 41:3">Dio bakal disebót wong seneng di bumi,</para>
  <para style="q2" vid="PSA 41:3">trós Kau dak bakal nyerake dio ke tangan mósó-mósónyo.<verse eid="PSA 41:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 41:4" />
    <char style="nd">ALLAHyhwh</char> bakal nguatke dio di ranjangnyo pas sakét,</para>
  <para style="q2" vid="PSA 41:4">trós di tempat tédóknyo Kau póléke dio dari sakétnyo.<verse eid="PSA 41:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 41:5" />Uji aku ni, “Ya <char style="nd">ALLAHyhwh</char>, mura atila samo aku!</para>
  <para style="q2" vid="PSA 41:5">Sembókela aku, karno aku la beduso samo Kau.”<verse eid="PSA 41:5" /></para>
  <para style="q1">
    <verse number="6" style="v" sid="PSA 41:6" />Mósó-mósó aku ngomong jahat pasal aku, <char style="add">cak ini</char>,</para>
  <para style="q2" vid="PSA 41:6">“Kapanla dio bakal mati trós namonyo ilang?”<verse eid="PSA 41:6" /></para>
  <para style="q1">
    <verse number="7" style="v" sid="PSA 41:7" />Pas dateng jingok, dio nónjókke kemunapékan.</para>
  <para style="q2" vid="PSA 41:7">Atinyo nyósón pitnahan,</para>
  <para style="q1" vid="PSA 41:7">abés tu dio metu trós nyeritokenyo di jalan.<verse eid="PSA 41:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 41:8" />Slóró wong yang mbenci aku samo-samo bebésék pasal aku,</para>
  <para style="q2" vid="PSA 41:8">dio wong ngerencanoke kejahatan pasal aku, <char style="add">ujinyo</char>,<verse eid="PSA 41:8" /></para>
  <para style="q3">
    <verse number="9" style="v" sid="PSA 41:9" />“Penyakét yang mematike la nimpo dio.</para>
  <para style="q3" vid="PSA 41:9">Pas dio tédók, dio dak bakal bangón lagi.”<verse eid="PSA 41:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="PSA 41:10" />Sampe-sampe kawan baék yang aku pecayoi,</para>
  <para style="q2" vid="PSA 41:10">yang makan roti samo-samo aku,</para>
  <para style="q2" vid="PSA 41:10">la ngangkat sekelnyo ngianati aku<note caller="+" style="f"><char style="fr" closed="false">41:10 </char><char style="fq" closed="false">la ngangkat sekelnyo ngianati aku: </char><char style="ft" closed="false">Teks asli iola “la ngangkat tumitnyo ke aku”. Makno kiasan ni dalem budayo asli Ibrani dak pulok jelas, tapi pecaknyo ini ni kiasan óntók ngianati wong. Ayat ni jugo dipakek Yesus di Yahya 13:18 pasal Yudas Iskariot yang behianat.</char></note>.<verse eid="PSA 41:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 41:11" />Tapi Kau, ya <char style="nd">ALLAHyhwh</char>, mura atila samo aku, trós bangkétkela aku,</para>
  <para style="q2" vid="PSA 41:11">supayo aku pacak mbales dio wong!<verse eid="PSA 41:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 41:12" />Inila caro aku tau Kau seneng samo aku:</para>
  <para style="q2" vid="PSA 41:12">karno mósó aku dak pacak nyorak-nyorak'i aku.<verse eid="PSA 41:12" /></para>
  <para style="q1">
    <verse number="13" style="v" sid="PSA 41:13" />Aku Kau topang karno ketólósan ati aku,</para>
  <para style="q2" vid="PSA 41:13">trós Kau nempatke aku di adepan Kau óntók selamo-lamonyo.<verse eid="PSA 41:13" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="14" style="v" sid="PSA 41:14" />Tepujila <char style="nd">ALLAHyhwh</char>, Tuhannyo Israel,</para>
  <para style="q2" vid="PSA 41:14">dari selamo-lamonyo sampe selamo-lamonyo!</para>
  <para style="q1" vid="PSA 41:14">“Iyo, kami ngamininyo!”<verse eid="PSA 41:14" /></para>
  <chapter eid="PSA 41" />
  <chapter number="42" style="c" sid="PSA 42" />
  <para style="s2">Di tenga pegómólan, jiwo yang teteken nemuke arepan dalem Allah<note caller="+" style="f"><char style="fr" closed="false">42:1 </char><char style="ft" closed="false">Saér Nyanyian 42–43 sebenernyo jadi sikok saér.</char></note></para>
  <para style="d">
    <verse number="1" style="v" sid="PSA 42:1" />
    <char style="add">Catetan</char> óntók pemémpén pujian: Maskil<note caller="+" style="f"><char style="fr" closed="false">42:1 </char><char style="fq" closed="false">Maskil: </char><char style="ft" closed="false">Kato ni dari baso asli. Maknonyo dak pulok jelas. Ini ni móngkén semacem nyanyian.</char></note> dari ketórónan Korah.<verse eid="PSA 42:1" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="2" style="v" sid="PSA 42:2" />Pecak ruso ngerinduke banyu sungi,</para>
  <para style="q2" vid="PSA 42:2">pecak itula jiwo aku ngerinduke Kau, ya Allah.<verse eid="PSA 42:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 42:3" />Jiwo aku aós samo Allah, Tuhan yang édóp.</para>
  <para style="q1" vid="PSA 42:3">Kapan aku dateng lagi trós masók ke hadérat Allah?<verse eid="PSA 42:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 42:4" />Banyu mato aku jadi pajóan aku siang malem,</para>
  <para style="q2" vid="PSA 42:4">pas denger terós omongan cak ini, “Di mano Tuhan kau?”<verse eid="PSA 42:4" /></para>
  <para style="q1">
    <verse number="5" style="v" sid="PSA 42:5" />Inila yang aku inget pas numpake isi ati ke diri aku dewek:</para>
  <para style="q2" vid="PSA 42:5">amen dulu tu aku bejalan besamo wong banyak;</para>
  <para style="q2" vid="PSA 42:5">aku mémpén arak-arak'an nuju <char style="w" lemma="Ruma Agóng Allah">Ruma Agóng Allah</char></para>
  <para style="q3" vid="PSA 42:5">dengen sorak'an jugo ucapan sókór,</para>
  <para style="q2" vid="PSA 42:5">dalem keramean wong yang ngadoke pesta ari rayo.<verse eid="PSA 42:5" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="6" style="v" sid="PSA 42:6" />Ói jiwo aku, ngapo kau teteken trós ancór di dalem aku?</para>
  <para style="q1" vid="PSA 42:6">Bearepla samo Allah!</para>
  <para style="q1" vid="PSA 42:6">Soalnyo aku bakal besókór lagi samo Dio,</para>
  <para style="q2" vid="PSA 42:6">karno petolongan yang dateng dari adepan-Nyo!<verse eid="PSA 42:6" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="7" style="v" sid="PSA 42:7" />Ya Tuhanku, jiwo aku teteken di dalem aku.</para>
  <para style="q1" vid="PSA 42:7">Karno tu, aku nginget Kau</para>
  <para style="q2" vid="PSA 42:7">dari daera Sungi Yordan jugo Pegónóngan Hermon,</para>
  <para style="q2" vid="PSA 42:7">dari Gónóng Mijar<note caller="+" style="f"><char style="fr" closed="false">42:7 </char><char style="fq" closed="false">Sungi Yordan jugo Pegónóngan Hermon, dari Gónóng Mijar: </char><char style="ft" closed="false">Ini ni iola namo-namo tempat di tana Israel, tana aér penyaér ni.</char></note>.<verse eid="PSA 42:7" /></para>
  <para style="q1">
    <verse number="8" style="v" sid="PSA 42:8" />Laótan manggél laótan dengen gemóró banyu terjón Kau.</para>
  <para style="q2" vid="PSA 42:8">Slóró ombak jugo gelombang Kau nerjang aku.<verse eid="PSA 42:8" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="9" style="v" sid="PSA 42:9" />Pas siang ari <char style="nd"><char style="w">ALLAHyhwh</char></char> ngótós kasé stio-Nyo,</para>
  <para style="q2" vid="PSA 42:9">trós pas malem ari nyanyian-Nyo nyertoi aku,</para>
  <para style="q3" vid="PSA 42:9">sikok doa ke Tuhan keédópan aku.<verse eid="PSA 42:9" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="10" style="v" sid="PSA 42:10" />Aku nak ngomong samo Allah, bókét batu aku,</para>
  <para style="q2" vid="PSA 42:10">“Ngapo Kau ngelupoke aku?</para>
  <para style="q2" vid="PSA 42:10">Ngapo aku harós bejalan dalem kegelepan karno penindesan mósó?”<verse eid="PSA 42:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="PSA 42:11" />Pecak tujahan ke dalem tulang-tulang aku,</para>
  <para style="q2" vid="PSA 42:11">mósó-mósó ngejek'i aku.</para>
  <para style="q1" vid="PSA 42:11">Siang malem dio wong ngomong samo aku, “Di mano Tuhan kau?”<verse eid="PSA 42:11" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="12" style="v" sid="PSA 42:12" />Ói jiwo aku, ngapo kau teteken?</para>
  <para style="q2" vid="PSA 42:12">Ngapo kau ancór di dalem aku?</para>
  <para style="q1" vid="PSA 42:12">Bearepla samo Allah!</para>
  <para style="q1" vid="PSA 42:12">Soalnyo aku bakal besókór lagi samo Dio,</para>
  <para style="q2" vid="PSA 42:12">penolong aku jugo Tuhan aku.<verse eid="PSA 42:12" /></para>
  <chapter eid="PSA 42" />
  <chapter number="43" style="c" sid="PSA 43" />
  <para style="q1">
    <verse number="1" style="v" sid="PSA 43:1" />
    <note caller="+" style="f">
      <char style="fr" closed="false">43:0 </char>
      <char style="ft" closed="false">Saér Nyanyian 42–43 sebenernyo jadi sikok saér.</char>
    </note>Ya Allah, enjókkela keadélan samo aku!</para>
  <para style="q2" vid="PSA 43:1">Bela-la pekaro aku dari bangso kapér!</para>
  <para style="q2" vid="PSA 43:1">Lepaskela aku dari wong yang calak jugo jahat!<verse eid="PSA 43:1" /></para>
  <para style="q1">
    <verse number="2" style="v" sid="PSA 43:2" />Soalnyo Kaula Tuhan tempat peléndóngan aku.</para>
  <para style="q1" vid="PSA 43:2">Ngapo Kau mbuang aku?</para>
  <para style="q1" vid="PSA 43:2">Ngapo aku harós terós bejalan dalem kegelepan karno penindesan mósó?<verse eid="PSA 43:2" /></para>
  <para style="q1">
    <verse number="3" style="v" sid="PSA 43:3" />Kérémla terang Kau jugo kebeneran Kau!</para>
  <para style="q2" vid="PSA 43:3">Biarla aku ditóntónnyo</para>
  <para style="q2" vid="PSA 43:3">trós digawaknyo ke <char style="w" lemma="Sion">bókét Kau yang suci</char>,</para>
  <para style="q3" vid="PSA 43:3">tempat tinggal Kau.<verse eid="PSA 43:3" /></para>
  <para style="q1">
    <verse number="4" style="v" sid="PSA 43:4" />Mangko aku bakal pegi ke mesba Allah,</para>
  <para style="q2" vid="PSA 43:4">ke Tuhan <char style="add">sumber</char> kesenengan aku, yang békén aku besorak.</para>
  <para style="q1" vid="PSA 43:4">Aku bakal muji Kau dengen kecapi,</para>
  <para style="q2" vid="PSA 43:4">ya Allah, ya Tuhanku!<verse eid="PSA 43:4" /></para>
  <para style="b" />
  <para style="q1">
    <verse number="5" style="v" sid="PSA 43:5" />Ói jiwo aku, ngapo kau teteken?</para>
  <para style="q2" vid="PSA 43:5">Ngapo kau ancór di dalem aku?</para>
  <para style="q1" vid="PSA 43:5">Bearepla samo Allah!</para>
  <para style="q1" vid="PSA 43:5">Soalnyo aku bakal besókór lagi samo Dio,</para>
  <para style="q2" vid="PSA 43:5">penolong aku jugo Tuhan aku.<verse eid="PSA 43:5" /></para>
  <chapter eid="PSA 43" />
  <chapter number="44" style="c" sid="PSA 44" />
